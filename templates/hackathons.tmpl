<!doctype html>
<html lang="en">
<head>
  <title>Hackathons - bitcoin++</title>
  {{ block "header" . }} {{ end }}
</head>
<body class="bg-white text-gray-900">
  {{ block "mainnav" . }} {{ end }}
  <main>
    <section class="bg-white py-10 sm:py-16">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="mx-auto max-w-2xl text-center">
          <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Hackathons</h1>
          <p class="mt-2 text-lg leading-8 text-gray-600">Build, ship, and show off bitcoin projects at upcoming bitcoin++ events.</p>
        </div>

        {{ if .Competitions }}
        <div class="mt-14 space-y-14 sm:mt-16">
          {{ range .Competitions }}
          {{ $timeline := $.CompetitionTimeline . }}
          <article class="relative mx-auto max-w-2xl overflow-hidden rounded-2xl bg-white lg:max-w-none">
            <div class="relative z-20 lg:w-full lg:max-w-xl">
              <svg class="absolute inset-y-0 -right-24 hidden h-full w-80 translate-x-1/5 transform fill-white lg:block" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
                <polygon points="0,0 90,0 50,100 0,100" />
              </svg>
              <div class="relative px-6 py-16 sm:px-8 sm:py-20 lg:px-10 lg:py-24">
                <div class="max-w-xl">
                  <div class="flex flex-wrap items-center gap-2">
                    <span class="rounded-full bg-orange-50 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-orange-600">{{ $.CompetitionStatusLabelFor . }}</span>
                    {{ if $.CompetitionVisibleToAdmin . }}
                    <span class="rounded-full bg-amber-300/90 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-amber-950">Hidden</span>
                    {{ end }}
                  </div>
                  <h2 class="mt-5 text-4xl font-bold tracking-tight text-white lg:text-gray-900">{{ .Title }}</h2>
                  <div class="mt-4 flex flex-wrap gap-x-4 gap-y-2 text-sm font-medium text-gray-200 lg:text-gray-600">
                    {{ if $.CompetitionConferenceLabel . }}
                    {{ $confURL := $.CompetitionConferenceURL . }}
                    {{ if $confURL }}
                    <a href="{{ $confURL }}" onclick="event.stopPropagation()" class="text-white underline decoration-white/30 underline-offset-4 hover:decoration-white lg:text-gray-900 lg:decoration-gray-300">{{ $.CompetitionConferenceLabel . }}</a>
                    {{ else }}
                    <span>{{ $.CompetitionConferenceLabel . }}</span>
                    {{ end }}
                    {{ end }}
                    {{ if $.CompetitionConferenceDate . }}<span>{{ $.CompetitionConferenceDate . }}</span>{{ end }}
                  </div>
                  {{ if .Description }}
                  <div class="mt-6 line-clamp-3 text-base leading-7 text-gray-200 lg:text-gray-600">{{ $.RichText .Description }}</div>
                  {{ end }}

                  <div class="mt-8">
                    {{ if $timeline.HasCountdown }}
                    <div class="hackathon-countdown inline-flex items-center gap-2 rounded-full bg-gray-100 px-3 py-1 text-xs font-mono text-gray-700"
                         data-start="{{ $timeline.CountdownUnix }}"
                         data-end="{{ $timeline.CountdownUnix }}"
                         data-before-prefix="{{ $timeline.Label }}"
                         data-after-prefix="{{ $timeline.Label }}">
                      <span data-cd-prefix class="text-gray-500">{{ $timeline.Label }}</span>
                      <span data-cd-value class="font-semibold text-gray-900">{{ $timeline.Value }}</span>
                    </div>
                    {{ else }}
                    <div class="inline-flex items-center gap-2 rounded-full bg-gray-100 px-3 py-1 text-xs font-mono text-gray-700">
                      <span class="text-gray-500">{{ $timeline.Label }}</span>
                      <span class="font-semibold text-gray-900">{{ $timeline.Value }}</span>
                    </div>
                    {{ end }}
                  </div>

                  <div class="mt-10 flex flex-col justify-start gap-y-4" onclick="event.stopPropagation()">
                    <a href="{{ $.CompetitionURL . }}" class="w-max rounded-2xl px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 {{ $.CompetitionConferenceTag . }}">View hackathon</a>
                    {{ if $.CompetitionAcceptsProjects . }}
                    <div class="sm:flex">
                      <div class="relative rounded-full px-3 py-1 text-sm leading-6 text-gray-500 lg:ring-1 lg:ring-gray-900/10 hover:ring-gray-900/20">
                        <a href="{{ $.CompetitionURL . }}/projects/new" class="whitespace-nowrap font-semibold text-white {{ $.CompetitionConferenceTag . }}-text"><span class="absolute inset-0" aria-hidden="true"></span>Create project<span aria-hidden="true">&rarr;</span></a>
                      </div>
                    </div>
                    {{ end }}
                    <div class="sm:flex">
                      <div class="relative rounded-full px-3 py-1 text-sm leading-6 text-gray-500 lg:ring-1 lg:ring-gray-900/10 hover:ring-gray-900/20">
                        <a href="{{ $.CompetitionScheduleURL . }}" class="whitespace-nowrap font-semibold text-white {{ $.CompetitionConferenceTag . }}-text"><span class="absolute inset-0" aria-hidden="true"></span>View schedule<span aria-hidden="true">&rarr;</span></a>
                      </div>
                    </div>
                    {{ if $.CompetitionCanAdminEdit . }}
                    <div class="sm:flex">
                      <div class="relative rounded-full px-3 py-1 text-sm leading-6 text-gray-500 lg:ring-1 lg:ring-gray-900/10 hover:ring-gray-900/20">
                        <a href="{{ $.CompetitionAdminEditURL . }}" class="whitespace-nowrap font-semibold text-white {{ $.CompetitionConferenceTag . }}-text"><span class="absolute inset-0" aria-hidden="true"></span>Edit<span aria-hidden="true">&rarr;</span></a>
                      </div>
                    </div>
                    {{ end }}
                  </div>
                </div>
              </div>
            </div>
            <div class="absolute inset-0 z-10 bg-gradient-to-t from-gray-950 via-gray-950/50 lg:hidden"></div>
            <div class="absolute inset-0 lg:left-auto lg:w-2/3">
              <picture>
                {{ if $.CompetitionImageAVIF . }}<source srcset="{{ $.CompetitionImageAVIF . }}" type="image/avif">{{ end }}
                <img class="h-full w-full object-cover" src="{{ $.CompetitionImagePNG . }}" alt="" onerror="this.onerror=null; this.src='/static/img/berlin_hack_day.png';">
              </picture>
            </div>
          </article>
          {{ end }}
        </div>
        {{ else }}
        <section class="mx-auto mt-14 max-w-2xl rounded-2xl border border-gray-200 bg-white px-6 py-12 text-center shadow-sm">
          <p class="text-sm text-gray-600">No public hackathons yet.</p>
        </section>
        {{ end }}
      </div>
    </section>
  </main>
  {{ block "footer" . }} {{ end }}
</body>
</html>
