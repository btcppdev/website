<!doctype html>
<html lang="en">
<head>
  <title>Hackathons - bitcoin++</title>
  {{ block "header" . }} {{ end }}
</head>
<body class="bg-gray-50 text-gray-900">
  {{ block "mainnav" . }} {{ end }}
  <main class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-3xl font-semibold tracking-tight">Hackathons</h1>
        <p class="mt-2 text-sm text-gray-600">Bitcoin++ project competitions and showcases.</p>
      </div>
    </div>

    {{ if .Competitions }}
    <section class="overflow-hidden rounded-lg bg-white shadow">
      <ul class="divide-y divide-gray-100">
        {{ range .Competitions }}
        <li class="group cursor-pointer px-4 py-5 hover:bg-gray-50 focus:bg-gray-50 sm:px-6"
            role="link"
            tabindex="0"
            onclick="window.location.href='{{ $.CompetitionURL . }}'"
            onkeydown="if (event.key === 'Enter' || event.key === ' ') { event.preventDefault(); window.location.href='{{ $.CompetitionURL . }}'; }">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div class="min-w-0">
              <div class="flex flex-wrap items-center gap-2">
                <div class="text-lg font-semibold text-gray-900">{{ .Title }}</div>
                {{ if $.CompetitionVisibleToAdmin . }}
                <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-700">Hidden</span>
                {{ end }}
              </div>
              <div class="mt-1 break-all font-mono text-xs text-gray-500">{{ $.CompetitionURL . }}</div>
              {{ if .Description }}
              <div class="mt-3 line-clamp-3 text-sm leading-6 text-gray-700">{{ $.RichText .Description }}</div>
              {{ end }}
              <div class="mt-4 flex flex-wrap gap-x-6 gap-y-3 text-sm text-gray-600">
                {{ if $.CompetitionConferenceLabel . }}
                <div>
                  <div class="text-xs font-medium uppercase tracking-wide text-gray-500">Conference</div>
                  <div>
                    {{ $confURL := $.CompetitionConferenceURL . }}
                    {{ if $confURL }}
                    <a href="{{ $confURL }}" onclick="event.stopPropagation()" class="font-medium text-indigo-600 hover:text-indigo-500">{{ $.CompetitionConferenceLabel . }}</a>
                    {{ else }}
                    {{ $.CompetitionConferenceLabel . }}
                    {{ end }}
                  </div>
                </div>
                {{ end }}
                <div>
                  <div class="text-xs font-medium uppercase tracking-wide text-gray-500">Status</div>
                  <div class="text-gray-900">{{ $.CompetitionStatusLabelFor . }}</div>
                </div>
                <div>
                  <div class="text-xs font-medium uppercase tracking-wide text-gray-500">{{ $.CompetitionTimelineLabel . }}</div>
                  <div class="text-gray-900">{{ $.CompetitionTimelineValue . }}</div>
                  <a href="{{ $.CompetitionScheduleURL . }}" onclick="event.stopPropagation()" class="text-xs font-medium text-indigo-600 hover:text-indigo-500">View schedule</a>
                </div>
                <div>
                  <div class="text-xs font-medium uppercase tracking-wide text-gray-500">Team size</div>
                  <div>{{ with .MaxTeamSize }}Up to {{ . }}{{ else }}Unlimited{{ end }}</div>
                </div>
              </div>
            </div>
            <div class="flex flex-wrap gap-2 lg:justify-end" onclick="event.stopPropagation()">
              {{ if $.CompetitionAcceptsProjects . }}
              <a href="{{ $.CompetitionURL . }}/projects/new" class="inline-flex items-center justify-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700">New project</a>
              {{ end }}
              {{ if $.CompetitionCanAdminEdit . }}
              <a href="{{ $.CompetitionAdminEditURL . }}" class="inline-flex items-center justify-center rounded-md bg-gray-900 px-3 py-2 text-sm font-semibold text-white hover:bg-gray-800">Edit</a>
              {{ end }}
            </div>
          </div>
        </li>
        {{ end }}
      </ul>
    </section>
    {{ else }}
    <section class="rounded-lg bg-white px-4 py-10 text-center shadow sm:px-6">
      <p class="text-sm text-gray-600">No public hackathons yet.</p>
    </section>
    {{ end }}
  </main>
  {{ block "footer" . }} {{ end }}
</body>
</html>
