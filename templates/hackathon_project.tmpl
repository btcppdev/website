<!doctype html>
<html lang="en">
<head>
  <title>{{ if .IsNew }}Create project{{ else }}{{ .Project.Title }}{{ end }} - {{ .Competition.Title }}</title>
  {{ block "header" . }} {{ end }}
</head>
<body class="bg-gray-50 text-gray-900">
  {{ block "mainnav" . }} {{ end }}
  <main class="mx-auto max-w-4xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="mb-6">
      <a href="{{ .HackathonURL }}" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">&larr; Hackathon</a>
      <h1 class="mt-2 text-2xl font-semibold tracking-tight">{{ if .IsNew }}Create project{{ else }}{{ .Project.Title }}{{ end }}</h1>
      <p class="mt-1 text-sm text-gray-600">{{ .Competition.Title }}</p>
    </div>

    {{ if .FlashMessage }}
    <div class="mb-4 rounded-md border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-800">{{ .FlashMessage }}</div>
    {{ end }}
    {{ if .FlashError }}
    <div class="mb-4 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">{{ .FlashError }}</div>
    {{ end }}

    <form method="POST" action="{{ if .IsNew }}{{ .ProjectCreateURL }}{{ else }}{{ .ProjectURL .Project }}{{ end }}" class="rounded-lg bg-white shadow">
      <div class="space-y-6 px-4 py-5 sm:p-6">
        {{ if not .CanEdit }}
        <div class="rounded-md border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">Project edits are closed.</div>
        {{ end }}
        <div>
          <label for="Title" class="block text-sm font-medium text-gray-700">Title</label>
          <input id="Title" name="Title" type="text" required value="{{ .Project.Title }}" {{ if not .CanEdit }}disabled{{ end }}
                 class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600 disabled:bg-gray-100">
        </div>

        <div>
          <label for="ShortDescription" class="block text-sm font-medium text-gray-700">Short description</label>
          <input id="ShortDescription" name="ShortDescription" type="text" value="{{ .Project.ShortDescription }}" {{ if not .CanEdit }}disabled{{ end }}
                 class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600 disabled:bg-gray-100">
        </div>

        <div>
          <label for="Description" class="block text-sm font-medium text-gray-700">Description</label>
          <textarea id="Description" name="Description" rows="7" {{ if not .CanEdit }}disabled{{ end }}
                    class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600 disabled:bg-gray-100">{{ .Project.Description }}</textarea>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="GitHubURL" class="block text-sm font-medium text-gray-700">GitHub URL</label>
            <input id="GitHubURL" name="GitHubURL" type="url" value="{{ .Project.GitHubURL }}" {{ if not .CanEdit }}disabled{{ end }}
                   class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600 disabled:bg-gray-100">
          </div>
          <div>
            <label for="DemoURL" class="block text-sm font-medium text-gray-700">Demo URL</label>
            <input id="DemoURL" name="DemoURL" type="url" value="{{ .Project.DemoURL }}" {{ if not .CanEdit }}disabled{{ end }}
                   class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600 disabled:bg-gray-100">
          </div>
          <div>
            <label for="VideoURL" class="block text-sm font-medium text-gray-700">Video URL</label>
            <input id="VideoURL" name="VideoURL" type="url" value="{{ .Project.VideoURL }}" {{ if not .CanEdit }}disabled{{ end }}
                   class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600 disabled:bg-gray-100">
          </div>
          <div>
            <label for="SlidesURL" class="block text-sm font-medium text-gray-700">Slides URL</label>
            <input id="SlidesURL" name="SlidesURL" type="url" value="{{ .Project.SlidesURL }}" {{ if not .CanEdit }}disabled{{ end }}
                   class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600 disabled:bg-gray-100">
          </div>
          <div>
            <label for="DocsURL" class="block text-sm font-medium text-gray-700">Docs URL</label>
            <input id="DocsURL" name="DocsURL" type="url" value="{{ .Project.DocsURL }}" {{ if not .CanEdit }}disabled{{ end }}
                   class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600 disabled:bg-gray-100">
          </div>
          <div>
            <label for="Tags" class="block text-sm font-medium text-gray-700">Tags</label>
            <input id="Tags" name="Tags" type="text" value="{{ .ProjectTagsCSV }}" {{ if not .CanEdit }}disabled{{ end }}
                   class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600 disabled:bg-gray-100">
          </div>
        </div>
      </div>
      <div class="flex flex-wrap items-center justify-end gap-3 border-t border-gray-200 px-4 py-4 sm:px-6">
        <a href="{{ .HackathonURL }}" class="rounded-md px-3 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-100">Cancel</a>
        {{ if .CanEdit }}
        <button type="submit" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Save</button>
        {{ end }}
      </div>
    </form>

    {{ if and (not .IsNew) .CanSubmit }}
    <form method="POST" action="{{ .ProjectSubmitURL .Project }}" class="mt-4 rounded-lg bg-white shadow">
      <div class="space-y-4 px-4 py-5 sm:p-6">
        <div>
          <h2 class="text-sm font-semibold text-gray-900">Submission</h2>
          {{ if .OptInAwards }}
          <p class="mt-1 text-sm text-gray-600">Award opt-ins</p>
          {{ end }}
        </div>
        {{ if .OptInAwards }}
        <fieldset class="space-y-3">
          {{ range .OptInAwards }}
          <label class="flex gap-3 rounded-md border border-gray-200 px-3 py-3">
            <input name="AwardID" type="checkbox" value="{{ .ID }}" {{ if $.AwardOptedIn . }}checked{{ end }}
                   class="mt-0.5 h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600">
            <span>
              <span class="block text-sm font-medium text-gray-900">{{ .Title }}</span>
              {{ if .Description }}<span class="mt-1 block text-sm text-gray-600">{{ .Description }}</span>{{ end }}
            </span>
          </label>
          {{ end }}
        </fieldset>
        {{ end }}
      </div>
      <div class="flex justify-end border-t border-gray-200 px-4 py-4 sm:px-6">
        <button type="submit" class="rounded-md bg-black px-3 py-2 text-sm font-semibold text-white hover:bg-gray-800">Submit project</button>
      </div>
    </form>
    {{ end }}

    {{ if not .IsNew }}
    <section class="mt-6 rounded-lg bg-white shadow">
      <div class="border-b border-gray-200 px-4 py-4 sm:px-6">
        <h2 class="text-sm font-semibold text-gray-900">Team</h2>
      </div>
      <div class="space-y-6 px-4 py-5 sm:p-6">
        {{ if .InviteLink }}
        <div class="rounded-md border border-green-200 bg-green-50 px-4 py-3">
          <label for="InviteLink" class="block text-sm font-medium text-green-900">Invite link created</label>
          <div class="mt-2 flex flex-col gap-2 sm:flex-row">
            <input id="InviteLink" type="url" readonly value="{{ .InviteLink }}"
                   class="block w-full rounded-md bg-white px-3 py-2 font-mono text-xs text-gray-900 outline outline-1 outline-green-300">
            <button type="button" data-copy-target="InviteLink" class="inline-flex items-center justify-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Copy</button>
          </div>
        </div>
        {{ end }}

        <div>
          {{ if .Members }}
          <ul class="divide-y divide-gray-100 rounded-md border border-gray-200">
            {{ range .Members }}
            <li class="flex items-center justify-between gap-4 px-3 py-2 text-sm">
              <span>
                <span class="block font-medium text-gray-900">{{ if .Name }}{{ .Name }}{{ else }}{{ .PersonID }}{{ end }}</span>
                <span class="block text-xs text-gray-500">{{ if .Email }}{{ .Email }}{{ else }}{{ .PersonID }}{{ end }}</span>
              </span>
              <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-700">{{ .Role }}</span>
            </li>
            {{ end }}
          </ul>
          {{ else }}
          <p class="text-sm text-gray-600">No team members yet.</p>
          {{ end }}
        </div>

        {{ if .CanEdit }}
        <form method="POST" action="{{ .ProjectInviteURL .Project }}" class="grid gap-3 sm:grid-cols-[1fr_auto] sm:items-end">
          <div>
            <label for="Email" class="block text-sm font-medium text-gray-700">Invite email</label>
            <input id="Email" name="Email" type="email"
                   class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
            <p class="mt-1 text-xs text-gray-500">Links expire after 24 hours. Add an email to restrict the invite to that address.</p>
          </div>
          <button type="submit" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Generate one-time invite</button>
        </form>
        {{ end }}
      </div>
    </section>
    {{ end }}
  </main>
  {{ block "footer" . }} {{ end }}
  <script>
    document.querySelectorAll('[data-copy-target]').forEach((button) => {
      button.addEventListener('click', async () => {
        const input = document.getElementById(button.dataset.copyTarget);
        if (!input) return;
        try {
          await navigator.clipboard.writeText(input.value);
          button.textContent = 'Copied';
        } catch (_) {
          input.focus();
          input.select();
          button.textContent = 'Select';
        }
      });
    });
  </script>
</body>
</html>
