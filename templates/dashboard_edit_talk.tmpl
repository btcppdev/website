<!DOCTYPE html>
<html>
<head>
  <title>edit talk - bitcoin++</title>
  {{ block "header" . }} {{ end }}
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>&#10024;</text></svg>">
</head>
<body class="btcpp-admin-page btcpp-dashboard-page">
  {{ block "mainnav" . }} {{ end }}
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-6">
      <a href="/dashboard?hr={{ .HMAC }}&em={{ .Email }}" class="text-sm text-indigo-600 hover:text-indigo-700">&larr; Dashboard</a>
    </div>

    {{ if .Conf }}{{ template "conf_hero" .Conf }}{{ end }}

    <h1 class="mt-6 text-2xl font-bold text-gray-900">Edit talk</h1>

    {{ if .Locked }}
    <div class="mt-6 rounded-md bg-yellow-50 border border-yellow-200 px-4 py-3">
      <p class="text-sm text-yellow-900"><strong>Edits are locked.</strong> {{ .LockReason }}.</p>
      <p class="mt-1 text-xs text-yellow-800">Need to change something? Email <a href="mailto:speak@btcpp.dev" class="underline">speak@btcpp.dev</a>.</p>
    </div>
    {{ end }}

    {{ if .Proposal.ConfTalk }}
    <form class="dashboard-talk-resources" method="POST" enctype="multipart/form-data" action="/dashboard/talks/{{ .Proposal.ID }}/resources?hr={{ .HMAC }}&em={{ .Email }}">
      <input type="hidden" name="ReturnTo" value="edit">
      <input type="hidden" name="ReturnProposalID" value="{{ .Proposal.ID }}">
      <div class="dashboard-talk-resources__head">
        <span>Post-talk resources</span>
        <small>Public on your archive and the agenda. Available after talk edits lock.</small>
      </div>
      <label>
        <span>GitHub repo</span>
        <input type="url" name="GithubRepoURL" value="{{ .Proposal.ConfTalk.GithubRepoURL }}" placeholder="https://github.com/org/repo">
      </label>
      <label>
        <span>Slides link</span>
        {{ if .Proposal.ConfTalk.SlidesURL }}
        <a href="{{ .Proposal.ConfTalk.SlidesURL | safeURL }}" target="_blank" rel="noopener noreferrer">View current slides</a>
        {{ else }}
        <input type="url" name="SlidesURL" value="{{ .Proposal.ConfTalk.SlidesURL }}" placeholder="https://example.com/slides.pdf">
        {{ end }}
      </label>
      {{ if .Proposal.ConfTalk.SlidesURL }}
      <label class="dashboard-talk-resources__remove">
        <span>Remove slides</span>
        <input type="checkbox" name="RemoveSlides" value="1">
      </label>
      {{ else }}
      <label>
        <span>Upload slides</span>
        <input type="file" name="SlidesFile" accept=".pdf,.ppt,.pptx,.key,.odp">
      </label>
      {{ end }}
      <div class="dashboard-talk-resources__actions">
        {{ if .Proposal.ConfTalk.GithubRepoURL }}<a href="{{ .Proposal.ConfTalk.GithubRepoURL | safeURL }}" target="_blank" rel="noopener noreferrer">View repo</a>{{ end }}
        <button type="submit" class="dashboard-inline-action is-primary">Save resources</button>
      </div>
    </form>
    {{ end }}

    <form method="POST" action="/dashboard/talks/{{ .Proposal.ID }}/edit?hr={{ .HMAC }}&em={{ .Email }}"
          class="mt-8 space-y-6">

      <div>
        <label for="Title" class="block text-sm font-semibold text-gray-900">Talk title</label>
        <input id="Title" name="Title" type="text" required {{ if .Locked }}disabled{{ end }}
               value="{{ .Proposal.Title }}"
               class="mt-1 block w-full rounded-md border-gray-300 shadow-sm py-2 px-3 outline outline-1 -outline-offset-1 outline-gray-300 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin disabled:bg-gray-100" />
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="TalkType" class="block text-sm font-semibold text-gray-900">Type</label>
          <select id="TalkType" name="TalkType" required {{ if .Locked }}disabled{{ end }}
                  class="mt-1 block w-full rounded-md py-2 pl-3 pr-7 outline outline-1 -outline-offset-1 outline-gray-300 disabled:bg-gray-100">
            {{ $current := .Proposal.TalkType }}
            {{ range .TalkTypes }}
            <option value="{{ . }}" {{ if eq . $current }}selected{{ end }}>{{ . }}</option>
            {{ end }}
          </select>
        </div>
        <div>
          <label for="DesiredDuration" class="block text-sm font-semibold text-gray-900">Duration (min)</label>
          <select id="DesiredDuration" name="DesiredDuration" required {{ if .Locked }}disabled{{ end }}
                  class="mt-1 block w-full rounded-md py-2 pl-3 pr-7 outline outline-1 -outline-offset-1 outline-gray-300 disabled:bg-gray-100">
            {{ $cur := .Proposal.DesiredDuration }}
            {{ range .Durations }}
            <option value="{{ . }}" {{ if eq . $cur }}selected{{ end }}>{{ . }}</option>
            {{ end }}
          </select>
        </div>
      </div>

      <div>
        <label for="Description" class="block text-sm font-semibold text-gray-900">Description</label>
        <textarea id="Description" name="Description" rows="6" required {{ if .Locked }}disabled{{ end }}
                  class="mt-1 block w-full rounded-md py-2 px-3 outline outline-1 -outline-offset-1 outline-gray-300 disabled:bg-gray-100">{{ .Proposal.Description }}</textarea>
      </div>

      <div>
        <label for="Setup" class="block text-sm font-semibold text-gray-900">Setup / equipment</label>
        <textarea id="Setup" name="Setup" rows="3" {{ if .Locked }}disabled{{ end }}
                  class="mt-1 block w-full rounded-md py-2 px-3 outline outline-1 -outline-offset-1 outline-gray-300 disabled:bg-gray-100">{{ .Proposal.Setup }}</textarea>
      </div>

      <div>
        <label for="Comments" class="block text-sm font-semibold text-gray-900">Comments to the org</label>
        <textarea id="Comments" name="Comments" rows="3" {{ if .Locked }}disabled{{ end }}
                  class="mt-1 block w-full rounded-md py-2 px-3 outline outline-1 -outline-offset-1 outline-gray-300 disabled:bg-gray-100">{{ .Proposal.Comments }}</textarea>
      </div>

      {{ if not .Locked }}
      <div class="flex items-center justify-end gap-3 pt-2">
        <a href="/dashboard?hr={{ .HMAC }}&em={{ .Email }}"
           class="px-4 py-2 text-sm font-medium text-gray-700 hover:text-gray-900">Cancel</a>
        <button type="submit"
                class="px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700">
          Save changes
        </button>
      </div>
      {{ end }}
    </form>
  </div>
  {{ block "footer" . }} {{ end }}
</body>
</html>
