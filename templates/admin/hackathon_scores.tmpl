<!doctype html>
<html lang="en">
<head>
  <title>{{ .Competition.Title }} Scores - Admin - bitcoin++</title>
  {{ block "header" . }} {{ end }}
  {{ template "admin_favicon" "" }}
</head>
<body class="btcpp-admin-page admin-hackathon-page bg-gray-50 text-gray-900">
  {{ block "mainnav" . }} {{ end }}
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <a href="{{ .BackURL }}" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">&larr; {{ .BackLabel }}</a>
        <h1 class="mt-2 text-2xl font-semibold tracking-tight">{{ .Competition.Title }} scores</h1>
        <p class="mt-1 text-sm text-gray-600">Review submitted judge scorecards.</p>
      </div>
      <a href="{{ .HackathonURL .Competition }}" class="inline-flex items-center justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-gray-300 hover:bg-gray-50">Public page</a>
    </div>
    {{ template "admin_hackathon_tabs" . }}

    {{ if .FlashMessage }}
    <div class="mb-4 rounded-md border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-800">{{ .FlashMessage }}</div>
    {{ end }}
    {{ if .FlashError }}
    <div class="btcpp-admin-flash btcpp-admin-flash--error mb-4">{{ .FlashError }}</div>
    {{ end }}

    {{ if .ResultsFinalized }}
    <section class="mb-6 flex flex-col gap-3 rounded-lg border border-green-300 bg-green-50 px-4 py-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2 class="text-sm font-semibold text-green-900">Results are finalized and public</h2>
        <p class="mt-1 text-sm text-green-800">Published {{ .ResultsFinalizedLabel }}. Reopen results before changing award recipients.</p>
      </div>
      <form method="POST" action="{{ .ResultsURL .Competition }}/reopen" onsubmit="return confirm('Reopen these results? Winner badges and award recipients will immediately be hidden from the public page.');">
        <input type="hidden" name="ReturnTo" value="scores">
        <button type="submit" class="rounded-md bg-white px-3 py-2 text-sm font-semibold text-green-900 shadow-sm ring-1 ring-green-400 hover:bg-green-100">Reopen results</button>
      </form>
    </section>
    {{ else }}
    <section class="mb-6 flex flex-col gap-3 rounded-lg border border-amber-300 bg-amber-50 px-4 py-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2 class="text-sm font-semibold text-amber-950">Winner assignments are private</h2>
        <p class="mt-1 text-sm text-amber-900">Finalize only when judging is complete. This publishes every assigned recipient and locks award changes.</p>
      </div>
      <form method="POST" action="{{ .ResultsURL .Competition }}/finalize" onsubmit="return confirm('Finalize and publish these results? All assigned winners will become public and recipient changes will be locked.');">
        <input type="hidden" name="ReturnTo" value="scores">
        <button type="submit" class="rounded-md bg-amber-900 px-3 py-2 text-sm font-semibold text-white hover:bg-amber-800">Finalize and publish results</button>
      </form>
    </section>
    {{ end }}

    <section class="mb-8 overflow-hidden rounded-lg bg-white shadow">
      <div class="border-b border-gray-200 px-4 py-4 sm:px-6">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <h2 class="text-sm font-semibold text-gray-900">Rankings</h2>
          <div class="flex items-center gap-3">
            <nav class="inline-flex overflow-hidden rounded-md shadow-sm ring-1 ring-gray-300" aria-label="Judging event">
              {{ range .JudgeEvents }}
              <a href="{{ $.ScoresURLForJudgeEvent . }}" data-score-tab {{ if $.ScoreJudgeEventIs . }}aria-current="page"{{ end }} class="{{ if $.ScoreJudgeEventIs . }}bg-indigo-600 text-white{{ else }}bg-white text-gray-700 hover:bg-gray-50{{ end }} border-l border-gray-300 first:border-l-0 px-3 py-1.5 text-sm font-semibold">
                <span class="flex items-center gap-1.5">{{ .Name }}{{ if $.JudgeEventAcceptsScores . }}<span class="{{ if $.ScoreJudgeEventIs . }}bg-white/20 text-white{{ else }}bg-green-50 text-green-700{{ end }} rounded-full px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide">Open</span>{{ end }}</span>
                <span class="block text-[11px] font-medium {{ if $.ScoreJudgeEventIs . }}text-indigo-100{{ else }}text-gray-500{{ end }}">{{ $.JudgeEventTimeOnlyRange . }}</span>
              </a>
              {{ end }}
            </nav>
            <span class="text-sm text-gray-500">{{ len .ScoreSummaries }} projects</span>
          </div>
        </div>
      </div>
      <div class="grid gap-3 border-b border-gray-200 bg-gray-50 px-4 py-4 sm:grid-cols-4 sm:px-6">
        <div class="rounded-md bg-white p-3 shadow-sm ring-1 ring-gray-200">
          <div class="text-xs font-medium uppercase tracking-wide text-gray-500">Judges invited</div>
          <div class="mt-1 text-2xl font-semibold text-gray-900">{{ .ScoreInvitedJudgeCount }}</div>
        </div>
        <div class="rounded-md bg-white p-3 shadow-sm ring-1 ring-gray-200">
          <div class="text-xs font-medium uppercase tracking-wide text-gray-500">Ballots submitted</div>
          <div class="mt-1 text-2xl font-semibold text-gray-900">{{ .ScoreSubmittedBallotCount }}</div>
        </div>
        <div class="rounded-md bg-white p-3 shadow-sm ring-1 ring-gray-200">
          <div class="text-xs font-medium uppercase tracking-wide text-gray-500">Projects ranked</div>
          <div class="mt-1 text-2xl font-semibold text-gray-900">{{ .ScoreRankedProjectCount }}</div>
        </div>
        <div class="rounded-md bg-white p-3 shadow-sm ring-1 ring-gray-200">
          <div class="text-xs font-medium uppercase tracking-wide text-gray-500">Last ballot</div>
          <div class="mt-1 text-sm font-semibold text-gray-900">{{ .ScoreLastSubmittedAtLabel }}</div>
        </div>
      </div>
      {{ if .ScoreSummaries }}
      {{ if .ScoreHasNextJudgeEvent }}
      <form method="POST" action="{{ .JudgingURL .Competition }}/advance" class="grid gap-3 border-b border-gray-200 bg-gray-50 px-4 py-4 sm:grid-cols-[1fr_auto] sm:items-end sm:px-6">
        <input type="hidden" name="JudgeEventID" value="{{ .ScoreJudgeEventID }}">
        <div>
          <label for="TopN" class="block text-xs font-medium text-gray-700">Projects to advance to {{ .ScoreNextJudgeEventLabel }}</label>
          <input id="TopN" name="TopN" type="number" min="1" value="5" required
                 class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
        </div>
        <button type="submit" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Advance to {{ .ScoreNextJudgeEventLabel }}</button>
      </form>
      {{ else }}
      <div class="border-b border-gray-200 bg-indigo-50 px-4 py-4 text-sm text-indigo-900 sm:px-6">
        <strong>Final judging round.</strong> Assign the winning awards from the rankings below; there is no later round to advance projects into.
      </div>
      {{ end }}
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 text-left text-sm">
          <thead class="bg-gray-50 text-xs uppercase tracking-wide text-gray-500">
            <tr>
              <th scope="col" class="px-4 py-3">Project</th>
              <th scope="col" class="px-4 py-3">#</th>
              <th scope="col" class="px-4 py-3">Ranked by</th>
              <th scope="col" class="px-4 py-3">Points</th>
              <th scope="col" class="px-4 py-3">Avg rank</th>
              <th scope="col" class="px-4 py-3">Award</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            {{ range .ScoreSummaries }}
            <tr>
              <td class="px-4 py-3 font-medium text-gray-900">{{ .ProjectTitle }}</td>
              <td class="whitespace-nowrap px-4 py-3 font-mono text-xs text-gray-600">{{ .ProjectNumber }}</td>
              <td class="px-4 py-3 text-gray-700">{{ .ScoredScorecards }} judge{{ if ne .ScoredScorecards 1 }}s{{ end }}</td>
              <td class="px-4 py-3 font-medium text-gray-900">{{ .PointsLabel }}</td>
              <td class="px-4 py-3 text-gray-700">{{ .RankAverage }}</td>
              <td class="px-4 py-3">
                {{ $projectID := .ProjectID }}
                {{ $assignedAwards := $.ProjectAssignedAwards $projectID }}
                {{ if $assignedAwards }}
                <div class="mb-2 flex min-w-64 flex-wrap gap-1.5">
                  {{ range $assignedAwards }}
                  {{ if $.ResultsFinalized }}<span class="inline-flex items-center rounded-full bg-green-50 px-2 py-1 text-xs font-semibold text-green-800 ring-1 ring-green-200">{{ .Title }}</span>{{ else }}<form method="POST" action="{{ $.AwardsURL $.Competition }}/remove" class="inline-flex items-center rounded-full bg-green-50 text-xs font-semibold text-green-800 ring-1 ring-green-200">
                    <input type="hidden" name="ProjectID" value="{{ $projectID }}">
                    <input type="hidden" name="AwardID" value="{{ .ID }}">
                    <input type="hidden" name="Source" value="scores">
                    <span class="px-2 py-1">{{ .Title }}</span>
                    <button type="submit" class="border-l border-green-200 px-2 py-1 hover:bg-green-100" aria-label="Remove {{ .Title }} from this project">&times;</button>
                  </form>{{ end }}
                  {{ end }}
                </div>
                {{ end }}
                {{ $assignableAwards := $.ProjectAssignableAwards $projectID }}
                {{ if $assignableAwards }}
                <form method="POST" action="{{ $.AwardsURL $.Competition }}/assign" class="flex min-w-64 gap-2">
                  <input type="hidden" name="ProjectID" value="{{ $projectID }}">
                  <input type="hidden" name="Source" value="scores">
                  <select name="AwardID" required
                          class="block w-full rounded-md bg-white px-2 py-1 text-xs text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                    <option value="">{{ if $assignedAwards }}Add another award{{ else }}Select award{{ end }}</option>
                    {{ range $assignableAwards }}
                    <option value="{{ .ID }}">{{ .Title }}</option>
                    {{ end }}
                  </select>
                  <button type="submit" class="rounded-md bg-indigo-600 px-2.5 py-1.5 text-xs font-semibold text-white hover:bg-indigo-700">Assign</button>
                </form>
                {{ else if not $assignedAwards }}
                <span class="text-gray-400">No awards available</span>
                {{ end }}
              </td>
            </tr>
            {{ end }}
          </tbody>
        </table>
      </div>
      {{ else }}
      <div class="px-4 py-10 text-center sm:px-6">
        <p class="text-sm text-gray-600">No projects are available to rank yet.</p>
      </div>
      {{ end }}
    </section>

    {{ if .NonFinalistProjects }}
    <section class="mb-8 overflow-hidden rounded-lg bg-white shadow">
      <div class="border-b border-gray-200 px-4 py-4 sm:px-6">
        <h2 class="text-sm font-semibold text-gray-900">Non-finalist projects</h2>
        <p class="mt-1 text-sm text-gray-600">Assign bounties and other awards that are open to projects outside the final round. Finalists-only awards are intentionally excluded.</p>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 text-left text-sm">
          <thead class="bg-gray-50 text-xs uppercase tracking-wide text-gray-500">
            <tr>
              <th scope="col" class="px-4 py-3">Project</th>
              <th scope="col" class="px-4 py-3">#</th>
              <th scope="col" class="px-4 py-3">Award</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            {{ range .NonFinalistProjects }}
            {{ $projectID := .ID }}
            {{ $assignedAwards := $.ProjectAssignedAwards $projectID }}
            {{ $assignableAwards := $.ProjectAssignableAwards $projectID }}
            <tr>
              <td class="px-4 py-3 font-medium text-gray-900">{{ .Title }}</td>
              <td class="whitespace-nowrap px-4 py-3 font-mono text-xs text-gray-600">{{ $.ProjectNumberLabel . }}</td>
              <td class="px-4 py-3">
                {{ if $assignedAwards }}
                <div class="mb-2 flex min-w-64 flex-wrap gap-1.5">
                  {{ range $assignedAwards }}
                  {{ if $.ResultsFinalized }}<span class="inline-flex items-center rounded-full bg-green-50 px-2 py-1 text-xs font-semibold text-green-800 ring-1 ring-green-200">{{ .Title }}</span>{{ else }}<form method="POST" action="{{ $.AwardsURL $.Competition }}/remove" class="inline-flex items-center rounded-full bg-green-50 text-xs font-semibold text-green-800 ring-1 ring-green-200">
                    <input type="hidden" name="ProjectID" value="{{ $projectID }}">
                    <input type="hidden" name="AwardID" value="{{ .ID }}">
                    <input type="hidden" name="Source" value="scores">
                    <span class="px-2 py-1">{{ .Title }}</span>
                    <button type="submit" class="border-l border-green-200 px-2 py-1 hover:bg-green-100" aria-label="Remove {{ .Title }} from this project">&times;</button>
                  </form>{{ end }}
                  {{ end }}
                </div>
                {{ end }}
                {{ if $assignableAwards }}
                <form method="POST" action="{{ $.AwardsURL $.Competition }}/assign" class="flex min-w-64 gap-2">
                  <input type="hidden" name="ProjectID" value="{{ $projectID }}">
                  <input type="hidden" name="Source" value="scores">
                  <select name="AwardID" required
                          class="block w-full rounded-md bg-white px-2 py-1 text-xs text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                    <option value="">{{ if $assignedAwards }}Add another award{{ else }}Select award{{ end }}</option>
                    {{ range $assignableAwards }}
                    <option value="{{ .ID }}">{{ .Title }}</option>
                    {{ end }}
                  </select>
                  <button type="submit" class="rounded-md bg-indigo-600 px-2.5 py-1.5 text-xs font-semibold text-white hover:bg-indigo-700">Assign</button>
                </form>
                {{ else if not $assignedAwards }}
                <span class="text-gray-400">No non-finalist awards available</span>
                {{ end }}
              </td>
            </tr>
            {{ end }}
          </tbody>
        </table>
      </div>
    </section>
    {{ end }}

    <section class="overflow-hidden rounded-lg bg-white shadow">
      <div class="border-b border-gray-200 px-4 py-4 sm:px-6">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div>
            <h2 class="text-sm font-semibold text-gray-900">Judge ballots</h2>
            <p class="mt-1 text-sm text-gray-600">Ranked choices for {{ .ScoreJudgeEventLabel }}.</p>
          </div>
          <span class="text-sm text-gray-500">{{ len .ScoreBallots }} judges</span>
        </div>
      </div>
      {{ if .ScoreBallots }}
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 text-left text-sm">
          <thead class="bg-gray-50 text-xs uppercase tracking-wide text-gray-500">
            <tr>
              <th scope="col" class="px-4 py-3">Judge</th>
              {{ range .ScoreBallotRanks }}
              <th scope="col" class="px-4 py-3">{{ .RankLabel }}</th>
              {{ end }}
              <th scope="col" class="px-4 py-3">Submitted</th>
              <th scope="col" class="px-4 py-3 text-right">Action</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            {{ range .ScoreBallots }}
            <tr>
              <td class="whitespace-nowrap px-4 py-3 font-medium text-gray-900">{{ .JudgeName }}</td>
              {{ range .Ranks }}
              <td class="px-4 py-3 text-gray-700">
                {{ if .ProjectTitle }}
                <span class="font-medium text-gray-900">{{ .ProjectTitle }}</span>
                {{ else }}
                <span class="text-gray-400">-</span>
                {{ end }}
              </td>
              {{ end }}
              <td class="whitespace-nowrap px-4 py-3 text-gray-600">{{ with .SubmittedAt }}{{ .Format "Jan 2, 2006 3:04 PM" }}{{ else }}-{{ end }}</td>
              <td class="whitespace-nowrap px-4 py-3 text-right">
                {{ if .HasRankings }}
                <form method="POST" action="{{ $.JudgingURL $.Competition }}/scores/remove-ballot">
                  <input type="hidden" name="JudgeEventID" value="{{ $.ScoreJudgeEventID }}">
                  <input type="hidden" name="JudgePersonID" value="{{ .JudgePersonID }}">
                  <button type="submit" class="rounded-md px-2.5 py-1.5 text-xs font-semibold text-red-700 hover:bg-red-50">Remove</button>
                </form>
                {{ else }}
                <span class="text-gray-400">-</span>
                {{ end }}
              </td>
            </tr>
            {{ end }}
          </tbody>
        </table>
      </div>
      {{ else }}
      <div class="px-4 py-10 text-center sm:px-6">
        <p class="text-sm text-gray-600">No judge ballots are available for this event yet.</p>
      </div>
      {{ end }}
    </section>
  </div>
</body>
</html>
