<!DOCTYPE html>
<html>
<head>
  <title>Invite a speaker · admin · {{ .Conf.Desc }}</title>
  {{ block "header" . }} {{ end }}
  {{ template "admin_favicon" .Conf }}
</head>
<body class="btcpp-admin-page h-full bg-gray-50">
  {{ block "mainnav" . }} {{ end }}
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-6">
      <a href="/{{ .Conf.Tag }}/admin/review?id={{ .Proposal.ID }}" class="text-sm text-gray-500 hover:text-gray-700">&larr; Back to review</a>
    </div>

    <h1 class="text-2xl font-bold text-gray-900">Invite a speaker</h1>
    <p class="mt-2 text-sm text-gray-600">
      Share this link with the person you want to add to <span class="font-semibold">"{{ .Proposal.Title }}"</span>.
      They'll fill in their own name and email; the speaker entry gets created on submit.
    </p>

    <div class="mt-8 bg-white shadow rounded-lg p-6">
      <label for="invite-link" class="block text-sm font-semibold text-gray-900">Invite link</label>
      <div class="mt-2 flex gap-2">
        <input id="invite-link" type="text" readonly
               value="{{ .InviteURL }}"
               class="block w-full rounded-md bg-gray-50 px-3.5 py-2 text-sm text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 font-mono"
               onclick="this.select()" />
        <button type="button"
                onclick="navigator.clipboard.writeText(document.getElementById('invite-link').value).then(()=>{this.textContent='Copied!';setTimeout(()=>{this.textContent='Copy'},1500)})"
                class="shrink-0 inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700">
          Copy
        </button>
      </div>
      <p class="mt-3 text-xs text-gray-500">
        Anyone with this link can add themselves as a speaker on this talk. To revoke, edit the
        <code class="font-mono">InviteToken</code> field on the proposal.
      </p>
    </div>
  </div>
  {{ block "footer" . }} {{ end }}
</body>
</html>
