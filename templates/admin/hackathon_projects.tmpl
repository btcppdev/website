<!doctype html>
<html lang="en">
<head>
  <title>{{ .Competition.Title }} Projects - Admin - bitcoin++</title>
  {{ block "header" . }} {{ end }}
  {{ template "admin_favicon" "" }}
  <script src="/static/js/person-picker.js" defer></script>
</head>
<body class="btcpp-admin-page admin-hackathon-page bg-gray-50 text-gray-900">
  {{ block "mainnav" . }} {{ end }}
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <a href="{{ .BackURL }}" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">&larr; {{ .BackLabel }}</a>
        <h1 class="mt-2 text-2xl font-semibold tracking-tight">{{ .Competition.Title }} projects</h1>
        <p class="mt-1 text-sm text-gray-600">All submitted and in-progress projects for this hackathon.</p>
      </div>
      <a href="{{ .HackathonURL .Competition }}" class="inline-flex items-center justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-gray-300 hover:bg-gray-50">Public page</a>
    </div>
    {{ template "admin_hackathon_tabs" . }}

    {{ if .FlashMessage }}
    <div class="mb-4 rounded-md border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-800">{{ .FlashMessage }}</div>
    {{ end }}
    {{ if .FlashError }}
    <div class="mb-4 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">{{ .FlashError }}</div>
    {{ end }}

    <details class="mb-6 overflow-hidden rounded-lg bg-white shadow">
      <summary class="flex cursor-pointer list-none items-center justify-between gap-4 border-b border-gray-200 px-4 py-4 sm:px-6">
        <span>
          <span class="block text-sm font-semibold text-gray-900">Admin add project</span>
          <span class="mt-1 block text-sm text-gray-600">Create a project directly, even if public submissions are closed.</span>
        </span>
        <span class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white">Add project</span>
      </summary>
      <form method="POST" action="{{ .ProjectsURL .Competition }}" class="grid gap-4 px-4 py-5 sm:grid-cols-6 sm:p-6">
        <div class="sm:col-span-2">
          <label for="AdminProjectTitle" class="block text-sm font-medium text-gray-700">Title *</label>
          <input id="AdminProjectTitle" name="Title" type="text" required
                 class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
        </div>
        <div class="sm:col-span-2">
          <label for="AdminProjectShortDescription" class="block text-sm font-medium text-gray-700">Short description</label>
          <input id="AdminProjectShortDescription" name="ShortDescription" type="text"
                 class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
        </div>
        <div>
          <label for="AdminProjectNumber" class="block text-sm font-medium text-gray-700">#</label>
          <input id="AdminProjectNumber" name="ProjectNumber" type="number" min="1"
                 class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
        </div>
        <div>
          <label for="AdminProjectStatus" class="block text-sm font-medium text-gray-700">Status</label>
          <select id="AdminProjectStatus" name="Status"
                  class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
            <option value="submitted" selected>Submitted</option>
            <option value="created">Created</option>
            <option value="hidden">Hidden</option>
            <option value="advanced">Advanced</option>
          </select>
        </div>
        <div class="sm:col-span-2">
          <label for="AdminProjectOwnerSearch" class="block text-sm font-medium text-gray-700">Team people</label>
          <div class="relative mt-1" data-person-picker data-person-picker-name="TeamPersonID">
            <input id="AdminProjectOwnerSearch" type="search" data-person-picker-input
                   placeholder="Search by name, email, or phone"
                   class="block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
            <p class="mt-2 hidden text-xs text-indigo-700" data-person-picker-flash></p>
          </div>
        </div>
        <div class="sm:col-span-2">
          <label for="AdminProjectDemoURL" class="block text-sm font-medium text-gray-700">Demo URL</label>
          <input id="AdminProjectDemoURL" name="DemoURL" type="url"
                 class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
        </div>
        <div class="sm:col-span-2">
          <label for="AdminProjectGitHubURL" class="block text-sm font-medium text-gray-700">GitHub URL</label>
          <input id="AdminProjectGitHubURL" name="GitHubURL" type="url"
                 class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
        </div>
        <div class="sm:col-span-6 flex justify-end">
          <button type="submit" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Create project</button>
        </div>
      </form>
    </details>

    <section class="overflow-hidden rounded-lg bg-white shadow">
      <div class="border-b border-gray-200 px-4 py-4 sm:px-6">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div class="flex items-center gap-3">
            <h2 class="text-sm font-semibold text-gray-900">Projects</h2>
            <span class="text-xs text-gray-500" data-project-autosave-status></span>
          </div>
          <form method="POST" action="{{ .AssignProjectNumbersURL }}">
            <button type="submit" class="inline-flex items-center justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-gray-300 hover:bg-gray-50">Assign missing numbers</button>
          </form>
        </div>
      </div>
      {{ if .Projects }}
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 text-sm">
          <thead class="bg-gray-50 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">
            <tr>
              <th scope="col" class="px-4 py-3">#</th>
              <th scope="col" class="px-4 py-3">Project</th>
              <th scope="col" class="px-4 py-3">Team</th>
              <th scope="col" class="px-4 py-3">Status</th>
              <th scope="col" class="px-4 py-3">Submitted</th>
              <th scope="col" class="px-4 py-3">Links</th>
              <th scope="col" class="px-4 py-3">Updated</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            {{ range .Projects }}
            {{ $project := . }}
            <tr class="align-top">
              <td class="whitespace-nowrap px-4 py-3">
                <form id="ProjectAdmin-{{ .ID }}" method="POST" action="{{ $.ProjectAdminURL . }}" data-project-autosave-form>
                  <input type="hidden" name="AutoSave" value="1">
                </form>
                <input form="ProjectAdmin-{{ .ID }}" name="ProjectNumber" type="number" min="1" {{ with .ProjectNumber }}value="{{ . }}"{{ end }}
                       data-project-autosave
                       class="block w-20 rounded-md bg-white px-2 py-1 font-mono text-xs text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
              </td>
              <td class="px-4 py-3">
                <a href="{{ $.ProjectPublicURL . }}" class="font-medium text-indigo-600 hover:text-indigo-500">{{ .Title }}</a>
                <div class="mt-1"><a href="{{ $.ProjectPublicURL . }}/edit" class="text-xs font-semibold text-indigo-600 hover:text-indigo-500">Edit submission</a></div>
                {{ if .ShortDescription }}<div class="mt-1 max-w-md text-xs leading-5 text-gray-600">{{ .ShortDescription }}</div>{{ end }}
                {{ $optIns := $.ProjectAwardOptIns . }}
                {{ if $optIns }}
                <div class="mt-2 flex max-w-md flex-wrap gap-1">
                  {{ range $optIns }}
                  <span class="rounded-full bg-indigo-50 px-2 py-0.5 text-xs font-medium text-indigo-700">{{ .AwardTitle }}</span>
                  {{ end }}
                </div>
                {{ end }}
              </td>
              <td class="px-4 py-3">
                {{ $members := $.ProjectMembers . }}
                {{ if $members }}
                <ul class="space-y-1">
                  {{ range $members }}
                  <li>
                    <span class="font-medium text-gray-900">{{ if .Name }}{{ .Name }}{{ else }}{{ .PersonID }}{{ end }}</span>
                    <span class="text-xs text-gray-500">({{ .Role }})</span>
                    {{ if .Email }}<div class="text-xs text-gray-500">{{ .Email }}</div>{{ end }}
                    {{ if ne .Role "owner" }}
                    <form method="POST" action="/{{ $.Conf.Tag }}/hackathon/projects/{{ $project.ID }}/team/remove" class="mt-1" onsubmit="return confirm('Remove {{ .Name }} from this team?');">
                      <input type="hidden" name="PersonID" value="{{ .PersonID }}">
                      <input type="hidden" name="ReturnTo" value="admin-projects">
                      <button type="submit" class="text-xs font-semibold text-red-700 hover:text-red-900">Remove member</button>
                    </form>
                    {{ end }}
                  </li>
                  {{ end }}
                </ul>
                {{ else }}
                <span class="text-gray-500">No members</span>
                {{ end }}
              </td>
              <td class="whitespace-nowrap px-4 py-3">
                <select form="ProjectAdmin-{{ .ID }}" name="Status"
                        data-project-autosave
                        class="block min-w-28 rounded-md bg-white py-1 pl-2 pr-8 text-xs text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                  <option value="created" {{ if eq .Status "created" }}selected{{ end }}>Created</option>
                  <option value="submitted" {{ if eq .Status "submitted" }}selected{{ end }}>Submitted</option>
                  <option value="hidden" {{ if eq .Status "hidden" }}selected{{ end }}>Hidden</option>
                  <option value="advanced" {{ if eq .Status "advanced" }}selected{{ end }}>Advanced</option>
                </select>
              </td>
              <td class="whitespace-nowrap px-4 py-3 text-gray-600">
                {{ with .SubmittedAt }}{{ .Format "Jan 2, 2006 3:04 PM" }}{{ else }}Not submitted{{ end }}
              </td>
              <td class="px-4 py-3">
                <div class="flex flex-wrap gap-x-3 gap-y-1">
                  {{ if .GitHubURL }}<a class="font-medium text-indigo-600 hover:text-indigo-500" href="{{ .GitHubURL }}">GitHub</a>{{ end }}
                  {{ if .DemoURL }}<a class="font-medium text-indigo-600 hover:text-indigo-500" href="{{ .DemoURL }}">Demo</a>{{ end }}
                  {{ if .VideoURL }}<a class="font-medium text-indigo-600 hover:text-indigo-500" href="{{ .VideoURL }}">Video</a>{{ end }}
                  {{ if .SlidesURL }}<a class="font-medium text-indigo-600 hover:text-indigo-500" href="{{ .SlidesURL }}">Slides</a>{{ end }}
                  {{ if .DocsURL }}<a class="font-medium text-indigo-600 hover:text-indigo-500" href="{{ .DocsURL }}">Docs</a>{{ end }}
                  {{ if and (not .GitHubURL) (not .DemoURL) (not .VideoURL) (not .SlidesURL) (not .DocsURL) }}<span class="text-gray-500">None</span>{{ end }}
                </div>
              </td>
              <td class="whitespace-nowrap px-4 py-3 text-gray-600">{{ .UpdatedAt.Format "Jan 2, 2006 3:04 PM" }}</td>
            </tr>
            {{ end }}
          </tbody>
        </table>
      </div>
      {{ else }}
      <div class="px-4 py-10 text-center sm:px-6">
        <p class="text-sm text-gray-600">No projects have been created for this hackathon yet.</p>
      </div>
      {{ end }}
    </section>
  </div>
  <script>
    (function () {
      function statusFor(form) {
        return document.querySelector('[data-project-autosave-status]');
      }

      function setStatus(form, text, className) {
        const status = statusFor(form);
        if (!status) return;
        status.textContent = text;
        status.className = className;
      }

      async function autosave(input) {
        const formID = input.getAttribute('form');
        const form = formID ? document.getElementById(formID) : input.form;
        if (!form || !form.reportValidity()) return;
        setStatus(form, 'Saving...', 'text-xs text-gray-500');
        try {
          const response = await fetch(form.action, {
            method: form.method || 'POST',
            body: new URLSearchParams(new FormData(form)),
            headers: {
              'Accept': 'text/plain',
              'Content-Type': 'application/x-www-form-urlencoded'
            }
          });
          if (!response.ok) {
            const message = (await response.text()).trim() || 'Save failed';
            throw new Error(message);
          }
          setStatus(form, 'Saved', 'text-xs font-medium text-green-700');
        } catch (error) {
          setStatus(form, error.message || 'Save failed', 'text-xs font-medium text-red-700');
        }
      }

      for (const input of document.querySelectorAll('[data-project-autosave]')) {
        input.addEventListener('change', function () {
          autosave(input);
        });
      }
    })();
  </script>
</body>
</html>
