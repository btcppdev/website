<!DOCTYPE html>
<html>
  <head>
    <title>youtube publish slots @ bitcoin++</title>
    {{ block "header" . }} {{ end }}
  </head>
  <body>
    {{ block "mainnav" . }} {{ end }}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-5xl">

        <section class="mt-6 mb-6">
          <div class="overflow-hidden sm:rounded-lg bg-white shadow">
            <div class="px-4 py-5 sm:p-6 flex items-start justify-between gap-4">
              <div>
                <a href="/{{ .Conf.Tag }}/admin/recordings" class="text-xs text-gray-500 hover:text-gray-700">&larr; back to recordings</a>
                <h1 class="text-xl font-bold text-gray-900">YouTube publish slots</h1>
                <p class="text-sm text-gray-500">Set the recurring channel schedule used by recordings autoschedule.</p>
              </div>
              <a href="/{{ .Conf.Tag }}/admin/recordings/autoschedule" class="px-3 py-1.5 text-sm rounded-md text-white bg-indigo-600 hover:bg-indigo-700">Autoschedule</a>
            </div>
          </div>
        </section>

        {{ if .FlashMessage }}
        <section class="mb-6">
          <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg">{{ .FlashMessage }}</div>
        </section>
        {{ end }}
        {{ if .FlashError }}
        <section class="mb-6">
          <div class="bg-yellow-50 border border-yellow-300 text-yellow-800 px-4 py-3 rounded-lg">{{ .FlashError }}</div>
        </section>
        {{ end }}

        <form method="POST" action="/{{ .Conf.Tag }}/admin/recordings/youtube-slots" class="mb-8 bg-white shadow rounded-lg overflow-hidden">
          <div class="px-4 py-4 border-b border-gray-200 flex flex-wrap items-end gap-4">
            <label class="block">
              <span class="block text-xs font-medium text-gray-500 uppercase tracking-wider">Timezone</span>
              <input type="text" name="timezone" value="{{ .Timezone }}" class="mt-1 w-64 rounded-md border-gray-300 text-sm shadow-sm focus:border-indigo-500 focus:ring-indigo-500">
            </label>
            <div class="text-xs text-gray-500">Enter publish times as 24-hour `HH:MM`, separated by spaces, commas, or new lines.</div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-0 divide-y md:divide-y-0 md:divide-x divide-gray-200">
            {{ range .Groups }}
            <div class="p-4 border-b border-gray-100">
              <label class="block">
                <span class="block text-sm font-semibold text-gray-900">{{ .Name }}</span>
                <textarea name="times_{{ .Weekday }}" rows="4" class="mt-2 block w-full rounded-md border-gray-300 text-sm shadow-sm focus:border-indigo-500 focus:ring-indigo-500" placeholder="10:05&#10;14:04">{{ .Times }}</textarea>
              </label>
            </div>
            {{ end }}
          </div>

          <div class="px-4 py-4 border-t border-gray-200 flex items-center justify-end gap-3">
            <a href="/{{ .Conf.Tag }}/admin/recordings" class="px-3 py-1.5 text-sm rounded-md text-gray-700 bg-gray-100 hover:bg-gray-200">Cancel</a>
            <button type="submit" class="px-3 py-1.5 text-sm rounded-md text-white bg-indigo-600 hover:bg-indigo-700">Save slots</button>
          </div>
        </form>

      </div>
    </div>
  </body>
</html>
