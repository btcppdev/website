<!DOCTYPE html>
<html>
<head>
  <title>Edit talk - {{ .Conf.Desc }}</title>
  {{ block "header" . }} {{ end }}
  {{ template "admin_favicon" .Conf }}
</head>
<body class="bg-gray-50">
  {{ block "mainnav" . }} {{ end }}
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-4">
      <a href="{{ .ReturnURL }}" class="text-xs text-gray-500 hover:text-gray-700">&larr; back</a>
    </div>

    <section class="mb-6">
      <div class="overflow-hidden sm:rounded-lg bg-white shadow">
        <div class="px-4 py-5 sm:p-6">
          <h1 class="text-xl font-bold text-gray-900">Edit talk</h1>
          <p class="mt-1 text-sm text-gray-500">{{ .Conf.Desc }} &middot; {{ .Conf.DateDesc }}</p>
          <p class="mt-2 text-xs text-gray-500">
            Status: <span class="font-medium text-gray-700">{{ .Proposal.Status }}</span>.
            Changes save immediately. If this talk is already <em>Scheduled</em>,
            attendees won't see updated cal-invite copy until you trigger
            <span class="font-mono">Send cal updates</span> from the schedule page.
          </p>
        </div>
      </div>
    </section>

    {{ if .Flash }}
    <div class="mb-4 rounded-md bg-green-50 border border-green-200 px-4 py-3">
      <p class="text-sm text-green-800">{{ .Flash }}</p>
    </div>
    {{ end }}
    {{ if .FlashErr }}
    <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3">
      <p class="text-sm text-red-800">{{ .FlashErr }}</p>
    </div>
    {{ end }}

    {{/*
      Speakers panel — separate from the content-edit form below
      because Remove POSTs to a different endpoint. Each row is
      its own <form> so the buttons don't nest illegally and the
      content-edit Save button doesn't submit a remove by accident.
      ?return= rides through so the remove handler bounces back
      here on success rather than dropping into the review queue.
    */}}
    <section class="mb-6 bg-white shadow rounded-lg p-6">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-semibold text-gray-900">Speakers ({{ len .Speakers }})</h2>
        {{ if .InviteURL }}
        <button type="button"
                data-share-url="{{ .InviteURL }}"
                class="affiliate-share-btn inline-flex items-center rounded-md bg-indigo-600 px-2.5 py-1 text-xs font-semibold text-white hover:bg-indigo-700"
                title="Copy the share-a-link URL — anyone with the link can join this talk as a co-speaker">
          Copy invite link
        </button>
        {{ else }}
        <a href="/{{ .Conf.Tag }}/admin/proposal/{{ .Proposal.ID }}/invite"
           class="inline-flex items-center rounded-md bg-indigo-600 px-2.5 py-1 text-xs font-semibold text-white hover:bg-indigo-700"
           title="Mint a share-a-link URL so a new speaker can join this talk">
          Generate invite link
        </a>
        {{ end }}
      </div>
      {{/*
        Add-existing-speaker search box. Hits /api/speakers/search
        (returns up to 10 JSON matches by name/email substring),
        renders a dropdown, posts the picked speaker ID to the
        attach handler. No invite-token round-trip, no email — just
        wires the SpeakerConf onto the proposal. If the talk is
        Scheduled the handler also fires a force=true REQUEST so
        the new attendee gets a calendar invite.
      */}}
      <div class="relative mb-3" data-speaker-picker>
        <form method="POST"
              action="/{{ .Conf.Tag }}/admin/proposal/{{ .Proposal.ID }}/speakers/attach"
              class="flex items-center gap-2">
          <input type="hidden" name="speakerID" data-speaker-id>
          <input type="text"
                 data-speaker-q
                 placeholder="Add speaker by name or email…"
                 autocomplete="off"
                 class="flex-1 rounded-md border border-gray-300 px-3 py-1.5 text-xs focus:outline-2 focus:outline-bitcoin" />
          <button type="submit"
                  data-speaker-submit
                  disabled
                  class="inline-flex items-center rounded-md bg-green-600 px-2.5 py-1.5 text-xs font-semibold text-white hover:bg-green-700 disabled:bg-gray-300 disabled:cursor-not-allowed">
            Attach
          </button>
        </form>
        <ul data-speaker-results
            class="hidden absolute z-10 mt-1 w-full max-h-60 overflow-auto rounded-md border border-gray-200 bg-white shadow-lg text-xs">
        </ul>
      </div>

      {{ if .Speakers }}
      <ul class="divide-y divide-gray-100 border border-gray-100 rounded-md">
        {{ range .Speakers }}
        {{ if .Speaker }}
        <li class="flex items-center justify-between gap-3 px-3 py-2">
          <div class="flex items-center gap-2 min-w-0">
            <img src="{{ if .Speaker.Photo }}{{ speakerPhoto .Speaker.Photo }}{{ else }}/static/img/speaker-placeholder.png{{ end }}"
                 alt="{{ .Speaker.Name }}"
                 class="size-7 rounded-full object-cover bg-gray-100 shrink-0" />
            <div class="min-w-0">
              <p class="text-sm font-medium text-gray-900 truncate">{{ .Speaker.Name }}</p>
              {{ if .Speaker.Email }}
              <p class="text-xs text-gray-500 truncate font-mono">{{ .Speaker.Email }}</p>
              {{ end }}
            </div>
          </div>
          <form method="POST"
                action="/{{ $.Conf.Tag }}/admin/proposal/{{ $.Proposal.ID }}/speakers/{{ .ID }}/remove?return=/{{ $.Conf.Tag }}/admin/proposal/{{ $.Proposal.ID }}/edit"
                class="shrink-0">
            <button type="submit"
                    class="inline-flex items-center rounded-md border border-red-200 bg-white px-2.5 py-1 text-xs font-medium text-red-700 hover:bg-red-50"
                    onclick="return confirm('Remove {{ .Speaker.Name }} from this talk? If the talk is Scheduled they get a CANCEL cal invite and the remaining speakers get an updated REQUEST.');">
              Remove
            </button>
          </form>
        </li>
        {{ end }}
        {{ end }}
      </ul>
      {{ else }}
      <p class="text-xs text-gray-500 italic">No speakers on this talk yet. Share the invite link above so a speaker can join.</p>
      {{ end }}
    </section>

    <form method="POST" action="/{{ .Conf.Tag }}/admin/proposal/{{ .Proposal.ID }}/edit?return={{ .ReturnURL }}"
          class="space-y-6 bg-white shadow rounded-lg p-6">

      <div>
        <label for="Title" class="block text-sm font-semibold text-gray-900">Title</label>
        <input id="Title" name="Title" type="text" required
               value="{{ .Proposal.Title }}"
               class="mt-1 block w-full rounded-md border-gray-300 shadow-sm py-2 px-3 outline outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:outline-bitcoin" />
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="TalkType" class="block text-sm font-semibold text-gray-900">Type</label>
          <select id="TalkType" name="TalkType" required
                  class="mt-1 block w-full rounded-md py-2 pl-3 pr-7 outline outline-1 -outline-offset-1 outline-gray-300">
            {{ $current := .Proposal.TalkType }}
            {{ range .TalkTypes }}
            <option value="{{ . }}" {{ if eq . $current }}selected{{ end }}>{{ . }}</option>
            {{ end }}
          </select>
        </div>
        <div>
          <label for="DesiredDuration" class="block text-sm font-semibold text-gray-900">Duration (min)</label>
          <select id="DesiredDuration" name="DesiredDuration" required
                  class="mt-1 block w-full rounded-md py-2 pl-3 pr-7 outline outline-1 -outline-offset-1 outline-gray-300">
            {{ $cur := .Proposal.DesiredDuration }}
            {{ range .Durations }}
            <option value="{{ . }}" {{ if eq . $cur }}selected{{ end }}>{{ . }}</option>
            {{ end }}
          </select>
        </div>
      </div>

      <div>
        <label for="Description" class="block text-sm font-semibold text-gray-900">Description</label>
        <textarea id="Description" name="Description" rows="6" required
                  class="mt-1 block w-full rounded-md py-2 px-3 outline outline-1 -outline-offset-1 outline-gray-300">{{ .Proposal.Description }}</textarea>
      </div>

      <div>
        <label for="Setup" class="block text-sm font-semibold text-gray-900">Setup / equipment</label>
        <textarea id="Setup" name="Setup" rows="3"
                  class="mt-1 block w-full rounded-md py-2 px-3 outline outline-1 -outline-offset-1 outline-gray-300">{{ .Proposal.Setup }}</textarea>
      </div>

      <div>
        <label for="Comments" class="block text-sm font-semibold text-gray-900">Comments</label>
        <textarea id="Comments" name="Comments" rows="3"
                  class="mt-1 block w-full rounded-md py-2 px-3 outline outline-1 -outline-offset-1 outline-gray-300">{{ .Proposal.Comments }}</textarea>
      </div>

      <div class="flex items-center justify-end gap-3 pt-2">
        <a href="{{ .ReturnURL }}"
           class="px-4 py-2 text-sm font-medium text-gray-700 hover:text-gray-900">Cancel</a>
        <button type="submit"
                class="px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700">
          Save changes
        </button>
      </div>
    </form>
  </div>
  <script>
    // Speaker picker: debounced search against /api/speakers/search,
    // renders a dropdown of matches; click → fill hidden speakerID
    // and enable the Attach submit. Free-form text without a pick
    // keeps the submit disabled to dodge accidental attaches.
    (function () {
      var picker = document.querySelector('[data-speaker-picker]');
      if (!picker) return;
      var qInput  = picker.querySelector('[data-speaker-q]');
      var idInput = picker.querySelector('[data-speaker-id]');
      var submit  = picker.querySelector('[data-speaker-submit]');
      var results = picker.querySelector('[data-speaker-results]');
      var timer = null;

      function setPicked(id, label) {
        idInput.value = id;
        if (label) qInput.value = label;
        submit.disabled = !id;
        results.classList.add('hidden');
      }

      function render(hits) {
        results.innerHTML = '';
        if (!hits || !hits.length) {
          results.classList.add('hidden');
          return;
        }
        hits.forEach(function (h) {
          var li = document.createElement('li');
          li.className = 'cursor-pointer px-3 py-2 hover:bg-gray-100 border-b border-gray-100 last:border-b-0';
          li.innerHTML = '<div class="font-medium text-gray-900"></div>' +
                         '<div class="text-gray-500 font-mono"></div>';
          li.firstChild.textContent = h.name + (h.company ? ' · ' + h.company : '');
          li.lastChild.textContent = h.email;
          li.addEventListener('click', function () {
            setPicked(h.id, h.name + ' <' + h.email + '>');
          });
          results.appendChild(li);
        });
        results.classList.remove('hidden');
      }

      qInput.addEventListener('input', function () {
        idInput.value = '';
        submit.disabled = true;
        var q = qInput.value.trim();
        if (timer) clearTimeout(timer);
        if (q.length < 2) {
          results.classList.add('hidden');
          return;
        }
        timer = setTimeout(function () {
          fetch('/api/speakers/search?q=' + encodeURIComponent(q), { credentials: 'same-origin' })
            .then(function (r) { return r.ok ? r.json() : []; })
            .then(render)
            .catch(function () { results.classList.add('hidden'); });
        }, 200);
      });

      document.addEventListener('click', function (e) {
        if (!picker.contains(e.target)) results.classList.add('hidden');
      });
    })();

    // Copy invite link to clipboard. Mirrors the dashboard's
    // affiliate-share button click handler, scoped to this page
    // so we don't depend on a shared <script src=> load.
    (function () {
      document.querySelectorAll('.affiliate-share-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var url = btn.getAttribute('data-share-url');
          if (!url) return;
          navigator.clipboard.writeText(url).then(function () {
            var orig = btn.textContent;
            btn.textContent = 'Copied!';
            setTimeout(function () { btn.textContent = orig; }, 1500);
          }, function () {
            // Clipboard API rejected (HTTP context, denied perm,
            // etc) — fall back to a prompt so the admin can copy
            // manually rather than silent failure.
            window.prompt('Copy this URL:', url);
          });
        });
      });
    })();
  </script>
</body>
</html>
