<!DOCTYPE html>
<html>
<head>
  <title>{{ .Conf.Desc }} · organizer dashboard</title>
  {{ block "header" . }} {{ end }}
  {{ template "admin_favicon" .Conf }}
</head>
<body class="btcpp-admin-page bg-gray-50">
  {{ block "mainnav" . }} {{ end }}
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-12">
    <a href="/dashboard" class="text-xs text-gray-500 hover:text-gray-700">&larr; Back to all events</a>

    <article class="dashboard-ledger-card dashboard-admin-conf-card">
      <div class="dashboard-ledger-card__hero-wrap">
        <a href="/{{ .Conf.Tag }}" class="dashboard-ledger-card__hero" target="_blank" rel="noopener noreferrer">
          <picture>
            <source srcset="/static/img/{{ .Conf.Tag }}/leading.avif" type="image/avif" />
            <img src="/static/img/{{ .Conf.Tag }}/leading.png" alt="{{ .Conf.Desc }}" />
          </picture>
          <div class="dashboard-ledger-card__scrim"></div>
          <div class="dashboard-ledger-card__hero-copy">
            <div class="dashboard-ledger-card__meta">{{ .Conf.DateDesc }} · {{ .Conf.Location }}</div>
            <h2><span>{{ .Conf.EmojiOrDefault }}</span>{{ .Conf.Desc }}</h2>
          </div>
        </a>
        <div class="dashboard-ledger-card__tools">
        {{ if .IsConfVolcoord }}
        <button type="button"
                data-conf-tag="{{ .Conf.Tag }}"
                class="copy-vol-invite-btn dashboard-ledger-card__pill">
          Copy volunteer invite link
        </button>
        {{ end }}
        <a href="/{{ .Conf.Tag }}" target="_blank" rel="noopener noreferrer"
           class="dashboard-ledger-card__pill is-accent">
          Conference webpage <span aria-hidden="true">&rarr;</span>
        </a>
        </div>
      </div>
    </article>

    {{ if .FlashMessage }}
    <div class="mt-6 rounded-md bg-green-50 border border-green-200 px-4 py-3">
      <p class="text-sm text-green-800">{{ .FlashMessage }}</p>
    </div>
    {{ end }}

    {{ if .Stats }}
    <h2 class="mt-8 text-xs font-semibold uppercase tracking-wider text-gray-500">At a glance</h2>
    <div class="mt-3 grid grid-cols-2 sm:grid-cols-4 gap-3">
      <div class="rounded-md border border-gray-200 bg-white px-4 py-3">
        <p class="text-xs font-medium uppercase tracking-wider text-gray-500">Tickets sold</p>
        <p class="mt-1 text-2xl font-semibold text-gray-900">{{ .Stats.TicketsSold }}</p>
        <p class="mt-1 text-xs text-gray-500">{{ .Stats.CheckedInAttendees }} checked in</p>
        {{ if .Stats.RevenueByCurrency }}
        <p class="mt-1 text-xs text-gray-500">
          {{ range $i, $rev := .Stats.RevenueByCurrency }}{{ if $i }} · {{ end }}{{ printf "%.0f" $rev.Amount }} {{ $rev.Currency }}{{ end }}
        </p>
        {{ end }}
      </div>
      <div class="rounded-md border border-gray-200 bg-white px-4 py-3">
        <p class="text-xs font-medium uppercase tracking-wider text-gray-500">Speakers confirmed</p>
        <p class="mt-1 text-2xl font-semibold text-gray-900">{{ .Stats.SpeakersConfirmed }}</p>
        <p class="mt-1 text-xs text-gray-500">
          {{ if .Stats.PendingApplications }}{{ .Stats.PendingApplications }} application{{ if ne .Stats.PendingApplications 1 }}s{{ end }} pending{{ else }}no apps pending{{ end }}
        </p>
      </div>
      <div class="rounded-md border border-gray-200 bg-white px-4 py-3">
        <p class="text-xs font-medium uppercase tracking-wider text-gray-500">Volunteers scheduled</p>
        <p class="mt-1 text-2xl font-semibold text-gray-900">{{ .Stats.VolunteersScheduled }}</p>
      </div>
      <div class="rounded-md border border-gray-200 bg-white px-4 py-3">
        <p class="text-xs font-medium uppercase tracking-wider text-gray-500">Sponsors</p>
        <p class="mt-1 text-2xl font-semibold text-gray-900">{{ .Stats.SponsorsPaid }} <span class="text-sm font-normal text-gray-500">paid</span></p>
        <p class="mt-1 text-xs text-gray-500">
          {{ .Stats.SponsorsCommitted }} committed · {{ .Stats.SponsorsInProgress }} in-progress
        </p>
      </div>
    </div>

    {{ if or .Stats.AffiliateTickets .Stats.TopAffiliates }}
    <div class="mt-3 rounded-md border border-gray-200 bg-white px-4 py-3">
      <div class="flex items-baseline justify-between gap-2 flex-wrap">
        <p class="text-xs font-medium uppercase tracking-wider text-gray-500">Affiliate tickets</p>
        <p class="text-2xl font-semibold text-gray-900">{{ .Stats.AffiliateTickets }}</p>
      </div>
      {{ if .Stats.TopAffiliates }}
      <p class="mt-3 text-xs font-medium uppercase tracking-wider text-gray-500">Top affiliates</p>
      <table class="mt-2 min-w-full text-sm">
        <thead>
          <tr class="text-left text-xs font-medium text-gray-500">
            <th class="py-1 pr-3">Email</th>
            <th class="py-1 pr-3">Earned (sats)</th>
            <th class="py-1">Tickets</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {{ range .Stats.TopAffiliates }}
          <tr>
            <td class="py-1 pr-3 text-gray-900 font-mono text-xs break-all">{{ .Email }}</td>
            <td class="py-1 pr-3 text-gray-700 font-mono text-xs">{{ sats .EarnedSats }}</td>
            <td class="py-1 text-gray-700">{{ .TicketsSold }}</td>
          </tr>
          {{ end }}
        </tbody>
      </table>
      {{ end }}
    </div>
    {{ end }}
    {{ end }}

    {{ if .IsConfAdmin }}
    <h2 class="mt-10 text-xs font-semibold uppercase tracking-wider text-gray-500">Talk applications</h2>
    <div class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-3">
      <a href="/{{ .Conf.Tag }}/admin/review"
         class="group flex items-center gap-3 bg-white shadow rounded-lg px-4 py-3 hover:bg-indigo-50 hover:shadow-md transition">
        <div class="text-2xl">&#128221;</div>
        <div class="min-w-0 flex-1">
          <p class="text-sm font-semibold text-gray-900">Review applications</p>
          <p class="text-xs text-gray-500">
            {{ if .ReviewCountsReady }}{{ if .PendingCount }}{{ .PendingCount }} pending{{ else }}all caught up{{ end }}{{ if .DecisionedCount }} &middot; {{ .DecisionedCount }} decisioned{{ end }}{{ else }}counts refreshing{{ end }}
          </p>
        </div>
        <span class="text-sm font-medium text-indigo-600 group-hover:text-indigo-700">Walk through &rarr;</span>
      </a>
      <a href="/{{ .Conf.Tag }}/admin/applicants"
         class="group flex items-center gap-3 bg-white shadow rounded-lg px-4 py-3 hover:bg-gray-50 hover:shadow-md transition">
        <div class="text-2xl">&#128203;</div>
        <div class="min-w-0 flex-1">
          <p class="text-sm font-semibold text-gray-900">Talk proposals</p>
          <p class="text-xs text-gray-500">Per-card actions + cal invites</p>
        </div>
        <span class="text-sm font-medium text-gray-600 group-hover:text-gray-900">Open &rarr;</span>
      </a>
      <a href="/{{ .Conf.Tag }}/admin/schedule"
         class="group flex items-center gap-3 bg-white shadow rounded-lg px-4 py-3 hover:bg-indigo-50 hover:shadow-md transition">
        <div class="text-2xl">&#128197;</div>
        <div class="min-w-0 flex-1">
          <p class="text-sm font-semibold text-gray-900">Schedule talks</p>
          <p class="text-xs text-gray-500">Drag &amp; drop into venues</p>
        </div>
        <span class="text-sm font-medium text-indigo-600 group-hover:text-indigo-700">Open &rarr;</span>
      </a>
      <a href="/{{ .Conf.Tag }}/admin/cliparts"
         class="group flex items-center gap-3 bg-white shadow rounded-lg px-4 py-3 hover:bg-indigo-50 hover:shadow-md transition">
        <div class="text-2xl">&#127912;</div>
        <div class="min-w-0 flex-1">
          <p class="text-sm font-semibold text-gray-900">Talk cliparts</p>
          <p class="text-xs text-gray-500">Upload artwork per talk</p>
        </div>
        <span class="text-sm font-medium text-indigo-600 group-hover:text-indigo-700">Open &rarr;</span>
      </a>
      <a href="/{{ .Conf.Tag }}/admin/invite-speaker"
         class="group flex items-center gap-3 bg-white shadow rounded-lg px-4 py-3 hover:bg-indigo-50 hover:shadow-md transition">
        <div class="text-2xl">&#128231;</div>
        <div class="min-w-0 flex-1">
          <p class="text-sm font-semibold text-gray-900">Invite a speaker</p>
          <p class="text-xs text-gray-500">Send a magic link directly</p>
        </div>
        <span class="text-sm font-medium text-indigo-600 group-hover:text-indigo-700">Open &rarr;</span>
      </a>
    </div>
    {{ end }}

    <h2 class="mt-10 text-xs font-semibold uppercase tracking-wider text-gray-500">Other event tools</h2>
    <div class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-3">
      {{ if .IsGlobalAdmin }}
      <a href="/{{ .Conf.Tag }}/admin/details"
         class="flex items-center gap-3 bg-white shadow rounded-lg px-4 py-3 hover:bg-gray-50">
        <div class="text-2xl">&#9881;</div>
        <div class="min-w-0 flex-1">
          <p class="text-sm font-medium text-gray-900">Event details</p>
          <p class="text-xs text-gray-500">State, venue hours, stages, breaks</p>
        </div>
      </a>
      {{ end }}
      <a href="/{{ .Conf.Tag }}/admin/run-of-show"
         class="flex items-center gap-3 bg-white shadow rounded-lg px-4 py-3 hover:bg-gray-50">
        <div class="text-2xl">&#127916;</div>
        <span class="text-sm font-medium text-gray-900">Run of show</span>
      </a>
      <a href="/{{ .Conf.Tag }}/run-of-show" target="_blank" rel="noopener noreferrer"
         class="flex items-center gap-3 bg-white shadow rounded-lg px-4 py-3 hover:bg-gray-50">
        <div class="text-2xl">&#128279;</div>
        <span class="text-sm font-medium text-gray-900">Public run of show</span>
      </a>
      <a href="/{{ .Conf.Tag }}/admin/speakers"
         class="flex items-center gap-3 bg-white shadow rounded-lg px-4 py-3 hover:bg-gray-50">
        <div class="text-2xl">&#127908;</div>
        <span class="text-sm font-medium text-gray-900">Speakers</span>
      </a>
      <a href="/{{ .Conf.Tag }}/admin/registrations"
         class="flex items-center gap-3 bg-white shadow rounded-lg px-4 py-3 hover:bg-gray-50">
        <div class="text-2xl">&#127915;</div>
        <span class="text-sm font-medium text-gray-900">Registrations</span>
      </a>
      {{ if .IsConfAdmin }}
      <a href="/{{ .Conf.Tag }}/admin/sponsors"
         class="flex items-center gap-3 bg-white shadow rounded-lg px-4 py-3 hover:bg-gray-50">
        <div class="text-2xl">&#128176;</div>
        <span class="text-sm font-medium text-gray-900">Sponsorships</span>
      </a>
      <a href="/{{ .Conf.Tag }}/admin/social"
         class="flex items-center gap-3 bg-white shadow rounded-lg px-4 py-3 hover:bg-gray-50">
        <div class="text-2xl">&#128241;</div>
        <span class="text-sm font-medium text-gray-900">Social posts</span>
      </a>
      <a href="/{{ .Conf.Tag }}/admin/recordings"
         class="flex items-center gap-3 bg-white shadow rounded-lg px-4 py-3 hover:bg-gray-50">
        <div class="text-2xl">&#127909;</div>
        <span class="text-sm font-medium text-gray-900">Recordings</span>
      </a>
      {{ end }}
      <a href="/{{ .Conf.Tag }}/admin/social-cards.zip"
         class="flex items-center gap-3 bg-white shadow rounded-lg px-4 py-3 hover:bg-gray-50">
        <div class="text-2xl">&#128190;</div>
        <span class="text-sm font-medium text-gray-900">Download all talk cards (.zip)</span>
      </a>
      <a href="/{{ .Conf.Tag }}/admin/gifts"
         class="flex items-center gap-3 bg-white shadow rounded-lg px-4 py-3 hover:bg-gray-50">
        <div class="text-2xl">&#127873;</div>
        <span class="text-sm font-medium text-gray-900">Speaker gifts CSV</span>
      </a>
      {{ if .IsConfAdmin }}
      <a href="/{{ .Conf.Tag }}/admin/comp-tickets"
         class="flex items-center gap-3 bg-white shadow rounded-lg px-4 py-3 hover:bg-gray-50">
        <div class="text-2xl">&#127915;</div>
        <span class="text-sm font-medium text-gray-900">Issue comp tickets</span>
      </a>
      <a href="/{{ .Conf.Tag }}/admin/discounts"
         class="flex items-center gap-3 bg-white shadow rounded-lg px-4 py-3 hover:bg-gray-50">
        <div class="text-2xl">&#127991;</div>
        <span class="text-sm font-medium text-gray-900">Discounts</span>
      </a>
      {{ end }}
      {{ if .IsConfVolcoord }}
      <a href="/{{ .Conf.Tag }}/volcoord"
         class="flex items-center gap-3 bg-white shadow rounded-lg px-4 py-3 hover:bg-gray-50">
        <div class="text-2xl">&#129489;</div>
        <span class="text-sm font-medium text-gray-900">Volunteers</span>
      </a>
      {{ end }}
      <a href="/{{ .Conf.Tag }}/admin/hotels"
         class="flex items-center gap-3 bg-white shadow rounded-lg px-4 py-3 hover:bg-gray-50">
        <div class="text-2xl">&#127976;</div>
        <span class="text-sm font-medium text-gray-900">Hotels</span>
      </a>
      <a href="/{{ .Conf.Tag }}/admin/satellites"
         class="flex items-center gap-3 bg-white shadow rounded-lg px-4 py-3 hover:bg-gray-50">
        <div class="text-2xl">&#128752;</div>
        <span class="text-sm font-medium text-gray-900">Satellite events</span>
      </a>
    </div>
  </div>
  <script>
    // Copy the {origin}/volunteer/{tag} URL to the clipboard. Uses
    // window.location.origin so dev and prod resolve to the right
    // host without server-side URI threading.
    (function () {
      document.querySelectorAll('.copy-vol-invite-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var tag = btn.dataset.confTag;
          if (!tag) return;
          var url = window.location.origin + '/volunteer/' + tag;
          var original = btn.textContent;
          navigator.clipboard.writeText(url).then(function () {
            btn.textContent = 'Copied!';
            btn.classList.add('bg-green-600');
            btn.classList.remove('bg-indigo-600', 'hover:bg-indigo-700');
            setTimeout(function () {
              btn.textContent = original;
              btn.classList.remove('bg-green-600');
              btn.classList.add('bg-indigo-600', 'hover:bg-indigo-700');
            }, 1500);
          }).catch(function () {
            btn.textContent = 'Copy failed';
            setTimeout(function () { btn.textContent = original; }, 1500);
          });
        });
      });
    })();
  </script>
  {{ block "footer" . }} {{ end }}
</body>
</html>
