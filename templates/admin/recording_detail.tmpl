<!DOCTYPE html>
<html>
  <head>
    <title>{{ if .Row.ConfTalk }}{{ if .Row.ConfTalk.Proposal }}{{ .Row.ConfTalk.Proposal.Title }}{{ else }}{{ .Row.Recording.TalkName }}{{ end }}{{ else }}{{ .Row.Recording.TalkName }}{{ end }} · recording</title>
    {{ block "header" . }} {{ end }}
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>&#127909;</text></svg>">
  </head>
  <body class="btcpp-admin-page">
    {{ block "mainnav" . }} {{ end }}
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-8">

      <a href="/{{ .Conf.Tag }}/admin/recordings" class="text-xs text-gray-500 hover:text-gray-700">&larr; Recordings</a>

      <header class="mt-2 mb-6">
        <h1 class="text-2xl font-bold text-gray-900">
          {{ if .Row.ConfTalk }}{{ if .Row.ConfTalk.Proposal }}{{ .Row.ConfTalk.Proposal.Title }}{{ else }}{{ .Row.Recording.TalkName }}{{ end }}{{ else }}{{ .Row.Recording.TalkName }}{{ end }}
        </h1>
        <p class="text-sm text-gray-500 mt-1">
          {{ if and .Row.ConfTalk .Row.ConfTalk.Conf }}<span>{{ .Row.ConfTalk.Conf.Desc }}</span>{{ end }}
          {{ if and .Row.ConfTalk .Row.ConfTalk.Sched }}<span class="ml-2">· recorded {{ .Row.ConfTalk.Sched.Start.Format "Jan 2, 2006" }}</span>{{ end }}
        </p>
        {{ if .Row.Speakers }}
        <p class="text-sm text-gray-700 mt-1">
          Speakers:
          {{ range $i, $s := .Row.Speakers }}{{ if $i }}, {{ end }}{{ $s.Name }}{{ if $s.Twitter.Handle }} (<a href="{{ $s.Twitter.Link }}" class="text-indigo-600" target="_blank" rel="noopener">@{{ $s.Twitter.Handle }}</a>){{ end }}{{ end }}
        </p>
        {{ end }}
      </header>

      {{ if .FlashMessage }}
      <div class="mb-4 rounded-md bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-800">{{ .FlashMessage }}</div>
      {{ end }}
      {{ if .FlashError }}
      <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">{{ .FlashError }}</div>
      {{ end }}

      <section class="mb-6 bg-white shadow rounded-lg p-5">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-gray-500 mb-3">Source video</h2>
        {{ if .Row.Recording.FileURI }}
        <p class="text-sm text-gray-700">Spaces key: <code class="bg-gray-100 px-1.5 py-0.5 rounded text-xs">{{ .Row.Recording.FileURI }}</code></p>
        {{ else }}
        <p class="text-sm text-yellow-700">No <code>FileURI</code> set. Add the Spaces key to the recording row before uploading.</p>
        {{ end }}
        <dl class="mt-4 grid grid-cols-1 sm:grid-cols-3 gap-3 text-xs">
          <div>
            <dt class="font-medium text-gray-500">PublishAt</dt>
            <dd class="mt-1 text-gray-900">{{ if .Row.Recording.PublishAt }}{{ .Row.Recording.PublishAt.Format "Jan 2, 2006 3:04 PM MST" }}{{ else }}—{{ end }}</dd>
          </div>
          <div>
            <dt class="font-medium text-gray-500">YouTube status</dt>
            <dd class="mt-1 text-gray-900">
              {{ if .Row.YTStatus }}{{ .Row.YTStatus }}{{ else if .Row.YTPrivacyStatus }}{{ .Row.YTPrivacyStatus }}{{ else }}—{{ end }}
              {{ if .Row.YTUploadStatus }}<div class="text-gray-500">{{ .Row.YTUploadStatus }}</div>{{ end }}
            </dd>
          </div>
          <div>
            <dt class="font-medium text-gray-500">X status</dt>
            <dd class="mt-1 text-gray-900">{{ if .Row.XStatus }}{{ .Row.XStatus }}{{ else }}—{{ end }}</dd>
          </div>
          <div>
            <dt class="font-medium text-gray-500">YouTube PublishAt</dt>
            <dd class="mt-1 text-gray-900">{{ if .Row.YTPublishAt }}{{ .Row.YTPublishAt.Format "Jan 2, 2006 3:04 PM MST" }}{{ else }}—{{ end }}</dd>
          </div>
        </dl>
        {{ if .Row.YTError }}
        <div class="mt-3 rounded-md bg-red-50 border border-red-200 px-3 py-2 text-xs text-red-800">YouTube error: {{ .Row.YTError }}</div>
        {{ end }}
        {{ if .Row.YTStatusError }}
        <div class="mt-3 rounded-md bg-yellow-50 border border-yellow-200 px-3 py-2 text-xs text-yellow-800">YouTube status lookup failed: {{ .Row.YTStatusError }}</div>
        {{ end }}
        {{ if eq .Row.YTPrivacyStatus "public" }}
        <div class="mt-3 rounded-md bg-blue-50 border border-blue-200 px-3 py-2 text-xs text-blue-800">This YouTube video is already public. Schedule changes here will update recording/X state, but YouTube will not be moved back into scheduled state.</div>
        {{ end }}
        {{ if .Row.XError }}
        <div class="mt-3 rounded-md bg-red-50 border border-red-200 px-3 py-2 text-xs text-red-800">X error: {{ .Row.XError }}</div>
        {{ end }}
        <form method="POST" action="/{{ .Conf.Tag }}/admin/recordings/{{ .Row.Recording.ID }}/schedule" class="mt-4 flex flex-wrap items-end gap-3">
          <div>
            <label class="block text-xs font-medium text-gray-700">Publish time</label>
            <input id="publish-at-input" type="datetime-local" name="publish_at" value="{{ .PublishAtInput }}"
                   class="mt-1 rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-bitcoin">
          </div>
          <div class="pb-2 text-xs text-gray-500">{{ .PublishTimezone }}</div>
          <button type="submit" name="action" value="save"
                  class="px-3 py-2 text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700">Save schedule</button>
          {{ if .Row.Recording.PublishAt }}
          <button type="submit" name="action" value="clear"
                  class="px-3 py-2 text-sm rounded-md bg-gray-100 text-gray-700 hover:bg-gray-200">Clear</button>
          {{ end }}
        </form>
      </section>

      <!-- YouTube section -->
      <section class="mb-6 bg-white shadow rounded-lg p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-semibold uppercase tracking-wider text-gray-500">YouTube</h2>
          {{ if .Row.YTURL }}
          <a href="{{ .Row.YTURL }}" target="_blank" rel="noopener" class="text-xs text-indigo-600 hover:text-indigo-800">{{ .Row.YTURL }} ↗</a>
          {{ end }}
        </div>

        {{ if .JobActive }}
        <div id="yt-status" class="mb-4 rounded-md bg-blue-50 border border-blue-200 px-4 py-3 text-sm text-blue-800">
          Uploading to YouTube… this can take several minutes for a longform talk. You can leave this page; the upload continues server-side.
        </div>
        <script>
          (function poll() {
            fetch('/{{ .Conf.Tag }}/admin/recordings/{{ .Row.Recording.ID }}/status')
              .then(r => r.json())
              .then(j => {
                if (j.status === 'succeeded') {
                  location.reload();
                } else if (j.status === 'failed') {
                  document.getElementById('yt-status').className = 'mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800';
                  document.getElementById('yt-status').innerText = 'Upload failed: ' + j.message;
                } else {
                  setTimeout(poll, 4000);
                }
              })
              .catch(() => setTimeout(poll, 6000));
          })();
        </script>
        {{ else if eq .JobStatus "failed" }}
        <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">Last upload failed: {{ .JobMessage }}</div>
        {{ else if eq .JobStatus "succeeded" }}
        <div class="mb-4 rounded-md bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-800">Upload succeeded: <a href="{{ .JobMessage }}" target="_blank" rel="noopener" class="underline">{{ .JobMessage }}</a></div>
        {{ end }}

        <form method="POST" action="/{{ .Conf.Tag }}/admin/recordings/{{ .Row.Recording.ID }}/upload-yt" class="space-y-4">
          <div>
            <label class="block text-xs font-medium text-gray-700">Title <span class="text-gray-400">(max 100 chars)</span></label>
            <input type="text" name="yt_title" value="{{ .YTTitle }}" maxlength="100"
                   class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-bitcoin">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-700">Description</label>
            <textarea name="yt_body" rows="14"
                      class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-bitcoin font-mono">{{ .YTBody }}</textarea>
          </div>
          <div class="flex items-center gap-3">
            <label class="text-xs text-gray-700">
              Privacy:
              <select name="privacy" class="ml-1 rounded border-gray-300 text-sm">
                <option value="public" selected>Public</option>
                <option value="unlisted">Unlisted</option>
                <option value="private">Private</option>
              </select>
            </label>
            <button type="submit"
                    {{ if or (not .YouTubeReady) (not .Row.Recording.FileURI) .JobActive }}disabled{{ end }}
                    class="px-4 py-2 text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 disabled:bg-gray-300 disabled:cursor-not-allowed">
              {{ if .Row.YTURL }}Re-upload to YouTube{{ else }}Upload to YouTube{{ end }}
            </button>
            {{ if not .YouTubeReady }}
            <span class="text-xs text-gray-500">(authorize YouTube on the recordings page first)</span>
            {{ else if not .Row.Recording.FileURI }}
            <span class="text-xs text-gray-500">(no FileURI set)</span>
            {{ end }}
          </div>
        </form>
      </section>

      <!-- X section -->
      <section class="mb-6 bg-white shadow rounded-lg p-5">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-sm font-semibold uppercase tracking-wider text-gray-500">X.com</h2>
          <div class="flex items-center gap-3">
            {{ if .Row.XReplyURL }}
            <a href="{{ .Row.XReplyURL }}" target="_blank" rel="noopener" class="text-xs text-indigo-600 hover:text-indigo-800">reply ↗</a>
            {{ end }}
            {{ if .Row.XURL }}
            <a href="{{ .Row.XURL }}" target="_blank" rel="noopener" class="text-xs text-indigo-600 hover:text-indigo-800">{{ .Row.XURL }} ↗</a>
            {{ end }}
          </div>
        </div>

        {{ if .XJobActive }}
        <div id="x-status" data-stage="{{ .XJobStatus }}" class="mb-4 rounded-md bg-blue-50 border border-blue-200 px-4 py-3 text-sm text-blue-800">
          <div class="flex flex-wrap items-center gap-2 text-xs font-medium">
            <span data-x-stage="prepare" class="x-stage rounded-full bg-blue-600 px-2 py-0.5 text-white">Prepare</span>
            <span data-x-stage="download" class="x-stage rounded-full bg-blue-100 px-2 py-0.5 text-blue-800">Download</span>
            <span data-x-stage="upload" class="x-stage rounded-full bg-blue-100 px-2 py-0.5 text-blue-800">Upload</span>
            <span data-x-stage="save" class="x-stage rounded-full bg-blue-100 px-2 py-0.5 text-blue-800">Save</span>
            <span data-x-stage="done" class="x-stage rounded-full bg-blue-100 px-2 py-0.5 text-blue-800">Done</span>
          </div>
          <div id="x-status-message" class="mt-3">X automation running: {{ .XJobMessage }}</div>
          <div id="x-progress-wrap" class="mt-3 hidden h-2 w-full overflow-hidden rounded-full bg-blue-100">
            <div id="x-progress-bar" class="h-full w-0 rounded-full bg-blue-600 transition-all"></div>
          </div>
        </div>
        <script>
          function updateXProgress(stage, progress) {
            document.querySelectorAll('.x-stage').forEach(function(el) {
              var active = el.getAttribute('data-x-stage') === stage;
              el.className = active
                ? 'x-stage rounded-full bg-blue-600 px-2 py-0.5 text-white'
                : 'x-stage rounded-full bg-blue-100 px-2 py-0.5 text-blue-800';
            });
            var wrap = document.getElementById('x-progress-wrap');
            var bar = document.getElementById('x-progress-bar');
            if (!wrap || !bar) return;
            if (stage === 'download' || stage === 'upload') {
              wrap.classList.remove('hidden');
              bar.style.width = Math.max(0, Math.min(100, progress || 0)) + '%';
            } else {
              wrap.classList.add('hidden');
            }
          }
          (function pollX() {
            fetch('/{{ .Conf.Tag }}/admin/recordings/{{ .Row.Recording.ID }}/x-status')
              .then(r => r.json())
              .then(j => {
                var el = document.getElementById('x-status');
                var msg = document.getElementById('x-status-message');
                if (!el) return;
                updateXProgress(j.stage, j.progress);
                if (j.status === 'succeeded' || j.status === 'posted' || j.status === 'scheduled') {
                  el.className = 'mb-4 rounded-md bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-800';
                  if (msg) msg.innerText = j.url ? 'X posted: ' + j.url : 'X automation finished: ' + (j.message || j.status);
                  setTimeout(function() { location.reload(); }, 1500);
                } else if (j.status === 'failed' || j.status === 'auth_required') {
                  el.className = 'mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800';
                  if (msg) msg.innerText = 'X automation failed: ' + (j.message || j.status);
                } else {
                  if (msg) msg.innerText = 'X automation running: ' + (j.message || j.status || 'working');
                  setTimeout(pollX, 4000);
                }
              })
              .catch(() => setTimeout(pollX, 6000));
          })();
        </script>
        {{ else if eq .XJobStatus "failed" }}
        <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">Last X automation failed: {{ .XJobMessage }}</div>
        {{ else if eq .XJobStatus "succeeded" }}
        <div class="mb-4 rounded-md bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-800">Last X automation finished: {{ .XJobMessage }}</div>
        {{ end }}

        <form method="POST" action="/{{ .Conf.Tag }}/admin/recordings/{{ .Row.Recording.ID }}/x-copy" class="space-y-3">
          <label class="block text-xs font-medium text-gray-700">Main post</label>
          <textarea id="x-body" name="x_body" rows="6" required
                    class="block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-bitcoin font-mono">{{ .XBody }}</textarea>
          <input type="hidden" id="x-publish-at" name="publish_at" value="{{ .PublishAtInput }}">
          <div class="flex items-center gap-3">
            <button type="submit"
                    class="px-3 py-1.5 text-sm rounded-md text-white bg-indigo-600 hover:bg-indigo-700">Save X text</button>
            {{ $xBusy := or (eq .Row.XStatus "scheduling") (eq .Row.XStatus "scheduled") (eq .Row.XStatus "posting") }}
            <button type="submit" formaction="/{{ .Conf.Tag }}/admin/recordings/{{ .Row.Recording.ID }}/post-x"
                    {{ if or .Row.XURL (not .Row.Recording.FileURI) $xBusy (not .XUploaderEnabled) }}disabled{{ end }}
                    class="px-3 py-1.5 text-sm rounded-md text-white bg-black hover:bg-gray-800 disabled:bg-gray-300 disabled:cursor-not-allowed">
              {{ if eq .Row.XStatus "posting" }}Posting...{{ else }}Post now{{ end }}
            </button>
            <button id="x-schedule-button" type="submit" formaction="/{{ .Conf.Tag }}/admin/recordings/{{ .Row.Recording.ID }}/schedule-x"
                    {{ if or .Row.XURL (not .Row.Recording.FileURI) $xBusy (not .XUploaderEnabled) }}disabled{{ end }}
                    class="{{ if not .PublishAtInput }}hidden {{ end }}px-3 py-1.5 text-sm rounded-md text-white bg-emerald-600 hover:bg-emerald-700 disabled:bg-gray-300 disabled:cursor-not-allowed">
              {{ if eq .Row.XStatus "scheduled" }}Scheduled on X{{ else if eq .Row.XStatus "scheduling" }}Scheduling X...{{ else }}Schedule{{ end }}
            </button>
            <button type="button" onclick="navigator.clipboard.writeText(document.getElementById('x-body').value); this.innerText='Copied!'; setTimeout(()=>this.innerText='Copy text',1500);"
                    class="px-3 py-1.5 text-sm rounded-md bg-gray-100 text-gray-700 hover:bg-gray-200">Copy text</button>
            <a href="{{ .XIntentURL }}" target="_blank" rel="noopener"
               class="px-3 py-1.5 text-sm rounded-md text-white bg-black hover:bg-gray-800">Open X compose ↗</a>
          </div>
        </form>

        <div class="mt-4 space-y-3">
          <label class="block text-xs font-medium text-gray-700">Reply</label>
          <textarea id="x-reply-body" rows="3" readonly
                    class="block w-full rounded-md bg-gray-50 px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 font-mono">{{ .XReplyBody }}</textarea>
          <div class="flex items-center gap-3">
            <button type="button" onclick="navigator.clipboard.writeText(document.getElementById('x-reply-body').value); this.innerText='Copied!'; setTimeout(()=>this.innerText='Copy reply',1500);"
                    class="px-3 py-1.5 text-sm rounded-md bg-gray-100 text-gray-700 hover:bg-gray-200">Copy reply</button>
            <form method="POST" action="/{{ .Conf.Tag }}/admin/recordings/{{ .Row.Recording.ID }}/retry-x" class="inline">
              <button type="submit" class="px-3 py-1.5 text-sm rounded-md text-white bg-indigo-600 hover:bg-indigo-700">Retry X automation</button>
            </form>
          </div>
        </div>

        <form method="POST" action="/{{ .Conf.Tag }}/admin/recordings/{{ .Row.Recording.ID }}/x" class="mt-5 space-y-2">
          <label class="block text-xs font-medium text-gray-700">Resulting X URL</label>
          <div class="flex gap-2">
            <input type="text" name="x_url" value="{{ .Row.XURL }}" placeholder="https://x.com/btcplusplus/status/…"
                   class="flex-1 rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-bitcoin">
            <button type="submit" class="px-3 py-1.5 text-sm rounded-md text-white bg-indigo-600 hover:bg-indigo-700">Save</button>
          </div>
        </form>
      </section>

    </div>
    <script>
      (function() {
        var publishAt = document.getElementById('publish-at-input');
        var xPublishAt = document.getElementById('x-publish-at');
        var scheduleButton = document.getElementById('x-schedule-button');
        if (!publishAt || !xPublishAt || !scheduleButton) {
          return;
        }
        function syncPublishAt() {
          var hasPublishAt = publishAt.value.trim() !== '';
          xPublishAt.value = publishAt.value;
          scheduleButton.classList.toggle('hidden', !hasPublishAt);
        }
        publishAt.addEventListener('input', syncPublishAt);
        publishAt.addEventListener('change', syncPublishAt);
        syncPublishAt();
      })();
    </script>
  </body>
</html>
