<!DOCTYPE html>
<html>
  <head>
    <title>recordings @ bitcoin++</title>
    {{ block "header" . }} {{ end }}
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>&#127909;</text></svg>">
  </head>
  <body class="btcpp-admin-page">
    {{ block "mainnav" . }} {{ end }}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-6xl">

        <section id="topline" class="mt-6 mb-6">
          <div class="overflow-hidden sm:rounded-lg bg-white shadow">
            <div class="px-4 py-5 sm:p-6 flex items-center justify-between">
              <div>
                <a href="/{{ .Conf.Tag }}/admin" class="text-xs text-gray-500 hover:text-gray-700">&larr; {{ .Conf.Desc }} dashboard</a>
                <h1 class="text-xl font-bold text-gray-900">Recordings</h1>
                <p class="text-sm text-gray-500">Upload longform talks to YouTube and X.com from a single dashboard.</p>
              </div>
              <div class="flex items-center gap-2 flex-wrap justify-end">
                <a href="/{{ .Conf.Tag }}/admin/recordings/autoschedule" class="px-3 py-1.5 text-sm rounded-md text-white bg-indigo-600 hover:bg-indigo-700">Autoschedule YouTube</a>
                <a href="/{{ .Conf.Tag }}/admin/recordings/youtube-slots" class="px-3 py-1.5 text-sm rounded-md text-gray-700 bg-gray-100 hover:bg-gray-200">Publish slots</a>
                {{ if .AutopublishEnabled }}
                  <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">Autopublish on</span>
                {{ else }}
                  <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-700">Autopublish off</span>
                {{ end }}
                {{ if .YouTubeReady }}
                  <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">YouTube connected ✓</span>
                  <form method="POST" action="/{{ .Conf.Tag }}/admin/recordings/oauth/youtube/disconnect" class="inline">
                    <button type="submit" class="text-xs text-gray-500 hover:text-gray-700 underline">disconnect</button>
                  </form>
                {{ else }}
                  <a href="{{ .YouTubeAuthURL }}" class="px-3 py-1.5 text-sm rounded-md text-white bg-red-600 hover:bg-red-700">Authorize YouTube</a>
                {{ end }}
                {{ if .XUploaderEnabled }}
                  <form method="POST" action="/{{ .Conf.Tag }}/admin/recordings/x/auth-check" class="inline">
                    <button type="submit" class="px-3 py-1.5 text-sm rounded-md text-white bg-black hover:bg-gray-800">Test X auth</button>
                  </form>
                {{ else }}
                  <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-700">X uploader off</span>
                {{ end }}
              </div>
            </div>
          </div>
        </section>

        {{ if .FlashMessage }}
        <section class="mb-6">
          <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg">{{ .FlashMessage }}</div>
        </section>
        {{ end }}
        {{ if .FlashError }}
        <section class="mb-6">
          <div class="bg-yellow-50 border border-yellow-300 text-yellow-800 px-4 py-3 rounded-lg">{{ .FlashError }}</div>
        </section>
        {{ end }}

        {{ if .Rows }}
        <section class="mb-6">
          <div class="bg-white shadow rounded-lg overflow-hidden">
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Talk</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Conf</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Speakers</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Publish</th>
                  <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">File</th>
                  <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">YouTube</th>
                  <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">X</th>
                  <th class="px-4 py-3"></th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
                {{ range .Rows }}
                <tr class="hover:bg-gray-50">
                  <td class="px-4 py-3 text-sm text-gray-900">
                    {{ if .ConfTalk }}{{ if .ConfTalk.Proposal }}{{ .ConfTalk.Proposal.Title }}{{ else }}{{ .Recording.TalkName }}{{ end }}{{ else }}{{ .Recording.TalkName }}{{ end }}
                    {{ if and .ConfTalk .ConfTalk.Sched }}<div class="text-xs text-gray-400">{{ .ConfTalk.Sched.Start.Format "Jan 2, 2006" }}</div>{{ end }}
                  </td>
                  <td class="px-4 py-3 text-sm text-gray-700">{{ if and .ConfTalk .ConfTalk.Conf }}{{ .ConfTalk.Conf.Desc }}{{ end }}</td>
                  <td class="px-4 py-3 text-sm text-gray-700">
                    {{ range $i, $s := .Speakers }}{{ if $i }}, {{ end }}{{ $s.Name }}{{ end }}
                  </td>
                  <td class="px-4 py-3 text-sm text-gray-700">
                    {{ if .Recording.PublishAt }}{{ .Recording.PublishAt.Format "Jan 2, 2006 3:04 PM MST" }}{{ else }}<span class="text-gray-300">—</span>{{ end }}
                    {{ if .YTPublishAt }}
                    <div class="mt-1 text-xs text-red-700">YT: {{ .YTPublishAt.Format "Jan 2, 2006 3:04 PM MST" }}</div>
                    {{ else if .YTPrivacyStatus }}
                    <div class="mt-1 text-xs text-gray-400">YT: {{ .YTPrivacyStatus }}</div>
                    {{ end }}
                  </td>
                  <td class="px-4 py-3 text-center">
                    {{ if .HasFile }}
                      <span class="text-green-600">✓</span>
                    {{ else }}
                      <form method="POST" action="/{{ $.Conf.Tag }}/admin/recordings/{{ .Recording.ID }}/file" enctype="multipart/form-data" class="flex items-center justify-center gap-2">
                        <input type="file" name="recording_file" accept="video/*,.mp4,.mov,.m4v,.webm" required class="block w-36 text-xs text-gray-600 file:mr-2 file:rounded-md file:border-0 file:bg-gray-100 file:px-2 file:py-1 file:text-xs file:text-gray-700 hover:file:bg-gray-200">
                        <button type="submit" class="px-2 py-1 text-xs rounded-md bg-indigo-600 text-white hover:bg-indigo-700">Upload</button>
                      </form>
                    {{ end }}
                  </td>
                  <td class="px-4 py-3 text-center">
                    {{ if .HasYT }}<a href="{{ .YTURL }}" class="text-green-600" target="_blank" rel="noopener">✓</a>{{ else if .YTStatus }}<span class="text-xs text-gray-600">{{ .YTStatus }}</span>{{ else }}<span class="text-gray-300">—</span>{{ end }}
                    {{ if .YTPrivacyStatus }}<div class="text-[11px] text-gray-400">{{ .YTPrivacyStatus }}{{ if .YTUploadStatus }} / {{ .YTUploadStatus }}{{ end }}</div>{{ end }}
                    {{ if .YTStatusError }}<div class="text-[11px] text-red-500">status error</div>{{ end }}
                  </td>
                  <td class="px-4 py-3 text-center">
                    {{ if .HasX }}<a href="{{ .XURL }}" class="text-green-600" target="_blank" rel="noopener">✓</a>{{ else if .XStatus }}<span class="text-xs text-gray-600">{{ .XStatus }}</span>{{ else }}<span class="text-gray-300">—</span>{{ end }}
                  </td>
                  <td class="px-4 py-3 text-right">
                    <a href="/{{ $.Conf.Tag }}/admin/recordings/{{ .Recording.ID }}" class="text-sm text-indigo-600 hover:text-indigo-800">Open →</a>
                  </td>
                </tr>
                {{ end }}
              </tbody>
            </table>
          </div>
        </section>
        {{ else }}
        <section class="mb-6 text-sm text-gray-500">No recordings found. Add a recording row and refresh.</section>
        {{ end }}

      </div>
    </div>
  </body>
</html>
