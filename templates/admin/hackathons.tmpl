<!doctype html>
<html lang="en">
<head>
  <title>Hackathons - Admin - bitcoin++</title>
  {{ block "header" . }} {{ end }}
  {{ template "admin_favicon" "" }}
</head>
<body class="bg-gray-50 text-gray-900">
  {{ block "mainnav" . }} {{ end }}
  <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <a href="/admin" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">&larr; Admin</a>
        <h1 class="mt-2 text-2xl font-semibold tracking-tight">Hackathons</h1>
        <p class="mt-1 text-sm text-gray-600">Create and update competition setup before opening project registration.</p>
      </div>
      <div class="flex flex-wrap gap-2">
        <a href="/hackathons" class="inline-flex items-center justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-gray-300 hover:bg-gray-50">
          Public page
        </a>
        <a href="/admin/hackathons/new" class="inline-flex items-center justify-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700">
          Create new hackathon
        </a>
      </div>
    </div>

    {{ if .FlashMessage }}
    <div class="mb-4 rounded-md border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-800">{{ .FlashMessage }}</div>
    {{ end }}
    {{ if .FlashError }}
    <div class="mb-4 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">{{ .FlashError }}</div>
    {{ end }}

    <details class="mb-6 rounded-lg bg-white shadow" {{ if or .SearchQuery (ne .Sort "newest") }}open{{ end }}>
      <summary class="cursor-pointer px-4 py-3 text-sm font-semibold text-gray-900 hover:bg-gray-50">Filter and sort</summary>
      <form method="GET" action="/admin/hackathons" class="border-t border-gray-100 p-4">
        <div class="grid gap-3 md:grid-cols-[minmax(0,1fr)_12rem_auto] md:items-end">
          <div>
            <label for="HackathonSearch" class="block text-xs font-medium uppercase tracking-wide text-gray-500">Search</label>
            <input id="HackathonSearch" name="q" type="search" value="{{ .SearchQuery }}" placeholder="Search title or conference" class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600">
          </div>
          <div>
            <label for="HackathonSort" class="block text-xs font-medium uppercase tracking-wide text-gray-500">Sort</label>
            <select id="HackathonSort" name="sort" class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600">
              <option value="newest" {{ if eq .Sort "newest" }}selected{{ end }}>Newest</option>
              <option value="oldest" {{ if eq .Sort "oldest" }}selected{{ end }}>Oldest</option>
              <option value="title" {{ if eq .Sort "title" }}selected{{ end }}>Title A-Z</option>
              <option value="conference" {{ if eq .Sort "conference" }}selected{{ end }}>Conference</option>
            </select>
          </div>
          <div class="flex gap-2">
            <button type="submit" class="inline-flex items-center justify-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Apply</button>
            {{ if .SearchQuery }}
            <a href="/admin/hackathons{{ if ne .Sort "newest" }}?sort={{ .Sort }}{{ end }}" class="inline-flex items-center justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-700 outline outline-1 -outline-offset-1 outline-gray-300 hover:bg-gray-50">Clear</a>
            {{ end }}
          </div>
        </div>
      </form>
    </details>

    <section class="overflow-hidden rounded-lg bg-white shadow">
      <div class="border-b border-gray-200 px-4 py-4 sm:px-6">
        <h2 class="text-sm font-semibold text-gray-900">Competitions</h2>
      </div>
      {{ if .Competitions }}
      <ul class="divide-y divide-gray-100">
        {{ range .Competitions }}
        <li class="group cursor-pointer px-4 py-4 hover:bg-gray-50 focus:bg-gray-50 sm:px-6"
            role="link"
            tabindex="0"
            onclick="window.location.href='{{ $.EditURL . }}'"
            onkeydown="if ((event.key === 'Enter' || event.key === ' ') && event.target === this) { event.preventDefault(); window.location.href='{{ $.EditURL . }}'; }">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div class="min-w-0 flex-1">
              <div class="flex flex-col gap-2 sm:flex-row sm:items-start">
                <div class="min-w-0">
                  <div class="text-sm font-semibold text-gray-900">{{ .Title }}</div>
                  <div class="mt-1 break-all font-mono text-xs text-gray-500">/hackathons/{{ .Slug }}</div>
                </div>
              </div>
              <div class="mt-3 flex flex-wrap gap-x-5 gap-y-2 text-sm text-gray-600">
                <div>
                  <span class="text-xs font-medium uppercase tracking-wide text-gray-500">Visibility</span>
                  <form method="POST" action="{{ $.VisibilityURL . }}" class="mt-1" onclick="event.stopPropagation()" onkeydown="event.stopPropagation()">
                    <select name="Visibility"
                            onchange="this.form.submit()"
                            class="block rounded-md bg-white px-2 py-1 text-xs text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                      <option value="hidden" {{ if eq .Visibility "hidden" }}selected{{ end }}>Hidden</option>
                      <option value="public" {{ if eq .Visibility "public" }}selected{{ end }}>Public</option>
                    </select>
                  </form>
                </div>
                <div>
                  <span class="text-xs font-medium uppercase tracking-wide text-gray-500">Conference</span>
                  <div>
                    {{ $confURL := $.ConfURL .ConferenceID }}
                    {{ if $confURL }}
                    <a href="{{ $confURL }}" class="text-indigo-600 hover:text-indigo-500" onclick="event.stopPropagation()" onkeydown="event.stopPropagation()">{{ $.ConfLabel .ConferenceID }}</a>
                    {{ else }}
                    {{ $.ConfLabel .ConferenceID }}
                    {{ end }}
                  </div>
                </div>
                <div>
                  <span class="text-xs font-medium uppercase tracking-wide text-gray-500">Team size</span>
                  <div>{{ with .MaxTeamSize }}{{ . }}{{ else }}Unlimited{{ end }}</div>
                </div>
                <div>
                  <span class="text-xs font-medium uppercase tracking-wide text-gray-500">
                    {{ if and ($.TimelineLabel .) (not ($.TimelineIsScheduleLink .)) }}
                    {{ $.TimelineLabel . }}
                    {{ else }}
                    Timeline
                    {{ end }}
                  </span>
                  <div class="text-gray-900">{{ if $.TimelineValue . }}{{ $.TimelineValue . }}{{ else }}TBA{{ end }}</div>
                  <a href="{{ $.ScheduleURL . }}" class="text-xs font-medium text-indigo-600 hover:text-indigo-500" onclick="event.stopPropagation()" onkeydown="event.stopPropagation()">View schedule</a>
                </div>
              </div>
            </div>
            <div class="flex flex-col gap-3 sm:flex-row sm:items-center lg:justify-end">
              <div class="flex flex-wrap items-center gap-x-3 gap-y-2 text-sm">
                <a href="{{ $.HackathonURL . }}" class="inline-flex items-center justify-center rounded-md bg-white px-3 py-1.5 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-gray-300 hover:bg-gray-50" onclick="event.stopPropagation()" onkeydown="event.stopPropagation()">Public page</a>
              </div>
            </div>
          </div>
        </li>
        {{ end }}
      </ul>
      {{ else }}
      <div class="px-4 py-10 text-center sm:px-6">
        {{ if .SearchQuery }}
        <p class="text-sm text-gray-600">No hackathons match your search.</p>
        {{ else }}
        <p class="text-sm text-gray-600">No hackathons have been created yet.</p>
        <a href="/admin/hackathons/new" class="mt-4 inline-flex items-center justify-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700">
          Create new hackathon
        </a>
        {{ end }}
      </div>
      {{ end }}
    </section>
  </div>
</body>
</html>
