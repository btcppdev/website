<!DOCTYPE html>
<html>
<head>
  <title>Run of Show · {{ .Conf.Desc }}</title>
  {{ block "header" . }} {{ end }}
  {{ template "admin_favicon" .Conf }}
  <style>
    @media print {
      .print\:hidden { display: none !important; }
      body { background: #fff; }
      .stage-panel { display: block !important; page-break-before: always; }
      .stage-panel:first-of-type { page-break-before: auto; }

      /* One day per printed page. */
      section { page-break-before: always; }
      section:first-of-type { page-break-before: auto; }

      /* Critical: the table wrapper has overflow-hidden +
         rounded-lg + shadow on screen so the rounded corners clip
         the table cleanly. In print, overflow-hidden makes the
         wrapper an atomic block — when its table is taller than
         the page, the browser pushes the whole wrapper to a fresh
         page, leaving a huge gap below the day title. Override:
         let content flow through the wrapper, drop visual flourishes
         that don't add value on paper. */
      section > div {
        overflow: visible !important;
        box-shadow: none !important;
        border-radius: 0 !important;
      }

      /* Don't split a row mid-page; repeat column headers on each
         page so a multi-page table stays readable. */
      tr { page-break-inside: avoid; }
      thead { display: table-header-group; }

      /* Force print to render row background colors (amber-50 for
         info, indigo-50 for shifts). Browsers strip backgrounds by
         default ("color-adjust: economy") to save toner; opt in
         explicitly. -webkit- prefix for Chrome/Safari. */
      body, table, tr, td {
        -webkit-print-color-adjust: exact !important;
        print-color-adjust: exact !important;
        color-adjust: exact !important;
      }
    }
  </style>
</head>
<body class="bg-gray-50">
  <div class="print:hidden">{{ block "mainnav" . }} {{ end }}</div>
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-8">
    <div class="print:hidden">
      <a href="/{{ .Conf.Tag }}/admin" class="text-xs text-gray-500 hover:text-gray-700">&larr; {{ .Conf.Desc }} dashboard</a>
    </div>

    <div class="mt-1 flex items-start justify-between gap-4">
      <div>
        <h1 class="text-xl font-bold text-gray-900">Run of Show</h1>
        <p class="text-sm text-gray-500">{{ .Conf.Desc }} &mdash; {{ .Conf.DateDesc }}</p>
      </div>
      <div class="print:hidden flex items-center gap-2 shrink-0">
        <button type="button" data-ros-follow-toggle
                class="inline-flex items-center rounded-md border border-gray-300 bg-white px-3 py-1.5 text-xs font-semibold text-gray-700 hover:bg-gray-50">
          Follow now
        </button>
        <a href="/{{ .Conf.Tag }}/run-of-show" target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center rounded-md border border-gray-300 bg-white px-3 py-1.5 text-xs font-semibold text-gray-700 hover:bg-gray-50">
          Public link
        </a>
        <button type="button" onclick="window.print()"
                class="inline-flex items-center rounded-md border border-gray-300 bg-white px-3 py-1.5 text-xs font-semibold text-gray-700 hover:bg-gray-50">
          Print
        </button>
      </div>
    </div>

    {{ if .Stages }}
    <div id="ros-filters" class="print:hidden mt-4 flex flex-wrap items-center gap-x-5 gap-y-2 text-xs text-gray-700">
      <span class="font-semibold uppercase tracking-wider text-gray-500">Show:</span>
      <label class="inline-flex items-center gap-1.5 cursor-pointer">
        <input type="checkbox" data-toggle="talks" checked class="rounded border-gray-300">
        Talks
      </label>
      <label class="inline-flex items-center gap-1.5 cursor-pointer">
        <input type="checkbox" data-toggle="volunteers" class="rounded border-gray-300">
        Volunteers
      </label>
      <label class="inline-flex items-center gap-1.5 cursor-pointer">
        <input type="checkbox" data-toggle="venue" checked class="rounded border-gray-300">
        Venue
      </label>
    </div>

    <div class="print:hidden mt-5 flex flex-wrap gap-2" role="tablist" aria-label="Stages">
      {{ range $i, $stage := .Stages }}
      <a href="#{{ $stage.Venue.Tag }}"
         data-stage-tab="{{ $stage.Venue.Tag }}"
         class="stage-tab rounded-md border px-3 py-1.5 text-sm font-semibold {{ if eq $i 0 }}border-gray-900 bg-gray-900 text-white{{ else }}border-gray-300 bg-white text-gray-700 hover:bg-gray-50{{ end }}">
        {{ $stage.Venue.Label }}
      </a>
      {{ end }}
    </div>
    {{ end }}

    {{ if .FlashMessage }}
    <div class="mt-4 rounded-md bg-green-50 border border-green-200 px-4 py-3 print:hidden">
      <p class="text-sm text-green-800">{{ .FlashMessage }}</p>
    </div>
    {{ end }}

    {{ if not .Stages }}
    <div class="mt-8 bg-white shadow rounded-lg px-4 py-5 sm:p-6 text-center text-gray-500">
      Nothing scheduled yet — once you add ConfInfo (doors / coffee / lunch), volunteer shifts, or talks, they'll appear here.
    </div>
    {{ else }}
    {{ range $i, $stage := .Stages }}
    <div id="{{ $stage.Venue.Tag }}" data-stage-panel="{{ $stage.Venue.Tag }}" class="stage-panel {{ if ne $i 0 }}hidden{{ end }}">
      <h2 class="mt-8 text-lg font-semibold text-gray-900">{{ $stage.Venue.Label }}</h2>
      {{ range $stage.Days }}
      <section class="mt-5">
      <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500">
        {{ if le .Idx 0 }}Setup · {{ end }}{{ .Date.Format "Mon, Jan 2" }}
      </h3>
      <div class="mt-2 bg-white shadow rounded-lg overflow-hidden">
        <table class="ros-table min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-32">Time</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-28">Media</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">What</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Who</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {{ range .Rows }}
            {{ if .NowMarkerBefore }}
            <tr class="ros-row ros-now-marker ros-current-target ros-row-{{ .Kind }}"{{ if .VenueTag }} data-venue="{{ .VenueTag }}"{{ end }}>
              <td colspan="4" class="px-4 py-1 bg-green-50 text-green-800">
                <div class="flex items-center gap-2 text-xs font-semibold uppercase tracking-wider">
                  <span class="h-px flex-1 bg-green-300"></span>
                  <span>Now</span>
                  <span class="h-px flex-1 bg-green-300"></span>
                </div>
              </td>
            </tr>
            {{ end }}
            <tr class="ros-row ros-row-{{ .Kind }} {{ if .IsCurrent }}ros-current-target bg-green-50 ring-2 ring-inset ring-green-400{{ else if eq .Kind "info" }}bg-amber-50{{ else if eq .Kind "shift" }}bg-indigo-50{{ end }}"{{ if .VenueTag }} data-venue="{{ .VenueTag }}"{{ end }}>
              <td class="px-4 py-2 text-sm text-gray-700 font-mono whitespace-nowrap align-top">
                {{ if and .Adjusted (eq .Kind "talk") }}
                <div class="text-xs text-gray-400">was <span class="line-through">{{ formatTime .OriginalStart }}</span></div>
                {{ end }}
                <div>{{ formatTime .Start }}</div>
                {{ if .Adjusted }}<div class="mt-1 text-[10px] font-semibold uppercase tracking-wider text-green-700">{{ signedMinutes .DelayMinutes }}</div>{{ end }}
                {{ if and .HasAdjustment (not .Adjusted) }}<div class="mt-1 text-[10px] font-semibold uppercase tracking-wider text-green-700">resumes on time</div>{{ end }}
                {{ if .IsCurrent }}<div class="mt-1 inline-flex rounded bg-green-100 px-1.5 py-0.5 text-[10px] font-bold uppercase tracking-wider text-green-800">Now</div>{{ end }}
                {{ if .AnchorID }}
                <form method="POST" action="/{{ $.Conf.Tag }}/admin/run-of-show/adjust" class="print:hidden mt-2 flex flex-wrap items-center gap-1 text-xs">
                  <input type="hidden" name="anchor_kind" value="{{ .AnchorKind }}">
                  <input type="hidden" name="anchor_id" value="{{ .AnchorID }}">
                  <input type="hidden" name="venue_tag" value="{{ .VenueTag }}">
                  {{ if .Adjusted }}<input type="hidden" name="current_delay_minutes" value="{{ .DelayMinutes }}">{{ end }}
                  {{ if eq .Kind "talk" }}
                  <input type="hidden" name="propagation_mode" value="until_next_anchor">
                  {{ else }}
                  <input type="hidden" name="propagation_mode" value="item_only">
                  {{ end }}
                  <input type="number" name="delay_minutes" value="{{ if .HasAdjustment }}{{ .AdjustmentMinutes }}{{ else }}0{{ end }}" min="-240" max="240"
                         class="w-16 rounded border-gray-300 px-1 py-0.5 text-xs">
                  <button type="submit" class="rounded border border-gray-300 bg-white px-1.5 py-0.5 font-semibold text-gray-700 hover:bg-gray-50">Set</button>
                  {{ if .HasAdjustment }}
                  <button type="submit" name="action" value="clear" class="rounded border border-gray-300 bg-white px-1.5 py-0.5 font-semibold text-gray-500 hover:bg-gray-50">Clear</button>
                  {{ else if and .Adjusted (eq .Kind "talk") }}
                  <button type="submit" name="action" value="resume" class="rounded border border-green-300 bg-green-50 px-1.5 py-0.5 font-semibold text-green-800 hover:bg-green-100">Resume</button>
                  {{ end }}
                </form>
                {{ end }}
              </td>
              <td class="px-4 py-2 align-top">
                {{ if and (eq .Kind "talk") .MediaURL }}
                <a href="{{ .MediaURL }}" target="_blank" rel="noopener noreferrer" class="block w-24 overflow-hidden rounded border border-gray-200 bg-gray-100">
                  <img src="{{ .MediaURL }}" alt="" loading="lazy" class="aspect-video w-full object-cover">
                </a>
                {{ end }}
              </td>
              <td class="px-4 py-2 text-sm text-gray-900 align-top">
                {{ if eq .Kind "talk" }}<span class="font-semibold">{{ .What }}</span>{{ else }}{{ .What }}{{ end }}
              </td>
              <td class="px-4 py-2 text-sm text-gray-700 align-top">
                {{ if .Who }}<div>{{ .Who }}</div>{{ end }}
                {{ if .Crew }}
                <div class="{{ if .Who }}mt-1 {{ end }}space-y-0.5 text-xs leading-5">
                  {{ range .Crew }}
                  <div><span class="font-semibold text-gray-500 uppercase tracking-wide">{{ .Label }}:</span> <span class="text-gray-800">{{ .Names }}</span></div>
                  {{ end }}
                </div>
                {{ end }}
              </td>
            </tr>
            {{ end }}
            {{ if .NowMarkerAfter }}
            <tr class="ros-now-marker ros-current-target">
              <td colspan="4" class="px-4 py-1 bg-green-50 text-green-800">
                <div class="flex items-center gap-2 text-xs font-semibold uppercase tracking-wider">
                  <span class="h-px flex-1 bg-green-300"></span>
                  <span>Now</span>
                  <span class="h-px flex-1 bg-green-300"></span>
                </div>
              </td>
            </tr>
            {{ end }}
          </tbody>
        </table>
      </div>
      </section>
      {{ end }}
    </div>
    {{ end }}
    {{ end }}
  </div>

  <style>
    /* Category toggles. Each checkbox hides a category of ROW (never
       columns) so the table shape stays constant. Venue = ConfInfo
       rows (doors / coffee / breakfast / lunch). */
    body.ros-hide-talks .ros-row-talk { display: none; }
    body.ros-hide-volunteers .ros-row-shift { display: none; }
    body.ros-hide-venue .ros-row-info { display: none; }
    {{ range .Venues }}
    body.ros-hide-stage-{{ .Tag }} .ros-row-talk[data-venue="{{ .Tag }}"] { display: none; }
    /* Where-column color so different stages are easy to tell apart
       at a glance. Last-of-type targets the Where cell (column 4)
       without coupling to a class on the <td>. Talks only — non-talk
       rows have empty Where so the color rule is harmless there. */
    .ros-row-talk[data-venue="{{ .Tag }}"] > td:last-of-type {
      color: {{ .Color }};
      font-weight: 600;
    }
    {{ end }}
  </style>
  <script>
    (function () {
      var tabs = document.querySelectorAll('[data-stage-tab]');
      var panels = document.querySelectorAll('[data-stage-panel]');
      function selectStage(stage) {
        var active = stage || (tabs[0] && tabs[0].dataset.stageTab);
        var found = false;
        tabs.forEach(function (btn) {
          if (btn.dataset.stageTab === active) {
            found = true;
          }
        });
        if (!found && tabs[0]) {
          active = tabs[0].dataset.stageTab;
        }
        tabs.forEach(function (btn) {
          var selected = btn.dataset.stageTab === active;
          btn.classList.toggle('border-gray-900', selected);
          btn.classList.toggle('bg-gray-900', selected);
          btn.classList.toggle('text-white', selected);
          btn.classList.toggle('border-gray-300', !selected);
          btn.classList.toggle('bg-white', !selected);
          btn.classList.toggle('text-gray-700', !selected);
        });
        panels.forEach(function (panel) {
          panel.classList.toggle('hidden', panel.dataset.stagePanel !== active);
        });
      }
      function stageFromHash() {
        return decodeURIComponent(window.location.hash.replace(/^#/, ''));
      }
      tabs.forEach(function (tab) {
        tab.addEventListener('click', function () {
          selectStage(tab.dataset.stageTab);
          if (window.rosFollowNow) {
            window.setTimeout(window.rosFollowNow, 50);
          }
        });
      });
      window.addEventListener('hashchange', function () {
        selectStage(stageFromHash());
        if (window.rosFollowNow) {
          window.setTimeout(window.rosFollowNow, 50);
        }
      });
      selectStage(stageFromHash());
    })();
  </script>
  <script>
    // Toggle wiring. Category checkboxes carry data-toggle (talks /
    // volunteers / venue) and toggle a body.ros-hide-{toggle} class.
    (function () {
      var body = document.body;
      body.classList.add('ros-hide-volunteers');
      document.querySelectorAll('#ros-filters input[data-toggle]').forEach(function (cb) {
        cb.addEventListener('change', function () {
          var cls = 'ros-hide-' + cb.dataset.toggle;
          body.classList.toggle(cls, !cb.checked);
          if (window.rosFollowNow) {
            window.rosFollowNow();
          }
        });
      });
    })();
  </script>
  <script>
    (function () {
      var storageKey = 'btcpp:run-of-show:follow';
      var scrollKey = 'btcpp:run-of-show:scroll:{{ .Conf.Tag }}';
      var followBtn = document.querySelector('[data-ros-follow-toggle]');
      var follow = localStorage.getItem(storageKey) === '1';
      function saveScroll() {
        sessionStorage.setItem(scrollKey, String(window.scrollY || 0));
      }
      function restoreScroll() {
        var saved = sessionStorage.getItem(scrollKey);
        if (!saved) {
          return;
        }
        sessionStorage.removeItem(scrollKey);
        var y = parseInt(saved, 10);
        if (!isNaN(y)) {
          window.scrollTo(0, y);
        }
      }
      function visible(el) {
        return !!(el && el.offsetParent !== null);
      }
      function currentTarget() {
        var targets = Array.prototype.slice.call(document.querySelectorAll('.ros-current-target'));
        for (var i = 0; i < targets.length; i++) {
          if (visible(targets[i])) {
            return targets[i];
          }
        }
        return null;
      }
      function updateButton() {
        if (!followBtn) {
          return;
        }
        followBtn.textContent = follow ? 'Following now' : 'Follow now';
        followBtn.classList.toggle('border-green-600', follow);
        followBtn.classList.toggle('bg-green-50', follow);
        followBtn.classList.toggle('text-green-800', follow);
        followBtn.classList.toggle('border-gray-300', !follow);
        followBtn.classList.toggle('bg-white', !follow);
        followBtn.classList.toggle('text-gray-700', !follow);
      }
      window.rosFollowNow = function () {
        if (!follow) {
          return;
        }
        var target = currentTarget();
        if (target) {
          target.scrollIntoView({ block: 'center', behavior: 'smooth' });
        }
      };
      if (followBtn) {
        followBtn.addEventListener('click', function () {
          follow = !follow;
          localStorage.setItem(storageKey, follow ? '1' : '0');
          updateButton();
          window.rosFollowNow();
        });
      }
      updateButton();
      window.addEventListener('load', function () {
        window.setTimeout(function () {
          if (follow) {
            window.rosFollowNow();
          } else {
            restoreScroll();
          }
        }, 150);
      });
      document.querySelectorAll('form[action$="/admin/run-of-show/adjust"]').forEach(function (form) {
        form.addEventListener('submit', saveScroll);
      });
      if (window.EventSource) {
        var events = new EventSource('/{{ .Conf.Tag }}/run-of-show/events');
        events.addEventListener('reload', function () {
          saveScroll();
          window.location.reload();
        });
      }
    })();
  </script>
</body>
</html>
