<!DOCTYPE html>
<html>
  <head>
    <title>upload recordings to youtube @ bitcoin++</title>
    {{ block "header" . }} {{ end }}
  </head>
  <body class="btcpp-admin-page">
    {{ block "mainnav" . }} {{ end }}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-6xl">

        <section class="mt-6 mb-6">
          <div class="overflow-hidden sm:rounded-lg bg-white shadow">
            <div class="px-4 py-5 sm:p-6 flex items-start justify-between gap-4">
              <div>
                <a href="/{{ .Conf.Tag }}/admin/recordings" class="text-xs text-gray-500 hover:text-gray-700">&larr; back to recordings</a>
                <h1 class="text-xl font-bold text-gray-900">Upload eligible to YouTube</h1>
                <p class="text-sm text-gray-500">Review recordings with source files before queueing uploads to the connected YouTube channel.</p>
              </div>
              {{ if .YouTubeReady }}
                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">YouTube connected</span>
              {{ else }}
                <a href="{{ .YouTubeAuthURL }}" class="px-3 py-1.5 text-sm rounded-md text-white bg-red-600 hover:bg-red-700">Authorize YouTube</a>
              {{ end }}
            </div>
          </div>
        </section>

        {{ if .FlashMessage }}
        <section class="mb-6">
          <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg">{{ .FlashMessage }}</div>
        </section>
        {{ end }}
        {{ if .FlashError }}
        <section class="mb-6">
          <div class="bg-yellow-50 border border-yellow-300 text-yellow-800 px-4 py-3 rounded-lg">{{ .FlashError }}</div>
        </section>
        {{ end }}

        <section class="mb-6">
          <div class="bg-white shadow rounded-lg overflow-hidden">
            <div class="px-4 py-3 border-b border-gray-200 flex items-center justify-between">
              <h2 class="text-sm font-semibold text-gray-900">Ready to upload</h2>
              <span class="text-xs text-gray-500">{{ len .Eligible }} eligible</span>
            </div>
            {{ if .Eligible }}
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Talk</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Source file</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">YouTube visibility</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
                {{ range .Eligible }}
                <tr>
                  <td class="px-4 py-3 text-sm text-gray-900">
                    {{ if and .ConfTalk .ConfTalk.Proposal }}{{ .ConfTalk.Proposal.Title }}{{ else }}{{ .Recording.TalkName }}{{ end }}
                    {{ if and .ConfTalk .ConfTalk.Sched }}<div class="text-xs text-gray-400">recorded {{ .ConfTalk.Sched.Start.Format "Jan 2, 2006" }}</div>{{ end }}
                  </td>
                  <td class="px-4 py-3 text-sm text-gray-500 break-all">{{ .Recording.FileURI }}</td>
                  <td class="px-4 py-3 text-sm text-gray-700">
                    {{ if .Recording.PublishAt }}
                      {{ if .Recording.PublishAt.After $.Now }}
                        private until {{ .Recording.PublishAt.Format "Jan 2, 2006 3:04 PM MST" }}
                      {{ else }}
                        unlisted
                      {{ end }}
                    {{ else }}
                      unlisted
                    {{ end }}
                  </td>
                </tr>
                {{ end }}
              </tbody>
            </table>
            <form method="POST" action="/{{ .Conf.Tag }}/admin/recordings/upload-youtube" class="border-t border-gray-200">
              <div class="px-4 py-4 bg-gray-50 border-b border-gray-200">
                <h3 class="text-sm font-semibold text-gray-900">Playlist</h3>
                <p class="text-xs text-gray-500">Optional. The selected playlist is saved to this event and reused for future uploads.</p>
                <div class="mt-3 grid gap-3 md:grid-cols-2">
                  <label class="flex items-start gap-2 rounded-md border border-gray-200 bg-white px-3 py-3 text-sm text-gray-700">
                    <input type="radio" name="playlist_mode" value="saved" {{ if .Conf.YouTubePlaylistID }}checked{{ end }} {{ if not .Conf.YouTubePlaylistID }}disabled{{ end }} class="mt-1 border-gray-300 text-red-600">
                    <span>
                      <span class="block font-medium text-gray-900">Use saved playlist</span>
                      <span class="block text-xs text-gray-500">{{ if .Conf.YouTubePlaylistID }}{{ if .Conf.YouTubePlaylistTitle }}{{ .Conf.YouTubePlaylistTitle }}{{ else }}{{ .Conf.YouTubePlaylistID }}{{ end }}{{ else }}No saved playlist yet{{ end }}</span>
                    </span>
                  </label>
                  <label class="flex items-start gap-2 rounded-md border border-gray-200 bg-white px-3 py-3 text-sm text-gray-700">
                    <input type="radio" name="playlist_mode" value="none" {{ if not .Conf.YouTubePlaylistID }}checked{{ end }} class="mt-1 border-gray-300 text-red-600">
                    <span>
                      <span class="block font-medium text-gray-900">Do not add to playlist</span>
                      <span class="block text-xs text-gray-500">Upload videos without changing playlist membership.</span>
                    </span>
                  </label>
                  <label class="rounded-md border border-gray-200 bg-white px-3 py-3 text-sm text-gray-700">
                    <span class="flex items-start gap-2">
                      <input type="radio" name="playlist_mode" value="existing" class="mt-1 border-gray-300 text-red-600">
                      <span>
                        <span class="block font-medium text-gray-900">Choose existing playlist</span>
                        <span class="block text-xs text-gray-500">Save this selection to the event.</span>
                      </span>
                    </span>
                    <select name="playlist_id" class="mt-3 block w-full rounded-md border-gray-300 text-sm text-gray-900 shadow-sm focus:border-red-500 focus:ring-red-500">
                      <option value="">Select playlist</option>
                      {{ range .YouTubePlaylists }}
                      <option value="{{ .ID }}">{{ .Title }}</option>
                      {{ end }}
                    </select>
                  </label>
                  <label class="rounded-md border border-gray-200 bg-white px-3 py-3 text-sm text-gray-700">
                    <span class="flex items-start gap-2">
                      <input type="radio" name="playlist_mode" value="create" class="mt-1 border-gray-300 text-red-600">
                      <span>
                        <span class="block font-medium text-gray-900">Create or find by title</span>
                        <span class="block text-xs text-gray-500">If a playlist with this title already exists, it will be reused.</span>
                      </span>
                    </span>
                    <input type="text" name="playlist_title" value="{{ .DefaultPlaylistTitle }}" class="mt-3 block w-full rounded-md border-gray-300 text-sm text-gray-900 shadow-sm focus:border-red-500 focus:ring-red-500">
                  </label>
                </div>
              </div>
              <div class="px-4 py-4 flex items-center justify-end gap-3">
                <a href="/{{ .Conf.Tag }}/admin/recordings" class="px-3 py-1.5 text-sm rounded-md text-gray-700 bg-gray-100 hover:bg-gray-200">Cancel</a>
                {{ if .YouTubeReady }}
                  <button type="submit" class="px-3 py-1.5 text-sm rounded-md text-white bg-red-600 hover:bg-red-700">Start {{ len .Eligible }} upload{{ if ne (len .Eligible) 1 }}s{{ end }}</button>
                {{ else }}
                  <button type="button" disabled class="px-3 py-1.5 text-sm rounded-md text-white bg-gray-300 cursor-not-allowed">Start uploads</button>
                {{ end }}
              </div>
            </form>
            {{ else }}
            <div class="px-4 py-6 text-sm text-gray-500">No eligible recordings found.</div>
            {{ end }}
          </div>
        </section>

        {{ if .Skipped }}
        <section class="mb-8">
          <div class="bg-white shadow rounded-lg overflow-hidden">
            <div class="px-4 py-3 border-b border-gray-200 flex items-center justify-between">
              <h2 class="text-sm font-semibold text-gray-900">Skipped</h2>
              <span class="text-xs text-gray-500">{{ len .Skipped }} skipped</span>
            </div>
            <table class="min-w-full divide-y divide-gray-200">
              <tbody class="bg-white divide-y divide-gray-200">
                {{ range .Skipped }}
                <tr>
                  <td class="px-4 py-3 text-sm text-gray-900">{{ if and .Row.ConfTalk .Row.ConfTalk.Proposal }}{{ .Row.ConfTalk.Proposal.Title }}{{ else }}{{ .Row.Recording.TalkName }}{{ end }}</td>
                  <td class="px-4 py-3 text-sm text-gray-500">{{ .Reason }}</td>
                </tr>
                {{ end }}
              </tbody>
            </table>
          </div>
        </section>
        {{ end }}

      </div>
    </div>
  </body>
</html>
