<!DOCTYPE html>
<html>
<head>
  <title>Hotels · {{ .Conf.Desc }}</title>
  {{ block "header" . }} {{ end }}
  {{ template "admin_favicon" .Conf }}
</head>
<body class="btcpp-admin-page bg-gray-50">
  {{ block "mainnav" . }} {{ end }}
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12">
    <div>
      <a href="/{{ .Conf.Tag }}/admin" class="text-xs text-gray-500 hover:text-gray-700">&larr; {{ .Conf.Desc }} dashboard</a>
      <h1 class="mt-1 text-xl font-bold text-gray-900">Hotels</h1>
      <p class="mt-1 text-sm text-gray-500">Up to {{ len .Slots }} hotels per event. They render on the conf page in <span class="font-medium">Order</span> ascending — lower number first.</p>
    </div>

    {{ if .FlashMessage }}
    <div class="mt-6 rounded-md bg-green-50 border border-green-200 px-4 py-3">
      <p class="text-sm text-green-800">{{ .FlashMessage }}</p>
    </div>
    {{ end }}
    {{ if .FlashError }}
    <div class="mt-6 rounded-md bg-red-50 border border-red-200 px-4 py-3">
      <p class="text-sm text-red-800">{{ .FlashError }}</p>
    </div>
    {{ end }}

    <form method="POST" action="/{{ .Conf.Tag }}/admin/hotels" class="mt-6 space-y-4">
      {{ range $idx, $slot := .Slots }}
      {{ $p := printf "h%d_" $slot.Index }}
      <div class="bg-white shadow rounded-lg p-5">
        <div class="flex items-center justify-between mb-4">
          <span class="text-xs font-semibold uppercase tracking-wider text-gray-500">
            {{ if $slot.Hotel }}Slot {{ add $slot.Index 1 }}{{ else }}Slot {{ add $slot.Index 1 }} (empty){{ end }}
          </span>
          {{ if and $slot.Hotel $.IsConfAdmin }}
          <label class="inline-flex items-center gap-1 text-xs text-red-600">
            <input type="checkbox" name="{{ $p }}Delete" value="1" class="rounded border-gray-300">
            Remove this hotel
          </label>
          {{ end }}
        </div>

        <input type="hidden" name="{{ $p }}ID" value="{{ if $slot.Hotel }}{{ $slot.Hotel.ID }}{{ end }}">

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div class="sm:col-span-2">
            <label class="block text-xs font-medium text-gray-700">Name</label>
            <input type="text" name="{{ $p }}Name"
                   value="{{ if $slot.Hotel }}{{ $slot.Hotel.Name }}{{ end }}"
                   placeholder="Hotel name"
                   {{ if not $.IsConfAdmin }}readonly{{ end }}
                   class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-bitcoin read-only:bg-gray-50 read-only:text-gray-600">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-700">Order</label>
            <input type="number" name="{{ $p }}Order"
                   value="{{ $slot.SuggestedOrder }}"
                   {{ if not $.IsConfAdmin }}readonly{{ end }}
                   class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-bitcoin read-only:bg-gray-50 read-only:text-gray-600">
          </div>

          <div class="sm:col-span-2">
            <label class="block text-xs font-medium text-gray-700">URL</label>
            <input type="url" name="{{ $p }}URL"
                   value="{{ if $slot.Hotel }}{{ $slot.Hotel.URL }}{{ end }}"
                   placeholder="https://example.com"
                   {{ if not $.IsConfAdmin }}readonly{{ end }}
                   class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-bitcoin read-only:bg-gray-50 read-only:text-gray-600">
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-700">Type</label>
            <input type="text" name="{{ $p }}Type"
                   value="{{ if $slot.Hotel }}{{ $slot.Hotel.Type }}{{ end }}"
                   placeholder="e.g. 🏨 Recommended"
                   {{ if not $.IsConfAdmin }}readonly{{ end }}
                   class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-bitcoin read-only:bg-gray-50 read-only:text-gray-600">
          </div>

          <div class="sm:col-span-3">
            <label class="block text-xs font-medium text-gray-700">Description</label>
            <textarea name="{{ $p }}Desc" rows="2"
                      {{ if not $.IsConfAdmin }}readonly{{ end }}
                      class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-bitcoin read-only:bg-gray-50 read-only:text-gray-600">{{ if $slot.Hotel }}{{ $slot.Hotel.Desc }}{{ end }}</textarea>
          </div>

          <div class="sm:col-span-3">
            <span class="block text-xs font-medium text-gray-700">Image</span>
            <input type="hidden" id="{{ $p }}Img" name="{{ $p }}Img"
                   value="{{ if $slot.Hotel }}{{ $slot.Hotel.Img }}{{ end }}">
            <div class="mt-1 flex items-center gap-3">
              {{ if $.IsConfAdmin }}
              <button type="button" data-target="{{ $p }}Img"
                      class="hotel-upload-trigger inline-flex items-center rounded-md border border-gray-300 bg-white px-3 py-1.5 text-xs font-semibold text-gray-700 hover:bg-gray-50">
                Upload a file
              </button>
              {{ end }}
              <img id="{{ $p }}Img-preview" alt=""
                   class="{{ if and $slot.Hotel $slot.Hotel.Img }}{{ else }}hidden {{ end }}h-16 w-auto max-w-[200px] rounded border border-gray-200 bg-white object-contain"
                   src="{{ if and $slot.Hotel $slot.Hotel.Img }}{{ spacesURL $slot.Hotel.Img }}{{ end }}">
              {{ if $.IsConfAdmin }}
              <button type="button" data-target="{{ $p }}Img"
                      class="hotel-clear-trigger {{ if and $slot.Hotel $slot.Hotel.Img }}{{ else }}hidden {{ end }}text-xs font-medium text-red-600 hover:text-red-700">
                Remove image
              </button>
              {{ end }}
            </div>
            <p id="{{ $p }}Img-status" class="mt-1 text-xs text-gray-500">
              {{ if and $slot.Hotel $slot.Hotel.Img }}Image attached.{{ else }}No image yet.{{ end }}
            </p>
          </div>
        </div>
      </div>
      {{ end }}

      {{ if .IsConfAdmin }}
      <div class="flex items-center justify-end gap-3 pt-2">
        <a href="/{{ .Conf.Tag }}/admin" class="text-sm text-gray-600 hover:text-gray-800">Cancel</a>
        <button type="submit"
                class="inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700">
          Save hotels
        </button>
      </div>
      {{ end }}
    </form>
  </div>

  <input type="file" id="HotelFilePicker" accept="image/*" class="hidden">
  <script>
    // Per-row "Upload a file" button → hidden picker → POST to
    // /{conf}/admin/hotels/upload-img → drop the returned bare
    // Spaces path into the matching Img hidden input + show a
    // preview thumbnail. Mirrors the org-logo upload pattern;
    // each row is keyed by the data-target attribute so multiple
    // hotels can be edited at once without their state stomping
    // each other.
    (function () {
      const uploadURL = '/{{ .Conf.Tag }}/admin/hotels/upload-img';
      const picker = document.getElementById('HotelFilePicker');
      let activeTarget = null;
      document.querySelectorAll('.hotel-upload-trigger').forEach(function (btn) {
        btn.addEventListener('click', function () {
          activeTarget = btn.dataset.target;
          picker.value = '';
          picker.click();
        });
      });
      picker.addEventListener('change', function () {
        if (!activeTarget || !picker.files || picker.files.length === 0) return;
        const file = picker.files[0];
        const targetID = activeTarget;
        const status  = document.getElementById(targetID + '-status');
        const input   = document.getElementById(targetID);
        const preview = document.getElementById(targetID + '-preview');
        const clear   = document.querySelector('.hotel-clear-trigger[data-target="' + targetID + '"]');
        status.textContent = 'Uploading ' + file.name + '…';
        status.className = 'mt-1 text-xs text-gray-700';
        const fd = new FormData();
        fd.append('file', file);
        fetch(uploadURL, { method: 'POST', body: fd, credentials: 'same-origin' })
          .then(function (r) {
            if (!r.ok) return r.text().then(function (t) { throw new Error(t || ('HTTP ' + r.status)); });
            return r.json();
          })
          .then(function (data) {
            input.value = data.path;
            preview.src = data.url;
            preview.classList.remove('hidden');
            if (clear) clear.classList.remove('hidden');
            status.textContent = file.name + ' — uploaded.';
            status.className = 'mt-1 text-xs text-green-700';
          })
          .catch(function (err) {
            status.textContent = 'Upload failed: ' + (err.message || err);
            status.className = 'mt-1 text-xs text-red-700';
          })
          .finally(function () {
            if (activeTarget === targetID) activeTarget = null;
          });
      });
      document.querySelectorAll('.hotel-clear-trigger').forEach(function (btn) {
        btn.addEventListener('click', function () {
          const targetID = btn.dataset.target;
          const status  = document.getElementById(targetID + '-status');
          const input   = document.getElementById(targetID);
          const preview = document.getElementById(targetID + '-preview');
          input.value = '';
          preview.removeAttribute('src');
          preview.classList.add('hidden');
          btn.classList.add('hidden');
          status.textContent = 'No image yet.';
          status.className = 'mt-1 text-xs text-gray-500';
        });
      });
    })();
  </script>
  {{ block "footer" . }} {{ end }}
</body>
</html>
