<!doctype html>
<html lang="en">
<head>
  <title>{{ if .IsNew }}New hackathon{{ else }}{{ .Competition.Title }}{{ end }} - Admin - bitcoin++</title>
  {{ block "header" . }} {{ end }}
  {{ template "admin_favicon" "" }}
</head>
<body class="btcpp-admin-page admin-hackathon-page bg-gray-50 text-gray-900">
  {{ block "mainnav" . }} {{ end }}
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <a href="{{ .BackURL }}" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">&larr; {{ .BackLabel }}</a>
        <h1 class="mt-2 text-2xl font-semibold tracking-tight">{{ if .IsNew }}New hackathon{{ else if eq .SetupStep 1 }}Set basics{{ else if eq .SetupStep 2 }}Set timeline and schedule{{ else }}{{ .Competition.Title }}{{ end }}</h1>
        <p class="mt-1 text-sm text-gray-600">
          {{ if or .IsNew (eq .SetupStep 1) }}Create the public page and access settings.{{ else if eq .SetupStep 2 }}Add submission timing and conference schedule blocks.{{ else }}Main settings and schedule.{{ end }}
        </p>
      </div>
      {{ if and (not .IsNew) (eq .SetupStep 0) }}
      <div class="flex flex-wrap items-center gap-2">
        <a href="{{ .HackathonURL .Competition }}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-gray-300 hover:bg-gray-50">Public page</a>
      </div>
      {{ end }}
    </div>
    {{ if and (not .IsNew) (eq .SetupStep 0) }}{{ template "admin_hackathon_tabs" . }}{{ end }}

    {{ if .FlashMessage }}
    <div class="mb-4 rounded-md border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-800">{{ .FlashMessage }}</div>
    {{ end }}
    {{ if .FlashError }}
    <div class="btcpp-admin-flash btcpp-admin-flash--error mb-4">{{ .FlashError }}</div>
    {{ end }}

    {{ if or .IsNew (gt .SetupStep 0) }}
    {{ template "admin_hackathon_setup_steps" . }}
    {{ end }}

    <form id="HackathonSetupForm" method="POST" action="{{ if .IsNew }}/admin/hackathons{{ else }}{{ .EditURL .Competition }}{{ if gt .SetupStep 0 }}?setup={{ .SetupStep }}{{ end }}{{ end }}" class="mt-6 rounded-lg bg-white shadow">
      {{ if gt .SetupStep 0 }}
      <input type="hidden" name="SetupStep" value="{{ .SetupStep }}">
      {{ end }}
      {{ if eq .SetupStep 2 }}
      <input type="hidden" name="Title" value="{{ .Competition.Title }}">
      <input type="hidden" name="Slug" value="{{ .Competition.Slug }}">
      <input type="hidden" name="ConferenceID" value="{{ .Competition.ConferenceID }}">
      <input type="hidden" name="Visibility" value="{{ .Competition.Visibility }}">
      <input type="hidden" name="LifecycleOverride" value="{{ .Competition.LifecycleOverride }}">
      {{ if .Competition.PublicGalleryEnabled }}<input type="hidden" name="PublicGalleryEnabled" value="1">{{ end }}
      {{ if .Competition.AllowLateSubmissions }}<input type="hidden" name="AllowLateSubmissions" value="1">{{ end }}
      {{ if .Competition.PublicTablesEnabled }}<input type="hidden" name="PublicTablesEnabled" value="1">{{ end }}
      {{ with .Competition.MaxTeamSize }}<input type="hidden" name="MaxTeamSize" value="{{ . }}">{{ end }}
      <input type="hidden" name="DescriptionFormat" value="{{ if .Competition.DescriptionFormat }}{{ .Competition.DescriptionFormat }}{{ else }}markdown{{ end }}">
      <textarea name="Description" class="hidden">{{ .Competition.Description }}</textarea>
      {{ end }}
      {{ if .IsNew }}
      <input type="hidden" name="SetupFromSchedule" value="{{ if .SetupFromSchedule }}1{{ end }}">
      {{ end }}

      <div class="space-y-6 px-4 py-5 sm:p-6">
        {{ if or .IsNew (eq .SetupStep 1) }}
        <div class="rounded-md border border-gray-200 bg-gray-50 px-4 py-3">
          <h2 class="text-sm font-semibold text-gray-900">Step 1: Basics</h2>
          <p class="mt-1 text-sm text-gray-600">{{ if .IsNew }}Create the hackathon shell.{{ else }}Update the hackathon shell.{{ end }} Timeline, schedule, and awards come next.</p>
          {{ if .SetupFromSchedule }}
          <p class="mt-2 text-xs font-medium text-amber-800">Opened from the conference schedule. The conference is preselected.</p>
          {{ end }}
        </div>
        {{ end }}

        {{ if ne .SetupStep 2 }}
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <label for="Title" class="block text-sm font-medium text-gray-700">Title *</label>
            <input id="Title" name="Title" type="text" required value="{{ .Competition.Title }}"
                   class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
          </div>
          <div>
            <label for="Slug" class="block text-sm font-medium text-gray-700">Slug *</label>
            <input id="Slug" name="Slug" type="text" required value="{{ .Competition.Slug }}"
                   class="mt-1 block w-full rounded-md bg-white px-3 py-2 font-mono text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          <div>
            <label for="ConferenceID" class="block text-sm font-medium text-gray-700">Conference *</label>
            <select id="ConferenceID" name="ConferenceID" required
                    class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
              <option value="">Select a conference</option>
              {{ range .Confs }}
              <option value="{{ .Ref }}" {{ if eq $.Competition.ConferenceID .Ref }}selected{{ end }}>{{ .Tag }} - {{ .Desc }}</option>
              {{ end }}
            </select>
          </div>
          <div>
            <label for="Visibility" class="block text-sm font-medium text-gray-700">Visibility *</label>
            <select id="Visibility" name="Visibility" required
                    class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
              <option value="hidden" {{ if eq .Competition.Visibility "hidden" }}selected{{ end }}>Hidden</option>
              <option value="public" {{ if eq .Competition.Visibility "public" }}selected{{ end }}>Public</option>
            </select>
          </div>
          <div>
            <label for="LifecycleOverride" class="block text-sm font-medium text-gray-700">State override</label>
            <select id="LifecycleOverride" name="LifecycleOverride"
                    class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
              <option value="" {{ if eq .Competition.LifecycleOverride "" }}selected{{ end }}>Automatic</option>
              <option value="upcoming" {{ if eq .Competition.LifecycleOverride "upcoming" }}selected{{ end }}>Upcoming</option>
              <option value="open" {{ if eq .Competition.LifecycleOverride "open" }}selected{{ end }}>Submissions open</option>
              <option value="submissions_closed" {{ if eq .Competition.LifecycleOverride "submissions_closed" }}selected{{ end }}>Submissions closed</option>
              <option value="closed" {{ if eq .Competition.LifecycleOverride "closed" }}selected{{ end }}>Closed</option>
            </select>
          </div>
          <div>
            <label for="MaxTeamSize" class="block text-sm font-medium text-gray-700">Max team size</label>
            <input id="MaxTeamSize" name="MaxTeamSize" type="number" min="1" {{ with .Competition.MaxTeamSize }}value="{{ . }}"{{ end }}
                   class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
          </div>
        </div>
        <div class="grid gap-4 sm:grid-cols-3">
          <div>
            <label for="PublicGalleryEnabled" class="block text-sm font-medium text-gray-700">Public gallery</label>
            <label class="mt-1 flex min-h-10 items-center gap-2 rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300">
              <input id="PublicGalleryEnabled" name="PublicGalleryEnabled" type="checkbox" value="1" {{ if .Competition.PublicGalleryEnabled }}checked{{ end }}
                     class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600">
              Show submitted projects publicly
            </label>
          </div>
          <div>
            <label for="AllowLateSubmissions" class="block text-sm font-medium text-gray-700">Late submissions</label>
            <label class="mt-1 flex min-h-10 items-center gap-2 rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300">
              <input id="AllowLateSubmissions" name="AllowLateSubmissions" type="checkbox" value="1" {{ if .Competition.AllowLateSubmissions }}checked{{ end }}
                     class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600">
              Allow submissions after close
            </label>
          </div>
          <div>
            <label for="PublicTablesEnabled" class="block text-sm font-medium text-gray-700">Project tables</label>
            <label class="mt-1 flex min-h-10 items-center gap-2 rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300">
              <input id="PublicTablesEnabled" name="PublicTablesEnabled" type="checkbox" value="1" {{ if .Competition.PublicTablesEnabled }}checked{{ end }}
                     class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600">
              Show table list publicly
            </label>
          </div>
        </div>
        {{ end }}

        {{ if eq .SetupStep 2 }}
        <div data-segment-builder>
          <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <h2 class="text-sm font-semibold text-gray-900">Step 2: Schedule segments</h2>
              <p class="mt-1 text-sm text-gray-600">Add the hackathon blocks that should appear in the conference scheduler. Times and rooms are assigned on the conference schedule page.</p>
            </div>
            <div class="flex flex-col gap-2 sm:flex-row sm:items-end">
              {{ $schedulerURL := .ConferenceSchedulerURL .Competition }}
              {{ if $schedulerURL }}
              <a href="{{ $schedulerURL }}" class="inline-flex items-center justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-gray-300 hover:bg-gray-50">Go to scheduler</a>
              {{ end }}
              <button type="button" data-segment-add-defaults class="inline-flex items-center justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-gray-300 hover:bg-gray-50">Add default blocks</button>
              <label class="block text-xs font-medium uppercase tracking-wide text-gray-500">
                Add segment
                <select data-segment-select class="mt-1 block w-full min-w-48 rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                  <option value="">Choose segment</option>
                  <option value="kickoff" data-title="Kickoff" data-duration="30">Kickoff</option>
                  <option value="hacking" data-title="Hacking time" data-duration="120">Hacking time</option>
                  <option value="judges-meeting" data-title="Judges meeting" data-duration="30">Judges meeting</option>
                  <option value="expo" data-title="Project expo" data-duration="120">Project expo</option>
                  <option value="finals" data-title="Finals" data-duration="60">Finals</option>
                  <option value="awards" data-title="Awards" data-duration="45">Awards</option>
                  <option value="custom" data-title="Custom segment" data-duration="30">Custom</option>
                </select>
              </label>
              <button type="button" data-segment-add class="inline-flex items-center justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-gray-300 hover:bg-gray-50">Add</button>
            </div>
          </div>

          <div data-segment-list class="mt-4 flex gap-3 overflow-x-auto pb-3">
            {{ range .ScheduleSegments }}
            <div data-segment-row class="w-72 shrink-0 rounded-md border border-gray-200 bg-gray-50 p-3">
              <input type="hidden" name="SegmentID" value="{{ .ID }}">
              <input type="hidden" name="SegmentType" value="{{ .SegmentType }}">
              <div class="space-y-3">
                <label class="block text-sm font-medium text-gray-700">
                  Segment
                  <input name="SegmentTitle" type="text" required value="{{ .Title }}" class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                </label>
                <div class="grid grid-cols-[minmax(0,1fr)_auto] items-end gap-2">
                  <label class="block text-sm font-medium text-gray-700">
                    Minutes
                    <input name="SegmentDuration" type="number" min="1" step="1" required value="{{ .DefaultDurationMinutes }}" class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                  </label>
                  <button type="button" data-segment-remove class="rounded-md px-2.5 py-2 text-xs font-semibold text-red-700 hover:bg-red-50">Remove</button>
                </div>
              </div>
            </div>
            {{ end }}
          </div>
          <p data-segment-empty class="{{ if .ScheduleSegments }}hidden {{ end }}mt-4 rounded-md border border-dashed border-gray-300 px-4 py-3 text-sm text-gray-500">No schedule segments yet.</p>
        </div>

        <template data-segment-template>
          <div data-segment-row class="w-72 shrink-0 rounded-md border border-gray-200 bg-gray-50 p-3">
            <input type="hidden" name="SegmentID" value="">
            <input type="hidden" name="SegmentType" value="custom">
            <div class="space-y-3">
              <label class="block text-sm font-medium text-gray-700">
                Segment
                <input name="SegmentTitle" type="text" required value="" class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
              </label>
              <div class="grid grid-cols-[minmax(0,1fr)_auto] items-end gap-2">
                <label class="block text-sm font-medium text-gray-700">
                  Minutes
                  <input name="SegmentDuration" type="number" min="1" step="1" required value="30" class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                </label>
                <button type="button" data-segment-remove class="rounded-md px-2.5 py-2 text-xs font-semibold text-red-700 hover:bg-red-50">Remove</button>
              </div>
            </div>
          </div>
        </template>
        {{ end }}

        {{ if false }}
        <div data-timeline-builder>
          <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <h2 class="text-sm font-semibold text-gray-900">{{ if eq .SetupStep 2 }}Step 2: Timeline and schedule{{ else }}Timeline{{ end }}</h2>
              <p class="mt-1 text-sm text-gray-600">{{ if eq .SetupStep 2 }}Add only the timing segments this hackathon needs.{{ else }}Add or update timing segments.{{ end }}</p>
            </div>
            <div class="flex flex-col gap-2 sm:flex-row sm:items-end">
              <label class="block text-xs font-medium uppercase tracking-wide text-gray-500">
                Add segment
                <select data-timeline-select class="mt-1 block w-full min-w-48 rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                  <option value="">Choose segment</option>
                  <option value="submissions">Submissions</option>
                  <option value="hacking">Hacking</option>
                  <option value="judges-meeting">Judges meeting</option>
                  <option value="expo">Expo</option>
                  <option value="finals">Finals</option>
                  <option value="awards">Awards ceremony</option>
                </select>
              </label>
              <button type="button" data-timeline-add class="inline-flex items-center justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-gray-300 hover:bg-gray-50">Add</button>
            </div>
          </div>

          <div class="mt-4 space-y-4">
            <section data-timeline-segment="submissions" class="{{ if or .Competition.SubmissionsOpenAt .Competition.SubmissionsCloseAt .Competition.PublicGalleryAt }}{{ else }}hidden{{ end }} rounded-md border border-gray-200 bg-gray-50 p-4">
              <div class="mb-3 flex items-center justify-between gap-3">
                <h3 class="text-sm font-semibold text-gray-900">Submissions</h3>
                <button type="button" data-timeline-remove class="rounded-md px-2.5 py-1.5 text-xs font-semibold text-red-700 hover:bg-red-50">Remove</button>
              </div>
              <div class="grid gap-4 sm:grid-cols-3">
                <div>
                  <label for="SubmissionsOpenAt" class="block text-sm font-medium text-gray-700">Open</label>
                  <input id="SubmissionsOpenAt" name="SubmissionsOpenAt" type="datetime-local" {{ with .Competition.SubmissionsOpenAt }}value="{{ .Format "2006-01-02T15:04" }}"{{ end }}
                         class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                </div>
                <div>
                  <label for="SubmissionsCloseAt" class="block text-sm font-medium text-gray-700">Close</label>
                  <input id="SubmissionsCloseAt" name="SubmissionsCloseAt" type="datetime-local" {{ with .Competition.SubmissionsCloseAt }}value="{{ .Format "2006-01-02T15:04" }}"{{ end }}
                         class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                </div>
                <div>
                  <label for="PublicGalleryAt" class="block text-sm font-medium text-gray-700">Go public</label>
                  <input id="PublicGalleryAt" name="PublicGalleryAt" type="datetime-local" {{ with .Competition.PublicGalleryAt }}value="{{ .Format "2006-01-02T15:04" }}"{{ end }}
                         class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                </div>
              </div>
            </section>

            <section data-timeline-segment="hacking" class="{{ if or .Competition.HackingStartsAt .Competition.HackingEndsAt }}{{ else }}hidden{{ end }} rounded-md border border-gray-200 bg-gray-50 p-4">
              <div class="mb-3 flex items-center justify-between gap-3">
                <h3 class="text-sm font-semibold text-gray-900">Hacking</h3>
                <button type="button" data-timeline-remove class="rounded-md px-2.5 py-1.5 text-xs font-semibold text-red-700 hover:bg-red-50">Remove</button>
              </div>
              <div class="grid gap-4 sm:grid-cols-2">
                <div>
                  <label for="HackingStartsAt" class="block text-sm font-medium text-gray-700">Starts</label>
                  <input id="HackingStartsAt" name="HackingStartsAt" type="datetime-local" {{ with .Competition.HackingStartsAt }}value="{{ .Format "2006-01-02T15:04" }}"{{ end }}
                         class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                </div>
                <div>
                  <label for="HackingEndsAt" class="block text-sm font-medium text-gray-700">Ends</label>
                  <input id="HackingEndsAt" name="HackingEndsAt" type="datetime-local" {{ with .Competition.HackingEndsAt }}value="{{ .Format "2006-01-02T15:04" }}"{{ end }}
                         class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                </div>
              </div>
            </section>

            <section data-timeline-segment="judges-meeting" class="{{ if .Competition.JudgesMeetingAt }}{{ else }}hidden{{ end }} rounded-md border border-gray-200 bg-gray-50 p-4">
              <div class="mb-3 flex items-center justify-between gap-3">
                <h3 class="text-sm font-semibold text-gray-900">Judges meeting</h3>
                <button type="button" data-timeline-remove class="rounded-md px-2.5 py-1.5 text-xs font-semibold text-red-700 hover:bg-red-50">Remove</button>
              </div>
              <div class="max-w-sm">
                <label for="JudgesMeetingAt" class="block text-sm font-medium text-gray-700">Time</label>
                <input id="JudgesMeetingAt" name="JudgesMeetingAt" type="datetime-local" {{ with .Competition.JudgesMeetingAt }}value="{{ .Format "2006-01-02T15:04" }}"{{ end }}
                       class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
              </div>
            </section>

            <section data-timeline-segment="expo" class="{{ if or .Competition.ExpoStartsAt .Competition.ExpoEndsAt .Competition.ExpoJudgingStartsAt .Competition.ExpoJudgingEndsAt }}{{ else }}hidden{{ end }} rounded-md border border-gray-200 bg-gray-50 p-4">
              <div class="mb-3 flex items-center justify-between gap-3">
                <h3 class="text-sm font-semibold text-gray-900">Expo</h3>
                <button type="button" data-timeline-remove class="rounded-md px-2.5 py-1.5 text-xs font-semibold text-red-700 hover:bg-red-50">Remove</button>
              </div>
              <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
                <div>
                  <label for="ExpoStartsAt" class="block text-sm font-medium text-gray-700">Starts</label>
                  <input id="ExpoStartsAt" name="ExpoStartsAt" type="datetime-local" {{ with .Competition.ExpoStartsAt }}value="{{ .Format "2006-01-02T15:04" }}"{{ end }}
                         class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                </div>
                <div>
                  <label for="ExpoEndsAt" class="block text-sm font-medium text-gray-700">Ends</label>
                  <input id="ExpoEndsAt" name="ExpoEndsAt" type="datetime-local" {{ with .Competition.ExpoEndsAt }}value="{{ .Format "2006-01-02T15:04" }}"{{ end }}
                         class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                </div>
                <div>
                  <label for="ExpoJudgingStartsAt" class="block text-sm font-medium text-gray-700">Judging starts</label>
                  <input id="ExpoJudgingStartsAt" name="ExpoJudgingStartsAt" type="datetime-local" {{ with .Competition.ExpoJudgingStartsAt }}value="{{ .Format "2006-01-02T15:04" }}"{{ end }}
                         class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                </div>
                <div>
                  <label for="ExpoJudgingEndsAt" class="block text-sm font-medium text-gray-700">Judging ends</label>
                  <input id="ExpoJudgingEndsAt" name="ExpoJudgingEndsAt" type="datetime-local" {{ with .Competition.ExpoJudgingEndsAt }}value="{{ .Format "2006-01-02T15:04" }}"{{ end }}
                         class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                </div>
              </div>
            </section>

            <section data-timeline-segment="finals" class="{{ if or .Competition.FinalsStartsAt .Competition.FinalsEndsAt .Competition.FinalsJudgingStartsAt .Competition.FinalsJudgingEndsAt }}{{ else }}hidden{{ end }} rounded-md border border-gray-200 bg-gray-50 p-4">
              <div class="mb-3 flex items-center justify-between gap-3">
                <h3 class="text-sm font-semibold text-gray-900">Finals</h3>
                <button type="button" data-timeline-remove class="rounded-md px-2.5 py-1.5 text-xs font-semibold text-red-700 hover:bg-red-50">Remove</button>
              </div>
              <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
                <div>
                  <label for="FinalsStartsAt" class="block text-sm font-medium text-gray-700">Starts</label>
                  <input id="FinalsStartsAt" name="FinalsStartsAt" type="datetime-local" {{ with .Competition.FinalsStartsAt }}value="{{ .Format "2006-01-02T15:04" }}"{{ end }}
                         class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                </div>
                <div>
                  <label for="FinalsEndsAt" class="block text-sm font-medium text-gray-700">Ends</label>
                  <input id="FinalsEndsAt" name="FinalsEndsAt" type="datetime-local" {{ with .Competition.FinalsEndsAt }}value="{{ .Format "2006-01-02T15:04" }}"{{ end }}
                         class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                </div>
                <div>
                  <label for="FinalsJudgingStartsAt" class="block text-sm font-medium text-gray-700">Judging starts</label>
                  <input id="FinalsJudgingStartsAt" name="FinalsJudgingStartsAt" type="datetime-local" {{ with .Competition.FinalsJudgingStartsAt }}value="{{ .Format "2006-01-02T15:04" }}"{{ end }}
                         class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                </div>
                <div>
                  <label for="FinalsJudgingEndsAt" class="block text-sm font-medium text-gray-700">Judging ends</label>
                  <input id="FinalsJudgingEndsAt" name="FinalsJudgingEndsAt" type="datetime-local" {{ with .Competition.FinalsJudgingEndsAt }}value="{{ .Format "2006-01-02T15:04" }}"{{ end }}
                         class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                </div>
              </div>
            </section>

            <section data-timeline-segment="awards" class="{{ if .Competition.AwardsCeremonyAt }}{{ else }}hidden{{ end }} rounded-md border border-gray-200 bg-gray-50 p-4">
              <div class="mb-3 flex items-center justify-between gap-3">
                <h3 class="text-sm font-semibold text-gray-900">Awards ceremony</h3>
                <button type="button" data-timeline-remove class="rounded-md px-2.5 py-1.5 text-xs font-semibold text-red-700 hover:bg-red-50">Remove</button>
              </div>
              <div class="max-w-sm">
                <label for="AwardsCeremonyAt" class="block text-sm font-medium text-gray-700">Time</label>
                <input id="AwardsCeremonyAt" name="AwardsCeremonyAt" type="datetime-local" {{ with .Competition.AwardsCeremonyAt }}value="{{ .Format "2006-01-02T15:04" }}"{{ end }}
                       class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
              </div>
            </section>
          </div>
        </div>
        {{ end }}

        {{ if false }}
        <div class="rounded-md border border-gray-200 bg-gray-50 px-4 py-3">
          <label class="flex gap-3 text-sm text-gray-700">
            <input type="checkbox" name="SeedScheduleBlocks" value="1" {{ if .SeedScheduleBlocks }}checked{{ end }}
                   class="mt-1 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600">
            <span>
              <span class="block font-medium text-gray-900">Add standard schedule blocks</span>
              <span class="block text-gray-600">Creates sidebar items for kickoff, hacking time, expo, finals, and awards on the selected conference schedule.</span>
            </span>
          </label>
        </div>
        {{ end }}

        {{ if ne .SetupStep 2 }}
        <div class="grid gap-4 lg:grid-cols-[minmax(0,1fr)_14rem] lg:items-start">
          <div>
            <label for="Description" class="block text-sm font-medium text-gray-700">Description</label>
            <textarea id="Description" name="Description" rows="6"
                      class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">{{ .Competition.Description }}</textarea>
          </div>
          <div>
            <label for="DescriptionFormat" class="block text-sm font-medium text-gray-700">Description format</label>
            <select id="DescriptionFormat" name="DescriptionFormat"
                    class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
              <option value="plain" {{ if eq .Competition.DescriptionFormat "plain" }}selected{{ end }}>Plain text</option>
              <option value="markdown" {{ if or (eq .Competition.DescriptionFormat "") (eq .Competition.DescriptionFormat "markdown") }}selected{{ end }}>Markdown</option>
              <option value="html" {{ if eq .Competition.DescriptionFormat "html" }}selected{{ end }}>HTML</option>
            </select>
            <p class="mt-2 text-xs text-gray-500">Controls how the public description is rendered.</p>
          </div>
        </div>
        {{ end }}
      </div>
      <div class="flex items-center justify-end gap-3 border-t border-gray-200 px-4 py-4 sm:px-6">
        <a href="{{ if gt .SetupStep 0 }}{{ .EditURL .Competition }}{{ else }}{{ .BackURL }}{{ end }}" class="rounded-md px-3 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-100">Cancel</a>
        <button type="submit" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700">{{ if .IsNew }}Continue{{ else if eq .SetupStep 1 }}Save and continue to timeline{{ else if eq .SetupStep 2 }}Save and continue to awards{{ else }}Save{{ end }}</button>
      </div>
    </form>
  </div>
  <script>
  document.querySelectorAll('[data-segment-builder]').forEach(function (builder) {
    var select = builder.querySelector('[data-segment-select]');
    var addButton = builder.querySelector('[data-segment-add]');
    var addDefaultsButton = builder.querySelector('[data-segment-add-defaults]');
    var list = builder.querySelector('[data-segment-list]');
    var template = document.querySelector('[data-segment-template]');
    var empty = builder.querySelector('[data-segment-empty]');
    var defaultSegmentTypes = ['kickoff', 'hacking', 'judges-meeting', 'expo', 'finals', 'awards'];

    function updateEmptyState() {
      if (!empty || !list) return;
      empty.classList.toggle('hidden', !!list.querySelector('[data-segment-row]'));
    }

    function segmentTypeExists(type) {
      if (!list || !type) return false;
      return !!Array.prototype.find.call(list.querySelectorAll('input[name="SegmentType"]'), function (input) {
        return input.value === type;
      });
    }

    function optionForSegmentType(type) {
      if (!select || !type) return null;
      return Array.prototype.find.call(select.options, function (option) {
        return option.value === type;
      });
    }

    function addSegment(option, shouldFocus) {
      if (!option || !option.value || !template || !list) return;
      var fragment = template.content.cloneNode(true);
      var row = fragment.querySelector('[data-segment-row]');
      row.querySelector('input[name="SegmentType"]').value = option.value;
      row.querySelector('input[name="SegmentTitle"]').value = option.dataset.title || option.textContent.trim();
      row.querySelector('input[name="SegmentDuration"]').value = option.dataset.duration || '30';
      list.appendChild(fragment);
      updateEmptyState();
      if (shouldFocus) row.querySelector('input[name="SegmentTitle"]').focus();
    }

    if (addButton && select && list) {
      addButton.addEventListener('click', function () {
        addSegment(select.selectedOptions[0], true);
        select.value = '';
      });
    }

    if (addDefaultsButton && select && list) {
      addDefaultsButton.addEventListener('click', function () {
        defaultSegmentTypes.forEach(function (type) {
          if (!segmentTypeExists(type)) addSegment(optionForSegmentType(type), false);
        });
      });
    }

    builder.addEventListener('click', function (event) {
      var row = event.target.closest('[data-segment-row]');
      if (!row || !list) return;
      if (event.target.closest('[data-segment-remove]')) {
        row.remove();
        updateEmptyState();
      }
    });

    updateEmptyState();
  });
  </script>
</body>
</html>

