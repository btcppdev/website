<!doctype html>
<html lang="en">
<head>
  <title>{{ .Competition.Title }} Awards - Admin - bitcoin++</title>
  {{ block "header" . }} {{ end }}
  {{ template "admin_favicon" "" }}
  <script src="/static/js/person-picker.js" defer></script>
  <script src="/static/js/org-picker.js" defer></script>
</head>
<body class="btcpp-admin-page admin-hackathon-page bg-gray-50 text-gray-900">
  {{ block "mainnav" . }} {{ end }}
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <a href="{{ .BackURL }}" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">&larr; {{ .BackLabel }}</a>
        <h1 class="mt-2 text-2xl font-semibold tracking-tight">{{ .Competition.Title }} awards</h1>
        <p class="mt-1 text-sm text-gray-600">Set up awards and prizes before assigning winners.</p>
      </div>
      <a href="{{ .HackathonURL .Competition }}" class="inline-flex items-center justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-gray-300 hover:bg-gray-50">Public page</a>
    </div>
    {{ if eq .SetupStep 3 }}
    {{ template "admin_hackathon_setup_steps" . }}
    {{ else }}
    {{ template "admin_hackathon_tabs" . }}
    {{ end }}

    {{ if .FlashMessage }}
    <div class="mb-4 rounded-md border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-800">{{ .FlashMessage }}</div>
    {{ end }}
    {{ if .FlashError }}
    <div class="btcpp-admin-flash btcpp-admin-flash--error mb-4">{{ .FlashError }}</div>
    {{ end }}

	    {{ if .ResultsFinalized }}
	    <section class="mb-6 flex flex-col gap-3 rounded-lg border border-green-300 bg-green-50 px-4 py-4 sm:flex-row sm:items-center sm:justify-between">
	      <div>
        <h2 class="text-sm font-semibold text-green-900">Results are finalized and public</h2>
        <p class="mt-1 text-sm text-green-800">Published {{ .ResultsFinalizedLabel }}. Reopen results before changing award recipients.</p>
      </div>
      <form method="POST" action="{{ .ResultsURL .Competition }}/reopen" onsubmit="return confirm('Reopen these results? Winner badges and award recipients will immediately be hidden from the public page.');">
        <input type="hidden" name="ReturnTo" value="awards">
        <button type="submit" class="rounded-md bg-white px-3 py-2 text-sm font-semibold text-green-900 shadow-sm ring-1 ring-green-400 hover:bg-green-100">Reopen results</button>
      </form>
    </section>
    {{ else }}
    <section class="mb-6 flex flex-col gap-3 rounded-lg border border-amber-300 bg-amber-50 px-4 py-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2 class="text-sm font-semibold text-amber-950">Winner assignments are private</h2>
        <p class="mt-1 text-sm text-amber-900">You can continue assigning awards. Finalizing publishes all recipients and winner badges, then locks recipient changes.</p>
      </div>
      <form method="POST" action="{{ .ResultsURL .Competition }}/finalize" onsubmit="return confirm('Finalize and publish these results? All assigned winners will become public and recipient changes will be locked.');">
        <input type="hidden" name="ReturnTo" value="awards">
        <button type="submit" class="rounded-md bg-amber-900 px-3 py-2 text-sm font-semibold text-white hover:bg-amber-800">Finalize and publish results</button>
      </form>
	    </section>
	    {{ end }}

	    <div class="space-y-6">
	      <section class="overflow-hidden rounded-lg bg-white shadow" data-award-tabs>
        <div class="border-b border-gray-200 px-4 py-4 sm:px-6">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div>
              <h2 class="text-sm font-semibold text-gray-900">Awards</h2>
              <span class="text-sm text-gray-500">{{ len .Awards }} configured</span>
            </div>
            <button type="button"
                    class="rounded-md px-3 py-2 text-sm font-semibold {{ if .Awards }}bg-white text-gray-700 ring-1 ring-gray-300 hover:bg-gray-50{{ else }}bg-indigo-600 text-white{{ end }}"
                    data-award-tab="create-award"
                    aria-controls="award-panel-create-award"
                    aria-selected="{{ if .Awards }}false{{ else }}true{{ end }}">
              Add award
            </button>
          </div>
        </div>
        <div class="px-4 py-5 sm:p-6">
          {{ if .Awards }}
            <div class="-mx-1 mb-4 flex gap-2 overflow-x-auto px-1 pb-1" role="tablist" aria-label="Awards">
              {{ range $index, $award := .Awards }}
              <button type="button"
                      class="flex-none rounded-md px-3 py-2 text-sm font-semibold {{ if eq $index 0 }}bg-indigo-600 text-white{{ else }}bg-white text-gray-700 ring-1 ring-gray-300 hover:bg-gray-50{{ end }}"
                      data-award-tab="{{ .ID }}"
                      aria-controls="award-panel-{{ .ID }}"
                      aria-selected="{{ if eq $index 0 }}true{{ else }}false{{ end }}">
                {{ $.AwardTabLabel . }}
              </button>
              {{ end }}
            </div>
            {{ range $index, $award := .Awards }}
            <article id="award-panel-{{ .ID }}" class="rounded-md border border-gray-200 px-4 py-4{{ if ne $index 0 }} hidden{{ end }}" data-award-panel="{{ .ID }}" role="tabpanel">
              <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                <div>
                  <h3 class="text-base font-semibold text-gray-900">{{ .Title }}</h3>
                  {{ if .Description }}
                  <div class="mt-1 text-sm text-gray-600">{{ hackathonDescription .Description "markdown" }}</div>
                  {{ end }}
                  <div class="mt-3 flex flex-wrap gap-2">
                    <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-700">{{ $.AwardTypeLabel .AwardType }}</span>
                    {{ if .AwardRank }}
                    <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-700">Rank: {{ $.AwardRankLabel . }}</span>
                    {{ end }}
                    <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-700">{{ $.AwardStatusLabel .Status }}</span>
                    <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-700">{{ $.OptionalIntLabel .MaxAwardees }} awardees</span>
                    {{ if $.AwardHasSponsor . }}
                    <span class="rounded-full bg-amber-50 px-2 py-0.5 text-xs font-medium text-amber-800">Sponsor: {{ $.AwardSponsorLabel . }}</span>
                    {{ end }}
                    {{ if .OptInRequired }}
                    <span class="rounded-full bg-indigo-50 px-2 py-0.5 text-xs font-medium text-indigo-700">Opt-in required</span>
                    {{ end }}
                    {{ if .FinalistsOnly }}
                    <span class="rounded-full bg-amber-50 px-2 py-0.5 text-xs font-medium text-amber-700">Finalists only</span>
                    {{ end }}
                  </div>
                </div>
                <form method="POST" action="{{ $.AwardsURL $.Competition }}/archive">
                  <input type="hidden" name="AwardID" value="{{ .ID }}">
                  <button type="submit" class="rounded-md px-2.5 py-1.5 text-xs font-semibold text-red-700 hover:bg-red-50">Archive</button>
                </form>
              </div>

              <details class="mt-4 rounded-md bg-gray-50 p-3">
                <summary class="cursor-pointer text-sm font-semibold text-gray-900">Edit award</summary>
                <form method="POST" action="{{ $.AwardsURL $.Competition }}/update" class="mt-3 grid gap-3">
                  <input type="hidden" name="AwardID" value="{{ .ID }}">
                  <div class="grid gap-3 sm:grid-cols-2">
                    <div>
                      <label for="AwardType-{{ .ID }}" class="block text-xs font-medium text-gray-700">Type *</label>
                      <select id="AwardType-{{ .ID }}" name="AwardType" required
                              class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                        <option value="normal" {{ if eq .AwardType "normal" }}selected{{ end }}>Normal</option>
                        <option value="challenge" {{ if eq .AwardType "challenge" }}selected{{ end }}>Challenge</option>
                      </select>
                    </div>
                    <div>
                      <label for="AwardTitle-{{ .ID }}" class="block text-xs font-medium text-gray-700">Title *</label>
                      <input id="AwardTitle-{{ .ID }}" name="Title" type="text" required value="{{ .Title }}"
                             class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                    </div>
                  </div>
                  <div>
                    <label for="AwardSponsoredByOrgID-{{ .ID }}" class="block text-xs font-medium text-gray-700">Sponsor organization</label>
                    {{ $sponsorOrg := $.AwardSponsorOrg . }}
                    <div class="relative mt-1" data-org-picker data-org-picker-name="SponsoredByOrgID" data-org-picker-required="false">
                      <input type="hidden" name="SponsoredByOrgID" value="{{ .SponsoredByOrgID }}" data-org-picker-hidden>
                      <input id="AwardSponsoredByOrgID-{{ .ID }}" type="search" value="{{ with $sponsorOrg }}{{ .Name }}{{ end }}" data-org-picker-input
                             placeholder="Search sponsor organizations"
                             class="block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                      <p class="mt-2 hidden text-xs text-indigo-700" data-org-picker-flash></p>
                    </div>
                  </div>
                  <div>
                    <label for="AwardDescription-{{ .ID }}" class="block text-xs font-medium text-gray-700">Description (Markdown)</label>
                    <textarea id="AwardDescription-{{ .ID }}" name="Description" rows="3"
                              class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">{{ .Description }}</textarea>
                    <p class="mt-1 text-xs text-gray-500">Markdown links like <code>[details](https://example.com)</code> are clickable publicly.</p>
                  </div>
                  <div class="{{ if not ($.AwardIsChallenge .) }}hidden{{ end }}" data-award-field="challenge">
                    <label for="AwardJudgingInstructions-{{ .ID }}" class="block text-xs font-medium text-gray-700">Challenge judging instructions</label>
                    <textarea id="AwardJudgingInstructions-{{ .ID }}" name="JudgingInstructions" rows="2"
                              class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">{{ .JudgingInstructions }}</textarea>
                  </div>
                  <div class="grid gap-3 sm:grid-cols-3">
                    <div>
                      <label for="AwardRank-{{ .ID }}" class="block text-xs font-medium text-gray-700">Rank</label>
                      <input id="AwardRank-{{ .ID }}" name="AwardRank" type="number" min="1" {{ with .AwardRank }}value="{{ . }}"{{ end }}
                             class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                    </div>
                    <div>
                      <label for="AwardMaxAwardees-{{ .ID }}" class="block text-xs font-medium text-gray-700">Max awardees</label>
                      <input id="AwardMaxAwardees-{{ .ID }}" name="MaxAwardees" type="number" min="1" value="{{ $.OptionalIntLabel .MaxAwardees }}"
                             class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                    </div>
                    <div>
                      <label for="AwardStatus-{{ .ID }}" class="block text-xs font-medium text-gray-700">Status *</label>
                      <select id="AwardStatus-{{ .ID }}" name="Status" required
                              class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                        <option value="draft" {{ if eq .Status "draft" }}selected{{ end }}>Draft</option>
                        <option value="available" {{ if eq .Status "available" }}selected{{ end }}>Available</option>
                        <option value="unawarded" {{ if eq .Status "unawarded" }}selected{{ end }}>Unawarded</option>
                        <option value="awarded" {{ if eq .Status "awarded" }}selected{{ end }}>Awarded</option>
                      </select>
                    </div>
                    <div class="flex flex-col justify-end gap-2">
                      <label class="inline-flex items-center gap-2 text-sm text-gray-700">
                        <input name="OptInRequired" type="checkbox" {{ if .OptInRequired }}checked{{ end }}
                               class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600">
                        Opt-in required
                      </label>
                      <label class="inline-flex items-center gap-2 text-sm text-gray-700">
                        <input name="FinalistsOnly" type="checkbox" {{ if .FinalistsOnly }}checked{{ end }}
                               class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600">
                        Finalists only
                      </label>
                    </div>
                  </div>
                  <div class="flex justify-end">
                    <button type="submit" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Save award</button>
                  </div>
                </form>
              </details>

              {{ $awardees := $.Awardees . }}
              <div class="mt-4 border-t border-gray-100 pt-4">
                <h4 class="text-sm font-semibold text-gray-900">Assigned winners</h4>
                {{ if $awardees }}
                <ul class="mt-2 divide-y divide-green-100 rounded-md border border-green-200 bg-green-50">
                  {{ range $awardees }}
                  <li class="flex flex-col gap-3 px-3 py-3 text-sm sm:flex-row sm:items-center sm:justify-between">
                    <div>
                      <div class="inline-flex items-center gap-2">
                        <span class="rounded-full bg-green-600 px-2 py-0.5 text-xs font-semibold uppercase tracking-wide text-white">Winner</span>
                        <span class="font-medium text-gray-900">{{ .ProjectTitle }}</span>
                      </div>
                      <div class="mt-1 text-xs text-green-800">#{{ $.ProjectAwardNumber . }} · awarded {{ .AwardedAt.Format "Jan 2, 2006 3:04 PM" }}</div>
                    </div>
                    {{ if not $.ResultsFinalized }}<form method="POST" action="{{ $.AwardsURL $.Competition }}/remove">
                      <input type="hidden" name="AwardID" value="{{ .AwardID }}">
                      <input type="hidden" name="ProjectID" value="{{ .ProjectID }}">
                      <button type="submit" class="rounded-md px-2.5 py-1.5 text-xs font-semibold text-red-700 hover:bg-red-50">Remove</button>
                    </form>{{ end }}
                  </li>
                  {{ end }}
                </ul>
                {{ else }}
                <p class="mt-2 text-sm text-gray-600">No winners assigned yet.</p>
                {{ end }}

              </div>

              {{ if $.AwardIsChallenge . }}
              <details class="mt-4 border-t border-gray-100 pt-4">
                <summary class="cursor-pointer text-sm font-semibold text-gray-900">Challenge judging</summary>
                <div class="mt-3">
                {{ if .JudgingInstructions }}<p class="mt-1 whitespace-pre-line text-sm text-gray-600">{{ .JudgingInstructions }}</p>{{ end }}

                {{ $awardJudges := $.AwardJudges . }}
                {{ if $awardJudges }}
                <ul class="mt-3 divide-y divide-gray-100 rounded-md border border-gray-200">
                  {{ range $awardJudges }}
                  <li class="flex flex-col gap-3 px-3 py-3 text-sm sm:flex-row sm:items-center sm:justify-between">
                    <div>
                      <div class="font-medium text-gray-900">{{ if .Name }}{{ .Name }}{{ else }}{{ .PersonID }}{{ end }}</div>
                      <div class="mt-1 text-xs text-gray-500">{{ if .Email }}{{ .Email }}{{ else }}{{ .PersonID }}{{ end }}</div>
                    </div>
                    <form method="POST" action="{{ $.AwardsURL $.Competition }}/judges/remove">
                      <input type="hidden" name="AwardID" value="{{ .AwardID }}">
                      <input type="hidden" name="PersonID" value="{{ .PersonID }}">
                      <button type="submit" class="rounded-md px-2.5 py-1.5 text-xs font-semibold text-red-700 hover:bg-red-50">Remove</button>
                    </form>
                  </li>
                  {{ end }}
                </ul>
                {{ else }}
                <p class="mt-2 text-sm text-gray-600">No challenge judges assigned yet.</p>
                {{ end }}

                <form method="POST" action="{{ $.AwardsURL $.Competition }}/judges" class="mt-3 grid gap-3 sm:grid-cols-[1fr_auto] sm:items-end">
                  <input type="hidden" name="AwardID" value="{{ .ID }}">
                  <div>
                    <label for="AwardJudgePersonSearch-{{ .ID }}" class="block text-xs font-medium text-gray-700">Add challenge judge</label>
                    <div class="relative mt-1" data-person-picker data-person-picker-required="true" data-person-picker-name="PersonID">
                      <input id="AwardJudgePersonSearch-{{ .ID }}" type="search" data-person-picker-input
                             placeholder="Search by name, email, or phone"
                             class="block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                      <p class="mt-2 hidden text-xs text-indigo-700" data-person-picker-flash></p>
                    </div>
                  </div>
                  <button type="submit" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Add judge</button>
                </form>

                {{ $awardVotes := $.AwardVotes . }}
                {{ if $awardVotes }}
                <div class="mt-4">
                  <h5 class="text-xs font-semibold uppercase tracking-wide text-gray-500">Submitted challenge picks</h5>
                  <p class="mt-1 text-xs text-gray-500">Saving a challenge pick updates the assigned winner above automatically.</p>
                  <ul class="mt-2 divide-y divide-gray-100 rounded-md border border-gray-200">
                    {{ range $awardVotes }}
                    <li class="px-3 py-3 text-sm">
                      <div>
                        <div class="font-medium text-gray-900">{{ if .JudgeName }}{{ .JudgeName }}{{ else }}{{ .JudgePersonID }}{{ end }}</div>
                        <div class="mt-1 text-xs text-gray-500">Selected #{{ $.AwardVoteProjectNumber . }} · {{ .ProjectTitle }} · {{ .SubmittedAt.Format "Jan 2, 2006 3:04 PM" }}</div>
                      </div>
                      {{ if .Notes }}<p class="mt-2 text-sm text-gray-600">{{ .Notes }}</p>{{ end }}
                    </li>
                    {{ end }}
                  </ul>
                </div>
                {{ end }}
                </div>
              </details>
              {{ end }}

        {{ $prizes := $.AwardPrizes . }}
        <div class="mt-4 border-t border-gray-100 pt-4">
        <h4 class="text-sm font-semibold text-gray-900">Prizes</h4>
        <p class="mt-1 text-xs leading-5 text-gray-600"><strong>Value is always entered in satoshis.</strong> For tickets, merchandise, trophies, and other in-kind prizes, first convert the fair market value to sats. Enter a positive whole number without commas—for example, <code>1000000</code>.</p>
        {{ if $prizes }}
                <ul class="mt-2 divide-y divide-gray-100 rounded-md border border-gray-200">
          {{ range $prizes }}
          <li class="px-3 py-3 text-sm">
          <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
            <div>
            <div class="font-medium text-gray-900">{{ .Title }}</div>
            <div class="mt-1 text-xs text-gray-500">{{ $.PrizeTypeLabel .PrizeType }} · {{ $.PrizeStatusLabel .Status }}{{ if .ValueText }} · {{ $.PrizeValueLabel . }}{{ end }}{{ if .PoolPercentage }} · {{ $.PercentLabel .PoolPercentage }} pool{{ end }}</div>
            </div>
            <div class="flex items-center gap-2">
            <button type="button" onclick="const editor = this.closest('li').querySelector('[data-prize-edit]'); editor.open = true; editor.scrollIntoView({ behavior: 'smooth', block: 'nearest' });" class="rounded-md bg-white px-2.5 py-1.5 text-xs font-semibold text-gray-700 shadow-sm ring-1 ring-gray-300 hover:bg-gray-50">Edit</button>
            <form method="POST" action="{{ $.AwardsURL $.Competition }}/prizes/delete" onsubmit="return confirm('Delete this prize? This cannot be undone.');">
              <input type="hidden" name="PrizeID" value="{{ .ID }}">
              <input type="hidden" name="AwardID" value="{{ .AwardID }}">
              <button type="submit" class="rounded-md bg-white px-2.5 py-1.5 text-xs font-semibold text-red-700 shadow-sm ring-1 ring-red-200 hover:bg-red-50">Delete</button>
            </form>
            </div>
          </div>
          {{ if .Description }}<div class="mt-2 text-sm text-gray-600">{{ hackathonDescription .Description "markdown" }}</div>{{ end }}
          {{ if .PoolURL }}<a href="{{ .PoolURL }}" class="mt-2 inline-block text-sm font-medium text-indigo-600 hover:text-indigo-500">Pool</a>{{ end }}
          <details data-prize-edit class="mt-3 rounded-md bg-gray-50 p-3">
            <summary class="cursor-pointer text-xs font-semibold text-gray-700">Edit prize details</summary>
            <form method="POST" action="{{ $.AwardsURL $.Competition }}/prizes/update" class="mt-3 grid gap-3">
            <input type="hidden" name="PrizeID" value="{{ .ID }}">
            <input type="hidden" name="AwardID" value="{{ .AwardID }}">
            <div class="grid gap-3 sm:grid-cols-2">
              <label class="block text-xs font-medium text-gray-700">Prize title *
              <input name="Title" type="text" required value="{{ .Title }}" class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
              </label>
              <label class="block text-xs font-medium text-gray-700">Type *
              <select name="PrizeType" required data-prize-type class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                <option value="sats" {{ if eq .PrizeType "sats" }}selected{{ end }}>Sats</option>
                <option value="in_kind" {{ if eq .PrizeType "in_kind" }}selected{{ end }}>In-kind</option>
                <option value="tickets" {{ if eq .PrizeType "tickets" }}selected{{ end }}>Tickets</option>
                <option value="pooled" {{ if eq .PrizeType "pooled" }}selected{{ end }}>Pooled</option>
                <option value="trophy" {{ if eq .PrizeType "trophy" }}selected{{ end }}>Trophy</option>
              </select>
              </label>
            </div>
            <div class="grid gap-3 sm:grid-cols-3">
              <label class="block text-xs font-medium text-gray-700">Value (sats) *
              <input name="ValueText" type="number" min="1" step="1" inputmode="numeric" required value="{{ $.PrizeValueInput . }}" class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
              </label>
              <label data-pool-field class="block text-xs font-medium text-gray-700">Share of external pool (%)
              <input name="PoolPercentage" type="number" min="0" max="100" step="0.01" {{ with .PoolPercentage }}value="{{ . }}"{{ end }} class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
              <span class="mt-1 block text-xs font-normal text-gray-500">The percentage of an externally managed pool assigned to this prize.</span>
              </label>
              <label class="block text-xs font-medium text-gray-700">Status *
              <select name="Status" required class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                <option value="available" {{ if eq .Status "available" }}selected{{ end }}>Available</option>
                <option value="needs_funds" {{ if eq .Status "needs_funds" }}selected{{ end }}>Needs funds</option>
                <option value="awarded" {{ if eq .Status "awarded" }}selected{{ end }}>Awarded</option>
                <option value="paid" {{ if eq .Status "paid" }}selected{{ end }}>Paid</option>
              </select>
              </label>
            </div>
            <label class="block text-xs font-medium text-gray-700">Description (Markdown)
              <textarea name="Description" rows="2" class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">{{ .Description }}</textarea>
              <span class="mt-1 block text-xs font-normal text-gray-500">Markdown links like <code>[details](https://example.com)</code> are clickable publicly.</span>
            </label>
            <div class="grid gap-3 sm:grid-cols-2">
              <label data-pool-field class="block text-xs font-medium text-gray-700">External pool URL
              <input name="PoolURL" type="url" value="{{ .PoolURL }}" class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
              </label>
              <label class="block text-xs font-medium text-gray-700">Internal comments
              <input name="Comments" type="text" value="{{ .Comments }}" class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
              </label>
            </div>
            <div class="flex justify-end"><button type="submit" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Save prize</button></div>
            </form>
          </details>
          </li>
                  {{ end }}
                </ul>
                {{ else }}
                <p class="mt-2 text-sm text-gray-600">No prizes added yet.</p>
                {{ end }}
              </div>

              <details class="mt-4 rounded-md bg-gray-50 p-3">
                <summary class="cursor-pointer text-sm font-semibold text-gray-900">Add prize</summary>
                <form method="POST" action="{{ $.AwardsURL $.Competition }}/prizes" class="mt-3 grid gap-3">
                  <input type="hidden" name="AwardID" value="{{ .ID }}">
                  <div class="grid gap-3 sm:grid-cols-2">
                    <div>
                      <label for="PrizeTitle-{{ .ID }}" class="block text-xs font-medium text-gray-700">Prize title *</label>
                      <input id="PrizeTitle-{{ .ID }}" name="Title" type="text" required
                             class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                    </div>
                    <div>
                      <label for="PrizeType-{{ .ID }}" class="block text-xs font-medium text-gray-700">Type *</label>
                      <select id="PrizeType-{{ .ID }}" name="PrizeType" required data-prize-type
                              class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                        <option value="sats">Sats</option>
                        <option value="in_kind">In-kind</option>
                        <option value="tickets">Tickets</option>
                        <option value="pooled">Pooled</option>
                        <option value="trophy">Trophy</option>
                      </select>
                    </div>
                  </div>
                  <div class="grid gap-3 sm:grid-cols-3">
                    <div>
            <label for="ValueText-{{ .ID }}" class="block text-xs font-medium text-gray-700">Value (sats) *</label>
            <input id="ValueText-{{ .ID }}" name="ValueText" type="number" min="1" step="1" inputmode="numeric" required placeholder="1000000"
                             class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                    </div>
                    <div>
                      <label for="PoolPercentage-{{ .ID }}" class="block text-xs font-medium text-gray-700">Share of external pool (%)</label>
                      <input id="PoolPercentage-{{ .ID }}" name="PoolPercentage" type="number" min="0" max="100" step="0.01"
                             class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                    </div>
                    <div>
                      <label for="PrizeStatus-{{ .ID }}" class="block text-xs font-medium text-gray-700">Status *</label>
                      <select id="PrizeStatus-{{ .ID }}" name="Status" required
                              class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                        <option value="available">Available</option>
                        <option value="needs_funds">Needs funds</option>
                        <option value="awarded">Awarded</option>
                        <option value="paid">Paid</option>
                      </select>
                    </div>
                  </div>
                  <div>
                    <label for="PrizeDescription-{{ .ID }}" class="block text-xs font-medium text-gray-700">Description (Markdown)</label>
                    <textarea id="PrizeDescription-{{ .ID }}" name="Description" rows="2"
                              class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600"></textarea>
                    <p class="mt-1 text-xs text-gray-500">Markdown links like <code>[details](https://example.com)</code> are clickable publicly.</p>
                  </div>
                  <div class="grid gap-3 sm:grid-cols-2">
                    <div data-pool-field>
                      <label for="PoolURL-{{ .ID }}" class="block text-xs font-medium text-gray-700">External pool URL</label>
                      <input id="PoolURL-{{ .ID }}" name="PoolURL" type="url"
                             class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                    </div>
                    <div>
                      <label for="Comments-{{ .ID }}" class="block text-xs font-medium text-gray-700">Internal comments</label>
                      <input id="Comments-{{ .ID }}" name="Comments" type="text"
                             class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                    </div>
                  </div>
                  <div class="flex justify-end">
                    <button type="submit" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Add prize</button>
                  </div>
                </form>
              </details>

              <form method="POST" action="{{ $.AwardsURL $.Competition }}/assign" class="mt-4 grid gap-3 border-t border-gray-100 pt-4 sm:grid-cols-[1fr_auto] sm:items-end">
                <input type="hidden" name="AwardID" value="{{ .ID }}">
                <div>
                  <label for="ProjectID-{{ .ID }}" class="block text-xs font-medium text-gray-700">Manually assign project</label>
                  <select id="ProjectID-{{ .ID }}" name="ProjectID" required
                          class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                    <option value="">Select project</option>
                    {{ range $.Projects }}
                    <option value="{{ .ID }}">{{ $.ProjectSelectLabelForAward . $award }}</option>
                    {{ end }}
                  </select>
                </div>
                <button type="submit" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Assign</button>
              </form>
            </article>
            {{ end }}
          {{ end }}

          <article id="award-panel-create-award" class="rounded-md border border-gray-200 px-4 py-4{{ if .Awards }} hidden{{ end }}" data-award-panel="create-award" role="tabpanel">
            <h3 class="text-base font-semibold text-gray-900">Create award</h3>
            {{ if not .Awards }}
            <p class="mt-1 text-sm text-gray-600">No awards configured yet.</p>
            {{ end }}
            <form method="POST" action="{{ .AwardsURL .Competition }}" class="mt-4 grid gap-4">
              <div>
                <label for="AwardType" class="block text-sm font-medium text-gray-700">Type *</label>
                <select id="AwardType" name="AwardType" required
                        class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                  <option value="normal">Normal</option>
                  <option value="challenge">Challenge</option>
                </select>
              </div>
              <div>
                <label for="Title" class="block text-sm font-medium text-gray-700">Title *</label>
                <input id="Title" name="Title" type="text" required
                       class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
              </div>
              <div>
                <label for="SponsoredByOrgID" class="block text-sm font-medium text-gray-700">Sponsor organization</label>
                <div class="relative mt-1" data-org-picker data-org-picker-name="SponsoredByOrgID" data-org-picker-required="false">
                  <input type="hidden" name="SponsoredByOrgID" data-org-picker-hidden>
                  <input id="SponsoredByOrgID" type="search" data-org-picker-input
                         placeholder="Search sponsor organizations"
                         class="block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                  <p class="mt-2 hidden text-xs text-indigo-700" data-org-picker-flash></p>
                </div>
              </div>
              <div>
                <label for="Description" class="block text-sm font-medium text-gray-700">Description</label>
                <textarea id="Description" name="Description" rows="4"
                          class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600"></textarea>
              </div>
              <div class="hidden" data-award-field="challenge">
                <label for="JudgingInstructions" class="block text-sm font-medium text-gray-700">Challenge judging instructions</label>
                <textarea id="JudgingInstructions" name="JudgingInstructions" rows="3"
                          class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600"></textarea>
              </div>
              <div class="grid gap-4 sm:grid-cols-2">
                <div>
                  <label for="AwardRank" class="block text-sm font-medium text-gray-700">Rank</label>
                  <input id="AwardRank" name="AwardRank" type="number" min="1"
                         class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                </div>
                <div>
                  <label for="MaxAwardees" class="block text-sm font-medium text-gray-700">Max awardees</label>
                  <input id="MaxAwardees" name="MaxAwardees" type="number" min="1" value="1"
                         class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                </div>
                <div>
                  <label for="Status" class="block text-sm font-medium text-gray-700">Status *</label>
                  <select id="Status" name="Status" required
                          class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                    <option value="draft">Draft</option>
                    <option value="available">Available</option>
                    <option value="unawarded">Unawarded</option>
                    <option value="awarded">Awarded</option>
                  </select>
                </div>
              </div>
              <label class="inline-flex items-center gap-2 text-sm text-gray-700">
                <input name="OptInRequired" type="checkbox" class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600">
                Opt-in required
              </label>
              <div class="flex justify-end">
                <button type="submit" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Add award</button>
              </div>
            </form>
          </article>

          {{ if .ArchivedAwards }}
          <details class="mt-6 rounded-md border border-gray-200 bg-gray-50">
            <summary class="cursor-pointer px-4 py-3 text-sm font-semibold text-gray-900">Archived awards ({{ len .ArchivedAwards }})</summary>
            <ul class="divide-y divide-gray-200 border-t border-gray-200 bg-white">
              {{ range .ArchivedAwards }}
              <li class="flex flex-col gap-3 px-4 py-3 text-sm sm:flex-row sm:items-center sm:justify-between">
                <div>
                  <div class="font-medium text-gray-900">{{ .Title }}</div>
                  <div class="mt-1 text-xs text-gray-500">
                    {{ $.AwardStatusLabel .Status }} · archived {{ $.AwardArchivedAtLabel . }}
                    {{ if .OptInRequired }} · opt-in required{{ end }}
                  </div>
                </div>
                <div class="flex flex-wrap gap-2 sm:justify-end">
                  <form method="POST" action="{{ $.AwardsURL $.Competition }}/restore">
                    <input type="hidden" name="AwardID" value="{{ .ID }}">
                    <button type="submit" class="rounded-md bg-white px-2.5 py-1.5 text-xs font-semibold text-gray-900 shadow-sm ring-1 ring-gray-300 hover:bg-gray-50">Restore</button>
                  </form>
                  <form method="POST" action="{{ $.AwardsURL $.Competition }}/delete">
                    <input type="hidden" name="AwardID" value="{{ .ID }}">
                    <button type="submit" class="rounded-md px-2.5 py-1.5 text-xs font-semibold text-red-700 hover:bg-red-50">Delete</button>
                  </form>
                </div>
              </li>
              {{ end }}
            </ul>
          </details>
          {{ end }}
        </div>
      </section>

    </div>
  </div>
  <script>
    document.querySelectorAll('form').forEach((form) => {
      const type = form.querySelector('[data-prize-type]');
      const poolFields = form.querySelectorAll('[data-pool-field]');
      if (!type || !poolFields.length) return;
      function updatePoolFields() {
        const pooled = type.value === 'pooled';
        poolFields.forEach((field) => {
          field.hidden = !pooled;
          field.querySelectorAll('input').forEach((input) => {
            input.disabled = !pooled;
          });
        });
      }
      type.addEventListener('change', updatePoolFields);
      updatePoolFields();
    });
    document.querySelectorAll('[data-award-tabs]').forEach((root) => {
      const tabs = Array.from(root.querySelectorAll('[data-award-tab]'));
      const panels = Array.from(root.querySelectorAll('[data-award-panel]'));
      function setActive(id) {
        tabs.forEach((tab) => {
          const selected = tab.dataset.awardTab === id;
          tab.setAttribute('aria-selected', selected ? 'true' : 'false');
          tab.classList.toggle('bg-indigo-600', selected);
          tab.classList.toggle('text-white', selected);
          tab.classList.toggle('bg-white', !selected);
          tab.classList.toggle('text-gray-700', !selected);
          tab.classList.toggle('ring-1', !selected);
          tab.classList.toggle('ring-gray-300', !selected);
          tab.classList.toggle('hover:bg-gray-50', !selected);
        });
        panels.forEach((panel) => {
          panel.classList.toggle('hidden', panel.dataset.awardPanel !== id);
        });
      }
      tabs.forEach((tab) => {
        tab.addEventListener('click', () => setActive(tab.dataset.awardTab));
      });
      const requestedAward = new URLSearchParams(window.location.search).get('award');
      if (requestedAward && tabs.some((tab) => tab.dataset.awardTab === requestedAward)) {
        setActive(requestedAward);
      }
    });
    document.querySelectorAll('form').forEach((form) => {
      const type = form.querySelector('select[name="AwardType"]');
      if (!type) return;
      const challengeFields = Array.from(form.querySelectorAll('[data-award-field="challenge"]'));
      function syncAwardRequirements() {
        const isChallenge = type.value === 'challenge';
        challengeFields.forEach((field) => field.classList.toggle('hidden', !isChallenge));
      }
      type.addEventListener('change', syncAwardRequirements);
      syncAwardRequirements();
    });
  </script>
</body>
</html>
