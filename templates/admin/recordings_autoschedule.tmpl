<!DOCTYPE html>
<html>
  <head>
    <title>autoschedule recordings @ bitcoin++</title>
    {{ block "header" . }} {{ end }}
  </head>
  <body class="btcpp-admin-page">
    {{ block "mainnav" . }} {{ end }}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-6xl">

        <section class="mt-6 mb-6">
          <div class="overflow-hidden sm:rounded-lg bg-white shadow">
            <div class="px-4 py-5 sm:p-6 flex items-start justify-between gap-4">
              <div>
                <a href="/{{ .Conf.Tag }}/admin/recordings" class="text-xs text-gray-500 hover:text-gray-700">&larr; back to recordings</a>
                <h1 class="text-xl font-bold text-gray-900">Autoschedule YouTube</h1>
                <p class="text-sm text-gray-500">Review the next available channel slots before saving publish times.</p>
              </div>
              <a href="/{{ .Conf.Tag }}/admin/recordings/youtube-slots" class="px-3 py-1.5 text-sm rounded-md text-gray-700 bg-gray-100 hover:bg-gray-200">Publish slots</a>
            </div>
          </div>
        </section>

        {{ if .FlashError }}
        <section class="mb-6">
          <div class="bg-yellow-50 border border-yellow-300 text-yellow-800 px-4 py-3 rounded-lg">{{ .FlashError }}</div>
        </section>
        {{ end }}

        <section class="mb-6">
          <form method="GET" action="/{{ .Conf.Tag }}/admin/recordings/autoschedule" class="bg-white shadow rounded-lg px-4 py-4 flex items-center justify-between gap-4">
            <label class="flex items-center gap-2 text-sm text-gray-700">
              <input type="checkbox" name="reschedule" value="1" {{ if .RescheduleExisting }}checked{{ end }} class="rounded border-gray-300 text-indigo-600">
              Reschedule already scheduled unpublished videos
            </label>
            <button type="submit" class="px-3 py-1.5 text-sm rounded-md text-gray-700 bg-gray-100 hover:bg-gray-200">Refresh preview</button>
          </form>
        </section>

        <section class="mb-6">
          <div class="bg-white shadow rounded-lg overflow-hidden">
            <div class="px-4 py-3 border-b border-gray-200 flex items-center justify-between">
              <h2 class="text-sm font-semibold text-gray-900">Proposed schedule</h2>
              <span class="text-xs text-gray-500">{{ len .Items }} eligible</span>
            </div>
            {{ if .Items }}
            <table class="min-w-full divide-y divide-gray-200">
              <thead class="bg-gray-50">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Talk</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Publish at</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Slot</th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">YouTube</th>
                </tr>
              </thead>
              <tbody class="bg-white divide-y divide-gray-200">
                {{ range .Items }}
                <tr>
                  <td class="px-4 py-3 text-sm text-gray-900">
                    {{ if and .Row.ConfTalk .Row.ConfTalk.Proposal }}{{ .Row.ConfTalk.Proposal.Title }}{{ else }}{{ .Row.Recording.TalkName }}{{ end }}
                    {{ if and .Row.ConfTalk .Row.ConfTalk.Sched }}<div class="text-xs text-gray-400">recorded {{ .Row.ConfTalk.Sched.Start.Format "Jan 2, 2006" }}</div>{{ end }}
                  </td>
                  <td class="px-4 py-3 text-sm text-gray-700">{{ .PublishAt.Format "Jan 2, 2006 3:04 PM MST" }}</td>
                  <td class="px-4 py-3 text-sm text-gray-500">{{ .SlotLabel }}</td>
                  <td class="px-4 py-3 text-sm text-gray-500">{{ if .Row.YTPrivacyStatus }}{{ .Row.YTPrivacyStatus }}{{ else }}unknown{{ end }}</td>
                </tr>
                {{ end }}
              </tbody>
            </table>
            <form method="POST" action="/{{ .Conf.Tag }}/admin/recordings/autoschedule" class="px-4 py-4 border-t border-gray-200 flex items-center justify-end gap-3">
              {{ if .RescheduleExisting }}<input type="hidden" name="reschedule" value="1">{{ end }}
              <a href="/{{ .Conf.Tag }}/admin/recordings" class="px-3 py-1.5 text-sm rounded-md text-gray-700 bg-gray-100 hover:bg-gray-200">Cancel</a>
              <button type="submit" class="px-3 py-1.5 text-sm rounded-md text-white bg-indigo-600 hover:bg-indigo-700">Apply schedule</button>
            </form>
            {{ else }}
            <div class="px-4 py-6 text-sm text-gray-500">No eligible YouTube recordings found.</div>
            {{ end }}
          </div>
        </section>

        {{ if .Skipped }}
        <section class="mb-8">
          <div class="bg-white shadow rounded-lg overflow-hidden">
            <div class="px-4 py-3 border-b border-gray-200 flex items-center justify-between">
              <h2 class="text-sm font-semibold text-gray-900">Skipped</h2>
              <span class="text-xs text-gray-500">{{ len .Skipped }} skipped</span>
            </div>
            <table class="min-w-full divide-y divide-gray-200">
              <tbody class="bg-white divide-y divide-gray-200">
                {{ range .Skipped }}
                <tr>
                  <td class="px-4 py-3 text-sm text-gray-900">{{ if and .Row.ConfTalk .Row.ConfTalk.Proposal }}{{ .Row.ConfTalk.Proposal.Title }}{{ else }}{{ .Row.Recording.TalkName }}{{ end }}</td>
                  <td class="px-4 py-3 text-sm text-gray-500">{{ .SkipReason }}</td>
                </tr>
                {{ end }}
              </tbody>
            </table>
          </div>
        </section>
        {{ end }}

      </div>
    </div>
  </body>
</html>
