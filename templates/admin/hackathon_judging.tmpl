<!doctype html>
<html lang="en">
<head>
  <title>{{ .Competition.Title }} Judging - Admin - bitcoin++</title>
  {{ block "header" . }} {{ end }}
  {{ template "admin_favicon" "" }}
  <script src="/static/js/person-picker.js" defer></script>
</head>
<body class="btcpp-admin-page admin-hackathon-page bg-gray-50 text-gray-900">
  {{ block "mainnav" . }} {{ end }}
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <a href="{{ .BackURL }}" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">&larr; {{ .BackLabel }}</a>
        <h1 class="mt-2 text-2xl font-semibold tracking-tight">{{ .Competition.Title }} judging</h1>
        <p class="mt-1 text-sm text-gray-600">Assign judges and coordinators for scoring.</p>
      </div>
      <a href="{{ .HackathonURL .Competition }}" class="inline-flex items-center justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-gray-300 hover:bg-gray-50">Public page</a>
    </div>
    {{ template "admin_hackathon_tabs" . }}

    {{ if .FlashMessage }}
    <div class="mb-4 rounded-md border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-800">{{ .FlashMessage }}</div>
    {{ end }}
    {{ if .FlashError }}
    <div class="mb-4 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">{{ .FlashError }}</div>
    {{ end }}

    <div class="max-w-4xl space-y-6">
      <section class="overflow-hidden rounded-lg bg-white shadow">
        <div class="border-b border-gray-200 px-4 py-4 sm:px-6">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div>
              <h2 class="text-sm font-semibold text-gray-900">Judging events</h2>
              <p class="mt-1 text-sm text-gray-600">Events come from the timeline. Set rank counts and control how judging rounds open.</p>
            </div>
            <div class="flex flex-col gap-3 sm:flex-row sm:items-end">
              <form method="POST" action="{{ .JudgingURL .Competition }}/mode">
                <label for="JudgingMode" class="block text-sm font-medium text-gray-700">
                  Judging progression
                  <select id="JudgingMode" name="JudgingMode" required onchange="this.form.submit()"
                          class="mt-1 block w-full min-w-64 rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                    <option value="manual" {{ if .JudgingModeIsManual }}selected{{ end }}>Manual admin progression</option>
                    <option value="automatic" {{ if .JudgingModeIsAutomatic }}selected{{ end }}>Automatic by schedule</option>
                  </select>
                </label>
              </form>
            </div>
          </div>
        </div>
        <div class="px-4 py-5 sm:p-6">
          {{ if .JudgeEvents }}
          <div class="-mx-4 overflow-x-auto px-4 sm:-mx-6 sm:px-6">
            <div class="flex gap-4 pb-2">
            {{ range .JudgeEvents }}
            <div class="flex w-80 flex-none flex-col rounded-md border border-gray-200 bg-gray-50 p-3">
              <div class="flex-1">
                <div>
                  <div class="text-sm font-semibold text-gray-900">{{ .Name }}</div>
                  <div class="mt-1 text-xs text-gray-500">{{ $.JudgeTypeLabel .PlaybookType }} · {{ $.JudgeEventTimeOnlyRange . }}{{ if .StartingProjectNumber }} · starts at #{{ .StartingProjectNumber }}{{ end }}</div>
                  <div class="mt-2 flex flex-wrap gap-2">
                    <span class="rounded-full {{ if $.JudgeEventAcceptsScores . }}bg-green-50 text-green-700{{ else }}bg-gray-200 text-gray-700{{ end }} px-2 py-0.5 text-xs font-medium">{{ $.JudgeEventEffectiveStateLabel . }}</span>
                  </div>
                </div>
              </div>
              <div class="mt-4 flex flex-wrap items-end gap-2 border-t border-gray-200 pt-3">
                <form method="POST" action="{{ $.JudgingURL $.Competition }}/events/ranks" class="grid min-w-0 flex-1 grid-cols-[minmax(0,1fr)_auto] items-end gap-2">
                  <input type="hidden" name="JudgeEventID" value="{{ .ID }}">
                  <label class="block text-sm font-medium text-gray-700">
                    Ranks
                    <input name="RankLimit" type="number" min="1" step="1" required value="{{ $.RankLimit . }}"
                           class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                  </label>
                  <button type="submit" class="rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-gray-300 hover:bg-gray-50">Save ranks</button>
                </form>
                {{ if $.JudgingModeIsManual }}
                <div class="flex flex-none flex-wrap gap-2">
                  {{ if eq .State "open" }}
                  <form method="POST" action="{{ $.JudgingURL $.Competition }}/events/state">
                    <input type="hidden" name="JudgeEventID" value="{{ .ID }}">
                    <input type="hidden" name="State" value="closed">
                    <button type="submit" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Close scoring</button>
                  </form>
                  {{ else }}
                  <form method="POST" action="{{ $.JudgingURL $.Competition }}/events/state">
                    <input type="hidden" name="JudgeEventID" value="{{ .ID }}">
                    <input type="hidden" name="State" value="open">
                    <button type="submit" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700">{{ if eq .State "closed" }}Reopen{{ else }}Open{{ end }}</button>
                  </form>
                  {{ end }}
                </div>
                {{ end }}
              </div>
            </div>
            {{ end }}
            </div>
          </div>
          {{ else }}
          <p class="text-sm text-gray-600">No timeline blocks currently create judging events. Add Project expo or Finals blocks on the timeline.</p>
          {{ end }}
        </div>
      </section>

      <section class="rounded-lg bg-white shadow">
        <div class="border-b border-gray-200 px-4 py-4 sm:px-6">
          <h2 class="text-sm font-semibold text-gray-900">Judges</h2>
        </div>
        <div class="px-4 py-5 sm:p-6">
          {{ if .Judges }}
          <form method="POST" action="{{ .JudgingURL .Competition }}/judges/roles">
          <ul class="mb-6 divide-y divide-gray-100 rounded-md border border-gray-200">
            {{ range .Judges }}
            <li class="flex items-center justify-between gap-3 px-3 py-3 text-sm">
              <input type="hidden" name="JudgePersonID" value="{{ .PersonID }}">
              <div>
                <div class="font-medium text-gray-900">{{ if .Name }}{{ .Name }}{{ else }}{{ .PersonID }}{{ end }}</div>
                <div class="mt-1 flex flex-wrap items-center gap-2 text-xs text-gray-500">
                  <span>{{ if .Email }}{{ .Email }}{{ else }}{{ .PersonID }}{{ end }}</span>
                  {{ range $.JudgeRoleTypes . }}<span class="rounded-full bg-indigo-50 px-2 py-0.5 font-semibold text-indigo-700">{{ $.JudgeTypeLabel . }}</span>{{ end }}
                </div>
              </div>
              <div class="flex flex-wrap items-center justify-end gap-2">
                  <fieldset class="flex flex-wrap items-center justify-end gap-2 text-xs">
                    <legend class="sr-only">Judge roles for {{ .Name }}</legend>
                    <label class="flex items-center gap-1"><input type="checkbox" name="JudgeRole" value="{{ .PersonID }}|expo" {{ if $.JudgeHasType . "expo" }}checked{{ end }}> Expo</label>
                    <label class="flex items-center gap-1"><input type="checkbox" name="JudgeRole" value="{{ .PersonID }}|finals" {{ if $.JudgeHasType . "finals" }}checked{{ end }}> Finals</label>
                    <label class="flex items-center gap-1"><input type="checkbox" name="JudgeRole" value="{{ .PersonID }}|coordinator" {{ if $.JudgeHasType . "coordinator" }}checked{{ end }}> Coordinator</label>
                  </fieldset>
                <button type="submit" formnovalidate formaction="{{ $.JudgingURL $.Competition }}/judges/remove" name="PersonID" value="{{ .PersonID }}" class="rounded-md px-2.5 py-1.5 text-xs font-semibold text-red-700 hover:bg-red-50">Remove</button>
              </div>
            </li>
            {{ end }}
          </ul>
          <div class="mb-6 flex justify-end">
            <button type="submit" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Save judge roles</button>
          </div>
          </form>
          {{ else }}
          <p class="mb-6 text-sm text-gray-600">No judges assigned yet.</p>
          {{ end }}

          {{ if .JudgeInviteLink }}
          <div class="mb-6 rounded-md border border-indigo-200 bg-indigo-50 px-4 py-3">
            <label for="JudgeInviteLink" class="block text-xs font-semibold uppercase tracking-wide text-indigo-700">Judge invite link created</label>
            <div class="mt-2 flex flex-col gap-2 sm:flex-row">
              <input id="JudgeInviteLink" type="url" readonly value="{{ .JudgeInviteLink }}"
                     class="block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-indigo-200">
              <button type="button" data-copy-target="JudgeInviteLink" class="inline-flex items-center justify-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Copy</button>
            </div>
            {{ if .JudgeInviteQRCodeURI }}
            <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:items-center">
              <img src="{{ .JudgeInviteQRCodeURI | safeURL }}" width="160" height="160" alt="Judge invite QR code"
                   class="h-40 w-40 rounded-md bg-white p-2 ring-1 ring-indigo-200">
              <p class="text-xs text-indigo-700">Scan this code to open the same one-time judge invite link.</p>
            </div>
            {{ end }}
            <p class="mt-2 text-xs text-indigo-700">This link can be used once and expires after 24 hours.</p>
          </div>
          {{ end }}

          <form method="POST" action="{{ .JudgingURL .Competition }}/judges/invites" class="mb-6 grid gap-4 rounded-md border border-gray-200 bg-gray-50 p-4">
            <div>
              <h3 class="text-sm font-semibold text-gray-900">Generate judge invite link</h3>
              <p class="mt-1 text-sm text-gray-600">The recipient signs in with this one-time link and can judge this hackathon.</p>
            </div>
			<div>
			  <label for="JudgeInviteEmail" class="block text-sm font-medium text-gray-700">Recipient email <span class="font-normal text-gray-500">(optional)</span></label>
			  <input id="JudgeInviteEmail" name="Email" type="email" autocomplete="email" placeholder="judge@example.com"
			         class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
			  <p class="mt-1 text-xs text-gray-500">When present, the invitation is emailed and can only be accepted by an account using this address.</p>
			</div>
			<fieldset>
			  <legend class="block text-sm font-medium text-gray-700">Judging rounds *</legend>
			  <div class="mt-2 flex flex-wrap gap-x-5 gap-y-2 text-sm text-gray-900">
				<label class="flex items-center gap-2"><input type="checkbox" name="InviteJudgeType" value="expo" checked> Expo judge</label>
				<label class="flex items-center gap-2"><input type="checkbox" name="InviteJudgeType" value="finals" checked> Finals judge</label>
			  </div>
			  <p class="mt-1 text-xs text-gray-500">This link grants judging access only. Add coordinators separately from the judge list.</p>
			</fieldset>
            <div class="flex justify-end">
              <button type="submit" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Generate judge invite</button>
            </div>
          </form>

          <form method="POST" action="{{ .JudgingURL .Competition }}/judges" class="grid gap-4">
            <div>
              <fieldset>
                <legend class="block text-sm font-medium text-gray-700">Judge roles *</legend>
                <div class="mt-2 flex flex-wrap gap-x-5 gap-y-2 text-sm text-gray-900">
                  <label class="flex items-center gap-2"><input type="checkbox" name="JudgeType" value="expo" checked> Expo judge</label>
                  <label class="flex items-center gap-2"><input type="checkbox" name="JudgeType" value="finals"> Finals judge</label>
                  <label class="flex items-center gap-2"><input type="checkbox" name="JudgeType" value="coordinator"> Coordinator</label>
                </div>
              </fieldset>
              <p class="mt-1 text-xs text-gray-500">Select every role that applies. A person can judge both Expo and Finals.</p>
            </div>
            <div>
              <label for="JudgePersonSearch" class="block text-sm font-medium text-gray-700">Judge person *</label>
              <div class="relative mt-1" data-person-picker data-person-picker-required="true" data-person-picker-name="PersonID">
                <input id="JudgePersonSearch" type="search" data-person-picker-input
                       placeholder="Search by name, email, or phone"
                       class="block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                <p class="mt-2 hidden text-xs text-indigo-700" data-person-picker-flash></p>
              </div>
            </div>
            <div class="flex justify-end">
              <button type="submit" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Add judge</button>
            </div>
          </form>
        </div>
      </section>
    </div>
  </div>
  <script>
    document.querySelectorAll('[data-copy-target]').forEach((button) => {
      button.addEventListener('click', async () => {
        const input = document.getElementById(button.dataset.copyTarget);
        if (!input) return;
        try {
          await navigator.clipboard.writeText(input.value);
          button.textContent = 'Copied';
        } catch (_) {
          input.focus();
          input.select();
          try {
            document.execCommand('copy');
            button.textContent = 'Copied';
          } catch (_) {
            button.textContent = 'Select';
          }
        }
      });
    });
  </script>
</body>
</html>
