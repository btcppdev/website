<!doctype html>
<html lang="en">
<head>
  <title>Admin - bitcoin++</title>
  {{ block "header" . }} {{ end }}
  {{ template "admin_favicon" "" }}
</head>
<body class="btcpp-admin-page bg-gray-50 text-gray-900">
  {{ block "mainnav" . }} {{ end }}
  <div class="mx-auto max-w-5xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="mb-6 flex items-center justify-between gap-4">
      <div>
        <a href="/dashboard" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">&larr; Back to dashboard</a>
        <h1 class="mt-2 text-2xl font-semibold tracking-tight">Global admin</h1>
        <p class="mt-1 text-sm text-gray-600">Site-wide tools for newsletters, organizations, and permissions.</p>
      </div>
      <span class="inline-flex items-center rounded-full bg-amber-100 px-2 py-0.5 text-xs font-medium text-amber-800">global-admin</span>
    </div>

    {{ if .FlashMessage }}
    <div class="mb-4 rounded-md border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-800">{{ .FlashMessage }}</div>
    {{ end }}

    <section class="rounded-lg bg-white shadow">
      <div class="px-4 py-5 sm:p-6">
        <h2 class="text-sm font-semibold text-gray-900">Admin tools</h2>
        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          <a href="/admin/missives" class="block rounded-md border border-gray-200 px-4 py-3 hover:border-indigo-300 hover:bg-indigo-50">
            <div class="text-sm font-medium text-gray-900">Templated newsletters</div>
            <div class="mt-1 text-xs text-gray-500">Create and edit rebrand missives, upload hero images, and list all templated sends.</div>
          </a>
          <a href="/admin/orgs" class="block rounded-md border border-gray-200 px-4 py-3 hover:border-indigo-300 hover:bg-indigo-50">
            <div class="text-sm font-medium text-gray-900">Organizations</div>
            <div class="mt-1 text-xs text-gray-500">Manage sponsor and organization records.</div>
          </a>
        </div>
      </div>
    </section>

    <section id="homepage-speakers" class="mt-8 rounded-lg bg-white shadow">
      <div class="px-4 py-5 sm:p-6">
        <div class="flex items-center justify-between gap-4">
          <div>
            <h2 class="text-sm font-semibold text-gray-900">Homepage featured speakers</h2>
            <p class="mt-1 text-xs text-gray-500">Choose up to eight people for the expert speakers roll on the homepage.</p>
          </div>
        </div>

        <form method="POST" action="/admin/homepage-speakers" class="mt-4 space-y-4">
          <div class="grid gap-3 sm:grid-cols-2">
            {{ range $i, $speaker := .FeaturedSpeakerSlots }}
            {{ $slot := add $i 1 }}
            <div class="relative homepage-speaker-picker">
              <label for="HomepageSpeaker{{ $slot }}" class="block text-xs font-medium text-gray-700">Slot {{ $slot }}</label>
              <div class="mt-1 flex gap-2">
                <input type="text" id="HomepageSpeaker{{ $slot }}" autocomplete="off"
                       value="{{ if $speaker }}{{ $speaker.Name }}{{ if $speaker.Email }} · {{ $speaker.Email }}{{ end }}{{ end }}"
                       placeholder="Start typing a name or email..."
                       data-homepage-speaker-search
                       class="block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                <button type="button" data-homepage-speaker-clear class="rounded-md border border-gray-300 bg-white px-2.5 py-1.5 text-xs font-semibold text-gray-700 hover:bg-gray-50">Clear</button>
              </div>
              <input type="hidden" name="speaker_{{ $slot }}_id" value="{{ if $speaker }}{{ $speaker.ID }}{{ end }}" data-homepage-speaker-id>
            </div>
            {{ end }}
          </div>
          <div class="flex justify-end">
            <button type="submit" class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-indigo-700">
              Save homepage speakers
            </button>
          </div>
        </form>
      </div>
    </section>

    <section id="role-manager" class="mt-8 rounded-lg bg-white shadow">
      <div class="px-4 py-5 sm:p-6">
        <div class="flex items-center justify-between gap-4">
          <div>
            <h2 class="text-sm font-semibold text-gray-900">Role manager</h2>
            <p class="mt-1 text-xs text-gray-500">Add or remove admin / volcoord roles for any speaker. Tag format: <code class="rounded bg-gray-100 px-1">{conftag}-admin</code> or <code class="rounded bg-gray-100 px-1">global-volcoord</code>. Comma-separated.</p>
          </div>
        </div>

        <form method="POST" action="/admin/roles" class="mt-4 space-y-3">
          <div class="relative">
            <label for="RoleManagerEmail" class="block text-xs font-medium text-gray-700">Speaker (lookup by name or email)</label>
            <input type="text" id="RoleManagerEmail" autocomplete="off"
                   placeholder="Start typing a name or email..."
                   class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
            <input type="hidden" id="RoleManagerSpeakerID" name="speakerID" value="">
          </div>

          <div id="role-manager-current" class="hidden text-xs text-gray-600">
            Current roles for <span id="role-manager-name" class="font-semibold"></span>:
            <span id="role-manager-existing" class="ml-1 inline-flex flex-wrap gap-1"></span>
          </div>

          <div>
            <label for="RoleManagerRoles" class="block text-xs font-medium text-gray-700">Roles (comma-separated, leave empty to clear)</label>
            <input type="text" id="RoleManagerRoles" name="roles"
                   placeholder="e.g. vienna-admin, global-volcoord"
                   class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
          </div>

          <div class="flex items-center justify-end gap-2">
            <button type="submit"
                    class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-indigo-700 disabled:opacity-50"
                    id="RoleManagerSave"
                    disabled>
              Save roles
            </button>
          </div>
        </form>
      </div>
    </section>
  </div>

  <script>
    (function () {
      const emailInput = document.getElementById('RoleManagerEmail');
      const hiddenID   = document.getElementById('RoleManagerSpeakerID');
      const rolesInput = document.getElementById('RoleManagerRoles');
      const saveBtn    = document.getElementById('RoleManagerSave');
      const curBlock   = document.getElementById('role-manager-current');
      const curName    = document.getElementById('role-manager-name');
      const curRoles   = document.getElementById('role-manager-existing');
      if (!emailInput || !hiddenID || !rolesInput) return;

      const wrap = emailInput.parentElement;
      wrap.style.position = 'relative';
      const list = document.createElement('ul');
      list.className = 'absolute z-10 left-0 right-0 mt-1 max-h-60 overflow-auto rounded-md border border-gray-200 bg-white shadow hidden';
      list.setAttribute('role', 'listbox');
      wrap.appendChild(list);

      let debounceTimer = null;
      let activeFetch = 0;

      function renderHits(hits) {
        list.replaceChildren();
        if (!hits || hits.length === 0) { list.classList.add('hidden'); return; }
        for (const hit of hits) {
          const li = document.createElement('li');
          li.className = 'px-3 py-2 text-sm hover:bg-indigo-50 cursor-pointer';
          li.textContent = (hit.name || hit.email);
          const sub = document.createElement('div');
          sub.className = 'text-xs text-gray-500';
          sub.textContent = hit.email;
          li.appendChild(sub);
          li.addEventListener('mousedown', function (ev) {
            ev.preventDefault();
            emailInput.value = hit.email;
            hiddenID.value = hit.id;
            saveBtn.disabled = false;
            list.classList.add('hidden');
            fetchExistingRoles(hit.id, hit.name || hit.email);
          });
          list.appendChild(li);
        }
        list.classList.remove('hidden');
      }

      function fetchExistingRoles(speakerID, displayName) {
        fetch('/api/speakers/' + encodeURIComponent(speakerID) + '/roles', { credentials: 'same-origin' })
          .then(function (r) { return r.ok ? r.json() : { roles: [] }; })
          .then(function (data) {
            const roles = data.roles || [];
            rolesInput.value = roles.join(', ');
            curName.textContent = displayName;
            curRoles.replaceChildren();
            if (roles.length === 0) {
              const span = document.createElement('span');
              span.className = 'italic text-gray-400';
              span.textContent = '(none)';
              curRoles.appendChild(span);
            } else {
              for (const r of roles) {
                const tag = document.createElement('span');
                tag.className = 'inline-flex items-center rounded bg-gray-100 px-1.5 py-0.5 font-mono text-[11px]';
                tag.textContent = r;
                curRoles.appendChild(tag);
              }
            }
            curBlock.classList.remove('hidden');
          })
          .catch(function () { curBlock.classList.add('hidden'); });
      }

      emailInput.addEventListener('input', function () {
        hiddenID.value = '';
        saveBtn.disabled = true;
        curBlock.classList.add('hidden');
        const q = emailInput.value.trim();
        if (debounceTimer) clearTimeout(debounceTimer);
        if (q.length < 2) { list.classList.add('hidden'); return; }
        debounceTimer = setTimeout(function () {
          const id = ++activeFetch;
          fetch('/api/speakers/search?q=' + encodeURIComponent(q), { credentials: 'same-origin' })
            .then(function (r) { return r.ok ? r.json() : []; })
            .then(function (hits) { if (id !== activeFetch) return; renderHits(hits); })
            .catch(function () {});
        }, 200);
      });
      emailInput.addEventListener('blur', function () { setTimeout(function () { list.classList.add('hidden'); }, 150); });
    })();

    (function () {
      const pickers = document.querySelectorAll('.homepage-speaker-picker');
      if (!pickers.length) return;

      function displayName(hit) {
        return (hit.name || hit.email || '') + (hit.email ? ' · ' + hit.email : '');
      }

      pickers.forEach(function (picker) {
        const input = picker.querySelector('[data-homepage-speaker-search]');
        const hidden = picker.querySelector('[data-homepage-speaker-id]');
        const clear = picker.querySelector('[data-homepage-speaker-clear]');
        if (!input || !hidden) return;

        const list = document.createElement('ul');
        list.className = 'absolute z-10 left-0 right-0 mt-1 max-h-60 overflow-auto rounded-md border border-gray-200 bg-white shadow hidden';
        list.setAttribute('role', 'listbox');
        picker.appendChild(list);

        let debounceTimer = null;
        let activeFetch = 0;

        function renderHits(hits) {
          list.replaceChildren();
          if (!hits || hits.length === 0) { list.classList.add('hidden'); return; }
          for (const hit of hits) {
            const li = document.createElement('li');
            li.className = 'px-3 py-2 text-sm hover:bg-indigo-50 cursor-pointer';
            li.textContent = hit.name || hit.email;
            const sub = document.createElement('div');
            sub.className = 'text-xs text-gray-500';
            sub.textContent = hit.email || '';
            li.appendChild(sub);
            li.addEventListener('mousedown', function (ev) {
              ev.preventDefault();
              input.value = displayName(hit);
              hidden.value = hit.id;
              list.classList.add('hidden');
            });
            list.appendChild(li);
          }
          list.classList.remove('hidden');
        }

        input.addEventListener('input', function () {
          hidden.value = '';
          const q = input.value.trim();
          if (debounceTimer) clearTimeout(debounceTimer);
          if (q.length < 2) { list.classList.add('hidden'); return; }
          debounceTimer = setTimeout(function () {
            const id = ++activeFetch;
            fetch('/api/speakers/search?q=' + encodeURIComponent(q), { credentials: 'same-origin' })
              .then(function (r) { return r.ok ? r.json() : []; })
              .then(function (hits) { if (id !== activeFetch) return; renderHits(hits); })
              .catch(function () { list.classList.add('hidden'); });
          }, 200);
        });
        input.addEventListener('blur', function () { setTimeout(function () { list.classList.add('hidden'); }, 150); });
        clear.addEventListener('click', function () {
          input.value = '';
          hidden.value = '';
          list.classList.add('hidden');
          input.focus();
        });
      });
    })();
  </script>
</body>
</html>
