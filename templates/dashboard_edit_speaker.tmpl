<!DOCTYPE html>
<html>
<head>
  <title>{{ if eq .Mode "edit" }}Edit{{ else }}Create{{ end }} speaker profile · bitcoin++</title>
  {{ block "header" . }} {{ end }}
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>&#128100;</text></svg>">
</head>
<body class="bg-gray-50">
  {{ block "mainnav" . }} {{ end }}
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-6">
      {{ if .BackURL }}
      <a href="{{ .BackURL }}" class="text-sm text-indigo-600 hover:text-indigo-700">&larr; Back to speakers</a>
      {{ else }}
      <a href="/dashboard?hr={{ .HMAC }}&em={{ .Email }}" class="text-sm text-indigo-600 hover:text-indigo-700">&larr; Back to dashboard</a>
      {{ end }}
    </div>

    <h1 class="text-2xl font-bold text-gray-900">
      {{ if eq .Mode "edit" }}{{ if .IsAdmin }}Edit speaker profile{{ else }}Your speaker profile{{ end }}{{ else }}{{ if .IsAdmin }}Create speaker profile{{ else }}Create your speaker profile{{ end }}{{ end }}
    </h1>
    <p class="text-sm text-gray-500 mt-1">
      {{ if eq .Mode "edit" }}This is the row in the bitcoin++ speakers directory. Updates apply across every talk this speaker has given or is giving.{{ else }}Create a row in the bitcoin++ speakers directory. Attach the speaker to an event proposal from the proposal editor after saving.{{ end }}
    </p>

    {{ if .FlashMessage }}
    <div class="mt-4 rounded-md bg-yellow-50 border border-yellow-200 px-4 py-3">
      <p class="text-sm text-yellow-900">{{ .FlashMessage }}</p>
    </div>
    {{ end }}

    <form method="POST" action="{{ if .FormAction }}{{ .FormAction }}{{ else }}/dashboard/speaker?hr={{ .HMAC }}&em={{ .Email }}{{ end }}"
          enctype="multipart/form-data"
          class="mt-8 space-y-6 bg-white shadow rounded-lg p-6">

      <div>
        <label for="PicFile" class="block text-sm font-semibold text-gray-900">Photo {{ if and (eq .Mode "create") (not .IsAdmin) }}*{{ end }}</label>
        <p class="text-xs text-gray-500">You'll get a 1:1 cropper after picking the file. {{ if eq .Mode "edit" }}Leave empty to keep your current photo.{{ else }}Square crops work best.{{ end }}</p>
        <div class="mt-2 flex items-start gap-4">
          {{ if and .Speaker .Speaker.Photo }}
          <img src="{{ speakerPhoto .Speaker.Photo }}" alt="{{ .Speaker.Name }}"
               class="size-20 rounded-full object-cover bg-gray-50 ring-1 ring-gray-200 shrink-0" />
          {{ else }}
          <div class="size-20 rounded-full bg-gray-100 flex items-center justify-center shrink-0">
            <span class="text-3xl">&#128100;</span>
          </div>
          {{ end }}
          <div class="min-w-0 flex-1">
            <input name="PicFile" id="PicFile" type="file" accept="image/*"
                   {{ if and (eq .Mode "create") (not .IsAdmin) }}required{{ end }}
                   class="block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 file:mr-3 file:py-1 file:px-3 file:rounded-md file:border-0 file:text-xs file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" />
            <div id="PicError" class="mt-2 hidden rounded-md border border-red-200 bg-red-50 p-3 text-sm text-red-700" role="alert" aria-live="polite"></div>
            <div id="PicPreview" class="mt-2 hidden">
              <div class="flex items-start gap-3">
                <img id="PicPreviewImg" alt="cropped preview" class="size-20 flex-none rounded-full object-cover ring-1 ring-gray-300" />
                <div class="flex flex-col gap-2">
                  <div class="text-xs text-gray-500">Cropped preview. Pick a different file or re-crop to adjust.</div>
                  <div class="flex flex-wrap gap-2">
                    <button type="button" id="PicRecrop" class="self-start rounded-md border border-gray-300 bg-white px-3 py-1.5 text-xs font-semibold text-gray-700 hover:bg-gray-50">Re-crop</button>
                    <button type="button" id="PicClear" class="self-start rounded-md border border-red-200 bg-red-50 px-3 py-1.5 text-xs font-semibold text-red-700 hover:bg-red-100">Clear</button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      {{ if eq .Mode "create" }}
      <div>
        <label for="Name" class="block text-sm font-semibold text-gray-900">Name *</label>
        <input id="Name" name="Name" type="text" required
               class="mt-1 block w-full rounded-md py-2 px-3 outline outline-1 -outline-offset-1 outline-gray-300" />
      </div>
      <div>
        <label class="block text-sm font-semibold text-gray-900">Email</label>
        {{ if .IsAdmin }}
        <input id="Email" name="Email" type="email" required
               class="mt-1 block w-full rounded-md py-2 px-3 outline outline-1 -outline-offset-1 outline-gray-300" />
        {{ else }}
        <p class="mt-1 text-sm text-gray-700">{{ .EmailPlain }}</p>
        <p class="mt-1 text-xs text-gray-500">Locked to your magic-link email — sign in with a different address to use that one instead.</p>
        {{ end }}
      </div>
      {{ else }}
      <div class="grid grid-cols-1 gap-y-1 sm:grid-cols-2 sm:gap-x-6">
        <div>
          <label class="block text-sm font-semibold text-gray-900">Name</label>
          {{ if .IsAdmin }}
          <input id="Name" name="Name" type="text" required value="{{ .Speaker.Name }}"
                 class="mt-1 block w-full rounded-md py-2 px-3 outline outline-1 -outline-offset-1 outline-gray-300" />
          {{ else }}
          <p class="mt-1 text-sm text-gray-700">{{ .Speaker.Name }}</p>
          {{ end }}
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-900">Email</label>
          {{ if .IsAdmin }}
          <input id="Email" name="Email" type="email" required value="{{ .Speaker.Email }}"
                 class="mt-1 block w-full rounded-md py-2 px-3 outline outline-1 -outline-offset-1 outline-gray-300" />
          {{ else }}
          <p class="mt-1 text-sm text-gray-700">{{ .Speaker.Email }}</p>
          {{ end }}
        </div>
      </div>
      {{ if .IsAdmin }}
      <p class="text-xs text-gray-500">Name and email changes update the speaker directory row across every event.</p>
      {{ else }}
      <p class="text-xs text-gray-500">Email and name aren't editable here — contact <a href="mailto:speak@btcpp.dev" class="underline">speak@btcpp.dev</a> if either needs to change.</p>
      {{ end }}
      {{ end }}

      <hr class="border-gray-200" />

      <div class="grid grid-cols-1 gap-x-6 gap-y-4 sm:grid-cols-2">
        <div>
          <label for="Phone" class="block text-sm font-semibold text-gray-900">Phone</label>
          <input id="Phone" name="Phone" type="tel" value="{{ if .Speaker }}{{ .Speaker.Phone }}{{ end }}" class="mt-1 block w-full rounded-md py-2 px-3 outline outline-1 -outline-offset-1 outline-gray-300" />
        </div>
        <div>
          <label for="Signal" class="block text-sm font-semibold text-gray-900">Signal {{ if not .IsAdmin }}*{{ end }}</label>
          <input id="Signal" name="Signal" type="text" {{ if not .IsAdmin }}required{{ end }} value="{{ if .Speaker }}{{ .Speaker.Signal }}{{ end }}" class="mt-1 block w-full rounded-md py-2 px-3 outline outline-1 -outline-offset-1 outline-gray-300" />
        </div>
        <div>
          <label for="Telegram" class="block text-sm font-semibold text-gray-900">Telegram</label>
          <input id="Telegram" name="Telegram" type="text" value="{{ if .Speaker }}{{ .Speaker.Telegram }}{{ end }}" class="mt-1 block w-full rounded-md py-2 px-3 outline outline-1 -outline-offset-1 outline-gray-300" />
        </div>
        <div>
          <label for="Twitter" class="block text-sm font-semibold text-gray-900">Twitter / X handle</label>
          <input id="Twitter" name="Twitter" type="text" value="{{ if .Speaker }}{{ .Speaker.Twitter.Handle }}{{ end }}" placeholder="without @" class="mt-1 block w-full rounded-md py-2 px-3 outline outline-1 -outline-offset-1 outline-gray-300" />
        </div>
        <div>
          <label for="Nostr" class="block text-sm font-semibold text-gray-900">Nostr (npub)</label>
          <input id="Nostr" name="Nostr" type="text" value="{{ if .Speaker }}{{ .Speaker.Nostr }}{{ end }}" class="mt-1 block w-full rounded-md py-2 px-3 outline outline-1 -outline-offset-1 outline-gray-300" />
        </div>
        <div>
          <label for="Github" class="block text-sm font-semibold text-gray-900">Github URL</label>
          <input id="Github" name="Github" type="url" value="{{ if .Speaker }}{{ trim .Speaker.Github }}{{ end }}" class="mt-1 block w-full rounded-md py-2 px-3 outline outline-1 -outline-offset-1 outline-gray-300" />
        </div>
        <div>
          <label for="Website" class="block text-sm font-semibold text-gray-900">Website</label>
          <input id="Website" name="Website" type="url" value="{{ if .Speaker }}{{ trim .Speaker.Website }}{{ end }}" class="mt-1 block w-full rounded-md py-2 px-3 outline outline-1 -outline-offset-1 outline-gray-300" />
        </div>
        <div>
          <label for="Instagram" class="block text-sm font-semibold text-gray-900">Instagram</label>
          <input id="Instagram" name="Instagram" type="text" value="{{ if .Speaker }}{{ .Speaker.Instagram }}{{ end }}" class="mt-1 block w-full rounded-md py-2 px-3 outline outline-1 -outline-offset-1 outline-gray-300" />
        </div>
        <div>
          <label for="LinkedIn" class="block text-sm font-semibold text-gray-900">LinkedIn</label>
          <input id="LinkedIn" name="LinkedIn" type="text" value="{{ if .Speaker }}{{ .Speaker.LinkedIn }}{{ end }}" placeholder="linkedin.com/in/..." class="mt-1 block w-full rounded-md py-2 px-3 outline outline-1 -outline-offset-1 outline-gray-300" />
        </div>
        <div class="sm:col-span-2">
          <label for="TShirt" class="block text-sm font-semibold text-gray-900">T-shirt size</label>
          <select id="TShirt" name="TShirt" class="mt-1 block w-full rounded-md py-2 px-3 outline outline-1 -outline-offset-1 outline-gray-300">
            {{ $cur := "" }}{{ if .Speaker }}{{ $cur = .Speaker.TShirt }}{{ end }}
            <option value="" {{ if eq $cur "" }}selected{{ end }}>—</option>
            <option value="LS" {{ if eq $cur "LS" }}selected{{ end }}>Ladies Small</option>
            <option value="LM" {{ if eq $cur "LM" }}selected{{ end }}>Ladies Medium</option>
            <option value="LL" {{ if eq $cur "LL" }}selected{{ end }}>Ladies Large</option>
            <option value="MS" {{ if eq $cur "MS" }}selected{{ end }}>Men's Small</option>
            <option value="MM" {{ if eq $cur "MM" }}selected{{ end }}>Men's Medium</option>
            <option value="ML" {{ if eq $cur "ML" }}selected{{ end }}>Men's Large</option>
            <option value="MXL" {{ if eq $cur "MXL" }}selected{{ end }}>Men's XL</option>
            <option value="MXXL" {{ if eq $cur "MXXL" }}selected{{ end }}>Men's XXL</option>
            <option value="MXXXL" {{ if eq $cur "MXXXL" }}selected{{ end }}>Men's XXXL</option>
          </select>
        </div>
      </div>

      <div class="flex justify-end gap-3">
        <a href="{{ if .BackURL }}{{ .BackURL }}{{ else }}/dashboard?hr={{ .HMAC }}&em={{ .Email }}{{ end }}" class="inline-flex items-center px-4 py-2 text-sm font-semibold text-gray-700 hover:text-gray-900">Cancel</a>
        <button type="submit"
                class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-semibold rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700">
          {{ if eq .Mode "edit" }}Save{{ else }}Create profile{{ end }}
        </button>
      </div>
    </form>
  </div>
  {{ block "footer" . }} {{ end }}
  {{ template "pic_cropper" . }}
</body>
</html>
