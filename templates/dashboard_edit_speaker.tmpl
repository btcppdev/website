<!DOCTYPE html>
<html>
<head>
  <title>{{ if eq .Mode "edit" }}Edit{{ else }}Create{{ end }} speaker profile · bitcoin++</title>
  {{ block "header" . }} {{ end }}
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>&#128100;</text></svg>">
</head>
<body class="btcpp-profile-edit-page">
  {{ block "mainnav" . }} {{ end }}

  <div class="profile-edit-toolbar">
    <div>
      <span class="profile-edit-toolbar__live">● EDITING</span>
      <span>{{ if .Speaker }}{{ .Speaker.Name }}{{ else }}new profile{{ end }}</span>
      <span>{{ if eq .Mode "edit" }}identity section editable{{ else }}create identity row{{ end }}</span>
    </div>
    <div>
      {{ if .PublicURL }}<a href="{{ .PublicURL }}">VIEW PUBLIC →</a>{{ end }}
      <button type="submit" form="SpeakerProfileForm">{{ if eq .Mode "edit" }}SAVE CHANGES{{ else }}CREATE PROFILE{{ end }}</button>
    </div>
  </div>

  <main class="profile-edit-shell">
    <div class="profile-edit-back">
      {{ if .BackURL }}
      <a href="{{ .BackURL }}">← Back to speakers</a>
      {{ else }}
      <a href="/dashboard?hr={{ .HMAC }}&em={{ .Email }}">← Back to dashboard</a>
      {{ end }}
    </div>

    <header class="profile-edit-hero">
      <p class="profile-edit-tag">§ YOUR PROFILE</p>
      <h1>Arrange <span>your</span> record.</h1>
      <p>{{ if eq .Mode "edit" }}Edit the identity, links, and contact details that power your bitcoin++ public profile and event records.{{ else }}Create your bitcoin++ identity row. Public profile pages appear once you have an accepted or scheduled talk.{{ end }}</p>
    </header>

    {{ if .FlashMessage }}
    <div class="profile-edit-flash">{{ .FlashMessage }}</div>
    {{ end }}

    <div class="profile-edit-legend" aria-label="Profile visibility legend">
      <span><i class="is-public"></i><b>PUBLIC</b><em>Shown on /whois when eligible</em></span>
      <span><i class="is-members"></i><b>MEMBERS</b><em>Signed-in community later</em></span>
      <span><i class="is-hidden"></i><b>HIDDEN</b><em>Only you</em></span>
    </div>

    <form id="SpeakerProfileForm" method="POST" action="{{ if .FormAction }}{{ .FormAction }}{{ else }}/dashboard/speaker?hr={{ .HMAC }}&em={{ .Email }}{{ end }}" enctype="multipart/form-data" class="profile-edit-form">
      <section class="profile-edit-section is-open">
        <div class="profile-edit-section__index">✎</div>
        <div class="profile-edit-section__body">
          <div class="profile-edit-section__head">
            <div>
              <p>§ IDENTITY</p>
              <h2>Bio & links</h2>
              <span>{{ if .Speaker }}{{ if .Speaker.Bio }}bio {{ len .Speaker.Bio }} chars{{ else }}bio empty{{ end }} · links editable{{ else }}new identity row{{ end }}</span>
            </div>
            <div class="profile-edit-section__status">
              <span class="profile-privacy-pill"><i class="is-public"></i>PUBLIC</span>
              <strong>EDITING</strong>
            </div>
          </div>

          <div class="profile-edit-fields">
            <div class="profile-edit-photo">
              <label for="PicFile">PHOTO {{ if and (eq .Mode "create") (not .IsAdmin) }}*{{ end }}</label>
              <div>
                {{ if and .Speaker .Speaker.Photo }}
                <img src="{{ speakerPhoto .Speaker.Photo }}" alt="{{ .Speaker.Name }}">
                {{ else }}
                <span>{{ if .Speaker }}{{ printf "%.1s" .Speaker.Name }}{{ else }}+{{ end }}</span>
                {{ end }}
                <div>
                  <input name="PicFile" id="PicFile" type="file" accept="image/*" {{ if and (eq .Mode "create") (not .IsAdmin) }}required{{ end }}>
                  <small>Square crops work best. Leave empty to keep the current photo.</small>
                  <div id="PicError" class="profile-edit-error hidden" role="alert" aria-live="polite"></div>
                  <div id="PicPreview" class="profile-edit-preview hidden">
                    <img id="PicPreviewImg" alt="cropped preview">
                    <button type="button" id="PicRecrop">Re-crop</button>
                    <button type="button" id="PicClear">Clear</button>
                  </div>
                </div>
              </div>
            </div>

            {{ if eq .Mode "create" }}
            <label>DISPLAY NAME *
              <input id="Name" name="Name" type="text" required>
            </label>
            <label>EMAIL {{ if .IsAdmin }}*{{ end }}
              {{ if .IsAdmin }}
              <input id="Email" name="Email" type="email" required>
              {{ else }}
              <span class="profile-edit-locked">{{ .EmailPlain }}</span>
              {{ end }}
            </label>
            {{ else }}
            <label>DISPLAY NAME
              {{ if .IsAdmin }}
              <input id="Name" name="Name" type="text" required value="{{ .Speaker.Name }}">
              {{ else }}
              <span class="profile-edit-locked">{{ .Speaker.Name }}</span>
              {{ end }}
            </label>
            <label>EMAIL
              {{ if .IsAdmin }}
              <input id="Email" name="Email" type="email" required value="{{ .Speaker.Email }}">
              {{ else }}
              <span class="profile-edit-locked">{{ .Speaker.Email }}</span>
              {{ end }}
            </label>
            {{ end }}

            <label class="profile-edit-wide">BIO
              <textarea id="Bio" name="Bio" rows="5" maxlength="1200" placeholder="Who are you, what are you working on, and what should people ask you about?">{{ if .Speaker }}{{ .Speaker.Bio }}{{ end }}</textarea>
              <small>Public on your profile. The mockup suggests 280 chars; the site currently allows up to 1200.</small>
            </label>

            <label>WEBSITE
              <input id="Website" name="Website" type="url" value="{{ if .Speaker }}{{ trim .Speaker.Website }}{{ end }}">
            </label>
            <label>GITHUB URL
              <input id="Github" name="Github" type="url" value="{{ if .Speaker }}{{ trim .Speaker.Github }}{{ end }}">
            </label>
            <label>TWITTER / X HANDLE
              <input id="Twitter" name="Twitter" type="text" value="{{ if .Speaker }}{{ .Speaker.Twitter.Handle }}{{ end }}" placeholder="without @">
            </label>
            <label>NOSTR NPUB
              <input id="Nostr" name="Nostr" type="text" value="{{ if .Speaker }}{{ .Speaker.Nostr }}{{ end }}">
            </label>
            <label>INSTAGRAM
              <input id="Instagram" name="Instagram" type="text" value="{{ if .Speaker }}{{ .Speaker.Instagram }}{{ end }}">
            </label>
            <label>LINKEDIN
              <input id="LinkedIn" name="LinkedIn" type="text" value="{{ if .Speaker }}{{ .Speaker.LinkedIn }}{{ end }}" placeholder="linkedin.com/in/...">
            </label>
            <label>LEETCODE
              <input id="LeetCode" name="LeetCode" type="text" value="{{ if .Speaker }}{{ .Speaker.LeetCode }}{{ end }}" placeholder="leetcode.com/u/...">
            </label>
          </div>
        </div>
      </section>

      <section class="profile-edit-section is-open">
        <div class="profile-edit-section__index">☎</div>
        <div class="profile-edit-section__body">
          <div class="profile-edit-section__head">
            <div>
              <p>§ CONTACT</p>
              <h2>Event logistics</h2>
              <span>Used by organizers for speaker and volunteer coordination.</span>
            </div>
            <div class="profile-edit-section__status">
              <span class="profile-privacy-pill is-muted"><i class="is-hidden"></i>PRIVATE</span>
              <strong>EDITING</strong>
            </div>
          </div>
          <div class="profile-edit-fields">
            <label>PHONE {{ if not .IsAdmin }}*{{ end }}
              <input id="Phone" name="Phone" type="tel" {{ if not .IsAdmin }}required{{ end }} value="{{ if .Speaker }}{{ .Speaker.Phone }}{{ end }}">
            </label>
            <label>SIGNAL {{ if not .IsAdmin }}*{{ end }}
              <input id="Signal" name="Signal" type="text" {{ if not .IsAdmin }}required{{ end }} value="{{ if .Speaker }}{{ .Speaker.Signal }}{{ end }}">
            </label>
            <label>TELEGRAM
              <input id="Telegram" name="Telegram" type="text" value="{{ if .Speaker }}{{ .Speaker.Telegram }}{{ end }}">
            </label>
            <label>T-SHIRT SIZE
              <select id="TShirt" name="TShirt">
                {{ $cur := "" }}{{ if .Speaker }}{{ $cur = .Speaker.TShirt }}{{ end }}
                <option value="" {{ if eq $cur "" }}selected{{ end }}>—</option>
                <option value="LS" {{ if eq $cur "LS" }}selected{{ end }}>Ladies Small</option>
                <option value="LM" {{ if eq $cur "LM" }}selected{{ end }}>Ladies Medium</option>
                <option value="LL" {{ if eq $cur "LL" }}selected{{ end }}>Ladies Large</option>
                <option value="MS" {{ if eq $cur "MS" }}selected{{ end }}>Men's Small</option>
                <option value="MM" {{ if eq $cur "MM" }}selected{{ end }}>Men's Medium</option>
                <option value="ML" {{ if eq $cur "ML" }}selected{{ end }}>Men's Large</option>
                <option value="MXL" {{ if eq $cur "MXL" }}selected{{ end }}>Men's XL</option>
                <option value="MXXL" {{ if eq $cur "MXXL" }}selected{{ end }}>Men's XXL</option>
                <option value="MXXXL" {{ if eq $cur "MXXXL" }}selected{{ end }}>Men's XXXL</option>
              </select>
            </label>
          </div>
        </div>
      </section>

      {{ if and .Speaker (not .IsAdmin) }}
      <section class="profile-edit-section is-open">
        <div class="profile-edit-section__index">₿</div>
        <div class="profile-edit-section__body">
          <div class="profile-edit-section__head">
            <div>
              <p>§ PAYOUT DETAILS</p>
              <h2>Awards & payments</h2>
              <span>Private. Used only by authorized bitcoin++ organizers to distribute prizes and reimbursements.</span>
            </div>
            <div class="profile-edit-section__status">
              <span class="profile-privacy-pill is-muted"><i class="is-hidden"></i>PRIVATE</span>
              {{ if .Speaker.TaxFormUploadedAt }}<strong>✓ TAX FORM ON FILE</strong>{{ else }}<strong>INCOMPLETE</strong>{{ end }}
            </div>
          </div>
          <div class="profile-edit-fields">
            <label>LIGHTNING ADDRESS
              <input id="LightningAddress" name="LightningAddress" type="text" value="{{ .Speaker.LightningAddress }}" placeholder="you@example.com">
              <small>For Lightning prize payments. This is never shown on your public profile.</small>
            </label>
            <label>ON-CHAIN BITCOIN ADDRESS
              <input id="BitcoinAddress" name="BitcoinAddress" type="text" value="{{ .Speaker.BitcoinAddress }}" placeholder="bc1…">
              <small>Optional fallback for on-chain payments.</small>
            </label>
            <label>TAX FORM TYPE
              <select id="TaxFormType" name="TaxFormType">
                <option value="w9" {{ if eq .Speaker.TaxFormType "w9" }}selected{{ end }}>W-9 (US person)</option>
                <option value="w8ben" {{ if eq .Speaker.TaxFormType "w8ben" }}selected{{ end }}>W-8BEN (non-US person)</option>
              </select>
              <small>Choose W-9 if you are a U.S. person. Non-U.S. individuals should use W-8BEN.</small>
            </label>
            <div class="profile-edit-tax-forms">
              <span>DOWNLOAD A BLANK IRS FORM</span>
              <div>
                <a href="https://www.irs.gov/pub/irs-pdf/fw9.pdf" target="_blank" rel="noopener noreferrer">W-9 PDF ↗</a>
                <a href="https://www.irs.gov/pub/irs-pdf/fw8ben.pdf" target="_blank" rel="noopener noreferrer">W-8BEN PDF ↗</a>
              </div>
              <small>Fill out and sign the appropriate form, then upload the completed document here.</small>
            </div>
            <label>TAX FORM DOCUMENT
              <input id="TaxFormFile" name="TaxFormFile" type="file" accept="application/pdf,image/png,image/jpeg">
              {{ if .Speaker.TaxFormUploadedAt }}
              <small>On file: {{ .Speaker.TaxFormOriginalName }} · uploaded {{ .Speaker.TaxFormUploadedAt.Format "Jan 2, 2006" }}. Upload another file to replace it.</small>
              {{ else }}
              <small>PDF, PNG, or JPEG up to 10 MB. Encrypted before private storage.</small>
              {{ end }}
            </label>
          </div>
        </div>
      </section>
      {{ end }}

      <section class="profile-edit-section is-verified">
        <div class="profile-edit-section__index">▶</div>
        <div class="profile-edit-section__body">
          <div class="profile-edit-section__head">
            <div>
              <p>§ FROM YOUR RECORD</p>
              <h2>Talks & panels</h2>
              <span>Accepted and scheduled bitcoin++ talks are pulled automatically.</span>
            </div>
            <div class="profile-edit-section__status">
              <span class="profile-privacy-pill"><i class="is-public"></i>PUBLIC</span>
              <strong>✓ FROM YOUR RECORD</strong>
            </div>
          </div>
        </div>
      </section>
    </form>

    <section class="profile-edit-add">
      <p class="profile-edit-tag">§ ADD TO YOUR PROFILE</p>
      <div>
        <button type="button" disabled><span>◆</span><b>Event badges</b><em>Not configurable yet</em></button>
        <button type="button" disabled><span>⬡</span><b>Hackathon projects</b><em>Hackathon backend later</em></button>
        <button type="button" disabled><span>★</span><b>Awards</b><em>No awards model yet</em></button>
        <button type="button" disabled><span>✍</span><b>Technical writing</b><em>No linked writing sources yet</em></button>
        <button type="button" disabled><span>✓</span><b>Credentials</b><em>No credentials model yet</em></button>
      </div>
    </section>

    <div class="profile-edit-actions">
      <a href="{{ if .BackURL }}{{ .BackURL }}{{ else }}/dashboard?hr={{ .HMAC }}&em={{ .Email }}{{ end }}">CANCEL</a>
      <button type="submit" form="SpeakerProfileForm">{{ if eq .Mode "edit" }}SAVE CHANGES{{ else }}CREATE PROFILE{{ end }}</button>
    </div>
  </main>

  {{ block "footer" . }} {{ end }}
  {{ template "pic_cropper" . }}
</body>
</html>
