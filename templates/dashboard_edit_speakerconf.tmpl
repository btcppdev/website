<!DOCTYPE html>
<html>
<head>
  <title>edit speaker info - bitcoin++</title>
  {{ block "header" . }} {{ end }}
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>&#10024;</text></svg>">
</head>
<body>
  {{ block "mainnav" . }} {{ end }}
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-6">
      {{ if .BackURL }}
      <a href="{{ .BackURL }}" class="text-sm text-indigo-600 hover:text-indigo-700">&larr; Back to speakers</a>
      {{ else }}
      <a href="/dashboard?hr={{ .HMAC }}&em={{ .Email }}" class="text-sm text-indigo-600 hover:text-indigo-700">&larr; Back to dashboard</a>
      {{ end }}
    </div>

    {{ if .Conf }}{{ template "conf_hero" .Conf }}{{ end }}

    <h1 class="mt-6 text-2xl font-bold text-gray-900">Edit speaker info</h1>
    <p class="text-xs text-gray-500 mt-1">These apply across all your talks at this conference.</p>

    {{ if .Locked }}
    <div class="mt-6 rounded-md bg-yellow-50 border border-yellow-200 px-4 py-3">
      <p class="text-sm text-yellow-900"><strong>Edits are locked.</strong> {{ .LockReason }}.</p>
      <p class="mt-1 text-xs text-yellow-800">Need to change something? Email <a href="mailto:speak@btcpp.dev" class="underline">speak@btcpp.dev</a>.</p>
    </div>
    {{ end }}

    <form method="POST" action="{{ if .FormAction }}{{ .FormAction }}{{ else }}/dashboard/{{ .Conf.Tag }}/edit?hr={{ .HMAC }}&em={{ .Email }}{{ end }}"
          enctype="multipart/form-data"
          class="mt-8 space-y-6">

      <div>
        <label for="ComingFrom" class="block text-sm font-semibold text-gray-900">I'll be traveling from</label>
        <input id="ComingFrom" name="ComingFrom" type="text" {{ if not .IsAdmin }}required{{ end }} {{ if .Locked }}disabled{{ end }}
               value="{{ .SpeakerConf.ComingFrom }}"
               placeholder="Hometown, USA"
               class="mt-1 block w-full rounded-md py-2 px-3 outline outline-1 -outline-offset-1 outline-gray-300 disabled:bg-gray-100" />
      </div>

      <div>
        <label for="Company" class="block text-sm font-semibold text-gray-900">Company / org affiliation</label>
        <p class="mt-0.5 text-xs text-gray-500">Start typing to pick from existing orgs, or type a new name to enter free-form.</p>
        <div class="mt-1 relative">
          <input id="Company" name="Company" type="text" {{ if .Locked }}disabled{{ end }}
                 value="{{ .SpeakerConf.Company }}"
                 placeholder="ACME, Inc."
                 class="block w-full rounded-md py-2 px-3 outline outline-1 -outline-offset-1 outline-gray-300 disabled:bg-gray-100" />
        </div>
        <input id="OrgID" name="OrgID" type="hidden" value="" />

        <div class="mt-3">
          <label for="OrgLogoFile" class="block text-xs font-semibold text-gray-700">Org logo</label>
          {{ if .SpeakerConf.OrgPhoto }}
          <p class="mt-1 text-xs text-gray-500">Current: <span class="font-mono">{{ .SpeakerConf.OrgPhoto }}</span> (upload a new file to replace it)</p>
          {{ end }}
          <input id="OrgLogoFile" name="OrgLogoFile" type="file" accept="image/*" {{ if .Locked }}disabled{{ end }}
                 class="mt-1 block w-full text-sm py-2 px-3 outline outline-1 -outline-offset-1 outline-gray-300 rounded-md disabled:bg-gray-100" />
        </div>

        <div class="mt-3 flex gap-x-4">
          <div class="flex h-6 items-center">
            <div class="group relative inline-flex w-8 shrink-0 rounded-full bg-gray-200 p-px outline-offset-2 outline-bitcoin ring-1 ring-inset ring-gray-900/5 transition-colors duration-200 ease-in-out has-[:checked]:bg-bitcion has-[:focus-visible]:outline has-[:focus-visible]:outline-2">
              <span class="size-4 rounded-full bg-white shadow-sm ring-1 ring-gray-900/5 transition-transform duration-200 ease-in-out group-has-[:checked]:translate-x-3.5"></span>
              <input id="Sponsor" type="checkbox" name="Sponsor" {{ if .SpeakerConf.Sponsor }}checked{{ end }} {{ if .Locked }}disabled{{ end }}
                     aria-label="My company would like to sponsor"
                     class="absolute inset-0 size-full appearance-none focus:outline-none text-bitcoin" />
            </div>
          </div>
          <label for="Sponsor" class="text-sm/6 text-gray-600">My company would like to sponsor</label>
        </div>
      </div>

      <fieldset>
        <legend class="block text-sm font-semibold text-gray-900">Days I'm available</legend>
        <div class="mt-2 space-y-1">
          {{ $avails := .SpeakerConf.Availability }}
          {{ range .DaysList }}
          <div class="flex gap-x-4">
            <div class="flex h-6 items-center">
              <div class="group relative inline-flex w-8 shrink-0 rounded-full bg-gray-200 p-px outline-offset-2 outline-bitcoin ring-1 ring-inset ring-gray-900/5 transition-colors duration-200 ease-in-out has-[:checked]:bg-bitcion has-[:focus-visible]:outline has-[:focus-visible]:outline-2">
                <span class="size-4 rounded-full bg-white shadow-sm ring-1 ring-gray-900/5 transition-transform duration-200 ease-in-out group-has-[:checked]:translate-x-3.5"></span>
                <input id="day-{{ .ItemID }}" type="checkbox" name="Availability" value="{{ .ItemID }}"
                       {{ if inSlice .ItemID $avails }}checked{{ end }}
                       {{ if $.Locked }}disabled{{ end }}
                       aria-label="{{ .ItemDesc }}"
                       class="absolute inset-0 size-full appearance-none focus:outline-none text-bitcoin" />
              </div>
            </div>
            <label for="day-{{ .ItemID }}" class="text-sm/6 text-gray-600">{{ .ItemDesc }}</label>
          </div>
          {{ end }}
        </div>
      </fieldset>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="RecordOK" class="block text-sm font-semibold text-gray-900">Recording</label>
          <select id="RecordOK" name="RecordOK" {{ if not .IsAdmin }}required{{ end }} {{ if .Locked }}disabled{{ end }}
                  class="mt-1 block w-full rounded-md py-2 pl-3 pr-7 outline outline-1 -outline-offset-1 outline-gray-300 disabled:bg-gray-100">
            {{ $cur := .SpeakerConf.RecordOK }}
            {{ range .RecordingOptions }}
            <option value="{{ .ItemID }}" {{ if eq .ItemID $cur }}selected{{ end }}>{{ .ItemDesc }}</option>
            {{ end }}
          </select>
        </div>
        <div>
          <label for="Visa" class="block text-sm font-semibold text-gray-900">Need a visa?</label>
          <select id="Visa" name="Visa" {{ if not .IsAdmin }}required{{ end }} {{ if .Locked }}disabled{{ end }}
                  class="mt-1 block w-full rounded-md py-2 pl-3 pr-7 outline outline-1 -outline-offset-1 outline-gray-300 disabled:bg-gray-100">
            {{ $v := .SpeakerConf.Visa }}
            <option value="No" {{ if eq $v "No" }}selected{{ end }}>No</option>
            <option value="Yes" {{ if eq $v "Yes" }}selected{{ end }}>Yes</option>
            <option value="IDK" {{ if eq $v "IDK" }}selected{{ end }}>I don't know</option>
          </select>
        </div>
      </div>

      <div class="space-y-3">
        {{ if .IsReturningAttendee }}
        <input type="hidden" name="FirstEvent" value="" />
        {{ else }}
        <div class="flex gap-x-4">
          <div class="flex h-6 items-center">
            <div class="group relative inline-flex w-8 shrink-0 rounded-full bg-gray-200 p-px outline-offset-2 outline-bitcoin ring-1 ring-inset ring-gray-900/5 transition-colors duration-200 ease-in-out has-[:checked]:bg-bitcion has-[:focus-visible]:outline has-[:focus-visible]:outline-2">
              <span class="size-4 rounded-full bg-white shadow-sm ring-1 ring-gray-900/5 transition-transform duration-200 ease-in-out group-has-[:checked]:translate-x-3.5"></span>
              <input id="FirstEvent" type="checkbox" name="FirstEvent" {{ if .SpeakerConf.FirstEvent }}checked{{ end }} {{ if .Locked }}disabled{{ end }}
                     aria-label="This is my first bitcoin++ event"
                     class="absolute inset-0 size-full appearance-none focus:outline-none text-bitcoin" />
            </div>
          </div>
          <label for="FirstEvent" class="text-sm/6 text-gray-600">This is my first <span class="font-bitcoin">bitcoin++</span> event</label>
        </div>
        {{ end }}
        <div class="flex gap-x-4">
          <div class="flex h-6 items-center">
            <div class="group relative inline-flex w-8 shrink-0 rounded-full bg-gray-200 p-px outline-offset-2 outline-bitcoin ring-1 ring-inset ring-gray-900/5 transition-colors duration-200 ease-in-out has-[:checked]:bg-bitcion has-[:focus-visible]:outline has-[:focus-visible]:outline-2">
              <span class="size-4 rounded-full bg-white shadow-sm ring-1 ring-gray-900/5 transition-transform duration-200 ease-in-out group-has-[:checked]:translate-x-3.5"></span>
              <input id="DinnerRSVP" type="checkbox" name="DinnerRSVP" {{ if .SpeakerConf.DinnerRSVP }}checked{{ end }} {{ if .Locked }}disabled{{ end }}
                     aria-label="I'll be able to attend the VIP dinner the night before the conference starts"
                     class="absolute inset-0 size-full appearance-none focus:outline-none text-bitcoin" />
            </div>
          </div>
          <label for="DinnerRSVP" class="text-sm/6 text-gray-600">I'll be able to attend the VIP dinner{{ if .RSVPFor }} on {{ .RSVPFor }}{{ end }}, the night before the conference starts.</label>
        </div>
      </div>

      {{ if not .Locked }}
      <div class="flex items-center justify-end gap-3 pt-2">
        <a href="{{ if .BackURL }}{{ .BackURL }}{{ else }}/dashboard?hr={{ .HMAC }}&em={{ .Email }}{{ end }}"
           class="px-4 py-2 text-sm font-medium text-gray-700 hover:text-gray-900">Cancel</a>
        <button type="submit"
                class="px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700">
          Save changes
        </button>
      </div>
      {{ end }}
    </form>
  </div>
  {{ block "footer" . }} {{ end }}
  {{ if not .Locked }}
  <script src="/static/js/org-autocomplete.js" defer></script>
  {{ end }}
</body>
</html>
