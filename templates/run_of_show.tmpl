<!DOCTYPE html>
<html>
<head>
  <title>Run of Show · {{ .Conf.Desc }}</title>
  {{ block "header" . }} {{ end }}
</head>
<body class="btcpp-admin-page btcpp-run-of-show-page">
  <div class="ros-print-hidden">{{ block "mainnav" . }} {{ end }}</div>
  <main class="ros-shell">
    <section class="ros-hero">
      <div class="ros-hero__copy">
        <div class="dashboard-kicker">§ Run of show</div>
        <h1>{{ .Conf.ArchiveTitle }}{{ if .Conf.ArchiveEdition }} <span>{{ .Conf.ArchiveEdition }}</span>{{ end }}</h1>
        <p>{{ .Conf.DateDesc }} · {{ .Conf.Location }}{{ if .Conf.Venue }} · {{ .Conf.Venue }}{{ end }}</p>
      </div>
      <div class="ros-hero__actions ros-print-hidden">
        <button type="button" data-ros-follow-toggle>Follow now</button>
        <button type="button" onclick="window.print()">Print</button>
      </div>
    </section>

    <div id="ros-content">
      {{ if not .Stages }}
      <section class="ros-empty">
        Nothing scheduled yet.
      </section>
      {{ else }}
      <div class="ros-stage-tabs ros-print-hidden" role="tablist" aria-label="Stages">
        {{ range $i, $stage := .Stages }}
        <a href="#{{ $stage.Venue.Tag }}"
           data-stage-tab="{{ $stage.Venue.Tag }}"
           class="stage-tab {{ if eq $i 0 }}is-active{{ end }}">
          {{ $stage.Venue.Label }}
        </a>
        {{ end }}
      </div>

      {{ range $i, $stage := .Stages }}
      <div id="{{ $stage.Venue.Tag }}" data-stage-panel="{{ $stage.Venue.Tag }}" class="stage-panel {{ if ne $i 0 }}hidden{{ end }}">
        <header class="ros-stage-head">
          <h2>{{ $stage.Venue.Label }}</h2>
        </header>
        {{ range $stage.Days }}
        <section class="ros-day">
        <h3>{{ if le .Idx 0 }}Setup · {{ end }}{{ .Date.Format "Mon, Jan 2" }}</h3>
        <div class="ros-table-wrap">
          <table class="ros-table">
            <thead>
              <tr>
                <th class="ros-col-time">Time</th>
                <th class="ros-col-media">Media</th>
                <th>What</th>
                <th>Who</th>
              </tr>
            </thead>
            <tbody>
              {{ range .Rows }}
              {{ if .NowMarkerBefore }}
              <tr class="ros-now-marker ros-current-target">
                <td colspan="4">
                  <div><span></span><strong>Now</strong><span></span></div>
                </td>
              </tr>
              {{ end }}
              <tr class="ros-row {{ if .IsCurrent }}ros-current-target is-current{{ else if eq .Kind "info" }}is-info{{ end }}">
                <td class="ros-time" data-label="Time">
                  {{ if and .Adjusted (eq .Kind "talk") }}
                  <div class="ros-was">was <span>{{ formatTime .OriginalStart }}</span></div>
                  {{ end }}
                  <div>{{ formatTime .Start }}</div>
                  {{ if .Adjusted }}<div class="ros-updated">updated · {{ signedMinutes .DelayMinutes }}</div>{{ end }}
                  {{ if .IsCurrent }}<div class="ros-now-pill">Now</div>{{ end }}
                </td>
                <td class="ros-media {{ if not (and (eq .Kind "talk") .MediaURL) }}is-empty{{ end }}" data-label="Media">
                  {{ if and (eq .Kind "talk") .MediaURL }}
                  <a href="{{ .MediaURL }}" target="_blank" rel="noopener noreferrer">
                    <picture>
                      {{ if .MediaAVIFURL }}<source srcset="{{ .MediaAVIFURL }}" type="image/avif">{{ end }}
                      <img src="{{ .MediaURL }}" alt="" loading="lazy">
                    </picture>
                  </a>
                  {{ end }}
                </td>
                <td class="ros-what" data-label="What">
                  {{ if eq .Kind "talk" }}<strong>{{ .What }}</strong>{{ else }}{{ .What }}{{ end }}
                </td>
                <td class="ros-who" data-label="Who">
                  {{ if .Who }}<div>{{ .Who }}</div>{{ end }}
                  {{ if .Crew }}
                  <div class="ros-crew">
                    {{ range .Crew }}
                    <div><span>{{ .Label }}:</span> {{ .Names }}</div>
                    {{ end }}
                  </div>
                  {{ end }}
                </td>
              </tr>
              {{ end }}
              {{ if .NowMarkerAfter }}
              <tr class="ros-now-marker ros-current-target">
                <td colspan="4">
                  <div><span></span><strong>Now</strong><span></span></div>
                </td>
              </tr>
              {{ end }}
            </tbody>
          </table>
        </div>
        </section>
        {{ end }}
      </div>
      {{ end }}
      {{ end }}
    </div>
  </main>
  <div class="ros-print-hidden">{{ block "footer" . }} {{ end }}</div>

  <script>
    (function () {
      function stageFromHash() {
        return decodeURIComponent(window.location.hash.replace(/^#/, ''));
      }
      window.rosSelectStage = function (stage) {
        var tabs = document.querySelectorAll('[data-stage-tab]');
        var panels = document.querySelectorAll('[data-stage-panel]');
        var active = stage || (tabs[0] && tabs[0].dataset.stageTab);
        var found = false;
        tabs.forEach(function (btn) {
          if (btn.dataset.stageTab === active) {
            found = true;
          }
        });
        if (!found && tabs[0]) {
          active = tabs[0].dataset.stageTab;
        }
        tabs.forEach(function (btn) {
          var selected = btn.dataset.stageTab === active;
          btn.classList.toggle('is-active', selected);
        });
        panels.forEach(function (panel) {
          panel.classList.toggle('hidden', panel.dataset.stagePanel !== active);
        });
      };
      window.rosInitStageTabs = function () {
        document.querySelectorAll('[data-stage-tab]').forEach(function (tab) {
          tab.addEventListener('click', function () {
            window.rosSelectStage(tab.dataset.stageTab);
            if (window.rosFollowNow) {
              window.setTimeout(window.rosFollowNow, 50);
            }
          });
        });
        window.rosSelectStage(stageFromHash());
      };
      window.addEventListener('hashchange', function () {
        window.rosSelectStage(stageFromHash());
        if (window.rosFollowNow) {
          window.setTimeout(window.rosFollowNow, 50);
        }
      });
      window.rosInitStageTabs();
    })();
  </script>
  <script>
    (function () {
      var storageKey = 'btcpp:run-of-show:follow';
      var followBtn = document.querySelector('[data-ros-follow-toggle]');
      var follow = localStorage.getItem(storageKey) === '1';
      function visible(el) {
        return !!(el && el.offsetParent !== null);
      }
      function currentTarget() {
        var targets = Array.prototype.slice.call(document.querySelectorAll('.ros-current-target'));
        for (var i = 0; i < targets.length; i++) {
          if (visible(targets[i])) {
            return targets[i];
          }
        }
        return null;
      }
      function updateButton() {
        if (!followBtn) {
          return;
        }
        followBtn.textContent = follow ? 'Following now' : 'Follow now';
        followBtn.classList.toggle('is-following', follow);
      }
      window.rosFollowNow = function () {
        if (!follow) {
          return;
        }
        var target = currentTarget();
        if (target) {
          target.scrollIntoView({ block: 'center', behavior: 'smooth' });
        }
      };
      if (followBtn) {
        followBtn.addEventListener('click', function () {
          follow = !follow;
          localStorage.setItem(storageKey, follow ? '1' : '0');
          updateButton();
          window.rosFollowNow();
        });
      }
      updateButton();
      window.addEventListener('load', function () {
        window.setTimeout(window.rosFollowNow, 150);
      });
      function preserveMediaImages(nextRoot) {
        var current = {};
        document.querySelectorAll('#ros-content img[src]').forEach(function (img) {
          var src = img.getAttribute('src');
          if (!current[src]) {
            current[src] = [];
          }
          current[src].push(img);
        });
        nextRoot.querySelectorAll('img[src]').forEach(function (img) {
          var src = img.getAttribute('src');
          var existing = current[src] && current[src].shift();
          if (existing) {
            img.replaceWith(existing);
          }
        });
      }
      var refreshInFlight = false;
      function softRefreshRunOfShow() {
        if (refreshInFlight) {
          return;
        }
        refreshInFlight = true;
        fetch(window.location.href, {
          headers: { 'X-Requested-With': 'run-of-show-refresh' },
          cache: 'no-store'
        }).then(function (response) {
          if (!response.ok) {
            throw new Error('refresh failed');
          }
          return response.text();
        }).then(function (html) {
          var doc = new DOMParser().parseFromString(html, 'text/html');
          var currentRoot = document.getElementById('ros-content');
          var nextRoot = doc.getElementById('ros-content');
          if (!currentRoot || !nextRoot) {
            window.location.reload();
            return;
          }
          preserveMediaImages(nextRoot);
          currentRoot.replaceWith(nextRoot);
          if (window.rosInitStageTabs) {
            window.rosInitStageTabs();
          }
          if (window.rosFollowNow) {
            window.setTimeout(window.rosFollowNow, 50);
          }
        }).catch(function () {
          window.location.reload();
        }).finally(function () {
          refreshInFlight = false;
        });
      }
      if (window.EventSource) {
        var events = new EventSource('/{{ .Conf.Tag }}/run-of-show/events');
        events.addEventListener('reload', function () {
          softRefreshRunOfShow();
        });
      }
    })();
  </script>
</body>
</html>
