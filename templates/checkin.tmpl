<!DOCTYPE html>
<html>
<head>
  <title>bitcoin++ check-in</title>
  {{ block "header" . }} {{ end }}
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>✨</text></svg>">
</head>
<body class="btcpp-admin-page checkin-page checkin-page--{{ if .TicketType }}{{ .TicketType }}{{ else }}unknown{{ end }}">
{{ block "mainnav" . }} {{ end }}
  <main class="checkin-shell">
    <section class="checkin-card">
      {{ if .NeedsPin }}
      <p class="checkin-kicker">§ check-in</p>
      <h1>Enter passcode.</h1>
      <form method="POST" class="checkin-pin-form">
        <input id="pin" type="password" name="pin" placeholder="Passcode" required autofocus>
        <button type="submit">Enter</button>
      </form>
      {{ else }}
      <p class="checkin-kicker">§ ticket</p>
      <h1>{{ if .TicketType }}{{ .TicketType }}{{ else }}Unknown ticket{{ end }}</h1>
      {{ if .TicketRef }}<p class="checkin-ticket-ref">{{ .TicketRef }}</p>{{ end }}
      {{ end }}
      {{ if .Msg }}<p class="checkin-message">{{ .Msg }}</p>{{ end }}
    </section>

    {{ if .MerchPickups }}
    <section class="checkin-card checkin-card--merch">
      <p class="checkin-kicker">§ merch pickup</p>
      <h2>Add to bag.</h2>
      <div class="checkin-pickups">
        {{ range .MerchPickups }}
        <article class="checkin-pickup">
          <div>
            <strong>{{ .ProductNameSnapshot }}</strong>
            <span>{{ if .VariantLabelSnapshot }}{{ .VariantLabelSnapshot }} · {{ end }}Qty {{ .Quantity }}{{ if .SKUSnapshot }} · {{ .SKUSnapshot }}{{ end }}</span>
          </div>
          {{ if eq .Status "fulfilled" }}
          <span class="checkin-pill is-done">picked up</span>
          {{ else }}
          <form method="POST" action="/check-in/{{ $.TicketRef }}/merch/{{ .ID }}">
            <button type="submit">Mark picked up</button>
          </form>
          {{ end }}
        </article>
        {{ end }}
      </div>
    </section>
    {{ end }}
  </main>
  {{ block "footer" . }} {{ end }}
</body>
</html>
