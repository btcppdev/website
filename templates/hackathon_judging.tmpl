<!doctype html>
<html lang="en">
<head>
  <title>Judging - {{ .Competition.Title }} - bitcoin++ hackathon</title>
  {{ block "header" . }} {{ end }}
</head>
<body class="hack-redesign">
  {{ block "mainnav" . }} {{ end }}
  <main class="hack-shell">
    <div class="hack-ticker" aria-label="Hackathon judging">
      <span class="hack-ticker__live">▶ Judging</span>
      <span>{{ .Competition.Title }}</span>
      <span>•</span>
      <span>Judging</span>
    </div>

    <header class="hack-header">
      <div>
        <a href="/" class="hack-brand">bitcoin<span>++</span></a>
        <div class="hack-header__meta">[ {{ .Competition.Title }} · Judging ]</div>
      </div>
      <nav class="hack-header__nav" aria-label="Judging links">
        <a href="{{ .HackathonURL }}">← hackathon</a>
        <a href="{{ .ScheduleURL }}">schedule/</a>
      </nav>
    </header>

    <section class="hack-section">
      <div class="hack-section__head">
        <div>
          <div class="hack-label">§ Judging</div>
          <h1 style="margin:0;font-size:clamp(48px,7vw,88px);font-weight:700;line-height:.92;">Rank the <span class="hack-serif">projects.</span></h1>
        </div>
        <div class="hack-section__deck">Submit scores for the current judging round. Admins open and advance rounds from the backend.</div>
      </div>
    </section>

    {{ if .FlashMessage }}
    <div class="hack-alert hack-alert--success">{{ .FlashMessage }}</div>
    {{ end }}
    {{ if .FlashError }}
    <div class="hack-alert hack-alert--error">{{ .FlashError }}</div>
    {{ end }}

    {{ $event := .CurrentJudgeEvent }}
    <section class="hack-section hack-judging-round">
      {{ if $event }}
      <div class="hack-current-round{{ if .CanScoreJudgeEvent $event }} hack-current-round--open{{ end }}">
        <div class="hack-current-round__label">{{ if .CanScoreJudgeEvent $event }}Open now{{ else }}Current judging round{{ end }}</div>
        <div class="hack-current-round__body">
          <div>
            <div class="hack-label">{{ .JudgeTypeLabel $event.PlaybookType }}</div>
            <h2>{{ $event.Name }}</h2>
            <p class="hack-current-round__summary">{{ if .CanScoreJudgeEvent $event }}This is the active ballot. Rank each project once; changes save automatically.{{ else }}This round is selected, but it is not currently accepting scores for your account.{{ end }}</p>
          </div>
          <div class="hack-current-round__meta">
            <span>{{ .RankLimit $event }} ranks</span>
            <span>{{ .JudgeEventStateLabel $event }}</span>
            <span>{{ len .Projects }} project{{ if ne (len .Projects) 1 }}s{{ end }}</span>
            {{ if $event.StartingProjectNumber }}<span>Starts at #{{ $event.StartingProjectNumber }}</span>{{ end }}
          </div>
        </div>
        <div class="hack-current-round__times">
          {{ if or $event.StartsAt $event.EndsAt }}
          {{ if $event.StartsAt }}<div><span>Starts</span><time class="hackathon-judging-time" datetime="{{ $event.StartsAt.Format "2006-01-02T15:04:05Z07:00" }}">{{ $event.StartsAt.Format "2006-01-02 15:04" }}</time></div>{{ end }}
          {{ if $event.EndsAt }}<div><span>Ends</span><time class="hackathon-judging-time" datetime="{{ $event.EndsAt.Format "2006-01-02T15:04:05Z07:00" }}">{{ $event.EndsAt.Format "2006-01-02 15:04" }}</time></div>{{ end }}
          {{ else }}
          <div><span>Schedule</span><strong>Time TBA</strong></div>
          {{ end }}
        </div>
      </div>

      {{ if .Projects }}
      <form id="event-{{ $event.ID }}" method="POST" action="{{ .JudgingURL }}/scorecards" class="hack-form hack-judging-ballot">
        {{ if .CanScoreJudgeEvent $event }}
        <input type="hidden" name="JudgeEventID" value="{{ $event.ID }}">
        <div class="hack-form__body">
          <div class="hack-card__top">
            <div>
              <div class="hack-label" style="margin-bottom:8px;">Ballot</div>
              <h3 style="margin:0;font-size:32px;font-weight:700;">Current ranking</h3>
            </div>
            <div class="hack-judging-save">
              <span data-autosave-status></span>
            </div>
          </div>
          <p class="hack-judging-ballot__note">Choose each rank once. Changes save automatically.</p>
        </div>
        <div class="hack-table-wrap">
          <table class="hack-table">
            <thead>
              <tr>
                <th scope="col">Project</th>
                <th scope="col">Rank</th>
              </tr>
            </thead>
            <tbody>
              {{ range $.Projects }}
              {{ $project := . }}
              {{ $scorecard := $.Scorecard .ID $event.ID }}
              <tr>
                <td>
                  <input type="hidden" name="ProjectID" value="{{ .ID }}">
                  <a href="{{ $.ProjectURL . }}" class="hack-judging-project-link">{{ $.ProjectNumberLabel . }} · {{ .Title }}</a>
                  {{ if .ShortDescription }}<div class="hack-list__meta">{{ .ShortDescription }}</div>{{ end }}
                </td>
                <td class="hack-field hack-rank-cell">
                  <fieldset class="hack-rank-picker" aria-label="Rank {{ .Title }}">
                    {{ range $.RankOptions $event }}
                    {{ $rank := . }}
                    <label class="hack-rank-option">
                      <input type="radio" name="{{ printf "Rank_%s" $project.ID }}" value="{{ . }}" {{ with $scorecard }}{{ if eq ($.ScoreValue .Rank) (printf "%d" $rank) }}checked{{ end }}{{ end }}>
                      <span>{{ $.RankOptionLabel $event . }}</span>
                    </label>
                    {{ end }}
                    <label class="hack-rank-option">
                      <input type="radio" name="{{ printf "Rank_%s" .ID }}" value="" {{ if not $scorecard }}checked{{ else }}{{ if eq ($.ScoreValue $scorecard.Rank) "" }}checked{{ end }}{{ end }}>
                      <span>Not ranked</span>
                    </label>
                  </fieldset>
                </td>
              </tr>
              {{ end }}
            </tbody>
          </table>
        </div>
        {{ else }}
        <div class="hack-empty">This round is not open for your account.</div>
        {{ end }}
      </form>
      {{ else }}
      <div class="hack-empty">No projects are visible for this judging round.</div>
      {{ end }}
      {{ else }}
      <div class="hack-current-round hack-current-round--empty">
        <div class="hack-current-round__label">Current judging round</div>
        <div class="hack-current-round__body">
          <div>
            <div class="hack-label">Judging</div>
            <h2>Judging is not <span class="hack-serif">open.</span></h2>
          </div>
          <div class="hack-current-round__meta">
            <span>Waiting for admin</span>
          </div>
        </div>
      </div>
      {{ end }}
    </section>

    {{ if .ChallengeAwardsForJudge }}
    <section class="hack-section">
      <div class="hack-section__head">
        <div>
          <div class="hack-label">§ Challenges</div>
          <h2>Pick challenge <span class="hack-serif">winners.</span></h2>
        </div>
        <div class="hack-section__deck">Challenge judges select one project for each assigned challenge. These picks do not affect ranked scoring.</div>
      </div>
      <div class="hack-card-grid">
        {{ range .ChallengeAwardsForJudge }}
        {{ $award := . }}
        {{ $vote := $.AwardVote . }}
        {{ $options := $.ChallengeAwardProjectOptions . }}
        <article id="award-{{ .ID }}" class="hack-card">
          <div class="hack-card__body">
            <div class="hack-tags">
              <span class="hack-tag">Challenge</span>
              {{ if $.AwardHasSponsor . }}<span class="hack-tag">{{ $.AwardSponsorLabel . }}</span>{{ end }}
              {{ if .OptInRequired }}<span class="hack-tag">Opt-in required</span>{{ end }}
            </div>
            <h3>{{ .Title }}</h3>
            {{ if .Description }}<div class="hack-card__desc">{{ .Description }}</div>{{ end }}
            {{ if .JudgingInstructions }}<p class="hack-list__meta" style="margin-top:12px;white-space:pre-line;">{{ .JudgingInstructions }}</p>{{ end }}
            {{ if $.AwardSponsorURL . }}<div class="hack-card__links"><a href="{{ $.AwardSponsorURL . }}" target="_blank" rel="noreferrer">Sponsor</a></div>{{ end }}

            <form method="POST" action="{{ $.JudgingURL }}/award-votes" class="hack-form" style="margin-top:18px;">
              <input type="hidden" name="AwardID" value="{{ .ID }}">
              <div class="hack-form__body">
                {{ if $options }}
                <label class="hack-field">
                  <span>Winning project</span>
                  <select name="ProjectID" required>
                    <option value="">Choose project</option>
                    {{ range $options }}
                    <option value="{{ .ID }}" {{ if $.ProjectSelectedForAward . $award }}selected{{ end }}>{{ $.ProjectNumberLabel . }} · {{ .Title }}</option>
                    {{ end }}
                  </select>
                </label>
                <label class="hack-field">
                  <span>Notes</span>
                  <textarea name="Notes" rows="3" placeholder="Optional notes for admins">{{ with $vote }}{{ .Notes }}{{ end }}</textarea>
                </label>
                <div class="hack-actions" style="justify-content:flex-end;">
                  <button type="submit" class="hack-button hack-button--primary">Save pick</button>
                </div>
                {{ else }}
                <div class="hack-empty">No eligible projects are available for this challenge.</div>
                {{ end }}
              </div>
            </form>
          </div>
        </article>
        {{ end }}
      </div>
    </section>
    {{ end }}

    <section class="hack-section">
      <div class="hack-section__head">
        <div>
          <div class="hack-label">§ Projects</div>
          <h2>Visible <span class="hack-serif">submissions.</span></h2>
        </div>
        <div class="hack-section__deck">{{ len .Projects }} visible project{{ if ne (len .Projects) 1 }}s{{ end }}.</div>
      </div>
      {{ if .Projects }}
      <div class="hack-card-grid">
        {{ range .Projects }}
        <article id="project-{{ .ID }}" class="hack-card hack-judging-project-card" role="link" tabindex="0" data-url="{{ $.ProjectURL . }}" aria-label="Open {{ .Title }}">
          <div class="hack-card__body">
            <div class="hack-tags">
              <span class="hack-tag">{{ $.ProjectNumberLabel . }}</span>
              <span class="hack-tag">{{ $.ProjectStatusLabel .Status }}</span>
            </div>
            <h3>{{ .Title }}</h3>
            {{ if .ShortDescription }}<div class="hack-card__desc">{{ .ShortDescription }}</div>{{ end }}
            {{ if .Description }}<div class="hack-copy__body" style="font-size:14px;line-height:1.55;">{{ hackathonRichText .Description }}</div>{{ end }}
            {{ if .Tags }}
            <div class="hack-tags">
              {{ range .Tags }}<span class="hack-tag">{{ . }}</span>{{ end }}
            </div>
            {{ end }}
            <div class="hack-card__links">
              {{ if .GitHubURL }}<a href="{{ .GitHubURL }}">GitHub</a>{{ end }}
              {{ if .DemoURL }}<a href="{{ .DemoURL }}">Demo</a>{{ end }}
              {{ if .VideoURL }}<a href="{{ .VideoURL }}">Video</a>{{ end }}
              {{ if .SlidesURL }}<a href="{{ .SlidesURL }}">Slides</a>{{ end }}
              {{ if .DocsURL }}<a href="{{ .DocsURL }}">Docs</a>{{ end }}
            </div>
          </div>
        </article>
        {{ end }}
      </div>
      {{ else }}
      <div class="hack-empty">No projects are visible yet.</div>
      {{ end }}
    </section>
  </main>
  <script>
    (function () {
      const times = Array.prototype.slice.call(document.querySelectorAll('.hackathon-judging-time'));
      const tz = Intl.DateTimeFormat().resolvedOptions().timeZone || 'UTC';
      for (const el of times) {
        const value = el.getAttribute('datetime');
        if (!value) continue;
        const date = new Date(value);
        el.textContent = new Intl.DateTimeFormat(undefined, {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
          hour: 'numeric',
          minute: '2-digit',
          timeZone: tz,
          timeZoneName: 'short'
        }).format(date);
      }
    })();
    (function () {
      const pickers = Array.prototype.slice.call(document.querySelectorAll('fieldset[aria-label^="Rank "]'));
      for (const picker of pickers) {
        const checked = picker.querySelector('input[type="radio"]:checked');
        picker.dataset.currentRank = checked ? checked.value : '';
      }

      for (const card of document.querySelectorAll('.hack-judging-project-card[data-url]')) {
        function openProjectPage() {
          const target = card.dataset.url;
          if (!target) return;
          window.location.href = target;
        }
        card.addEventListener('click', function (event) {
          if (event.target.closest('a, button, input, label, select, textarea')) return;
          openProjectPage();
        });
        card.addEventListener('keydown', function (event) {
          if (event.key !== 'Enter' && event.key !== ' ') return;
          event.preventDefault();
          openProjectPage();
        });
      }

      function setSaveStatus(form, text, state) {
        const status = form.querySelector('[data-autosave-status]');
        if (!status) return;
        status.textContent = text;
        status.dataset.state = state || '';
      }

      async function saveBallot(form) {
        if (form.dataset.saving === 'true') {
          form.dataset.needsSave = 'true';
          return;
        }
        form.dataset.saving = 'true';
        form.dataset.needsSave = '';
        setSaveStatus(form, 'Saving...', 'saving');
        try {
          const body = new URLSearchParams(new FormData(form));
          const response = await fetch(form.action, {
            method: 'POST',
            body: body,
            credentials: 'same-origin'
          });
          if (!response.ok) throw new Error('save failed');
          setSaveStatus(form, 'Saved', 'saved');
        } catch (_) {
          setSaveStatus(form, 'Save failed', 'error');
          console.warn('Failed to save hackathon rankings');
        } finally {
          form.dataset.saving = '';
          if (form.dataset.needsSave === 'true') {
            saveBallot(form);
          }
        }
      }

      document.addEventListener('change', function (event) {
        const selected = event.target;
        if (!selected.matches('fieldset[aria-label^="Rank "] input[type="radio"]') || !selected.checked) return;

        const form = selected.closest('form');
        const selectedPicker = selected.closest('fieldset[aria-label^="Rank "]');
        if (!form || !selectedPicker) return;

        const previousRank = selectedPicker.dataset.currentRank || '';
        selectedPicker.dataset.currentRank = selected.value;
        if (selected.value === '') return;

        const choices = Array.prototype.slice.call(form.querySelectorAll('fieldset[aria-label^="Rank "] input[type="radio"]'));
        for (const choice of choices) {
          if (choice === selected || choice.value !== selected.value || !choice.checked) continue;
          choice.checked = false;

          const picker = choice.closest('fieldset[aria-label^="Rank "]');
          if (!picker) continue;
          const replacement = Array.prototype.find.call(picker.querySelectorAll('input[type="radio"]'), function (input) {
            return input.value === previousRank;
          });
          if (replacement) {
            replacement.checked = true;
            picker.dataset.currentRank = replacement.value;
          }
        }
        saveBallot(form);
      });
    })();
  </script>
  {{ block "footer" . }} {{ end }}
</body>
</html>
