<!doctype html>
<html lang="en">
<head>
  <title>Judging - {{ .Competition.Title }} - bitcoin++ hackathon</title>
  {{ block "header" . }} {{ end }}
</head>
<body class="bg-gray-50 text-gray-900">
  {{ block "mainnav" . }} {{ end }}
  <main class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <a href="/hackathons/{{ .Competition.Slug }}" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">&larr; Hackathon</a>
        <h1 class="mt-2 text-3xl font-semibold tracking-tight">Judging</h1>
        <p class="mt-1 text-sm text-gray-600">{{ .Competition.Title }}</p>
      </div>
      <a href="{{ .ScheduleURL }}" class="inline-flex items-center justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-gray-300 hover:bg-gray-50">Schedule</a>
    </div>

    {{ if .FlashMessage }}
    <div class="mb-4 rounded-md border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-800">{{ .FlashMessage }}</div>
    {{ end }}
    {{ if .FlashError }}
    <div class="mb-4 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">{{ .FlashError }}</div>
    {{ end }}

    <section class="mb-8 rounded-lg bg-white shadow">
      <div class="border-b border-gray-200 px-4 py-4 sm:px-6">
        <h2 class="text-sm font-semibold text-gray-900">Judge events</h2>
      </div>
      <div class="px-4 py-5 sm:p-6">
        {{ if .JudgeEvents }}
        <div class="grid gap-3 md:grid-cols-2">
          {{ range .JudgeEvents }}
          <article class="rounded-md border border-gray-200 px-4 py-3">
            <div class="flex items-start justify-between gap-3">
              <div>
                <h3 class="text-sm font-semibold text-gray-900">{{ .Name }}</h3>
                <p class="mt-1 text-xs text-gray-500">{{ $.JudgeTypeLabel .PlaybookType }}{{ if .StartingProjectNumber }} · starts at #{{ .StartingProjectNumber }}{{ end }}</p>
              </div>
              <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-700">Order {{ .Ordering }}</span>
            </div>
            <div class="mt-3 text-sm text-gray-700">
              {{ if or .StartsAt .EndsAt }}
              {{ if .StartsAt }}<div>Starts: <time class="hackathon-judging-time" datetime="{{ .StartsAt.Format "2006-01-02T15:04:05Z07:00" }}">{{ .StartsAt.Format "2006-01-02 15:04" }}</time></div>{{ end }}
              {{ if .EndsAt }}<div>Ends: <time class="hackathon-judging-time" datetime="{{ .EndsAt.Format "2006-01-02T15:04:05Z07:00" }}">{{ .EndsAt.Format "2006-01-02 15:04" }}</time></div>{{ end }}
              {{ else }}
              <div>Time TBA</div>
              {{ end }}
            </div>
          </article>
          {{ end }}
        </div>
        {{ else }}
        <p class="text-sm text-gray-600">No judge events have been set up yet.</p>
        {{ end }}
      </div>
    </section>

    <section>
      <div class="mb-4 flex items-center justify-between gap-4">
        <h2 class="text-lg font-semibold text-gray-900">Projects</h2>
        <span class="text-sm text-gray-500">{{ len .Projects }} visible</span>
      </div>
      {{ if .Projects }}
      <div class="space-y-4">
        {{ range .Projects }}
        {{ $project := . }}
        <article id="project-{{ .ID }}" class="rounded-lg bg-white p-5 shadow">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <div class="flex flex-wrap items-center gap-2">
                <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-700">{{ $.ProjectNumberLabel . }}</span>
                <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-700">{{ $.ProjectStatusLabel .Status }}</span>
              </div>
              <h3 class="mt-2 text-base font-semibold text-gray-900">{{ .Title }}</h3>
              {{ if .ShortDescription }}
              <p class="mt-1 text-sm text-gray-600">{{ .ShortDescription }}</p>
              {{ end }}
            </div>
          </div>
          {{ if .Description }}
          <p class="mt-4 whitespace-pre-line text-sm leading-6 text-gray-700">{{ .Description }}</p>
          {{ end }}
          {{ if .Tags }}
          <div class="mt-4 flex flex-wrap gap-2">
            {{ range .Tags }}
            <span class="rounded-full bg-indigo-50 px-2 py-0.5 text-xs font-medium text-indigo-700">{{ . }}</span>
            {{ end }}
          </div>
          {{ end }}
          <div class="mt-4 flex flex-wrap gap-x-4 gap-y-2 text-sm">
            {{ if .GitHubURL }}<a class="font-medium text-indigo-600 hover:text-indigo-500" href="{{ .GitHubURL }}">GitHub</a>{{ end }}
            {{ if .DemoURL }}<a class="font-medium text-indigo-600 hover:text-indigo-500" href="{{ .DemoURL }}">Demo</a>{{ end }}
            {{ if .VideoURL }}<a class="font-medium text-indigo-600 hover:text-indigo-500" href="{{ .VideoURL }}">Video</a>{{ end }}
            {{ if .SlidesURL }}<a class="font-medium text-indigo-600 hover:text-indigo-500" href="{{ .SlidesURL }}">Slides</a>{{ end }}
            {{ if .DocsURL }}<a class="font-medium text-indigo-600 hover:text-indigo-500" href="{{ .DocsURL }}">Docs</a>{{ end }}
          </div>
          {{ if $.JudgeEvents }}
          <div class="mt-5 space-y-4 border-t border-gray-200 pt-5">
            {{ range $.JudgeEvents }}
            {{ if $.CanScoreJudgeEvent . }}
            {{ $scorecard := $.Scorecard $project.ID .ID }}
            <form method="POST" action="{{ $.JudgingURL }}/scorecards" class="rounded-md border border-gray-200 px-4 py-3">
              <input type="hidden" name="ProjectID" value="{{ $project.ID }}">
              <input type="hidden" name="JudgeEventID" value="{{ .ID }}">
              <div class="mb-3 flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
                <div>
                  <h4 class="text-sm font-semibold text-gray-900">{{ .Name }}</h4>
                  <p class="mt-1 text-xs text-gray-500">{{ $.JudgeTypeLabel .PlaybookType }}</p>
                </div>
                {{ with $scorecard }}
                {{ if .SubmittedAt }}
                <span class="text-xs text-gray-500">Saved {{ .SubmittedAt.Format "2006-01-02 15:04" }}</span>
                {{ end }}
                {{ end }}
              </div>
              <div class="grid gap-3 sm:grid-cols-4">
                <div>
                  <label for="IdeaScore-{{ $project.ID }}-{{ .ID }}" class="block text-xs font-medium text-gray-700">Idea</label>
                  <input id="IdeaScore-{{ $project.ID }}-{{ .ID }}" name="IdeaScore" type="number" min="1" max="5" value="{{ with $scorecard }}{{ $.ScoreValue .IdeaScore }}{{ end }}"
                         class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                </div>
                <div>
                  <label for="ExecutionScore-{{ $project.ID }}-{{ .ID }}" class="block text-xs font-medium text-gray-700">Execution</label>
                  <input id="ExecutionScore-{{ $project.ID }}-{{ .ID }}" name="ExecutionScore" type="number" min="1" max="5" value="{{ with $scorecard }}{{ $.ScoreValue .ExecutionScore }}{{ end }}"
                         class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                </div>
                <div>
                  <label for="ImpactScore-{{ $project.ID }}-{{ .ID }}" class="block text-xs font-medium text-gray-700">Impact</label>
                  <input id="ImpactScore-{{ $project.ID }}-{{ .ID }}" name="ImpactScore" type="number" min="1" max="5" value="{{ with $scorecard }}{{ $.ScoreValue .ImpactScore }}{{ end }}"
                         class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                </div>
                <div>
                  <label for="Rank-{{ $project.ID }}-{{ .ID }}" class="block text-xs font-medium text-gray-700">Rank</label>
                  <input id="Rank-{{ $project.ID }}-{{ .ID }}" name="Rank" type="number" min="1" value="{{ with $scorecard }}{{ $.ScoreValue .Rank }}{{ end }}"
                         class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">
                </div>
              </div>
              <div class="mt-3">
                <label for="Comments-{{ $project.ID }}-{{ .ID }}" class="block text-xs font-medium text-gray-700">Comments</label>
                <textarea id="Comments-{{ $project.ID }}-{{ .ID }}" name="Comments" rows="3"
                          class="mt-1 block w-full rounded-md bg-white px-3 py-2 text-sm text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-indigo-600">{{ with $scorecard }}{{ .Comments }}{{ end }}</textarea>
              </div>
              <div class="mt-3 flex flex-wrap items-center justify-between gap-3">
                <label class="inline-flex items-center gap-2 text-sm text-gray-700">
                  <input name="NoShow" type="checkbox" {{ with $scorecard }}{{ if .NoShow }}checked{{ end }}{{ end }}
                         class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600">
                  No-show
                </label>
                <button type="submit" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Save scorecard</button>
              </div>
            </form>
            {{ end }}
            {{ end }}
          </div>
          {{ end }}
        </article>
        {{ end }}
      </div>
      {{ else }}
      <div class="rounded-lg bg-white px-4 py-10 text-center shadow">
        <p class="text-sm text-gray-600">No projects are visible yet.</p>
      </div>
      {{ end }}
    </section>
  </main>
  <script>
    (function () {
      const times = Array.prototype.slice.call(document.querySelectorAll('.hackathon-judging-time'));
      if (times.length === 0) return;

      const tz = Intl.DateTimeFormat().resolvedOptions().timeZone || 'UTC';
      for (const el of times) {
        const value = el.getAttribute('datetime');
        if (!value) continue;
        const date = new Date(value);
        el.textContent = new Intl.DateTimeFormat(undefined, {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
          hour: 'numeric',
          minute: '2-digit',
          timeZone: tz,
          timeZoneName: 'short'
        }).format(date);
      }
    })();
  </script>
  {{ block "footer" . }} {{ end }}
</body>
</html>
