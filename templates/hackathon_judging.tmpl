<!doctype html>
<html lang="en">
<head>
  <title>Judging - {{ .Competition.Title }} - bitcoin++ hackathon</title>
  {{ block "header" . }} {{ end }}
</head>
<body class="hack-redesign">
  {{ block "mainnav" . }} {{ end }}
  <main class="hack-shell">
    <div class="hack-ticker" aria-label="Hackathon judging">
      <span class="hack-ticker__live">▶ Judging</span>
      <span>{{ .Competition.Title }}</span>
      <span>•</span>
      <span>ranked ballots</span>
    </div>

    <header class="hack-header">
      <div>
        <a href="/" class="hack-brand">bitcoin<span>++</span></a>
        <div class="hack-header__meta">[ {{ .Competition.Title }} · Judging ]</div>
      </div>
      <nav class="hack-header__nav" aria-label="Judging links">
        <a href="{{ .HackathonURL }}">← hackathon</a>
        <a href="{{ .ScheduleURL }}">schedule/</a>
      </nav>
    </header>

    <section class="hack-section">
      <div class="hack-section__head">
        <div>
          <div class="hack-label">§ Judging</div>
          <h1 style="margin:0;font-size:clamp(48px,7vw,88px);font-weight:700;line-height:.92;">Rank the <span class="hack-serif">projects.</span></h1>
        </div>
        <div class="hack-section__deck">Choose each rank once per judging event. Scores are calculated from the final rankings.</div>
      </div>
    </section>

    {{ if .FlashMessage }}
    <div class="hack-alert hack-alert--success">{{ .FlashMessage }}</div>
    {{ end }}
    {{ if .FlashError }}
    <div class="hack-alert hack-alert--error">{{ .FlashError }}</div>
    {{ end }}

    <section class="hack-section">
      <div class="hack-section__head">
        <div>
          <div class="hack-label">§ Events</div>
          <h2>Judging <span class="hack-serif">windows.</span></h2>
        </div>
        <div class="hack-section__deck">Only active events you can score will show ballot forms below.</div>
      </div>
      {{ if .JudgeEvents }}
      <div class="hack-card-grid">
        {{ range .JudgeEvents }}
        <article class="hack-card">
          <div class="hack-card__body">
            <div class="hack-card__top">
              <h3>{{ .Name }}</h3>
              <span class="hack-badge">{{ $.RankLimit . }} ranks</span>
            </div>
            <div class="hack-card__desc">{{ $.JudgeTypeLabel .PlaybookType }}{{ if .StartingProjectNumber }} · starts at #{{ .StartingProjectNumber }}{{ end }}</div>
            <div class="hack-card__links" style="display:block;">
              {{ if or .StartsAt .EndsAt }}
              {{ if .StartsAt }}<div>Starts: <time class="hackathon-judging-time" datetime="{{ .StartsAt.Format "2006-01-02T15:04:05Z07:00" }}">{{ .StartsAt.Format "2006-01-02 15:04" }}</time></div>{{ end }}
              {{ if .EndsAt }}<div>Ends: <time class="hackathon-judging-time" datetime="{{ .EndsAt.Format "2006-01-02T15:04:05Z07:00" }}">{{ .EndsAt.Format "2006-01-02 15:04" }}</time></div>{{ end }}
              {{ else }}
              <div>Time TBA</div>
              {{ end }}
            </div>
          </div>
        </article>
        {{ end }}
      </div>
      {{ else }}
      <div class="hack-empty">No judge events have been set up yet.</div>
      {{ end }}
    </section>

    {{ if and .Projects .JudgeEvents }}
    <section class="hack-section">
      <div class="hack-section__head">
        <div>
          <div class="hack-label">§ Ballots</div>
          <h2>Save your <span class="hack-serif">rankings.</span></h2>
        </div>
        <div class="hack-section__deck">Each event has its own ballot and save button.</div>
      </div>
      {{ range .JudgeEvents }}
      {{ if $.CanScoreJudgeEvent . }}
      {{ $event := . }}
      <form id="event-{{ .ID }}" method="POST" action="{{ $.JudgingURL }}/scorecards" class="hack-form">
        <input type="hidden" name="JudgeEventID" value="{{ .ID }}">
        <div class="hack-form__body">
          <div class="hack-card__top">
            <div>
              <div class="hack-label" style="margin-bottom:8px;">{{ $.JudgeTypeLabel .PlaybookType }}</div>
              <h3 style="margin:0;font-size:32px;font-weight:700;">{{ .Name }}</h3>
            </div>
            <button type="submit" class="hack-button hack-button--accent">Save rankings →</button>
          </div>
        </div>
        <div class="hack-table-wrap">
          <table class="hack-table">
            <thead>
              <tr>
                <th scope="col">Project</th>
                <th scope="col">Rank</th>
              </tr>
            </thead>
            <tbody>
              {{ range $.Projects }}
              {{ $project := . }}
              {{ $scorecard := $.Scorecard .ID $event.ID }}
              <tr>
                <td>
                  <input type="hidden" name="ProjectID" value="{{ .ID }}">
                  <div style="font-weight:700;">{{ $.ProjectNumberLabel . }} · {{ .Title }}</div>
                  {{ if .ShortDescription }}<div class="hack-list__meta">{{ .ShortDescription }}</div>{{ end }}
                </td>
                <td class="hack-field" style="min-width:620px;">
                  <fieldset class="hack-rank-picker" aria-label="Rank {{ .Title }}">
                    <label class="hack-rank-option">
                      <input type="radio" name="{{ printf "Rank_%s" .ID }}" value="" {{ if not $scorecard }}checked{{ else }}{{ if eq ($.ScoreValue $scorecard.Rank) "" }}checked{{ end }}{{ end }}>
                      <span>Not ranked</span>
                    </label>
                    {{ range $.RankOptions $event }}
                    {{ $rank := . }}
                    <label class="hack-rank-option">
                      <input type="radio" name="{{ printf "Rank_%s" $project.ID }}" value="{{ . }}" {{ with $scorecard }}{{ if eq ($.ScoreValue .Rank) (printf "%d" $rank) }}checked{{ end }}{{ end }}>
                      <span>{{ $.RankOptionLabel $event . }}</span>
                    </label>
                    {{ end }}
                  </fieldset>
                </td>
              </tr>
              {{ end }}
            </tbody>
          </table>
        </div>
      </form>
      {{ end }}
      {{ end }}
    </section>
    {{ end }}

    <section class="hack-section">
      <div class="hack-section__head">
        <div>
          <div class="hack-label">§ Projects</div>
          <h2>Visible <span class="hack-serif">submissions.</span></h2>
        </div>
        <div class="hack-section__deck">{{ len .Projects }} visible project{{ if ne (len .Projects) 1 }}s{{ end }}.</div>
      </div>
      {{ if .Projects }}
      <div class="hack-card-grid">
        {{ range .Projects }}
        <article id="project-{{ .ID }}" class="hack-card">
          <div class="hack-card__body">
            <div class="hack-tags">
              <span class="hack-tag">{{ $.ProjectNumberLabel . }}</span>
              <span class="hack-tag">{{ $.ProjectStatusLabel .Status }}</span>
            </div>
            <h3>{{ .Title }}</h3>
            {{ if .ShortDescription }}<div class="hack-card__desc">{{ .ShortDescription }}</div>{{ end }}
            {{ if .Description }}<div class="hack-copy__body" style="font-size:14px;line-height:1.55;">{{ hackathonRichText .Description }}</div>{{ end }}
            {{ if .Tags }}
            <div class="hack-tags">
              {{ range .Tags }}<span class="hack-tag">{{ . }}</span>{{ end }}
            </div>
            {{ end }}
            <div class="hack-card__links">
              {{ if .GitHubURL }}<a href="{{ .GitHubURL }}">GitHub</a>{{ end }}
              {{ if .DemoURL }}<a href="{{ .DemoURL }}">Demo</a>{{ end }}
              {{ if .VideoURL }}<a href="{{ .VideoURL }}">Video</a>{{ end }}
              {{ if .SlidesURL }}<a href="{{ .SlidesURL }}">Slides</a>{{ end }}
              {{ if .DocsURL }}<a href="{{ .DocsURL }}">Docs</a>{{ end }}
            </div>
          </div>
        </article>
        {{ end }}
      </div>
      {{ else }}
      <div class="hack-empty">No projects are visible yet.</div>
      {{ end }}
    </section>
  </main>
  <script>
    (function () {
      const times = Array.prototype.slice.call(document.querySelectorAll('.hackathon-judging-time'));
      const tz = Intl.DateTimeFormat().resolvedOptions().timeZone || 'UTC';
      for (const el of times) {
        const value = el.getAttribute('datetime');
        if (!value) continue;
        const date = new Date(value);
        el.textContent = new Intl.DateTimeFormat(undefined, {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
          hour: 'numeric',
          minute: '2-digit',
          timeZone: tz,
          timeZoneName: 'short'
        }).format(date);
      }
    })();
    (function () {
      const pickers = Array.prototype.slice.call(document.querySelectorAll('fieldset[aria-label^="Rank "]'));
      for (const picker of pickers) {
        const checked = picker.querySelector('input[type="radio"]:checked');
        picker.dataset.currentRank = checked ? checked.value : '';
      }

      document.addEventListener('change', function (event) {
        const selected = event.target;
        if (!selected.matches('fieldset[aria-label^="Rank "] input[type="radio"]') || !selected.checked) return;

        const form = selected.closest('form');
        const selectedPicker = selected.closest('fieldset[aria-label^="Rank "]');
        if (!form || !selectedPicker) return;

        const previousRank = selectedPicker.dataset.currentRank || '';
        selectedPicker.dataset.currentRank = selected.value;
        if (selected.value === '') return;

        const choices = Array.prototype.slice.call(form.querySelectorAll('fieldset[aria-label^="Rank "] input[type="radio"]'));
        for (const choice of choices) {
          if (choice === selected || choice.value !== selected.value || !choice.checked) continue;
          choice.checked = false;

          const picker = choice.closest('fieldset[aria-label^="Rank "]');
          if (!picker) continue;
          const replacement = Array.prototype.find.call(picker.querySelectorAll('input[type="radio"]'), function (input) {
            return input.value === previousRank;
          });
          if (replacement) {
            replacement.checked = true;
            picker.dataset.currentRank = replacement.value;
          }
        }
      });
    })();
  </script>
  {{ block "footer" . }} {{ end }}
</body>
</html>
