<!doctype html>
<html lang="en">
<head>
  <title>Judging - {{ .Competition.Title }} - bitcoin++ hackathon</title>
  {{ block "header" . }} {{ end }}
</head>
<body class="bg-gray-50 text-gray-900">
  {{ block "mainnav" . }} {{ end }}
  <main class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <a href="/hackathons/{{ .Competition.Slug }}" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">&larr; Hackathon</a>
        <h1 class="mt-2 text-3xl font-semibold tracking-tight">Judging</h1>
        <p class="mt-1 text-sm text-gray-600">{{ .Competition.Title }}</p>
      </div>
      <a href="{{ .ScheduleURL }}" class="inline-flex items-center justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-gray-300 hover:bg-gray-50">Schedule</a>
    </div>

    {{ if .FlashMessage }}
    <div class="mb-4 rounded-md border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-800">{{ .FlashMessage }}</div>
    {{ end }}
    {{ if .FlashError }}
    <div class="mb-4 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">{{ .FlashError }}</div>
    {{ end }}

    <section class="mb-8 rounded-lg bg-white shadow">
      <div class="border-b border-gray-200 px-4 py-4 sm:px-6">
        <h2 class="text-sm font-semibold text-gray-900">Judge events</h2>
      </div>
      <div class="px-4 py-5 sm:p-6">
        {{ if .JudgeEvents }}
        <div class="grid gap-3 md:grid-cols-2">
          {{ range .JudgeEvents }}
          <article class="rounded-md border border-gray-200 px-4 py-3">
            <div class="flex items-start justify-between gap-3">
              <div>
                <h3 class="text-sm font-semibold text-gray-900">{{ .Name }}</h3>
                <p class="mt-1 text-xs text-gray-500">{{ $.JudgeTypeLabel .PlaybookType }}{{ if .StartingProjectNumber }} · starts at #{{ .StartingProjectNumber }}{{ end }}</p>
              </div>
	              <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-700">{{ $.RankLimit . }} ranks</span>
            </div>
            <div class="mt-3 text-sm text-gray-700">
              {{ if or .StartsAt .EndsAt }}
              {{ if .StartsAt }}<div>Starts: <time class="hackathon-judging-time" datetime="{{ .StartsAt.Format "2006-01-02T15:04:05Z07:00" }}">{{ .StartsAt.Format "2006-01-02 15:04" }}</time></div>{{ end }}
              {{ if .EndsAt }}<div>Ends: <time class="hackathon-judging-time" datetime="{{ .EndsAt.Format "2006-01-02T15:04:05Z07:00" }}">{{ .EndsAt.Format "2006-01-02 15:04" }}</time></div>{{ end }}
              {{ else }}
              <div>Time TBA</div>
              {{ end }}
            </div>
          </article>
          {{ end }}
        </div>
        {{ else }}
        <p class="text-sm text-gray-600">No judge events have been set up yet.</p>
        {{ end }}
      </div>
    </section>

    {{ if and .Projects .JudgeEvents }}
    <section class="mb-8 space-y-4">
      <div class="flex items-center justify-between gap-4">
        <h2 class="text-lg font-semibold text-gray-900">Rank projects</h2>
        <span class="text-sm text-gray-500">Choose each rank once per event</span>
      </div>
      {{ range .JudgeEvents }}
      {{ if $.CanScoreJudgeEvent . }}
      {{ $event := . }}
      <form id="event-{{ .ID }}" method="POST" action="{{ $.JudgingURL }}/scorecards" class="overflow-hidden rounded-lg bg-white shadow">
        <input type="hidden" name="JudgeEventID" value="{{ .ID }}">
        <div class="border-b border-gray-200 px-4 py-4 sm:px-6">
          <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <h3 class="text-sm font-semibold text-gray-900">{{ .Name }}</h3>
              <p class="text-xs text-gray-500">{{ $.JudgeTypeLabel .PlaybookType }} · rank your top {{ $.RankLimit . }}</p>
            </div>
            <button type="submit" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Save rankings</button>
          </div>
        </div>
        <div class="divide-y divide-gray-100">
          {{ range $.Projects }}
          {{ $project := . }}
          {{ $scorecard := $.Scorecard .ID $event.ID }}
          <div class="grid gap-3 px-4 py-3 sm:grid-cols-[1fr_minmax(38rem,42rem)] sm:items-center sm:px-6">
            <input type="hidden" name="ProjectID" value="{{ .ID }}">
            <div>
              <div class="flex flex-wrap items-center gap-2">
                <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-700">{{ $.ProjectNumberLabel . }}</span>
                <span class="text-sm font-medium text-gray-900">{{ .Title }}</span>
              </div>
              {{ if .ShortDescription }}
              <p class="mt-1 text-sm text-gray-600">{{ .ShortDescription }}</p>
              {{ end }}
            </div>
            <fieldset class="grid auto-cols-fr grid-flow-col gap-2 overflow-x-auto" aria-label="Rank {{ .Title }}">
              <label class="inline-flex min-w-28 cursor-pointer items-center justify-center gap-2 whitespace-nowrap rounded-md border border-gray-300 bg-white px-2.5 py-2 text-xs font-semibold text-gray-700">
                <input type="radio" name="{{ printf "Rank_%s" .ID }}" value="" {{ if not $scorecard }}checked{{ else }}{{ if eq ($.ScoreValue $scorecard.Rank) "" }}checked{{ end }}{{ end }}>
                <span>Not ranked</span>
              </label>
              {{ range $.RankOptions $event }}
              {{ $rank := . }}
              <label class="inline-flex min-w-28 cursor-pointer items-center justify-center gap-2 whitespace-nowrap rounded-md border border-gray-300 bg-white px-2.5 py-2 text-xs font-semibold text-gray-700">
                <input type="radio" name="{{ printf "Rank_%s" $project.ID }}" value="{{ . }}" {{ with $scorecard }}{{ if eq ($.ScoreValue .Rank) (printf "%d" $rank) }}checked{{ end }}{{ end }}>
                <span>{{ $.RankOptionLabel $event . }}</span>
              </label>
              {{ end }}
            </fieldset>
          </div>
          {{ end }}
        </div>
      </form>
      {{ end }}
      {{ end }}
    </section>
    {{ end }}

    <section>
      <div class="mb-4 flex items-center justify-between gap-4">
        <h2 class="text-lg font-semibold text-gray-900">Projects</h2>
        <span class="text-sm text-gray-500">{{ len .Projects }} visible</span>
      </div>
      {{ if .Projects }}
      <div class="space-y-4">
        {{ range .Projects }}
        {{ $project := . }}
        <article id="project-{{ .ID }}" class="rounded-lg bg-white p-5 shadow">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <div class="flex flex-wrap items-center gap-2">
                <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-700">{{ $.ProjectNumberLabel . }}</span>
                <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-700">{{ $.ProjectStatusLabel .Status }}</span>
              </div>
              <h3 class="mt-2 text-base font-semibold text-gray-900">{{ .Title }}</h3>
              {{ if .ShortDescription }}
              <p class="mt-1 text-sm text-gray-600">{{ .ShortDescription }}</p>
              {{ end }}
            </div>
          </div>
          {{ if .Description }}
          <p class="mt-4 whitespace-pre-line text-sm leading-6 text-gray-700">{{ .Description }}</p>
          {{ end }}
          {{ if .Tags }}
          <div class="mt-4 flex flex-wrap gap-2">
            {{ range .Tags }}
            <span class="rounded-full bg-indigo-50 px-2 py-0.5 text-xs font-medium text-indigo-700">{{ . }}</span>
            {{ end }}
          </div>
          {{ end }}
          <div class="mt-4 flex flex-wrap gap-x-4 gap-y-2 text-sm">
            {{ if .GitHubURL }}<a class="font-medium text-indigo-600 hover:text-indigo-500" href="{{ .GitHubURL }}">GitHub</a>{{ end }}
            {{ if .DemoURL }}<a class="font-medium text-indigo-600 hover:text-indigo-500" href="{{ .DemoURL }}">Demo</a>{{ end }}
            {{ if .VideoURL }}<a class="font-medium text-indigo-600 hover:text-indigo-500" href="{{ .VideoURL }}">Video</a>{{ end }}
            {{ if .SlidesURL }}<a class="font-medium text-indigo-600 hover:text-indigo-500" href="{{ .SlidesURL }}">Slides</a>{{ end }}
            {{ if .DocsURL }}<a class="font-medium text-indigo-600 hover:text-indigo-500" href="{{ .DocsURL }}">Docs</a>{{ end }}
          </div>
	        </article>
        {{ end }}
      </div>
      {{ else }}
      <div class="rounded-lg bg-white px-4 py-10 text-center shadow">
        <p class="text-sm text-gray-600">No projects are visible yet.</p>
      </div>
      {{ end }}
    </section>
  </main>
  <script>
    (function () {
      const times = Array.prototype.slice.call(document.querySelectorAll('.hackathon-judging-time'));
      const tz = Intl.DateTimeFormat().resolvedOptions().timeZone || 'UTC';
      for (const el of times) {
        const value = el.getAttribute('datetime');
        if (!value) continue;
        const date = new Date(value);
        el.textContent = new Intl.DateTimeFormat(undefined, {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
          hour: 'numeric',
          minute: '2-digit',
          timeZone: tz,
          timeZoneName: 'short'
        }).format(date);
      }
    })();
    (function () {
      const pickers = Array.prototype.slice.call(document.querySelectorAll('fieldset[aria-label^="Rank "]'));
      for (const picker of pickers) {
        const checked = picker.querySelector('input[type="radio"]:checked');
        picker.dataset.currentRank = checked ? checked.value : '';
      }

      document.addEventListener('change', function (event) {
        const selected = event.target;
        if (!selected.matches('fieldset[aria-label^="Rank "] input[type="radio"]') || !selected.checked) return;

        const form = selected.closest('form');
        const selectedPicker = selected.closest('fieldset[aria-label^="Rank "]');
        if (!form || !selectedPicker) return;

        const previousRank = selectedPicker.dataset.currentRank || '';
        selectedPicker.dataset.currentRank = selected.value;
        if (selected.value === '') return;

        const choices = Array.prototype.slice.call(form.querySelectorAll('fieldset[aria-label^="Rank "] input[type="radio"]'));
        for (const choice of choices) {
          if (choice === selected || choice.value !== selected.value || !choice.checked) continue;
          choice.checked = false;

          const picker = choice.closest('fieldset[aria-label^="Rank "]');
          if (!picker) continue;
          const replacement = Array.prototype.find.call(picker.querySelectorAll('input[type="radio"]'), function (input) {
            return input.value === previousRank;
          });
          if (replacement) {
            replacement.checked = true;
            picker.dataset.currentRank = replacement.value;
          }
        }
      });
    })();
  </script>
  {{ block "footer" . }} {{ end }}
</body>
</html>
