<!DOCTYPE html>
<html lang="en">
  <head>
    {{ template "site_seo" (dict "Title" (printf "Apply to speak at %s" .Conf.Desc) "Description" (printf "Apply to talk, present a workshop, or join a panel at %s, %s." .Conf.Desc .Conf.DateDesc) "Path" (printf "/talk/%s" .Conf.Tag) "Image" (confSocialImage .Conf.Tag "standard")) }}
    {{ template "form_page_header" . }}
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>✨</text></svg>">
  </head>
  <body class="btcpp-form-page">
    {{ block "mainnav" . }} {{ end }}
    <main class="btcpp-apply-page">
    <section id="form">
        <div class="isolate bg-white px-6 py-24 sm:py-32 lg:px-8">
            <div class="btcpp-form-layout">
            <div class="mx-auto max-w-2xl text-center" data-form-kicker="§00 · CALL FOR PRESENTERS">
                {{ if .InviteMode }}
                {{ if .EditTalkContent }}
                <h2 class="text-balance text-4xl font-semibold tracking-tight text-gray-900 sm:text-5xl">You're Invited!</h2>
                <p class="mt-2 text-lg/8 text-gray-600">Speak at <span class="font-semibold">{{ .Conf.Desc }}</span>{{ if .Conf.DateDesc }}, {{ .Conf.DateDesc }}{{ end }}.</p>
                <p class="mt-2 text-lg/8 text-gray-600">Fill in your talk details and bio below, then accept the invitation to lock it in.</p>
                {{ else }}
                <h2 class="text-balance text-4xl font-semibold tracking-tight text-gray-900 sm:text-5xl">Co-speaker Invitation</h2>
                <p class="mt-2 text-lg/8 text-gray-600">You've been invited to co-present <span class="font-semibold">"{{ .Proposal.Title }}"</span>{{ if .Conf }} at {{ .Conf.Desc }}{{ end }}.</p>
                <p class="mt-2 text-lg/8 text-gray-600">Fill in your details below to be added to the talk.</p>
                {{ end }}
                {{ else }}
                <h2 class="text-balance text-4xl font-semibold tracking-tight text-gray-900 sm:text-5xl">Speaker Signup</h2>
                <p class="mt-2 text-lg/8 text-gray-600">Apply to talk or present at {{ .Conf.Desc }}.</p>
                <p class="mt-2 text-lg/8 text-gray-600">Applications are due at 12:00 midnight on {{ .DueDate }}</p>
                {{ end }}
                <div class="btcpp-form-meta">
                    <div class="btcpp-form-meta__item">
                        <span class="btcpp-form-meta__label">Edition</span>
                        <span class="btcpp-form-meta__value">{{ .Conf.Desc }}</span>
                    </div>
                    {{ if .Conf.DateDesc }}
                    <div class="btcpp-form-meta__item">
                        <span class="btcpp-form-meta__label">Dates</span>
                        <span class="btcpp-form-meta__value">{{ .Conf.DateDesc }}</span>
                    </div>
                    {{ end }}
                    {{ if not .InviteMode }}
                    <div class="btcpp-form-meta__item">
                        <span class="btcpp-form-meta__label">CFP closes</span>
                        <span class="btcpp-form-meta__value">{{ .DueDate }}</span>
                    </div>
                    {{ end }}
                </div>
            </div>
            <div class="btcpp-form-panel">
            <form action="#"
            {{ if .InviteMode }}
            hx-post="/invite-speaker/{{ .Proposal.ID }}?t={{ .InviteToken }}"
            {{ else if .HMAC }}
            hx-post="/talk/{{ .Conf.Tag }}?hr={{ .HMAC }}&em={{ .Email }}"
            {{ else }}
            hx-post="/talk/{{ .Conf.Tag }}"
            {{ end }}
            class="btcpp-form-kit mx-auto mt-16 max-w-xl sm:mt-20"
            hx-validate="true"
            hx-target="#result"
            hx-swap="innerHTML show:#result:top"
            hx-disabled-elt="find input[type='text'], find button"
            enctype="multipart/form-data"
            >
                <div class="grid grid-cols-1 gap-x-8 gap-y-6 sm:grid-cols-2">
                    {{ if and $.KnownSpeaker $.KnownSpeaker.Name }}
                    <input type="hidden" name="Name" value="{{ $.KnownSpeaker.Name }}" />
                    {{ else }}
                    <div class="sm:col-span-2">
                        <label for="Name" class="block text-sm/6 font-semibold text-gray-900">Name or Nym *</label>
                        <div class="mt-2.5">
                            <input id="Name" type="text" name="Name"
                            autocomplete="name"
                            autoCorrect="off" autoCapitalize="off" spellCheck="false"
                            placeholder="Your Name"
                            required
                            class="block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin" />
                        </div>
                    </div>
                    {{ end }}
                    {{ if and $.KnownSpeaker $.KnownSpeaker.Phone }}
                    <input type="hidden" name="Phone" value="{{ $.KnownSpeaker.Phone }}" />
                    {{ else }}
                    <div class="sm:col-span-2">
                        <label for="Phone" class="block text-sm/6 font-semibold text-gray-900">Phone number</label>
                        <div class="mt-2.5">
                            <input id="Phone" type="tel" name="Phone"
                            autoComplete="home tel"
                            autoCorrect="off" autoCapitalize="off" spellCheck="false"
                            placeholder="+1 555-928-1900"
                            class="block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin" />
                        </div>
                    </div>
                    {{ end }}
                    {{ if and $.KnownSpeaker $.KnownSpeaker.Email }}
                    <input type="hidden" name="Email" value="{{ $.KnownSpeaker.Email }}" />
                    {{ else }}
                    <div class="sm:col-span-2">
                        <label for="Email" class="block text-sm/6 font-semibold text-gray-900">Email *</label>
                        <div class="mt-2.5">
                            <input id="Email" type="Email" name="Email"
                            required
                            autocomplete="email" class="block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin" placeholder="hello@example.com" />
                        </div>
                    </div>
                    {{ end }}
                    {{ if and $.KnownSpeaker $.KnownSpeaker.Signal }}
                    <input type="hidden" name="Signal" value="{{ $.KnownSpeaker.Signal }}" />
                    {{ else }}
                    <div class="sm:col-span-2">
                        <label for="Signal" class="block text-sm/6 font-semibold text-gray-900">Signal Username or Number *</label>
                        <div class="mt-2.5">
                            <input
                            name="Signal" id="Signal" type="text"
                            autoComplete="off" autoCorrect="off" autoCapitalize="off" spellCheck="false"
                            placeholder="example.99"
                            required
                            class="block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin" />
                        </div>
                    </div>
                    {{ end }}
                    {{ if and $.KnownSpeaker $.KnownSpeaker.Telegram }}
                    <input type="hidden" name="Telegram" value="{{ $.KnownSpeaker.Telegram }}" />
                    {{ else }}
                    <div class="sm:col-span-2">
                        <label for="Telegram" class="block text-sm/6 font-semibold text-gray-900">Telegram Username or Number</label>
                        <div class="mt-2.5">
                            <input
                            name="Telegram" id="Telegram" type="text"
                            autoComplete="off" autoCorrect="off" autoCapitalize="off" spellCheck="false"
                            placeholder="@niftynei"
                            class="block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin" />
                        </div>
                    </div>
                    {{ end }}
                    <div class="sm:col-span-2">
                        <label for="Hometown" class="block text-sm/6 font-semibold text-gray-900">I'll be traveling from... *</label>
                        <div class="mt-2.5">
                            <input
                            name="Hometown" id="Hometown" type="text"
                            autoComplete="off" autoCorrect="off" autoCapitalize="off" spellCheck="false"
                            placeholder="Hometown, USA"
                            required
                            value="{{ if $.KnownSpeakerConf }}{{ $.KnownSpeakerConf.ComingFrom }}{{ end }}"
                            class="block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin" />
                        </div>
                    </div>
                    <div class="sm:col-span-2">
                        <label for="Visa" class="block text-sm/6 font-semibold text-gray-900">
                        Will you need a Visa to attend? *
                        </label>
                        <div class="mt-2.5">
                            {{ $visa := "No" }}{{ if and $.KnownSpeakerConf $.KnownSpeakerConf.Visa }}{{ $visa = $.KnownSpeakerConf.Visa }}{{ end }}
                            <select id="Visa" name="Visa"
                                autocomplete="off"
                                aria-label="Need Visa?"
                                required
                                class="col-start-1 row-start-1 w-full appearance-none rounded-md py-2 pl-3.5 pr-7 text-base text-gray-500 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin sm:text-sm/6">
                                <option value="No" {{ if eq $visa "No" }}selected{{ end }}>No</option>
                                <option value="Yes" {{ if eq $visa "Yes" }}selected{{ end }}>Yes</option>
                                <option value="IDK" {{ if eq $visa "IDK" }}selected{{ end }}>I don't know</option>
                            </select>
                        </div>
                    </div>

                    {{ if and $.KnownSpeaker $.KnownSpeaker.Twitter.Handle }}
                    <input type="hidden" name="Twitter" value="{{ $.KnownSpeaker.Twitter.Handle }}" />
                    {{ else }}
                    <div class="sm:col-span-2">
                        <label for="Twitter" class="block text-sm/6 font-semibold text-gray-900">
                        X Account Username
                        </label>
                        <div class="mt-2.5">
                            <input
                            name="Twitter" id="Twitter" type="text"
                            autoComplete="off" autoCorrect="off" autoCapitalize="off" spellCheck="false"
                            placeholder="@niftynei"
                            class="block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin" />
                        </div>
                    </div>
                    {{ end }}
                    {{ if and $.KnownSpeaker $.KnownSpeaker.Nostr }}
                    <input type="hidden" name="Nostr" value="{{ $.KnownSpeaker.Nostr }}" />
                    {{ else }}
                    <div class="sm:col-span-2">
                        <label for="Nostr" class="block text-sm/6 font-semibold text-gray-900">
                        Nostr Npub
                        </label>
                        <div class="mt-2.5">
                            <input
                            name="Nostr" id="Nostr" type="text"
                            autoComplete="off" autoCorrect="off" autoCapitalize="off" spellCheck="false"
                            placeholder="npub1dwah..."
                            class="block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin" />
                        </div>
                    </div>
                    {{ end }}
                    {{ if and $.KnownSpeaker $.KnownSpeaker.Github }}
                    <input type="hidden" name="Github" value="{{ trim $.KnownSpeaker.Github }}" />
                    {{ else }}
                    <div class="sm:col-span-2">
                        <label for="Github" class="block text-sm/6 font-semibold text-gray-900">Link to your Github profile</label>
                        <div class="mt-2.5">
                            <input
                            name="Github" id="Github" type="url"
                            autoComplete="link" autoCorrect="off" autoCapitalize="off" spellCheck="false"
                            placeholder="https://github.com/niftynei"
                            class="block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin" />
                        </div>
                    </div>
                    {{ end }}
                    {{ if and $.KnownSpeaker $.KnownSpeaker.Website }}
                    <input type="hidden" name="Website" value="{{ trim $.KnownSpeaker.Website }}" />
                    {{ else }}
                    <div class="sm:col-span-2">
                        <label for="Website" class="block text-sm/6 font-semibold text-gray-900">Personal website</label>
                        <div class="mt-2.5">
                            <input
                            name="Website" id="Website" type="url"
                            autoComplete="link" autoCorrect="off" autoCapitalize="off" spellCheck="false"
                            placeholder="https://basicbitch.software"
                            class="block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin" />
                        </div>
                    </div>
                    {{ end }}

                    {{ if not (and $.KnownSpeaker $.KnownSpeaker.Photo) }}
                    <div class="sm:col-span-2">
                        <label for="PicFile" class="block text-sm/6 font-semibold text-gray-900">
                        Your pfp (Profile Picture) *
                        </label>
                        <div class="block text-sm/6 text-gray-600">
                        Square works best — you'll get a chance to crop after selecting. Less than 10MB.
                        </div>
                        <div class="mt-2.5">
                            <input
                            name="PicFile" id="PicFile" type="file"
                            accept="image/*"
                            required
                            class="block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin" />
                        </div>
                        <div id="PicError" class="mt-2.5 hidden rounded-md border border-red-200 bg-red-50 p-3 text-sm text-red-700" role="alert" aria-live="polite"></div>
                        <div id="PicPreview" class="mt-2.5 hidden">
                            <div class="flex items-start gap-3">
                                <img id="PicPreviewImg" alt="cropped preview" class="h-24 w-24 flex-none rounded-md object-cover ring-1 ring-gray-300" />
                                <div class="flex flex-col gap-2">
                                    <div class="text-xs text-gray-500">Cropped preview. Pick a different file or re-crop to adjust.</div>
                                    <div class="flex flex-wrap gap-2">
                                        <button type="button" id="PicRecrop" class="self-start rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50">Re-crop</button>
                                        <button type="button" id="PicClear" class="self-start rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm font-semibold text-red-700 hover:bg-red-100">Clear</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    {{ end }}

                    {{ if and $.KnownSpeaker $.KnownSpeaker.TShirt }}
                    <input type="hidden" name="Shirt" value="{{ $.KnownSpeaker.TShirt }}" />
                    {{ else }}
                    <div class="sm:col-span-2">
                        <label for="Shirt" class="block text-sm/6 font-semibold text-gray-900">
                        Shirt Size *
                        </label>
                        <div class="mt-2.5">
                            <select id="Shirt" name="Shirt"
                                autocomplete="off"
                                aria-label="Shirt Size"
                                required
                                class="col-start-1 row-start-1 w-full appearance-none rounded-md py-2 pl-3.5 pr-7 text-base text-gray-500 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin sm:text-sm/6">
                                <option value="LS">Ladies Small</option>
                                <option value="LM">Ladies Medium</option>
                                <option value="LL">Ladies Large</option>
                                <option value="MS">Men's Small</option>
                                <option value="MM" selected>Men's Medium</option>
                                <option value="ML">Men's Large</option>
                                <option value="MXL">Men's XL</option>
                                <option value="MXXL">Men's XXL</option>
                                <option value="MXXXL">Men's XXXL</option>
                            </select>
                        </div>
                    </div>
                    {{ end }}

                    <div class="sm:col-span-2">
                        <label for="Org" class="block text-sm/6 font-semibold text-gray-900">
                        Company or Organizational Affiliation *
                        </label>
                        <div class="mt-2.5">
                            {{ $org := "" }}{{ if and $.KnownSpeakerConf $.KnownSpeakerConf.Company }}{{ $org = $.KnownSpeakerConf.Company }}{{ else if and $.KnownSpeaker $.KnownSpeaker.Company }}{{ $org = $.KnownSpeaker.Company }}{{ end }}
                            <input
                            name="Org" id="Org" type="text"
                            autoComplete="organization" autoCorrect="off" autoCapitalize="off" spellCheck="false"
                            placeholder="bitcoin++"
                            required
                            value="{{ $org }}"
                            class="block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin" />
                        </div>
                    </div>

                    <div class="flex gap-x-4 sm:col-span-2">
                        <div class="flex h-6 items-center">
                            <div class="group relative inline-flex w-8 shrink-0 rounded-full bg-gray-200 p-px outline-offset-2 outline-bitcoin ring-1 ring-inset ring-gray-900/5 transition-colors duration-200 ease-in-out has-[:checked]:bg-bitcion has-[:focus-visible]:outline has-[:focus-visible]:outline-2">
                                <span class="size-4 rounded-full bg-white shadow-sm ring-1 ring-gray-900/5 transition-transform duration-200 ease-in-out group-has-[:checked]:translate-x-3.5"></span>
                                <input id="Sponsor" type="checkbox" name="Sponsor" aria-label="Subscribe to Newsletter" {{ if and $.KnownSpeakerConf $.KnownSpeakerConf.Sponsor }}checked{{ end }} class="absolute inset-0 size-full appearance-none focus:outline-none text-bitcoin" />
                            </div>
                        </div>
                        <label for="Sponsor" class="text-sm/6 text-gray-600">
                        Send me information about sponsoring <span class="font-bitcoin">bitcoin++</span>!
                        </label>
                    </div>
                    
                    <div class="sm:col-span-2">
                        <label for="OrgLogoFile" class="block text-sm/6 font-semibold text-gray-900">
                        Org's Logo
                        </label>
                        <div class="block text-sm/6 text-gray-600">
                        Must be less than 10MB.
                        </div>
                        <div class="mt-2.5">
                            <input 
                            name="OrgLogoFile" id="OrgLogoFile" type="file" 
                            class="block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin" />
                        </div>
                    </div>

                    {{ if or (not .InviteMode) .EditTalkContent }}
                    {{ $title := "" }}{{ if and .Proposal .Proposal.Title (not (hasPrefix .Proposal.Title "TBD (")) }}{{ $title = .Proposal.Title }}{{ end }}
                    {{ $desc := "" }}{{ if and .Proposal .Proposal.Description (ne .Proposal.Description "Description to come") }}{{ $desc = .Proposal.Description }}{{ end }}
                    {{ $setup := "" }}{{ if .Proposal }}{{ $setup = .Proposal.Setup }}{{ end }}
                    <div class="sm:col-span-2">
                        <label for="TalkTitle" class="block text-sm/6 font-semibold text-gray-900">
                        Talk/Workshop Title *
                        </label>
                        <div class="mt-2.5">
                            <input
                            name="TalkTitle" id="TalkTitle" type="text"
                            autoComplete="off" autoCorrect="off"
                            autoCapitalize="off" spellCheck="false"
                            placeholder="Lightning at the edges..."
                            required
                            value="{{ $title }}"
                            class="block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin" />
                        </div>
                    </div>

                    <div class="sm:col-span-2">
                        <label for="Description" class="block text-sm/6 font-semibold text-gray-900">
                        Talk/Workshop Description *
                        </label>
                        <div class="mt-2.5">
                            <textarea
                            name="Description" id="Description"
                            autoComplete="off" autoCorrect="off" autoCapitalize="off" spellCheck="false"
                            placeholder="This talk will..."
                            rows="3"
                            required
                            class="block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin">{{ $desc }}</textarea>
                        </div>
                    </div>

                    <fieldset>
                        <legend class="block text-sm/6 font-semibold text-gray-900">
                        Presentation Length *
                        </legend>
                        <div class="mt-2.5">
                        {{ range .PresentationType }}
                           {{ block "form_radiolist" . }} {{ end }}
                        {{ end }}
                        </div>
                    </fieldset>
                    {{ end }}

                    <fieldset class="sm:col-span-2">
                        <legend class="block text-sm/6 font-semibold text-gray-900">
                        Recording *
                        </legend>
                        <div class="mt-2.5">
                        {{ range .RecordingOptions }}
                           {{ block "form_radiolist" . }} {{ end }}
                        {{ end }}
                        </div>
                    </fieldset>

                    {{ if or (not .InviteMode) .EditTalkContent }}
                    <div class="sm:col-span-2">
                        <label for="Setup" class="block text-sm/6 font-semibold text-gray-900">
                        Workshop / talk setup notes
                        </label>
                        <div class="block text-sm/6 text-gray-600">
                        Optional. If your session needs participants to install software, bring hardware, or do anything ahead of time, list it here so we can pass it on.
                        </div>
                        <div class="mt-2.5">
                            <textarea
                            name="Setup" id="Setup"
                            autoComplete="off" autoCorrect="off" autoCapitalize="off" spellCheck="false"
                            placeholder="e.g. Please install Bitcoin Core 27.0 on your laptop ahead of the workshop."
                            rows="3"
                            class="block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin">{{ if .Proposal }}{{ .Proposal.Setup }}{{ end }}</textarea>
                        </div>
                    </div>
                    {{ end }}

                    <fieldset class="sm:col-span-2">
                        <legend class="block text-sm/6 font-semibold text-gray-900">
                        Days I'm Available to Present *
                        </legend>
                        <div class="mt-2.5">
                        {{ range .DaysList }}
                           {{ block "form_list" . }} {{ end }}
                        {{ end }}
                        </div>
                    </fieldset>

                    <div class="sm:col-span-2">
                        <label for="DinnerOpt" class="block text-sm/6 font-semibold text-gray-900">
                        I'll be able to attend the VIP dinner on {{ .RSVPFor }}, the night before the conference starts.
                        </label>
                        <div class="mt-2.5">
                            {{ $dinnerYes := true }}{{ if and $.KnownSpeakerConf (not $.KnownSpeakerConf.DinnerRSVP) }}{{ $dinnerYes = false }}{{ end }}
                            <select id="DinnerOpt" name="DinnerOpt"
                                autocomplete="off"
                                aria-label="Dinner RSVP"
                                required
                                class="col-start-1 row-start-1 w-full appearance-none rounded-md py-2 pl-3.5 pr-7 text-base text-gray-500 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin sm:text-sm/6">
                                <option value="Yes" {{ if $dinnerYes }}selected{{ end }}>Yes</option>
                                <option value="No" {{ if not $dinnerYes }}selected{{ end }}>No</option>
                            </select>
                        </div>
                    </div>


                    {{ if not .InviteMode }}
                    <fieldset class="sm:col-span-2">
                        <legend class="block text-sm/6 font-semibold text-gray-900">
                        Other Events I'm Interested in Presenting At
                        </legend>
                        <div class="mt-2.5">
                        {{ range .ConfItems }}
                           {{ block "form_list" . }} {{ end }}
                        {{ end }}
                        </div>
                    </fieldset>

                    <div class="sm:col-span-2">
                        <label for="Comments" class="block text-sm/6 font-semibold text-gray-900">
                        Additional Comments
                        </label>
                        <div class="mt-2.5">
                            <textarea
                            name="Comments" id="Comments"
                            autoComplete="off" autoCorrect="off" autoCapitalize="off" spellCheck="false"
                            placeholder="Excited about..."
                            rows="3"
                            class="block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin"></textarea>
                        </div>
                    </div>
                    {{ end }}

                    {{ if .IsReturningAttendee }}
                    <input type="hidden" name="FirstEvent" value="false" />
                    {{ else }}
                    <div class="flex gap-x-4 sm:col-span-2">
                        <div class="flex h-6 items-center">
                            <div class="group relative inline-flex w-8 shrink-0 rounded-full bg-gray-200 p-px outline-offset-2 outline-bitcoin ring-1 ring-inset ring-gray-900/5 transition-colors duration-200 ease-in-out has-[:checked]:bg-bitcion has-[:focus-visible]:outline has-[:focus-visible]:outline-2">
                                <span class="size-4 rounded-full bg-white shadow-sm ring-1 ring-gray-900/5 transition-transform duration-200 ease-in-out group-has-[:checked]:translate-x-3.5"></span>
                                <input id="FirstEvent" type="checkbox" name="FirstEvent" aria-label="Subscribe to Newsletter" {{ if and $.KnownSpeakerConf $.KnownSpeakerConf.FirstEvent }}checked{{ end }} class="absolute inset-0 size-full appearance-none focus:outline-none text-bitcoin" />
                            </div>
                        </div>
                        <label for="FirstEvent" class="text-sm/6 text-gray-600">
                        This is my first <span class="font-bitcoin">bitcoin++</span> event!
                        </label>
                    </div>
                    {{ end }}

                    {{ if .IsNewsletterSubscriber }}
                    <input type="hidden" name="Subscribe" value="false" />
                    {{ else }}
                    <div class="flex gap-x-4 sm:col-span-2">
                        <div class="flex h-6 items-center">
                            <div class="group relative inline-flex w-8 shrink-0 rounded-full bg-gray-200 p-px outline-offset-2 outline-bitcoin ring-1 ring-inset ring-gray-900/5 transition-colors duration-200 ease-in-out has-[:checked]:bg-bitcion has-[:focus-visible]:outline has-[:focus-visible]:outline-2">
                                <span class="size-4 rounded-full bg-white shadow-sm ring-1 ring-gray-900/5 transition-transform duration-200 ease-in-out group-has-[:checked]:translate-x-3.5"></span>
                                <input id="sub-newsletter" type="checkbox" name="Subscribe" checked aria-label="Subscribe to Newsletter" class="absolute inset-0 size-full appearance-none focus:outline-none text-bitcoin" />
                            </div>
                        </div>
                        <label for="sub-newsletter" class="text-sm/6 text-gray-600">
                        Add me to the <span class="font-bitcoin">bitcoin++</span> newsletter!
                        </label>
                    </div>
                    {{ end }}

                    {{ if not .InviteMode }}
                    <div class="sm:col-span-2">
                        <label for="Captcha" class="block text-sm/6 font-semibold text-gray-900">
                        What is ten divided by two? *
                        </label>
                        <div class="mt-2.5">
                            <input
                            name="Captcha" id="Captcha" type="number"
                            autoComplete="off" autoCorrect="off" autoCapitalize="off" spellCheck="false"
                            placeholder="5"
                            required
                            class="block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin" />
                        </div>
                    </div>
                    {{ else }}
                    <input type="hidden" name="Captcha" value="5" />
                    {{ end }}


                </div>
                <div class="mt-10">
                    <button type="submit"
                    class="inline-flex w-full items-center justify-center gap-2 rounded-md {{ if and .InviteMode .IsInvited }}bg-green-600 hover:bg-green-700 focus-visible:outline-green-600{{ else }}bg-bitcoin hover:bg-bitcoin focus-visible:outline-bitcoin{{ end }} px-3.5 py-2.5 text-center text-sm font-semibold text-white shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 disabled:opacity-60 disabled:cursor-wait">
                        <svg class="submit-spinner h-4 w-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
                        </svg>
                        <span class="submit-label-idle">{{ if .InviteMode }}{{ if .IsInvited }}Accept invitation{{ else }}Add me as a co-speaker{{ end }}{{ else }}Submit Application{{ end }}</span>
                        <span class="submit-label-busy">Submitting…</span>
                    </button>
                    {{ if and .InviteMode .IsInvited }}
                    <p class="mt-2 text-center text-xs text-gray-500">Saves your details and locks the talk in. We'll email a confirmation and issue your speaker ticket.</p>
                    {{ end }}
                </div>
            </form>
            {{ if and .InviteMode .IsInvited }}
            {{/* Decline button lives in its own form (HTML disallows
                 nesting), so the Accept submit + this Decline submit
                 don't trigger each other. Standard POST (not htmx)
                 because we redirect away on success. */}}
            <form method="POST" action="/invite-speaker/{{ .Proposal.ID }}/decline?t={{ .InviteToken }}" class="btcpp-form-secondary-action mx-auto mt-4 max-w-xl">
                <button type="submit"
                        onclick="return confirm('Decline this invitation? Your talk will not be added to the program and your co-speakers (if any) will be notified.');"
                        class="inline-flex w-full items-center justify-center rounded-md border border-gray-300 bg-white px-3.5 py-2.5 text-center text-sm font-semibold text-gray-700 hover:bg-gray-50">
                    Decline invitation
                </button>
                <p class="mt-2 text-center text-xs text-gray-500">Sorry to miss you — let us know if anything changes.</p>
            </form>
            {{ end }}
            <div id="result" class="mt-5 mx-auto max-w-xl text-red-700 scroll-mt-24">
            </div>
            </div>
            </div>
        </div>
    </section>
    </main>
    {{ template "generic_conf_footer" . }}

    {{ template "pic_cropper" . }}
  </body>
</html>
