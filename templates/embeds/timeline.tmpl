<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {{ template "site_seo" (dict "Title" "bitcoin++ Timeline · Every Edition Archived" "Description" "Explore the bitcoin++ event timeline: every edition, city, and upcoming conference." "Path" "/timeline" "Image" "/static/img/rebrand/breakthroughs.jpg") }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,300;1,400;1,600&family=IBM+Plex+Mono:wght@400;500;600;700&family=Source+Serif+4:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/static/css/btcpp-redesign.css">
    <link rel="stylesheet" href="/static/css/home-redesign.css">
    <link rel="shortcut icon" href="/static/favicon/favicon.ico" type="image/x-icon">
    <link rel="apple-touch-icon" href="/static/favicon/apple-touch-icon.png">
  </head>
  <body class="btcpp-home">
    <div class="home-page">
      {{ $next := .NextConf }}
      <div class="home-ticker" aria-label="bitcoin++ updates">
        <span class="home-ticker__label">bitcoin++</span>
        <div class="home-ticker__viewport">
          <div class="home-ticker__track">
            <div class="home-ticker__items">
              <em>NEXT</em><b>•</b>{{ if $next }}<strong>{{ $next.Desc }}</strong><b>•</b><em>{{ $next.DateDesc }}</em><b>•</b><a href="/{{ $next.Tag }}#tickets">GET TICKETS</a>{{ else }}<em>WATCH FOR THE NEXT EDITION</em>{{ end }}<b>•</b>
              <em>TECHNICAL BITCOIN CONFERENCES</em><b>•</b>
              <strong>{{ len .Past }} EDITIONS IN THE ARCHIVE</strong><b>•</b><a href="/timeline">BROWSE THE ARCHIVE</a><b>•</b>
              <em>INSIDER EDITION</em><b>•</b><a href="https://insider.btcpp.dev/" target="_blank" rel="noopener noreferrer">NEW DISPATCHES WEEKLY</a>
            </div>
            <div class="home-ticker__items">
              <em>NEXT</em><b>•</b>{{ if $next }}<strong>{{ $next.Desc }}</strong><b>•</b><em>{{ $next.DateDesc }}</em><b>•</b><a href="/{{ $next.Tag }}#tickets">GET TICKETS</a>{{ else }}<em>WATCH FOR THE NEXT EDITION</em>{{ end }}<b>•</b>
              <em>TECHNICAL BITCOIN CONFERENCES</em><b>•</b>
              <strong>{{ len .Past }} EDITIONS IN THE ARCHIVE</strong><b>•</b><a href="/timeline">BROWSE THE ARCHIVE</a><b>•</b>
              <em>INSIDER EDITION</em><b>•</b><a href="https://insider.btcpp.dev/" target="_blank" rel="noopener noreferrer">NEW DISPATCHES WEEKLY</a>
            </div>
          </div>
        </div>
      </div>

      <nav class="home-nav" aria-label="Primary navigation">
        <div class="home-nav__inner">
          <a href="/" class="home-nav__brand"><img src="/static/img/logo_blk.svg" alt="bitcoin++"></a>
          <input class="home-nav__toggle" type="checkbox" id="home-nav-toggle" aria-label="Toggle navigation">
          <div class="home-nav__controls">
            <a class="home-button is-accent home-nav__cta" href="{{ if $next }}/{{ $next.Tag }}#tickets{{ else }}/#events{{ end }}">GET TICKETS</a>
            <label class="home-nav__menu" for="home-nav-toggle" aria-label="Toggle navigation">
              <span></span><span></span><span></span>
            </label>
          </div>
          <div class="home-nav__links">
            <a href="/#events">events/</a>
            <a href="/timeline">timeline/</a>
            <a href="/whois">whois/</a>
            <a href="/dashboard">dashboard/</a>
            <a href="https://shop.btcpp.dev/" target="_blank" rel="noopener noreferrer">shop/</a>
            <a href="https://insider.btcpp.dev/" target="_blank" rel="noopener noreferrer">insider/</a>
          </div>
        </div>
      </nav>

      <main>
        <section class="timeline-hero">
          <div class="timeline-hero__grid">
            <div>
              <p class="home-section-label">The permanent record</p>
              <h1>Every edition, <span class="home-serif">archived.</span></h1>
            </div>
            <p class="home-deck">{{ len .Confs }} editions since 2022: the talks, hackathons, cities, and livestreams kept where anyone can find them.</p>
          </div>
          <div class="timeline-jump">
            {{ range .Years }}<a href="#y{{ .Year }}">{{ .Year }}</a>{{ end }}
          </div>
        </section>

        {{ range .Years }}
        <section id="y{{ .Year }}" class="timeline-year">
          <div class="timeline-year__head">
            <strong>{{ .Year }}</strong>
            <span class="timeline-meta">{{ len .Confs }} edition{{ if ne (len .Confs) 1 }}s{{ end }}</span>
          </div>
          {{ range .Confs }}
          <article class="timeline-edition">
            <div class="timeline-edition__grid">
              <div class="timeline-edition__media">
                <img src="{{ confImage .Tag "leading" }}" alt="{{ .Desc }}">
                <div class="timeline-edition__shade"></div>
                <div class="timeline-edition__overlay">
                  <span class="timeline-edition__badge {{ if not .HasEnded }}is-upcoming{{ end }}">{{ if .HasEnded }}Archived{{ else }}Upcoming{{ end }}</span>
                  <div>
                    <div class="timeline-edition__city">{{ .Desc }}</div>
                    <div class="timeline-edition__theme">{{ if .Tagline }}{{ .Tagline }}{{ else }}Technical edition{{ end }}</div>
                  </div>
                </div>
              </div>
              <div class="timeline-edition__body">
                <p class="timeline-edition__copy">{{ if .OGFlavor }}{{ .OGFlavor }}{{ else }}A bitcoin++ technical conference for builders, researchers, and protocol contributors.{{ end }}</p>
                <div class="timeline-meta">{{ .DateDesc }} · {{ .Location }}{{ if .Venue }} · {{ .Venue }}{{ end }}</div>
                <div class="timeline-links">
                  <a href="/{{ .Tag }}" class="home-button {{ if not .HasEnded }}is-accent{{ end }}">{{ if .HasEnded }}View archive{{ else }}Full program{{ end }}</a>
                  {{ if not .HasEnded }}<a href="/{{ .Tag }}#tickets" class="home-button is-outline">GET TICKETS</a>{{ end }}
                </div>
              </div>
            </div>
          </article>
          {{ end }}
        </section>
        {{ end }}
      </main>

      {{ template "generic_conf_footer" . }}
    </div>
  </body>
</html>
