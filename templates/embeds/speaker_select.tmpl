<!DOCTYPE html>
<html lang="en">
<head>
    {{ template "site_seo" (dict "Title" "Speak at bitcoin++" "Description" "Apply to give a talk, lead a workshop, or join a panel at an upcoming bitcoin++ technical conference." "Path" "/talk" "Image" "/static/img/atxpromo.png") }}
    {{ template "form_page_header" . }}
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>✨</text></svg>">
</head>
<body class="btcpp-notfound-page">
{{ block "mainnav" . }} {{ end }}
<main class="btcpp-notfound">
  <section class="btcpp-newsletter-hero">
    <div>
      <p class="btcpp-newsletter-hero__label">§00 · CALL FOR PRESENTERS</p>
      <h1>Showcase your work at the <span>frontier</span> of bitcoin.</h1>
      <p>Bring a technical talk, workshop, or panel to an upcoming bitcoin++ edition. Pick the event that matches your project best.</p>
    </div>
    <a href="#open-calls" class="btcpp-newsletter-hero__action">Choose an edition</a>
  </section>

  <section id="open-calls" class="btcpp-notfound__events">
    <div class="btcpp-notfound__events-inner">
      <div class="btcpp-notfound__events-head">
        <span>Open calls for presenters</span>
        <a href="/">All events →</a>
      </div>
      {{ range .Confs }}
        {{ if .Active }}
        <a class="btcpp-notfound-event" href="/talk/{{ .Tag }}">
          <div class="btcpp-notfound-event__date">{{ .DateDesc }}</div>
          <div class="btcpp-notfound-event__image">
            <picture>
              <source srcset="/static/img/{{ .Tag }}/leading.avif" type="image/avif">
              <img src="/static/img/{{ .Tag }}/leading.png" alt="{{ .Desc }}">
            </picture>
          </div>
          <div class="btcpp-notfound-event__title">
            <div class="btcpp-notfound-event__city">{{ .Desc }}</div>
            {{ if .Tagline }}<div class="btcpp-notfound-event__theme">{{ .Tagline }}</div>{{ else if .Venue }}<div class="btcpp-notfound-event__theme">{{ .Venue }}</div>{{ end }}
          </div>
          <div class="btcpp-notfound-event__status">APPLY <span class="btcpp-notfound-event__arrow">→</span></div>
        </a>
        {{ end }}
      {{ end }}
    </div>
  </section>

  <nav class="btcpp-notfound__routes" aria-label="Related pages">
    <a class="btcpp-notfound-route" href="/">
      <strong>home/</strong>
      <p>Back to the frontier.</p>
      <span>GO →</span>
    </a>
    <a class="btcpp-notfound-route" href="/volunteer">
      <strong>volunteer/</strong>
      <p>Help run the next bitcoin++.</p>
      <span>GO →</span>
    </a>
    <a class="btcpp-notfound-route" href="/sponsor">
      <strong>sponsor/</strong>
      <p>Support the technical frontier.</p>
      <span>GO →</span>
    </a>
    <a class="btcpp-notfound-route" href="https://www.youtube.com/@btcplusplus/playlists" target="_blank" rel="noopener noreferrer">
      <strong>archive/</strong>
      <p>Watch previous talks.</p>
      <span>GO →</span>
    </a>
  </nav>
</main>
{{ block "footer" . }} {{ end }}
</body>
</html>
