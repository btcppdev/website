<!DOCTYPE html>
<html lang="en">
<head>
    <title>bitcoin++ | Page not found</title>
    {{ template "form_page_header" . }}
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>✨</text></svg>">
</head>
<body class="btcpp-notfound-page">
{{ block "mainnav" . }} {{ end }}
<main class="btcpp-notfound">
  <section class="btcpp-notfound__hero">
    <div class="btcpp-section-tag">§ERR · BLOCK NOT FOUND</div>
    <h1 class="btcpp-notfound__code">4<span>0</span>4</h1>
    <p class="btcpp-notfound__copy">This block didn't make it into the chain. The page you're after has moved, been renamed, or never existed.</p>
    <div class="btcpp-notfound__action">
      <a href="/" class="btcpp-editorial-button">Back to home →</a>
    </div>
  </section>

  <section class="btcpp-notfound__events">
    <div class="btcpp-notfound__events-inner">
      <div class="btcpp-notfound__events-head">
        <span>Or jump to an upcoming edition</span>
        <a href="/">All events →</a>
      </div>
      {{ range .Confs }}
        {{ if .Active }}
          {{ block "404_conf" . }} {{ end }}
        {{ end }}
      {{ end }}
    </div>
  </section>

  <nav class="btcpp-notfound__routes" aria-label="Popular pages">
    <a class="btcpp-notfound-route" href="/">
      <strong>home/</strong>
      <p>Back to the frontier.</p>
      <span>GO →</span>
    </a>
    <a class="btcpp-notfound-route" href="/talk">
      <strong>speak/</strong>
      <p>Apply to present at an edition.</p>
      <span>GO →</span>
    </a>
    <a class="btcpp-notfound-route" href="/volunteer">
      <strong>volunteer/</strong>
      <p>Help run the next bitcoin++.</p>
      <span>GO →</span>
    </a>
    <a class="btcpp-notfound-route" href="/sponsor">
      <strong>sponsor/</strong>
      <p>Support the technical frontier.</p>
      <span>GO →</span>
    </a>
  </nav>
</main>
{{ block "footer" . }} {{ end }}
</body>
</html>
