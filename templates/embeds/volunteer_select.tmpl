<!DOCTYPE html>
<html lang="en">
<head>
    {{ template "site_seo" (dict "Title" "Volunteer at bitcoin++" "Description" "Apply to volunteer at an upcoming bitcoin++ event and help bring the technical bitcoin community together." "Path" "/volunteer" "Image" "/static/img/atxpromo.png") }}
    {{ template "form_page_header" . }}
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>✨</text></svg>">
</head>
<body class="btcpp-notfound-page">
{{ block "mainnav" . }} {{ end }}
<main class="btcpp-notfound">
  <section class="btcpp-newsletter-hero">
    <div>
      <p class="btcpp-newsletter-hero__label">§00 · VOLUNTEER CREW</p>
      <h1>Help run the next <span>bitcoin++</span> edition.</h1>
      <p>Join the crew on the ground: check-in, wayfinding, speaker support, and the details that keep a technical event moving.</p>
    </div>
    <a href="#open-roles" class="btcpp-newsletter-hero__action">Choose an edition</a>
  </section>

  <section id="open-roles" class="btcpp-notfound__events">
    <div class="btcpp-notfound__events-inner">
      <div class="btcpp-notfound__events-head">
        <span>Upcoming volunteer crews</span>
        <a href="/">All events →</a>
      </div>
      {{ range .Confs }}
        {{ if .Active }}
        <a class="btcpp-notfound-event" href="/volunteer/{{ .Tag }}">
          <div class="btcpp-notfound-event__date">{{ .DateDesc }}</div>
          <div class="btcpp-notfound-event__image">
            <picture>
              <source srcset="/static/img/{{ .Tag }}/leading.avif" type="image/avif">
              <img src="/static/img/{{ .Tag }}/leading.png" alt="{{ .Desc }}">
            </picture>
          </div>
          <div class="btcpp-notfound-event__title">
            <div class="btcpp-notfound-event__city">{{ .Desc }}</div>
            {{ if .Tagline }}<div class="btcpp-notfound-event__theme">{{ .Tagline }}</div>{{ else if .Venue }}<div class="btcpp-notfound-event__theme">{{ .Venue }}</div>{{ end }}
          </div>
          <div class="btcpp-notfound-event__status">SIGN UP <span class="btcpp-notfound-event__arrow">→</span></div>
        </a>
        {{ end }}
      {{ end }}
    </div>
  </section>

  <nav class="btcpp-notfound__routes" aria-label="Related pages">
    <a class="btcpp-notfound-route" href="/">
      <strong>home/</strong>
      <p>Back to the frontier.</p>
      <span>GO →</span>
    </a>
    <a class="btcpp-notfound-route" href="/talk">
      <strong>speak/</strong>
      <p>Apply to present at an edition.</p>
      <span>GO →</span>
    </a>
    <a class="btcpp-notfound-route" href="/sponsor">
      <strong>sponsor/</strong>
      <p>Support the technical frontier.</p>
      <span>GO →</span>
    </a>
    <a class="btcpp-notfound-route" href="/contact">
      <strong>contact/</strong>
      <p>Ask the crew a question.</p>
      <span>GO →</span>
    </a>
  </nav>
</main>
{{ block "footer" . }} {{ end }}
</body>
</html>
