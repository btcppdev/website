<!DOCTYPE html>
<html>
  <head>
    <title>bitcoin++ | Checkout</title>
    {{ block "checkout_header" . }}{{ end }}
  </head>
  <body class="btcpp-checkout-page">
    <main class="checkout-shell">
      <aside class="checkout-hero">
        <picture>
          <source srcset="/static/img/{{ .Conf.Tag }}/leading.avif" type="image/avif">
          <img src="/static/img/{{ .Conf.Tag }}/leading.png" alt="">
        </picture>
        <div class="checkout-hero__shade"></div>
        <div class="checkout-hero__content">
          <a href="/{{ .Conf.Tag }}" class="checkout-brand"><img src="/static/img/logo_blk.svg" alt="bitcoin++"></a>
          <div>
            <p class="checkout-kicker">{{ .Conf.DateDesc }}</p>
            <h1>{{ .Conf.Desc }}</h1>
            <p>{{ .Conf.Location }}{{ if .Conf.Venue }} · {{ .Conf.Venue }}{{ end }}</p>
          </div>
        </div>
      </aside>

      <section class="checkout-panel">
        <nav class="checkout-steps" aria-label="Checkout steps" data-step="01/04" data-current="register">
          <span class="is-active" data-checkout-nav="register"><b>01</b> register</span>
          <span data-checkout-nav="addons"><b>02</b> add-ons</span>
          <span data-checkout-nav="pay"><b>03</b> pay</span>
          <span data-checkout-nav="confirmed"><b>04</b> confirmed</span>
        </nav>

        <form method="POST" class="checkout-form checkout-flow" data-checkout-flow>
          <section class="checkout-flow__step" data-checkout-step="register">
          <div class="checkout-copy">
            {{ if .SponsorCheckout }}
            <h2>Sponsor a builder.</h2>
            <p>Fund conference access for a student, local developer, or open-source contributor.</p>
            {{ else }}
            <h2>Let's get you registered.</h2>
            <p>Two minutes, one form, zero accounts.</p>
            {{ end }}
          </div>

          <label class="checkout-field">
            <span>Email <em>required</em></span>
            <input type="email" id="Email" name="Email" placeholder="hello@example.com" required>
            {{ if .SponsorCheckout }}
            <small>Your receipt and follow-up land here.</small>
            {{ else }}
            <small>Your ticket QR lands here.</small>
            {{ end }}
          </label>

          <div class="checkout-grid">
            <label class="checkout-field">
              <span>{{ if .SponsorCheckout }}Sponsored passes{{ else }}Tickets{{ end }}</span>
              <input type="number" name="Count" value="{{ .Count }}" min="1" max="8" required>
            </label>

            <label class="checkout-field">
              <span>Discount code <em>optional</em></span>
              <input name="Discount" id="Discount" type="search"
                autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"
                hx-post="/tix/{{ .TixSlug }}/apply-discount"
                hx-trigger="input changed delay:500ms, search"
                hx-target="#discount_result"
                hx-swap="outerHTML"
                hx-include="[name='hidden_stuffs'], [name='Count']"
                placeholder="Have a code?"
                {{ if ne .Discount "" }}value="{{ .Discount }}"{{ end }}>
            </label>
          </div>

          <fieldset class="checkout-methods">
            <legend>Pay with</legend>
            <label>
              <input type="radio" name="PaymentMethod" value="btc" {{ if ne .PaymentMethod "card" }}checked{{ end }}>
              <span>
                <strong>Bitcoin</strong>
                <small>Lightning or on-chain · no card surcharge</small>
              </span>
            </label>
            <label>
              <input type="radio" name="PaymentMethod" value="card" {{ if eq .PaymentMethod "card" }}checked{{ end }}>
              <span>
                <strong>Card</strong>
                <small>Processed by Stripe · +10%</small>
              </span>
            </label>
          </fieldset>

          <label class="checkout-toggle">
            <input id="sub-newsletter" type="checkbox" name="Subscribe" checked>
            <span>Join the <span class="font-bitcoin">bitcoin++</span> mailing list</span>
          </label>

          <section class="checkout-cart-tabs checkout-cart-tabs--ticket">
            <div class="checkout-cart-tabs__panel">
              <div class="checkout-ticket-line">
                <span>
                  <strong>{{ if .SponsorCheckout }}Sponsored pass{{ else }}{{ .Tix.Tier }}{{ end }}</strong>
                  <small>{{ .Conf.Desc }}</small>
                </span>
                <b>{{ .Tix.Symbol }}{{ .DiscountPrice }}{{ .Tix.PostSymbol }}</b>
              </div>
            </div>
          </section>

          {{ template "tix_details.tmpl" . }}

          <div class="checkout-actions">
            <a href="/{{ .Conf.Tag }}#tickets">Back</a>
            <a href="#checkout-addons" class="checkout-actions__primary" data-checkout-next>Continue to add-ons →</a>
          </div>
          </section>

          <section id="checkout-addons" class="checkout-flow__step checkout-flow__step--addons" data-checkout-step="addons">
            <div class="checkout-copy">
              <h2>Grab some contraband.</h2>
              <p>Straight from the bitcoin++ shop. Pick it up with your badge—no shipping required.</p>
            </div>

            {{ if .AddOnProducts }}
            <div class="checkout-addons checkout-addons--step">
              {{ range .AddOnProducts }}
                {{ $p := . }}
                {{ if .Variants }}
                  {{ with index .Variants 0 }}
                  <article class="checkout-addon" data-checkout-addon data-name="{{ $p.Name }}" data-price-cents="{{ merchVariantPrice $p . }}">
                    <span class="checkout-addon__image">{{ if merchImage $p }}<img src="{{ merchImage $p | safeURL }}" alt="{{ $p.Name }}">{{ end }}</span>
                    <span class="checkout-addon__body">
                      <span><strong>{{ $p.Name }}</strong> <b>{{ merchMoney (merchVariantPrice $p .) $p }}</b></span>
                      <em>{{ $p.Subtitle }}</em>
                    </span>
                    <span class="checkout-addon__controls">
                      <button type="button" data-addon-add aria-label="Add {{ $p.Name }}" hidden>+ add</button>
                      <span class="checkout-addon__stepper">
                        <button type="button" data-addon-minus aria-label="Remove one {{ $p.Name }}">−</button>
                        <input type="number" name="addon_{{ .ID }}" value="0" min="0" max="4" aria-label="Quantity for {{ $p.Name }}">
                        <button type="button" data-addon-plus aria-label="Add one {{ $p.Name }}">+</button>
                      </span>
                    </span>
                  </article>
                  {{ end }}
                {{ end }}
              {{ end }}
            </div>
            {{ else }}
            <div class="checkout-addons__empty">
              <strong>No event add-ons are available yet.</strong>
              <span>You can still continue with just your ticket.</span>
            </div>
            {{ end }}

            <div class="checkout-addon-summary" aria-live="polite">
              <div data-addon-summary-lines>
                <div class="is-empty"><span>No add-ons—that's fine too</span><strong>$0.00</strong></div>
              </div>
              <div class="checkout-addon-summary__tax"><span>Sales tax · event pickup</span><strong data-addon-tax>$0.00</strong></div>
              <div class="is-total"><span>Total (tickets + merch)</span><strong data-addon-total></strong></div>
              <small data-addon-tax-status>Tax is calculated from the event pickup location.</small>
            </div>

            <div class="checkout-actions">
              <button type="button" class="checkout-actions__back" data-checkout-back>← Back</button>
              <button type="submit" data-checkout-submit>Skip — just the ticket →</button>
            </div>
          </section>
        </form>

        <footer class="checkout-footer">
          <span>Secure checkout · ticket delivered by email</span>
          <a href="mailto:hello@btcpp.dev">Questions? hello@btcpp.dev</a>
        </footer>
      </section>
    </main>
    <script src="/static/js/ticket-checkout.js?v=20260718-2" defer></script>
  </body>
</html>
