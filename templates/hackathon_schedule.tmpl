<!doctype html>
<html lang="en">
<head>
  <title>Schedule - {{ .Competition.Title }} - bitcoin++ hackathon</title>
  {{ block "header" . }} {{ end }}
</head>
<body class="bg-gray-50 text-gray-900">
  {{ block "mainnav" . }} {{ end }}
  <main class="mx-auto max-w-4xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <a href="/hackathons/{{ .Competition.Slug }}" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">&larr; Hackathon</a>
        <h1 class="mt-2 text-2xl font-semibold tracking-tight">Schedule</h1>
        <p class="mt-1 text-sm text-gray-600">{{ .Competition.Title }}</p>
      </div>
    </div>

    <section class="rounded-lg bg-white shadow">
      <div class="divide-y divide-gray-100">
        {{ range .ScheduleEvents }}
        <div class="grid gap-2 px-4 py-4 sm:grid-cols-3 sm:px-6">
          <div class="text-sm font-medium text-gray-900">{{ .Label }}</div>
          <div class="sm:col-span-2 text-sm text-gray-700">
            {{ if .Time }}
            <time class="hackathon-schedule-time" datetime="{{ .Time.Format "2006-01-02T15:04:05Z07:00" }}">{{ .Time.Format "2006-01-02 15:04" }}</time>{{ if .End }} - <time class="hackathon-schedule-time" datetime="{{ .End.Format "2006-01-02T15:04:05Z07:00" }}">{{ .End.Format "2006-01-02 15:04" }}</time>{{ end }}
            {{ else }}
            TBA
            {{ end }}
            {{ if .Venue }}<div class="mt-1 text-xs text-gray-500">{{ .Venue }}</div>{{ end }}
          </div>
        </div>
        {{ end }}
      </div>
    </section>
  </main>

  <script>
    (function () {
      const times = Array.prototype.slice.call(document.querySelectorAll('.hackathon-schedule-time'));
      if (times.length === 0) return;

      const tz = Intl.DateTimeFormat().resolvedOptions().timeZone || 'UTC';
      for (const el of times) {
        const value = el.getAttribute('datetime');
        if (!value) continue;
        const date = new Date(value);
        el.textContent = new Intl.DateTimeFormat(undefined, {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
          hour: 'numeric',
          minute: '2-digit',
          timeZone: tz,
          timeZoneName: 'short'
        }).format(date);
      }
    })();
  </script>
  {{ block "footer" . }} {{ end }}
</body>
</html>
