<!doctype html>
<html lang="en">
<head>
  <title>Schedule - {{ .Competition.Title }} - bitcoin++ hackathon</title>
  {{ block "header" . }} {{ end }}
</head>
<body class="hack-redesign">
  {{ block "mainnav" . }} {{ end }}
  <main class="hack-shell">
    <div class="hack-ticker" aria-label="Hackathon schedule">
      <span class="hack-ticker__live">▶ Schedule</span>
      <span>{{ .Competition.Title }}</span>
      <span>•</span>
      <span>local browser time</span>
    </div>

    <header class="hack-header">
      <div>
        <a href="/" class="hack-brand">bitcoin<span>++</span></a>
        <div class="hack-header__meta">[ {{ .Competition.Title }} · Schedule ]</div>
      </div>
      <nav class="hack-header__nav" aria-label="Schedule links">
        <a href="{{ .HackathonURL }}">← hackathon</a>
      </nav>
    </header>

    <section class="hack-section">
      <div class="hack-section__head">
        <div>
          <div class="hack-label">§ Schedule</div>
          <h1 style="margin:0;font-size:clamp(48px,7vw,88px);font-weight:700;line-height:.92;">Hackathon <span class="hack-serif">schedule.</span></h1>
        </div>
        <div class="hack-section__deck">Times are shown in your browser timezone.</div>
      </div>

      {{ if .ScheduleEvents }}
      <div class="hack-table-wrap">
        <table class="hack-table">
          <thead>
            <tr>
              <th scope="col">Event</th>
              <th scope="col">Time</th>
              <th scope="col">Venue</th>
            </tr>
          </thead>
          <tbody>
            {{ range .ScheduleEvents }}
            <tr>
              <td>{{ .Label }}</td>
              <td>
                {{ if .Time }}
                <time class="hackathon-schedule-time" datetime="{{ .Time.Format "2006-01-02T15:04:05Z07:00" }}">{{ .Time.Format "2006-01-02 15:04" }}</time>{{ if .End }} - <time class="hackathon-schedule-time" datetime="{{ .End.Format "2006-01-02T15:04:05Z07:00" }}">{{ .End.Format "2006-01-02 15:04" }}</time>{{ end }}
                {{ else }}
                TBA
                {{ end }}
              </td>
              <td>{{ if .Venue }}{{ .Venue }}{{ else }}TBA{{ end }}</td>
            </tr>
            {{ end }}
          </tbody>
        </table>
      </div>
      {{ else }}
      <div class="hack-empty">Schedule details are still being finalized.</div>
      {{ end }}
    </section>
  </main>

  <script>
    (function () {
      const times = Array.prototype.slice.call(document.querySelectorAll('.hackathon-schedule-time'));
      if (times.length === 0) return;

      const tz = Intl.DateTimeFormat().resolvedOptions().timeZone || 'UTC';
      for (const el of times) {
        const value = el.getAttribute('datetime');
        if (!value) continue;
        const date = new Date(value);
        el.textContent = new Intl.DateTimeFormat(undefined, {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
          hour: 'numeric',
          minute: '2-digit',
          timeZone: tz,
          timeZoneName: 'short'
        }).format(date);
      }
    })();
  </script>
  {{ block "footer" . }} {{ end }}
</body>
</html>
