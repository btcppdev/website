{{ define "head_meta" }}
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=IBM+Plex+Sans:wght@400;500;600;700&family=Source+Serif+4:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet">
{{ end }}

{{ define "shared_head_scripts" }}
    <script src="/static/js/script.js" type="text/javascript"></script>
    <script src="/static/js/htmx-206.min.js" type="text/javascript"></script>
    <script src="/static/js/cal-picker.js" type="text/javascript" defer></script>
    <script>
      // Salvage misplaced ?code= from the URL fragment. Visitors
      // who hand-build share links sometimes write
      //   /{tag}#tickets?code=X
      // instead of the standard
      //   /{tag}?code=X#tickets.
      // The server only sees the query string (not the fragment),
      // so the misplaced form would silently lose the discount.
      // Detect on load and bounce to the canonical shape so the
      // server-side stash logic (RenderConf) picks it up.
      (function () {
        // Bail when code= is already in the query string — otherwise
        // each reload appends another &code= and the page never
        // settles. (Belt and braces against the regex below: the
        // replace step strips the matched separator, but if anything
        // ever leaves a stray code= behind we don't want to spin.)
        if (/[?&]code=/.test(window.location.search)) return;
        const m = window.location.hash.match(/[#?&]code=([^#?&]+)/);
        if (!m) return;
        const code = decodeURIComponent(m[1]);
        // Match regex accepts # as a separator; replace must too,
        // otherwise a bare `#code=X` hash survives the rewrite and
        // the next page-load matches the same hash again → loop.
        let newHash = window.location.hash.replace(/[#?&]code=[^#?&]+/, '');
        if (newHash === '#') newHash = '';
        const sep = window.location.search ? '&' : '?';
        window.location.replace(
          window.location.pathname +
          window.location.search + sep + 'code=' + encodeURIComponent(code) +
          newHash
        );
      })();
    </script>
{{ end }}

