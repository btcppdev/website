{{ define "mainnav" }}
{{ $nav := navConfs }}
{{ if inDev }}
{{/* Permanent dev-mode banner — only renders when the server isn't
     running in prod. Fixed at the top of the
     viewport above the sticky nav so it stays visible during scroll
     and is hard to miss. */}}
<div class="dev-mode-banner">🚧 ⚠️ IN DEV MODE ⚠️ 🚧</div>
<style>
  .dev-mode-banner {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 60;
    background: #dc2626;
    color: #fff;
    text-align: center;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.08em;
    padding: 4px 8px;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
  }
  /* Push body content + the sticky main nav below the 28px banner
     so neither sits underneath. */
  body { padding-top: 28px; }
  body .site-nav { top: 28px; }
</style>
{{ end }}
<header class="site-nav">
  <nav class="site-nav__inner" aria-label="Primary navigation">
    <a href="/" class="site-nav__brand"><img src="/static/img/logo_blk.svg" alt="bitcoin++"></a>
    <input class="site-nav__toggle" type="checkbox" id="site-nav-toggle" aria-label="Toggle navigation">
    <div class="site-nav__controls">
      {{ if $nav.Upcoming }}
        {{ $next := index $nav.Upcoming 0 }}
        <a class="site-button is-accent site-nav__cta" href="/{{ $next.Tag }}#tickets">GET TICKETS</a>
      {{ else }}
        <a class="site-button is-accent site-nav__cta" href="/#events">GET TICKETS</a>
      {{ end }}
      <label class="site-nav__menu" for="site-nav-toggle" aria-label="Toggle navigation">
        <span></span><span></span><span></span>
      </label>
    </div>
    <div class="site-nav__links">
      <a href="/#events">events/</a>
      <a href="/timeline">timeline/</a>
      <a href="/whois">whois/</a>
      <a href="/dashboard">dashboard/</a>
      <a href="https://shop.btcpp.dev/" target="_blank" rel="noopener noreferrer">shop/</a>
      <a href="https://insider.btcpp.dev/" target="_blank" rel="noopener noreferrer">insider/</a>
    </div>
  </nav>
  <script>
    // Hide the "Log in" link on pages that require auth — every
    // visitor of /dashboard, /{conf}/admin/..., or /{conf}/volcoord/...
    // is either already signed in (link is noise) or will be
    // bounced to /login by the gate (link goes to a useless
    // intermediate). Path-based so it doesn't depend on cookie
    // state staying in sync.
    (function () {
      const p = window.location.pathname;
      const authed = p === '/dashboard' || p.startsWith('/dashboard/') ||
                     /^\/[^/]+\/admin(\/|$)/.test(p) ||
                     /^\/[^/]+\/volcoord(\/|$)/.test(p);
      if (!authed) return;
      document.querySelectorAll('[data-nav-login]').forEach(function (el) { el.style.display = 'none'; });
      document.querySelectorAll('[data-nav-login-wrap]').forEach(function (el) { el.style.display = 'none'; });
    })();
  </script>
</header>
{{ end }}

{{/*
  nav_conf_card — one tile in the desktop "Events" flyout. Three
  lines: title / tagline / date.
*/}}
{{ define "nav_conf_card" }}
<a href="/{{ .Tag }}" class="group relative rounded-lg p-3 text-sm leading-6 hover:bg-orange-50 flex items-start gap-3">
  <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-gray-50 group-hover:bg-white text-lg">
    {{ .EmojiOrDefault }}
  </div>
  <div class="min-w-0 flex-1">
    <div class="font-semibold text-gray-900 truncate">{{ .Desc }}</div>
    {{ if .Tagline }}<p class="mt-0.5 text-xs text-gray-600 truncate">{{ .Tagline }}</p>{{ end }}
    {{ if .DateDesc }}<p class="mt-0.5 text-xs text-gray-500 truncate">{{ .DateDesc }}</p>{{ end }}
  </div>
</a>
{{ end }}
