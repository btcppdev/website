{{ define "mainnav" }}
{{ $nav := navConfs }}
{{ if inDev }}
{{/* Permanent dev-mode banner — only renders when the server isn't
     running in prod. Fixed at the top of the
     viewport above the sticky nav so it stays visible during scroll
     and is hard to miss. */}}
<div class="dev-mode-banner">🚧 ⚠️ IN DEV MODE ⚠️ 🚧</div>
<style>
  .dev-mode-banner {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 60;
    background: #dc2626;
    color: #fff;
    text-align: center;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.08em;
    padding: 4px 8px;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
  }
  /* Push body content + the sticky main nav below the 28px banner
     so neither sits underneath. */
  body { padding-top: 28px; }
  header.sticky { top: 28px !important; }
</style>
{{ end }}
<header class="relative isolate z-20 bg-white sticky top-0 z-40">
  <nav class="mx-auto flex max-w-7xl items-center justify-between p-6 lg:px-8" aria-label="Global">
    <div class="flex lg:flex-1">
      <a href="/" class="-m-1.5 p-1.5"><span class="sr-only">bitcoin++</span> <img class="h-8 w-auto" src="/static/img/btcpp.svg" alt=""></a>
    </div>
    <div class="flex lg:hidden">
      <button type="button" onclick="toggleMenu(this)" class="-m-2.5 inline-flex items-center justify-center rounded-md p-2.5 text-gray-700">
        <span class="sr-only">Open main menu</span>
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
    <div class="hidden lg:flex lg:gap-x-12">
      <div></div>
      <div class="hidden lg:flex lg:flex-1 lg:items-center lg:justify-end lg:gap-x-8">
        <button onclick="toggleNavFlyout(this, 'nav-flyout-upcoming')" type="button" class="flex items-center gap-x-1 text-sm font-semibold leading-6 text-gray-900" aria-expanded="false">
          Upcoming
          <svg class="h-5 w-5 flex-none text-gray-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
          </svg>
        </button>
        <button onclick="toggleNavFlyout(this, 'nav-flyout-past')" type="button" class="flex items-center gap-x-1 text-sm font-semibold leading-6 text-gray-900" aria-expanded="false">
          Past
          <svg class="h-5 w-5 flex-none text-gray-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
          </svg>
        </button>
        <a href="/dashboard" data-nav-login class="text-sm font-semibold leading-6 text-gray-900 hover:text-indigo-600">
          Dashboard <span aria-hidden="true">&rarr;</span>
        </a>
        <style>
          .transition-in {
            transition-property: opacity transform;
            transition-timing-function: cubic-bezier(0, 0, 0.2, 1);
            transition-duration: 200ms;
          }

          .transition-out {
            transition-property: opacity transform;
            transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
            transition-duration: 250ms;
          }
        </style>

        {{/* Upcoming flyout */}}
        <div id="nav-flyout-upcoming" role="nav-flyout" class="absolute inset-x-0 top-0 -z-20 bg-white pt-14 shadow-lg ring-1 ring-gray-900/5" style="transform: translateY(-100%); opacity: 0;">
          <div class="mx-auto max-w-7xl px-6 py-10 lg:px-8 max-h-[80vh] overflow-y-auto">
            {{ if $nav.Upcoming }}
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-x-4 gap-y-2">
              {{ range $nav.Upcoming }}
              {{ template "nav_conf_card" . }}
              {{ end }}
            </div>
            {{ else }}
            <p class="text-sm text-gray-500">No upcoming events on the books — stay tuned.</p>
            {{ end }}
          </div>
        </div>

        {{/* Past flyout */}}
        <div id="nav-flyout-past" role="nav-flyout" class="absolute inset-x-0 top-0 -z-20 bg-white pt-14 shadow-lg ring-1 ring-gray-900/5" style="transform: translateY(-100%); opacity: 0;">
          <div class="mx-auto max-w-7xl px-6 py-10 lg:px-8 max-h-[80vh] overflow-y-auto">
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-x-4 gap-y-2">
              {{ range $nav.Past }}
              {{ template "nav_conf_card" . }}
              {{ end }}
              {{/* Pre-Notion archive links — original 2022 events live as
                   YouTube playlists rather than full /conf/ pages. */}}
              <a href="https://www.youtube.com/watch?v=kCON4wuecOw&list=PLHhfnB1Uefkor98E-ikci_sUtUKKYYSDA"
                 target="_blank" rel="noopener noreferrer"
                 class="group relative rounded-lg p-3 text-sm leading-6 hover:bg-orange-50 flex items-start gap-3">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-gray-50 group-hover:bg-white text-lg">&#129399;</div>
                <div class="min-w-0 flex-1">
                  <div class="font-semibold text-gray-900 truncate">CDMX | Dec 2022</div>
                  <p class="mt-0.5 text-xs text-gray-600 truncate">Onchain Privacy</p>
                </div>
              </a>
              <a href="https://www.youtube.com/watch?v=gI6CeAGhFjE&list=PLHhfnB1Uefkolyc9z03BKsWsnzvZoKYKf"
                 target="_blank" rel="noopener noreferrer"
                 class="group relative rounded-lg p-3 text-sm leading-6 hover:bg-orange-50 flex items-start gap-3">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-gray-50 group-hover:bg-white text-lg">&#129432;</div>
                <div class="min-w-0 flex-1">
                  <div class="font-semibold text-gray-900 truncate">Austin | Jun 2022</div>
                  <p class="mt-0.5 text-xs text-gray-600 truncate">Bootstrapping Bitcoin Dev</p>
                </div>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </nav>
  <script>
    // Hide the "Log in" link on pages that require auth — every
    // visitor of /dashboard, /{conf}/admin/..., or /{conf}/volcoord/...
    // is either already signed in (link is noise) or will be
    // bounced to /login by the gate (link goes to a useless
    // intermediate). Path-based so it doesn't depend on cookie
    // state staying in sync.
    (function () {
      const p = window.location.pathname;
      const authed = p === '/dashboard' || p.startsWith('/dashboard/') ||
                     /^\/[^/]+\/admin(\/|$)/.test(p) ||
                     /^\/[^/]+\/volcoord(\/|$)/.test(p);
      if (!authed) return;
      document.querySelectorAll('[data-nav-login]').forEach(function (el) { el.style.display = 'none'; });
      document.querySelectorAll('[data-nav-login-wrap]').forEach(function (el) { el.style.display = 'none'; });
    })();
  </script>
  <!-- Mobile menu, show/hide based on menu open state. -->
  <div class="hidden lg:hidden" role="nav-dialog" aria-modal="true">
    <div class="fixed inset-0 z-20"></div>
    <div class="fixed inset-y-0 right-0 z-20 w-full overflow-y-auto bg-white px-6 py-6 sm:max-w-sm sm:ring-1 sm:ring-gray-900/10">
      <div class="flex items-center justify-between">
        <a href="/" class="-m-1.5 p-1.5"><span class="sr-only">bitcoin++</span> <img class="h-8 w-auto" src="/static/img/btcpp.svg" alt=""></a>
        <button type="button" onclick="closeMenu(this)" class="-m-2.5 rounded-md p-2.5 text-gray-700">
          <span class="sr-only">Close menu</span>
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div class="mt-6 flow-root">
        <div class="-my-6 divide-y divide-gray-500/10">
          <div class="py-6" data-nav-login-wrap>
            <a href="/dashboard" data-nav-login class="block rounded-lg px-3 py-2 text-base font-semibold leading-7 text-gray-900 hover:bg-gray-50">
              Dashboard <span aria-hidden="true">&rarr;</span>
            </a>
          </div>
          <div class="space-y-2 py-6">
            <div>
              {{ if $nav.Upcoming }}
              <button type="button" onclick="toggleMobileFlyout(this, 'current')" class="flex w-full items-center justify-between rounded-lg py-2 pl-3 pr-3.5 text-base leading-7 text-gray-900 hover:bg-gray-50" aria-controls="disclosure-1" aria-expanded="false">
                Upcoming Events
                <svg class="h-5 w-5 flex-none rotate-180" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" role="nav-caret-current">
                  <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                </svg>
              </button>
              <div class="mt-2 space-y-2" role="mobile-flyout-current">
                {{ range $nav.Upcoming }}
                <a onclick="toggleMenu(this)" href="/{{ .Tag }}" class="flex items-center gap-2 rounded-lg py-2 pl-6 pr-3 text-sm font-semibold leading-7 text-gray-900 hover:bg-gray-50">
                  <span class="text-lg leading-none">{{ .EmojiOrDefault }}</span>
                  <span>{{ .Desc }} | {{ .DateDesc }}</span>
                </a>
                {{ end }}
              </div>
              {{ end }}
              <button type="button" onclick="toggleMobileFlyout(this, 'past')" class="flex w-full items-center justify-between rounded-lg py-2 pl-3 pr-3.5 text-base leading-7 text-gray-900 hover:bg-gray-50" aria-controls="disclosure-1" aria-expanded="false">
                Past Events
                <svg class="h-5 w-5 flex-none" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" role="nav-caret-past">
                  <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                </svg>
              </button>
              <div class="hidden mt-2 space-y-2" role="mobile-flyout-past">
                {{ range $nav.Past }}
                <a onclick="toggleMenu(this)" href="/{{ .Tag }}" class="flex items-center gap-2 rounded-lg py-2 pl-6 pr-3 text-sm font-semibold leading-7 text-neutral-600 hover:bg-gray-50">
                  <span class="text-lg leading-none">{{ .EmojiOrDefault }}</span>
                  <span>{{ .Desc }} | {{ .DateDesc }}</span>
                </a>
                {{ end }}
                <a href="https://www.youtube.com/watch?v=kCON4wuecOw&list=PLHhfnB1Uefkor98E-ikci_sUtUKKYYSDA" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 rounded-lg py-2 pl-6 pr-3 text-sm font-semibold leading-7 text-neutral-600 hover:bg-gray-50">
                  <span class="text-lg leading-none">&#129399;</span>
                  <span>CDMX | Dec 2022</span>
                </a>
                <a href="https://www.youtube.com/watch?v=gI6CeAGhFjE&list=PLHhfnB1Uefkolyc9z03BKsWsnzvZoKYKf" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 rounded-lg py-2 pl-6 pr-3 text-sm font-semibold leading-7 text-neutral-600 hover:bg-gray-50">
                  <span class="text-lg leading-none">&#129432;</span>
                  <span>Austin | Jun 2022</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>
{{ end }}

{{/*
  nav_conf_card — one tile in the desktop "Events" flyout. Three
  lines: title / tagline / date.
*/}}
{{ define "nav_conf_card" }}
<a href="/{{ .Tag }}" class="group relative rounded-lg p-3 text-sm leading-6 hover:bg-orange-50 flex items-start gap-3">
  <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-gray-50 group-hover:bg-white text-lg">
    {{ .EmojiOrDefault }}
  </div>
  <div class="min-w-0 flex-1">
    <div class="font-semibold text-gray-900 truncate">{{ .Desc }}</div>
    {{ if .Tagline }}<p class="mt-0.5 text-xs text-gray-600 truncate">{{ .Tagline }}</p>{{ end }}
    {{ if .DateDesc }}<p class="mt-0.5 text-xs text-gray-500 truncate">{{ .DateDesc }}</p>{{ end }}
  </div>
</a>
{{ end }}
