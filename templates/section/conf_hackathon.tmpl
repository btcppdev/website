{{ define "conf_hackathon_section" }}
{{ if .Hackathon }}
{{ $timeline := .HackathonTimeline }}
<section id="hackathon" class="conf-hackathon-redesign">
  <div class="conf-hackathon-redesign__inner">
    <div class="conf-hackathon-redesign__intro">
      <div>
        <p class="rebrand-section-label">Hackathon</p>
        <h2>{{ .Hackathon.Title }}</h2>
      </div>
      <div class="conf-hackathon-redesign__summary">
        {{ if .Hackathon.Description }}
        {{ .Hackathon.Description }}
        {{ else }}
        Build and submit projects tied to {{ .Conf.Desc }}.
        {{ end }}
      </div>
    </div>

    <article class="conf-hackathon-redesign__panel">
      <div class="conf-hackathon-redesign__meta" aria-label="Hackathon details">
        <div>
          <span>Status</span>
          <strong>{{ .HackathonStatusLabel }}</strong>
        </div>
        <div>
          <span>{{ $timeline.Label }}</span>
          <strong>
        {{ if $timeline.HasCountdown }}
            <span class="hackathon-countdown"
                  data-start="{{ $timeline.CountdownUnix }}"
                  data-end="{{ $timeline.CountdownUnix }}"
                  data-before-prefix="{{ $timeline.Label }}"
                  data-after-prefix="{{ $timeline.Label }}">
              <span data-cd-value>{{ $timeline.Value }}</span>
            </span>
        {{ else }}
            {{ $timeline.Value }}
        {{ end }}
          </strong>
        </div>
        <div>
          <span>{{ with .Hackathon.MaxTeamSize }}Max builders per team{{ else }}Team size{{ end }}</span>
          <strong>{{ with .Hackathon.MaxTeamSize }}{{ . }}{{ else }}Unlimited{{ end }}</strong>
        </div>
      </div>
      <div class="conf-hackathon-redesign__actions">
        <a href="{{ .HackathonURL }}" class="rebrand-button">View hackathon →</a>
        {{ if .HackathonAcceptsProjects }}
        <a href="{{ .HackathonCreateProjectURL }}" class="rebrand-button is-secondary">Create project</a>
        {{ end }}
        <a href="{{ .HackathonScheduleURL }}" class="rebrand-button is-secondary">View schedule</a>
        {{ if .HackathonCanAdmin }}
        <a href="{{ .HackathonAdminURL }}" class="rebrand-button is-secondary">Admin</a>
        {{ end }}
      </div>
    </article>
  </div>
</section>
{{ end }}
{{ end }}
