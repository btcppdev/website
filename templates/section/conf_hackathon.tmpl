{{ define "conf_hackathon_section" }}
{{ if .Hackathon }}
{{ $sectionLabel := .Conf.HackathonSectionLabel }}{{ if not $sectionLabel }}{{ $sectionLabel = "§ The hackathon" }}{{ end }}
{{ $headline := .Conf.HackathonHeadline }}{{ if not $headline }}{{ $headline = "Don't just talk. <span>Build.</span>" }}{{ end }}
{{ $judgesNote := "Judges coming soon" }}
{{ $proofLabel := .Conf.HackathonProofLabel }}{{ if not $proofLabel }}{{ $proofLabel = "Last edition · 37 projects · 90 hackers" }}{{ end }}
<section id="hackathon" class="conf-hackathon-redesign">
  <div class="conf-hackathon-redesign__inner">
    <div class="conf-hackathon-redesign__copy">
      <p class="rebrand-section-label">{{ $sectionLabel }}</p>
      <p class="conf-hackathon-redesign__edition">{{ .Hackathon.Title }}</p>
      <h2>{{ ishtml $headline }}</h2>
      <div class="conf-hackathon-redesign__summary">
        {{ if .Hackathon.Description }}
        {{ hackathonDescription .Hackathon.Description .Hackathon.DescriptionFormat }}
        {{ else }}
        Build and submit projects tied to {{ .Conf.Desc }}.
        {{ end }}
      </div>
      <div class="conf-hackathon-redesign__actions">
        <a href="{{ .HackathonURL }}" class="rebrand-button">Explore the hackathon →</a>
        <a href="{{ .HackathonURL }}#projects" class="rebrand-button is-secondary">Past projects →</a>
      </div>
      <div class="conf-hackathon-redesign__judges" aria-label="Hackathon judges">
        {{ if .HackathonJudges }}
        <div class="conf-hackathon-redesign__avatars" aria-hidden="true">
          {{ range .HackathonJudges }}
          <img src="{{ speakerPhoto .Photo }}" alt="" title="{{ if .Name }}{{ .Name }}{{ else }}Hackathon judge{{ end }}">
          {{ end }}
        </div>
        {{ end }}
        <p>{{ .HackathonJudgeNote $judgesNote }}</p>
      </div>
    </div>

    <aside class="conf-hackathon-redesign__proof" aria-label="Last edition hackathon highlights">
      <p class="conf-hackathon-redesign__proof-kicker">{{ $proofLabel }}</p>
      <div class="conf-hackathon-redesign__rows">
        {{ if .HackathonPlaceRows }}
        {{ range .HackathonPlaceRows }}
        <a href="{{ $.HackathonURL }}{{ if .ProjectID }}#project-{{ .ProjectID }}{{ else }}#awards{{ end }}" class="conf-hackathon-redesign__row">
          <span class="conf-hackathon-redesign__place">{{ .PlaceLabel }}</span>
          <span class="conf-hackathon-redesign__project">
            {{ if .SponsorLogoURL }}<span class="conf-hackathon-redesign__award-logo"><img src="{{ .SponsorLogoURL }}" alt="{{ .SponsorLogoAlt }}"></span>{{ end }}
            <strong>{{ .ProjectTitle }}{{ range .ExtraPrizeNames }} <span>+ {{ . }}</span>{{ end }}</strong>
            {{ if .Detail }}<em>{{ .Detail }}</em>{{ end }}
          </span>
        </a>
        {{ end }}
        {{ else }}
        <a href="{{ .HackathonURL }}#awards" class="conf-hackathon-redesign__row">
          <span class="conf-hackathon-redesign__place">★</span>
          <span class="conf-hackathon-redesign__project">
            <strong>Prize places coming soon</strong>
            <em>Ranked rewards will appear here once configured.</em>
          </span>
        </a>
        {{ end }}
      </div>
      <a href="{{ .HackathonURL }}#projects" class="conf-hackathon-redesign__all">See all projects →</a>
    </aside>
  </div>
</section>
{{ end }}
{{ end }}
