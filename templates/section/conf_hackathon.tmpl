{{ define "conf_hackathon_section" }}
{{ if .Hackathon }}
{{ $timeline := .HackathonTimeline }}
<section id="hackathon">
  <div class="bg-white py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-wide {{ .Conf.Tag }}-color">Hackathon</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">{{ .Hackathon.Title }}</h2>
        {{ if .Hackathon.Description }}
        <p class="mt-6 whitespace-pre-line text-lg leading-8 text-gray-600">{{ .Hackathon.Description }}</p>
        {{ else }}
        <p class="mt-6 text-lg leading-8 text-gray-600">Build and submit projects tied to {{ .Conf.Desc }}.</p>
        {{ end }}
      </div>

      <dl class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-4 sm:grid-cols-3">
        <div class="rounded-2xl bg-gray-50 px-6 py-5 text-center">
          <dt class="text-sm font-medium text-gray-500">Status</dt>
          <dd class="mt-2 text-lg font-semibold text-gray-900">{{ .HackathonStatusLabel }}</dd>
        </div>
        <div class="rounded-2xl bg-gray-50 px-6 py-5 text-center">
          <dt class="text-sm font-medium text-gray-500">Timeline</dt>
          <dd class="mt-2 text-lg font-semibold text-gray-900">
            {{ if $timeline.HasCountdown }}
            <span class="hackathon-countdown inline-flex items-center gap-2 rounded-full bg-gray-100 px-3 py-1 text-xs font-mono text-gray-700"
                  data-start="{{ $timeline.CountdownUnix }}"
                  data-end="{{ $timeline.CountdownUnix }}"
                  data-before-prefix="{{ $timeline.Label }}"
                  data-after-prefix="{{ $timeline.Label }}">
              <span data-cd-prefix class="text-gray-500">{{ $timeline.Label }}</span>
              <span data-cd-value class="font-semibold text-gray-900">{{ $timeline.Value }}</span>
            </span>
            {{ else }}
            <span class="text-gray-500">{{ $timeline.Label }}</span>
            <span>{{ $timeline.Value }}</span>
            {{ end }}
          </dd>
        </div>
        <div class="rounded-2xl bg-gray-50 px-6 py-5 text-center">
          <dt class="text-sm font-medium text-gray-500">Team size</dt>
          <dd class="mt-2 text-lg font-semibold text-gray-900">{{ with .Hackathon.MaxTeamSize }}Up to {{ . }}{{ else }}Unlimited{{ end }}</dd>
        </div>
      </dl>

      <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href="{{ .HackathonURL }}" class="inline-flex items-center justify-center rounded-md px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:opacity-90 {{ .Conf.Tag }}">View hackathon</a>
        {{ if .HackathonAcceptsProjects }}
        <a href="{{ .HackathonCreateProjectURL }}" class="inline-flex items-center justify-center rounded-md bg-white px-4 py-2.5 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-gray-300 hover:bg-gray-50">Create project</a>
        {{ end }}
        <a href="{{ .HackathonScheduleURL }}" class="inline-flex items-center justify-center rounded-md bg-white px-4 py-2.5 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-gray-300 hover:bg-gray-50">View schedule</a>
        {{ if .HackathonCanAdmin }}
        <a href="{{ .HackathonAdminURL }}" class="inline-flex items-center justify-center rounded-md bg-gray-900 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-gray-800">Admin</a>
        {{ end }}
      </div>
    </div>
  </div>
</section>
{{ end }}
{{ end }}
