{{/*
  sponsors_section — dynamic sponsor section styled to match the
  rebrand conference pages. Pulls grouped Sponsorships from sponsorTiers
  and renders each tier with shared rebrand sponsor classes.

  Expects context: a *types.Conf in `.Conf`. Renders nothing when
  the conf has no sponsorships.
*/}}
{{ define "sponsors_section" }}
{{ $tiers := sponsorTiers .Conf }}
{{ if $tiers }}
<section id="sponsors" class="rebrand-sponsors">
  <div class="rebrand-sponsors__intro">
    <div>
      <p class="rebrand-section-label">§06 · Sponsors</p>
      <h2>Who’s backing us</h2>
    </div>
    <div class="rebrand-sponsors__copy">
      <p>bitcoin++ is proud to be supported by a wide range of companies and individuals from across the bitcoin ecosystem. Check out what they're up to, both here online as well as at the conference.</p>
      <a href="/sponsor" class="rebrand-sponsors__cta">Become a sponsor →</a>
    </div>
  </div>
  <div class="rebrand-sponsor-tiers">
    {{ range $idx, $tier := $tiers }}
    <section class="rebrand-sponsor-tier rebrand-sponsor-tier--rank-{{ sponsorDisplayRank $tier.Level }}" aria-label="{{ $tier.Label }}">
      <div class="rebrand-sponsor-tier__label">
        <h3>{{ $tier.Label }}</h3>
        <span>{{ len $tier.Sponsors }} supporter{{ if ne (len $tier.Sponsors) 1 }}s{{ end }}</span>
      </div>
      <div class="rebrand-sponsor-grid">
        {{ range $tier.Sponsors }}
        {{ $org := .Org }}
        {{ if $org }}
        <a href="{{ if $org.Website }}{{ $org.Website }}{{ else }}#sponsors{{ end }}"
           {{ if $org.Website }}target="_blank" rel="noopener noreferrer"{{ end }}
           class="rebrand-sponsor-card">
          {{ if $org.LogoLight }}
          <img src="{{ $org.LogoLight }}" loading="lazy" alt="{{ $org.Name }}">
          {{ else if $org.LogoDark }}
          <img src="{{ $org.LogoDark }}" loading="lazy" alt="{{ $org.Name }}">
          {{ else }}
          <span>{{ $org.Name }}</span>
          {{ end }}
        </a>
        {{ end }}
        {{ end }}
      </div>
    </section>
    {{ end }}
  </div>
</section>
{{ end }}
{{ end }}
