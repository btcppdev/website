{{ define "satellites_section" }}
<section id="satellites" class="rebrand-satellites">
  <div class="rebrand-satellites__inner">
    <div class="rebrand-satellites__intro">
      <div>
        <p class="rebrand-section-label">§05 · Satellites</p>
        <h2>Satellite Events</h2>
      </div>
      <p>Other bitcoin events happening around {{ .Conf.Location }}. Additional ticket or registration may be necessary.</p>
    </div>

    <div class="rebrand-satellites__content">
      {{ if .SatelliteEvents }}
      <div class="rebrand-satellites__list">
        {{ range .SatelliteEvents }}
        <article class="rebrand-satellite-card{{ if not .ImageURL }} rebrand-satellite-card--no-image{{ end }}">
          {{ if .ImageURL }}
          <div class="satellite-event__image">
            <img src="{{ spacesURL .ImageURL }}" alt="" class="satellite-event__image-img">
          </div>
          {{ end }}
          <div class="rebrand-satellite-card__body">
            <div class="rebrand-satellite-card__meta">
              {{ $timeLabel := satelliteTimeLabel . $.Conf }}{{ if $timeLabel }}<time>{{ $timeLabel }}</time>{{ end }}
              {{ if .EventType }}<span>{{ .EventType }}</span>{{ end }}
              {{ if .Location }}<span>{{ .Location }}</span>{{ end }}
            </div>
            <div class="rebrand-satellite-card__copy">
              <h3>
                {{ if .EventURL }}
                <a target="_blank" href="{{ safeURL .EventURL }}">
                  {{ .Title }}
                </a>
                {{ else }}
                {{ .Title }}
                {{ end }}
              </h3>
              {{ if .Description }}<p>{{ .Description }}</p>{{ end }}
            </div>
            {{ if or .HostName .HostLogoURL }}
            <div class="rebrand-satellite-card__host">
              <div>
                {{ if .HostLogoURL }}<img src="{{ spacesURL .HostLogoURL }}" alt="">{{ end }}
                {{ if .HostName }}
                <p>
                  <span>Hosted by</span>
                  {{ if .HostURL }}
                  <a target="_blank" href="{{ safeURL .HostURL }}">{{ .HostName }}</a>
                  {{ else }}
                  {{ .HostName }}
                  {{ end }}
                </p>
                {{ end }}
              </div>
            </div>
            {{ end }}
          </div>
        </article>
        {{ end }}
      </div>
      {{ else }}
      <p class="rebrand-satellites__empty">Know of another bitcoin event happening nearby? Send it over and we'll review it for this page.</p>
      {{ end }}

      {{ if .Conf.Active }}
      <div class="rebrand-satellites__cta">
        <a href="/{{ .Conf.Tag }}/satellites/new">Suggest a satellite event</a>
      </div>
      {{ end }}
    </div>
  </div>
</section>
{{ end }}
