{{ define "admin_hackathon_tabs" }}
<nav class="mb-6 overflow-x-auto border-b border-gray-200" aria-label="Hackathon admin sections">
  <div class="flex min-w-max gap-6">
    <a href="{{ .EditURL .Competition }}"
       class="border-b-2 px-1 py-3 text-sm font-medium {{ if eq .ActiveTab "main" }}border-indigo-600 text-indigo-600{{ else }}border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700{{ end }}">Main</a>
    <a href="{{ .ProjectsURL .Competition }}"
       class="border-b-2 px-1 py-3 text-sm font-medium {{ if eq .ActiveTab "projects" }}border-indigo-600 text-indigo-600{{ else }}border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700{{ end }}">Projects</a>
    <a href="{{ .JudgingURL .Competition }}"
       class="border-b-2 px-1 py-3 text-sm font-medium {{ if eq .ActiveTab "judging" }}border-indigo-600 text-indigo-600{{ else }}border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700{{ end }}">Judging</a>
    <a href="{{ .ScoreReviewURL .Competition }}"
       class="border-b-2 px-1 py-3 text-sm font-medium {{ if eq .ActiveTab "scores" }}border-indigo-600 text-indigo-600{{ else }}border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700{{ end }}">Scores</a>
    <a href="{{ .AwardsURL .Competition }}"
       class="border-b-2 px-1 py-3 text-sm font-medium {{ if eq .ActiveTab "awards" }}border-indigo-600 text-indigo-600{{ else }}border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700{{ end }}">Awards</a>
  </div>
</nav>
{{ end }}
