{{ define "admin_hackathon_tabs" }}
<nav class="mb-6 overflow-x-auto rounded-lg bg-white px-4 shadow sm:px-6" aria-label="Hackathon admin sections">
  <div class="flex min-w-max gap-6">
    <a href="{{ .EditURL .Competition }}"
       class="border-b-2 px-1 py-3 text-sm font-medium {{ if eq .ActiveTab "main" }}border-indigo-600 text-indigo-600{{ else }}border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700{{ end }}">Main</a>
    <a href="{{ .ProjectsURL .Competition }}"
       class="inline-flex items-center gap-2 border-b-2 px-1 py-3 text-sm font-medium {{ if eq .ActiveTab "projects" }}border-indigo-600 text-indigo-600{{ else }}border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700{{ end }}">
      Projects
      <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs font-semibold text-gray-700">{{ .ProjectCount }}</span>
    </a>
    <a href="{{ .JudgingURL .Competition }}"
       class="inline-flex items-center gap-2 border-b-2 px-1 py-3 text-sm font-medium {{ if eq .ActiveTab "judging" }}border-indigo-600 text-indigo-600{{ else }}border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700{{ end }}">
      Judging
      <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs font-semibold text-gray-700">{{ .JudgeEventCount }}</span>
    </a>
    <a href="{{ .ScoreReviewURL .Competition }}"
       class="inline-flex items-center gap-2 border-b-2 px-1 py-3 text-sm font-medium {{ if eq .ActiveTab "scores" }}border-indigo-600 text-indigo-600{{ else }}border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700{{ end }}">
      Scores
      <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs font-semibold text-gray-700">{{ .ScoreProjectCount }}</span>
    </a>
    <a href="{{ .AwardsURL .Competition }}"
       class="inline-flex items-center gap-2 border-b-2 px-1 py-3 text-sm font-medium {{ if eq .ActiveTab "awards" }}border-indigo-600 text-indigo-600{{ else }}border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700{{ end }}">
      Awards
      <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs font-semibold text-gray-700">{{ .AwardCount }}</span>
    </a>
  </div>
</nav>
{{ end }}
