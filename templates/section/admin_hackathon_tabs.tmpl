{{ define "admin_hackathon_tabs" }}
<nav class="admin-hackathon-tabs mb-6 overflow-x-auto" aria-label="Hackathon admin sections">
  <div class="admin-hackathon-tabs__track">
    <a href="{{ .EditURL .Competition }}"
       class="admin-hackathon-tab{{ if eq .ActiveTab "main" }} is-active{{ end }}">Main</a>
    <a href="{{ .ProjectsURL .Competition }}"
       class="admin-hackathon-tab{{ if eq .ActiveTab "projects" }} is-active{{ end }}">
      Projects
      <span class="admin-hackathon-tab__count">{{ .ProjectCount }}</span>
    </a>
    <a href="{{ .TimelineURL .Competition }}"
      class="admin-hackathon-tab{{ if eq .ActiveTab "timeline" }} is-active{{ end }}">
      Timeline
      <span class="admin-hackathon-tab__count">{{ .ScheduleSegmentCount }}</span>
    </a>
    <a href="{{ .JudgingURL .Competition }}"
       class="admin-hackathon-tab{{ if eq .ActiveTab "judging" }} is-active{{ end }}">Judging</a>
    <a href="{{ .ScoreReviewURL .Competition }}"
       class="admin-hackathon-tab{{ if eq .ActiveTab "scores" }} is-active{{ end }}">
      Scores
      <span class="admin-hackathon-tab__count">{{ .ScoreProjectCount }}</span>
    </a>
    <a href="{{ .AwardsURL .Competition }}"
       class="admin-hackathon-tab{{ if eq .ActiveTab "awards" }} is-active{{ end }}">
      Awards
      <span class="admin-hackathon-tab__count">{{ .AwardCount }}</span>
    </a>
    <a href="{{ .PayoutsURL .Competition }}"
       class="admin-hackathon-tab{{ if eq .ActiveTab "payouts" }} is-active{{ end }}">Payouts</a>
  </div>
</nav>
{{ end }}
