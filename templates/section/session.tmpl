{{ define "session" }}
<!-- <li class="flex-row py-8"> -->
      <article class="relative isolate flex flex-col justify-end overflow-hidden rounded-2xl bg-gray-900 px-8 pb-8 pt-80 sm:pt-48 lg:pt-80">
        <picture>
          <source srcset="{{ talkClipart .TalkAvif }}" type="image/avif"/>
          <img src="{{ talkClipart .TalkPhoto }}" alt="" class="absolute inset-0 -z-10 h-full w-full object-cover"/>
        </picture>
        <div class="absolute inset-0 -z-10 bg-gradient-to-t from-gray-900 via-gray-900/40"></div>
        <div class="absolute inset-0 -z-10 rounded-2xl ring-1 ring-inset ring-gray-900/10"></div>

        {{/*
          Cal-picker sits inside the article at top-right. The picker's
          dropdown menu uses position:fixed (see cal_picker.tmpl) so it
          escapes the article's overflow-hidden — only the button needs
          to live inside. z-30 keeps the button above the title link's
          inset-0 click-target span; the JS handler also stopPropagates
          so the click never bubbles to the wrapping anchor.
        */}}
        {{ if and .Sched (isFuture .Sched.Start) .AnchorTag }}
        <div class="absolute top-3 right-3 z-30">
          {{ template "cal_picker" (dict
            "Title"    .Name
            "StartISO" (rfc3339 .Sched.Start)
            "EndISO"   (rfc3339 .Sched.End)
            "Location" (mapVenue .Venue)
            "ICSURL"   (printf "/%s/talk/%s/calendar.ics" .ConfTag .AnchorTag)
            "IconOnly" true
          ) }}
        </div>
        {{ end }}

        {{ if eq .Venue "one" }}
        <p class="text-left text-sm text-gray-300">
          Venue: <span class="font-medium text-orange-200">Main Stage</span>
        </p>
        {{ end }}
        {{ if eq .Venue "two" }}
        <p class="text-left text-sm text-gray-300">
          Venue: <span class="font-medium text-lime-200">Talks Stage</span>
        </p>
        {{ end }}
        {{ if eq .Venue "three" }}
        <p class="text-left text-sm text-gray-300">
          Venue: <span class="font-medium text-pink-200">Workshops</span>
        </p>
        {{ end }}
        <div class="flex flex-wrap items-center gap-y-1 overflow-hidden text-sm leading-6 text-gray-300">
          <time datetime="2020-03-16" class="mr-8">{{ .StartTime }}</time>
          {{ $spkCount := len .Speakers }}
          {{ range .Speakers }}
          <div class="-ml-4 flex items-center gap-x-4">
            <svg viewBox="0 0 2 2" class="-ml-0.5 h-0.5 w-0.5 flex-none fill-white/50">
              <circle cx="1" cy="1" r="1" />
            </svg>
            <div class="flex gap-x-2.5">
              <img src="{{ speakerPhoto .Photo }}" alt="" class="h-6 w-6 flex-none rounded-full object-cover bg-white/10">
              {{ if eq $spkCount 1 }}
                {{ .Name }}
              {{ end }}
            </div>
          </div>
          {{ end }}
        </div>
        <a href="/{{ .ConfTag }}/agenda#{{ .AnchorTag }}" class="shadow-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-bitcoin">
        <h3 class="mt-3 text-lg font-semibold leading-6 text-white">
            <span class="absolute inset-0"></span>
            {{ .Name }}
        </h3>
        </a>
      </article>
{{ end }}
