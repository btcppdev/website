<!DOCTYPE html>
<html lang="en">
  <head>
    <title>{{ .Conf.Desc }} - bitcoin++</title>
    {{ block "header" . }} {{ end }}
    {{ block "conf_seo" . }} {{ end }}
  </head>
  <body>
    {{ block "conf_nav" .Conf }} {{ end }}

    <section id="intro" class="lg:mb-20 lg:pb-20">
      <div class="relative">
        <div class="mx-auto max-w-7xl">
          <div class="relative z-10 pt-14 lg:w-full lg:max-w-2xl">
            <svg class="absolute inset-y-0 right-8 hidden h-full w-80 translate-x-1/2 transform fill-white lg:block" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
              <polygon points="0,0 90,0 50,100 0,100" />
            </svg>

            <div class="relative px-6 pt-12 pb-12 sm:pt-16 sm:pb-12 lg:px-8 lg:pt-12 lg:pb-24 lg:pr-0">
              <div class="mx-auto max-w-2xl lg:mx-0 lg:max-w-xl">
                <div class="hidden sm:mb-10 sm:flex">
                  <div class="relative rounded-full px-3 py-1 text-sm leading-6 text-gray-500 ring-1 ring-gray-900/10 hover:ring-gray-900/20">
                    Showcase at the frontier of bitcoin <a href="/sponsor" target="_blank" class="whitespace-nowrap font-semibold {{ .Conf.Tag }}-color"><span class="absolute inset-0" aria-hidden="true"></span>Become a Sponsor<span aria-hidden="true">&rarr;</span></a>
                  </div>
                </div>
                <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-6xl"><span class="font-bitcoin">bitcoin++</span> runs locally</h1>
                <p class="mt-6 text-lg leading-8 text-gray-600">{{ .Conf.OGFlavor }}</p>
                <p class="text-lg leading-8 text-gray-600">{{ .Conf.Location }} | {{ .Conf.Venue }} | {{ .Conf.DateDesc }}</p>
                <div class="mt-10 flex items-center gap-x-6">
                  <a href="#tickets" class="rounded-md {{ .Conf.Tag }} px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2">Get Your All Conf Pass</a>
                </div>
                {{ template "conf_countdown" .Conf }}
              </div>
            </div>
          </div>
        </div>
        <div class="relative z-30 mt-6 sm:mt-8 lg:absolute lg:inset-x-0 lg:bottom-0 lg:mt-0 lg:translate-y-[calc(50%+20px)]">
          {{ template "sponsor_banner" . }}
        </div>
        <div class="bg-gray-50 lg:absolute lg:inset-y-0 lg:right-0 lg:w-1/2">
          <img class="aspect-[3/2] object-cover lg:aspect-auto lg:h-full lg:w-full" src="/static/img/atx25_promo.png" alt="">
        </div>
      </div>
    </section>

    <section id="about">
      <div class="overflow-hidden bg-white pt-14 pb-8">
        <div class="mx-auto max-w-7xl px-6 lg:flex lg:px-8">
          <div class="bg-white py-10 sm:py-10">
            <h2 class="text-center mt-2 text-4xl font-bold tracking-tight text-gray-900 sm:text-4xl">Why Local Dev?</h2>
            <p class="mt-6 text-lg leading-8 text-gray-600">The local fixture mirrors the production conference shape: real navigation, ticket pricing, speaker rows, scheduled talks, sponsors, lodging, and satellite events. The data is fake, but the rendering paths are the same ones used for public event pages.</p>
            <p class="mt-6 text-lg leading-8 text-gray-600">Use it to exercise the full site without touching production records or needing a sanitized database dump.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="venue">
      <div class="overflow-hidden bg-white pt-14 pb-8">
        <div class="mx-auto max-w-7xl px-6 lg:flex lg:px-8">
          <div class="mx-auto grid max-w-2xl grid-cols-1 gap-x-12 gap-y-16 lg:mx-0 lg:min-w-full lg:max-w-none lg:flex-none lg:gap-y-8">
            <div class="lg:col-end-1 lg:w-full lg:max-w-lg lg:pb-8">
              <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Local Focus: {{ .Conf.Location }}</h2>
              <p class="mt-6 text-xl leading-8 text-gray-600">Run the site, seed the flows, and inspect a realistic conference page.</p>
              <p class="mt-6 text-base leading-7 text-gray-600"><span class="font-bitcoin">bitcoin++</span> local dev is staged at {{ .Conf.Venue }}, a fake venue backed by real page components and local-only fixture rows.</p>
              <div class="mt-10 flex">
                <a href="#tickets" class="rounded-md {{ .Conf.Tag }} px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2">Get Your All Access Pass<span aria-hidden="true">&rarr;</span></a>
              </div>
            </div>
            <div class="flex flex-wrap items-start justify-end gap-6 sm:gap-8 lg:contents">
              <div class="w-0 flex-auto lg:ml-auto lg:w-auto lg:flex-none lg:self-end">
                <img src="/static/img/A3_outside.jpg" alt="" class="aspect-[7/5] w-[37rem] max-w-none rounded-2xl bg-gray-50 object-cover">
              </div>
              <div class="contents lg:col-span-2 lg:col-end-2 lg:ml-auto lg:flex lg:w-[37rem] lg:items-start lg:justify-end lg:gap-x-8">
                <div class="order-first flex w-64 flex-none justify-end self-end lg:w-auto">
                  <img src="/static/img/A3_inside.jpg" alt="" class="aspect-[4/3] w-[24rem] max-w-none flex-none rounded-2xl bg-gray-50 object-cover">
                </div>
                <div class="flex w-96 flex-auto justify-end lg:w-auto lg:flex-none">
                  <img src="/static/img/A3_cowork.jpg" alt="" class="aspect-[7/5] w-[37rem] max-w-none flex-none rounded-2xl bg-gray-50 object-cover">
                </div>
                <div class="hidden sm:block sm:w-0 sm:flex-auto lg:w-auto lg:flex-none">
                  <img src="/static/img/A3_work.jpg" alt="" class="aspect-[4/3] w-[24rem] max-w-none rounded-2xl bg-gray-50 object-cover">
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white py-10 sm:py-10">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
          <h3 class="mt-2 text-xl tracking-tight text-gray-900 sm:text-xl">Where to Stay</h3>
          <p class="mt-6 text-lg leading-8 text-gray-600">These seeded lodging cards use the same hotel renderer as production conference pages.</p>
          <div class="mx-auto grid max-w-2xl grid-cols-1 gap-8 overflow-hidden lg:mx-0 lg:max-w-none lg:grid-cols-3 mt-12">
            {{ $tag := .Conf.Tag }}
            {{ range .Hotels }}
            {{ if .Img }}
            <div>
              <time datetime="2026-10" class="flex items-center text-sm font-semibold leading-6 {{ $tag }}-color">
                <svg viewBox="0 0 4 4" class="mr-4 h-1 w-1 flex-none" aria-hidden="true">
                  <circle cx="2" cy="2" r="2" fill="currentColor" />
                </svg>
                {{ .Type }}
                <div class="absolute -ml-2 h-px w-screen -translate-x-full bg-gray-900/10 sm:-ml-4 lg:static lg:ml-8 lg:-mr-6 lg:w-auto lg:flex-auto lg:translate-x-0" aria-hidden="true"></div>
              </time>
              <a href="{{ .URL }}" target="_blank">
                <img src="{{ spacesURL .Img }}" height="350" width="100%" class="mt-12 w-full max-h-xl rounded-xl" />
                <p class="mt-6 text-lg font-semibold leading-8 tracking-tight text-gray-900">{{ .Name }}</p>
                <p class="mt-1 text-base leading-7 text-gray-600">{{ .Desc }}</p>
              </a>
            </div>
            {{ end }}
            {{ end }}
          </div>
        </div>
      </div>
    </section>

    <section id="speakers">
      <div class="bg-white py-32">
        <div class="mx-auto max-w-7xl px-6 text-center lg:px-8">
          <div class="mx-auto max-w-2xl">
            <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Who's Coming</h2>
            <p class="mt-4 text-lg leading-8 text-gray-600"><span class="font-bitcoin">bitcoin++</span> local dev includes a small but realistic lineup so the speaker grid, social links, and agenda cards are populated.</p>
          </div>
          <ul role="list" class="mx-auto mt-20 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 sm:grid-cols-2 lg:mx-0 lg:max-w-none lg:grid-cols-3">
            {{ range .EventSpeakers }}
              {{ block "speaker" . }} {{ end }}
            {{ end }}
          </ul>
        </div>
      </div>
    </section>

    {{ if .Conf.HasAgenda }}
    <section id="agenda">
      <div class="bg-white py-32">
        <div class="mx-auto max-w-7xl px-6 text-center lg:px-8">
          <div class="mx-auto max-w-2xl">
            <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Conference Agenda</h2>
          </div>
          {{ if .Conf.HasEnded }}
            {{ template "agenda_past" . }}
          {{ else }}
            {{ template "agenda_active" . }}
          {{ end }}
        </div>
      </div>
    </section>
    {{ end }}

    {{ if .Conf.ShowHackathon }}
    <section id="hackathon">
      <div class="bg-white py-24 sm:py-32">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
          <div class="mx-auto max-w-2xl lg:mx-0">
            <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Hack the Harness</h2>
            <p class="mt-6 text-lg leading-8 text-gray-600">The hackathon copy is local-only, but the section keeps the same public event shape: a focused build prompt, a venue tie-in, and enough content for nav and layout testing.</p>
          </div>
          <div class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-8 lg:mx-0 lg:max-w-none lg:grid-cols-3">
            <div class="rounded-2xl bg-gray-50 p-8">
              <h3 class="text-lg font-semibold leading-8 tracking-tight text-gray-900">Checkout Flow</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">Test ticket purchase states, discounts, magic links, and attendee dashboard entry points.</p>
            </div>
            <div class="rounded-2xl bg-gray-50 p-8">
              <h3 class="text-lg font-semibold leading-8 tracking-tight text-gray-900">Program Tools</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">Exercise speaker applications, scheduled talks, venue chips, and calendar links.</p>
            </div>
            <div class="rounded-2xl bg-gray-50 p-8">
              <h3 class="text-lg font-semibold leading-8 tracking-tight text-gray-900">Admin Surfaces</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">Use the dev admin login to review sponsors, hotels, satellites, and conference controls.</p>
            </div>
          </div>
        </div>
      </div>
    </section>
    {{ end }}

    {{ if not .Conf.HasEnded }}
    <section id="tickets">
      <div class="mx-auto max-w-7xl px-6 text-center lg:px-8">
        <div class="mx-auto max-w-2xl">
          <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Get Your All Conference Pass</h2>
          {{ if .Tix }}
          <p class="mt-6 text-xl leading-8 text-gray-600">Current local fixture tier: <span class="{{ .Conf.Tag }}-color">{{ .Tix.Tier }}</span>.</p>
          {{ else }}
          <p class="mt-6 text-lg leading-8 text-gray-600">No local test tickets are currently available.</p>
          {{ end }}
        </div>
      </div>
      {{ if .Tix }}
      <div class="relative isolate bg-white pb-24 px-6 sm:pb-32 lg:px-16">
        <div class="mx-auto max-w-4xl lg:max-w-7xl">
          <div class="isolate mx-auto mt-16 grid max-w-md grid-cols-1 gap-y-8 sm:mt-20">
            <div class="flex flex-col justify-between rounded-3xl bg-white p-8 ring-1 ring-gray-200 xl:p-10">
              <div>
                <h3 id="tier-ticket" class="text-base font-semibold leading-7 text-bitcoin">Standard Pass</h3>
                <p class="mt-4 flex items-baseline gap-x-2">
                  {{ if and .MaxTix (ne .MaxTix.StandardPrice .Tix.StandardPrice) }}
                  <span class="line-through text-3xl font-bold tracking-tight text-gray-300">{{ .Tix.Symbol }}{{ .MaxTix.StandardPrice }} {{ .Tix.Currency }}</span>
                  {{ end }}
                  <span class="text-3xl font-bold tracking-tight text-gray-900">{{ .Tix.Symbol }}{{ .Tix.StandardPrice }} {{ .Tix.Currency }}</span>
                  <span class="text-base text-gray-500">/ticket</span>
                </p>
                <p class="mt-6 text-base leading-7 text-gray-600">Pay this price with bitcoin, or {{ .Tix.Symbol }}{{ .Tix.CardPrice false }} {{ .Tix.Currency }} by card after the payment processor surcharge.</p>
              </div>
              <a href="/tix/{{ .Tix.ID }}/checkout" aria-describedby="tier-ticket" class="mt-8 block rounded-md py-2.5 px-3.5 text-center font-semibold focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 sm:mt-10 bg-bitcoin" style="background: #FF8A00">Checkout</a>
            </div>
          </div>
        </div>
      </div>
      {{ end }}
    </section>
    {{ end }}

    {{ template "satellites_section" . }}
    {{ template "sponsors_section" . }}
    {{ block "footer" . }} {{ end }}
  </body>
</html>
