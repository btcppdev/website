<!doctype html>
<html lang="en">
<head>
  <title>{{ .Conf.Desc }} - bitcoin++</title>
  {{ block "header" . }} {{ end }}
  {{ block "conf_seo" . }} {{ end }}
</head>
<body class="bg-white text-gray-900">
  {{ block "mainnav" . }} {{ end }}
  <main class="mx-auto max-w-4xl px-6 py-16">
    <p class="text-sm font-semibold uppercase tracking-wide text-indigo-600">{{ .Conf.DateDesc }}</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl">{{ .Conf.Desc }}</h1>
    <p class="mt-4 text-lg text-gray-600">{{ .Conf.OGFlavor }}</p>
    <p class="mt-2 text-gray-600">{{ .Conf.Location }} | {{ .Conf.Venue }}</p>

    <div id="tickets" class="mt-10 rounded-lg border border-gray-200 p-6">
      <h2 class="text-xl font-semibold">Tickets</h2>
      {{ if .Tix }}
      <p class="mt-2 text-gray-600">{{ .Tix.Tier }} is available for {{ .Tix.Symbol }}{{ .Tix.USD }}{{ .Tix.PostSymbol }}.</p>
      <a class="mt-4 inline-flex rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700"
         href="/tix/{{ .Tix.ID }}+default+fiat/checkout">Open checkout</a>
      {{ else }}
      <p class="mt-2 text-gray-600">No local test tickets are currently available.</p>
      {{ end }}
    </div>

    <div class="mt-8 grid gap-4 sm:grid-cols-2">
      <a class="rounded-lg border border-gray-200 p-4 hover:border-indigo-300 hover:bg-indigo-50" href="/admin">
        <h2 class="font-semibold">Admin</h2>
        <p class="mt-1 text-sm text-gray-600">Use the dev login link printed by `just dev-up`.</p>
      </a>
      <a class="rounded-lg border border-gray-200 p-4 hover:border-indigo-300 hover:bg-indigo-50" href="/dashboard">
        <h2 class="font-semibold">Dashboard</h2>
        <p class="mt-1 text-sm text-gray-600">Local speaker and volunteer dashboard entry point.</p>
      </a>
    </div>
  </main>
</body>
</html>
