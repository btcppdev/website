<section id="hackathon">
<div class="bg-white pt-12 sm:pt-24">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl lg:mx-0">
      <h2 class="text-pretty text-4xl font-semibold tracking-tight text-gray-900 sm:text-5xl">Get ready to turbohack at <span class="font-bitcoin">bitcoin++</span> in Riga this August</h2>
      <p class="mt-6 text-base/7 text-gray-600">Prizes. 2-hours of effort. Get your team of four-turbo hackers together and compete for the pride and glory of being crowned the grand prize winner of this year's privacy hackathon.</p>
    </div>
    <div class="mx-auto mt-16 flex max-w-2xl flex-col gap-8 lg:mx-0 lg:mt-20 lg:max-w-none lg:flex-row lg:items-end">
      <div class="flex flex-col-reverse justify-between gap-x-16 gap-y-8 rounded-2xl bg-gray-50 p-8 sm:w-3/4 sm:max-w-md sm:flex-row-reverse sm:items-end lg:w-72 lg:max-w-none lg:flex-none lg:flex-col lg:items-start">
        <p class="flex-none text-3xl font-bold tracking-tight text-gray-900">100+</p>
        <div class="sm:w-80 sm:shrink lg:w-auto lg:flex-none">
          <p class="text-lg font-semibold tracking-tight text-gray-900">Hackers competing</p>
          <p class="mt-2 text-base/7 text-gray-600">Heros are made in the trenches of hacking.</p>
        </div>
      </div>
      <div class="flex flex-col-reverse justify-between gap-x-16 gap-y-8 rounded-2xl bg-orange-500 p-8 sm:flex-row-reverse sm:items-end lg:w-full lg:max-w-sm lg:flex-auto lg:flex-col lg:items-start lg:gap-y-44">
        <p class="flex-none text-3xl font-bold tracking-tight text-white">5M sats</p>
        <div class="sm:w-80 sm:shrink lg:w-auto lg:flex-none">
          <p class="text-lg font-semibold tracking-tight text-white">of Satoshis in Prizes</p>
          <p class="mt-2 text-base/7 text-gray-50">With a grand total of 5M sats to take home, you'll want to execute your best privacy ideas</p>
        </div>
      </div>
      <div class="flex flex-col-reverse justify-between gap-x-16 gap-y-8 rounded-2xl bg-gray-200 p-8 sm:w-11/12 sm:max-w-xl sm:flex-row-reverse sm:items-end lg:w-full lg:max-w-none lg:flex-auto lg:flex-col lg:items-start lg:gap-y-28">
        <p class="flex-none text-3xl font-bold tracking-tight text-gray-900">21,020,103</p>
        <div class="sm:w-80 sm:shrink lg:w-auto lg:flex-none">
          <p class="text-lg font-semibold tracking-tight text-gray-900">Lines of Code to Write</p>
          <p class="mt-2 text-base/7 text-gray-600">Builders build at bitcoin++. Come show us what you can do in 2 hours. Vibe coding strongly encouraged.</p>
        </div>
      </div>
    </div>
  </div>
</div>
<div class="mx-auto max-w-7xl sm:px-6 sm:pt-24 lg:px-8">
    <div class="relative isolate overflow-hidden bg-orange-500 px-6 py-24 text-center shadow-2xl sm:rounded-3xl sm:px-16 bg-[url(/static/img/riga/bnw.avif)] bg-center">
      <h2 class="text-balance text-4xl font-semibold tracking-tight text-white sm:text-5xl">Compete. Present. Win.</h2>
      <p class="mx-auto mt-6 max-w-xl text-pretty text-lg/8 text-gray-50">Find more details about our judges, prize categories, and winning criteria on Devpost</p>
      <div class="mt-10 flex items-center justify-center gap-x-6">
        <a href="https://privacy.devpost.com/?preview_token=cGsm330FXU%2B0aEH4MIPVCGEQRE4WvHinA9776gdRdCM%3D" target="_blank" class="rounded-md bg-white px-3.5 py-2.5 text-sm font-semibold shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 riga">Find out more on Devpost</a>
      </div>
      <svg viewBox="0 0 1024 1024" class="absolute left-1/2 top-1/2 -z-10 size-[64rem] -translate-x-1/2 [mask-image:radial-gradient(closest-side,white,transparent)]" aria-hidden="true">
        <circle cx="512" cy="512" r="512" fill="#fff" fill-opacity="0.7" />
        <defs>
          <radialGradient id="827591b1-ce8c-4110-b064-7cb85a0b1217">
            <stop stop-color="#7775D6" />
            <stop offset="1" stop-color="#E935C1" />
          </radialGradient>
        </defs>
      </svg>
    </div>
  </div>
</section>
<section id="speakers">
<div class="bg-white py-32">
  <div class="mx-auto max-w-7xl px-6 text-center lg:px-8">
    <div class="mx-auto max-w-2xl">
      <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Who's Coming</h2>
      <p class="mt-4 text-lg leading-8 text-gray-600"><span class="font-bitcoin">bitcoin++</span>'s first Riga conference features an all-star lineup of open-source devs, privacy advocates, and protocol experts.</p>
    </div>
    <ul role="list" class="mx-auto mt-20 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 sm:grid-cols-2 lg:mx-0 lg:max-w-none lg:grid-cols-3">
      {{ range .EventSpeakers }}
        {{ block "speaker" . }} {{ end }}
      {{ end }}
    </ul>
  </div>
</div>
</section>
{{ if .Conf.HasAgenda }}
<section id="agenda">
  <div class="bg-white py-32">
    <div class="mx-auto max-w-7xl px-6 text-center lg:px-8">
      <div class="mx-auto max-w-2xl">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Conference Agenda</h2>
      </div>
      {{ if .Conf.HasEnded }}
        {{ template "agenda_past" . }}
      {{ else }}
        {{ template "agenda_active" . }}
      {{ end }}
    </div>
  </div>
</section>
{{ end }}
<section id="satellites">
  <div class="bg-white py-32">
    <div class="mx-auto max-w-7xl px-6 text-center lg:px-8">
      <div class="mx-auto max-w-2xl">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Satellite Events</h2>
      </div>
      <p class="mt-2 text-lg leading-8 text-gray-600">Other bitcoin events happening in Riga! Additional ticket/registration may be necessary</p>
      <div class="mt-16 space-y-20 lg:mt-20 lg:space-y-20">

        <article class="relative isolate flex flex-col gap-8 lg:flex-row">
          <div class="relative aspect-[16/9] sm:aspect-[2/1] lg:aspect-square lg:w-64 lg:shrink-0">
            <img src="/static/img/riga/bitchat.jpg" alt="" class="absolute inset-0 h-full w-full rounded-2xl bg-gray-50 object-cover">
            <div class="absolute inset-0 rounded-2xl ring-1 ring-inset ring-gray-900/10"></div>
          </div>
          <div>
            <div class="flex items-center gap-x-4 text-xs">
              <time datetime="2020-03-16" class="text-gray-500">Aug 8, 2025 @ 8p</time>
              <span class="relative z-10 rounded-full bg-gray-50 px-3 py-1.5 font-medium text-gray-600 hover:bg-gray-100">Meetup</span>
            </div>
