<!DOCTYPE html>
<html lang="en">
  <head>
    {{ block "header" . }} {{ end }}
    {{ block "conf_seo" . }} {{ end }}
  </head>
<body>
{{ block "conf_nav" .Conf }} {{ end }}
<section id="intro" class="lg:mb-20 lg:pb-20">
 <div class="relative">
    <div class="mx-auto max-w-7xl">
      <div class="relative z-10 pt-14 lg:w-full lg:max-w-2xl">
        <svg class="absolute inset-y-0 right-8 hidden h-full w-80 translate-x-1/2 transform fill-white lg:block" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
          <polygon points="0,0 90,0 50,100 0,100" />
        </svg>

        <div class="relative px-6 pt-12 pb-12 sm:pt-16 sm:pb-12 lg:px-8 lg:pt-12 lg:pb-24 lg:pr-0">
          <div class="mx-auto max-w-2xl lg:mx-0 lg:max-w-xl">
            <div class="hidden sm:mb-10 sm:flex">
              <div class="relative rounded-full px-3 py-1 text-sm leading-6 text-gray-500 ring-1 ring-gray-900/10 hover:ring-gray-900/20">
                Get involved in the future of lightning. <a href="/sponsor" target="_blank" class="whitespace-nowrap font-semibold berlin25-color"><span class="absolute inset-0" aria-hidden="true"></span>Become a Sponsor<span aria-hidden="true">&rarr;</span></a>
              </div>
            </div>
            <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-6xl"><span class="font-bitcoin">lightning++</span> is programming payments</h1>
            <p class="mt-6 text-lg leading-8 text-gray-600">Join us in Berlin to learn about lightning and programmable payments</p>
            <p class="text-lg leading-8 text-gray-600">Berlin, Germany | web3 hub | October 2+3+4, 2025</p>
            <div class="mt-10 flex items-center gap-x-6">
              <a href="#tickets" class="rounded-md px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 berlin25">Get Your All Conf Pass</a>
            </div>
            {{ template "conf_countdown" .Conf }}
          </div>
        </div>
      </div>
    </div>
    <div class="relative z-30 mt-6 sm:mt-8 lg:absolute lg:inset-x-0 lg:bottom-0 lg:mt-0 lg:translate-y-[calc(50%+20px)]">
      {{ template "sponsor_banner" . }}
    </div>
    <div class="bg-gray-50 lg:absolute lg:inset-y-0 lg:right-0 lg:w-1/2">
      <img class="aspect-[3/2] object-cover lg:aspect-auto lg:h-full lg:w-full" src="/static/img/berlin/leading.png" alt="">
    </div>
  </div>
</section>
<section id="about" class="mx-auto max-w-2xl lg:max-w-4xl">
<div class="bg-white py-10 sm:py-10">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <h2 class="mt-2 text-4xl font-bold tracking-tight text-gray-900 sm:text-6xl">Why lightning + bitcoin</h2>
    <p class="mt-6 text-lg leading-8 text-gray-600">The lightning network is lighting up the private payments world. Can bitcoin defeat its haters and prove to the world it's a Medium of Exchange? Join us in Berlin this October 2+3+4 to explore the exploding ecosystem of programmable payments, anonymous infrastructure that's being added to the Bitcoin sovereign stack.</p>
    <div class="mx-auto grid max-w-2xl grid-cols-1 gap-8 overflow-hidden lg:mx-0 lg:max-w-none lg:grid-cols-4 mt-12">
      <div>
        <time datetime="2021-08" class="flex items-center text-sm font-semibold leading-6 berlin25-color">
	        Anonymous
      </div>
      <div>
        <time datetime="2021-12" class="flex items-center text-sm font-semibold leading-6 berlin25-color">
          Fast
      </div>
      <div>
        <time datetime="2022-02" class="flex items-center text-sm font-semibold leading-6 berlin25-color">
          Lightning++
      </div>
      <div>
        <time datetime="2022-12" class="flex items-center text-sm font-semibold leading-6 berlin25-color">
         Open Source 
      </div>
    </div>
  </div>
  </div>
</section>
<section id="venue">
<div class="overflow-hidden bg-white pt-32 pb-8">
  <div class="mx-auto max-w-7xl px-6 lg:flex lg:px-8">
    <div class="mx-auto grid max-w-2xl grid-cols-1 gap-x-12 gap-y-16 lg:mx-0 lg:min-w-full lg:max-w-none lg:flex-none lg:gap-y-8">
      <div class="lg:col-end-1 lg:w-full lg:max-w-lg lg:pb-8">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Conference Venue</h2>
        <p class="mt-6 text-xl leading-8 text-gray-600">Explore Berlin, get zapped</p>
        <p class="mt-6 text-base leading-7 text-gray-600"><span class="font-bitcoin">lightning++</span> is happening at web3.hub in Berlin, Germany.</p>
