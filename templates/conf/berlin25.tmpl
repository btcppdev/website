</section>
{{ block "mailing" . }} {{ end }}
<section id="hackathon">
<div class="bg-white pt-12 sm:pt-24">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl lg:mx-0">
      <h2 class="text-pretty text-4xl font-semibold tracking-tight text-gray-900 sm:text-5xl">Get ready to hack at <span class="font-bitcoin">bitcoin++</span> in Berlin this October</h2>
      <p class="mt-6 text-base/7 text-gray-600">Prizes. 6-hours of effort. Get your team of four-turbo hackers together and compete for the pride and glory of being crowned the grand prize winner of this year's privacy hackathon.</p>
    </div>
    <div class="mx-auto mt-16 flex max-w-2xl flex-col gap-8 lg:mx-0 lg:mt-20 lg:max-w-none lg:flex-row lg:items-end">
      <div class="flex flex-col-reverse justify-between gap-x-16 gap-y-8 rounded-2xl bg-gray-50 p-8 sm:w-3/4 sm:max-w-md sm:flex-row-reverse sm:items-end lg:w-72 lg:max-w-none lg:flex-none lg:flex-col lg:items-start">
        <p class="flex-none text-3xl font-bold tracking-tight text-gray-900">100+</p>
        <div class="sm:w-80 sm:shrink lg:w-auto lg:flex-none">
          <p class="text-lg font-semibold tracking-tight text-gray-900">Hackers competing</p>
          <p class="mt-2 text-base/7 text-gray-600">Heros are made in the trenches of hacking.</p>
        </div>
      </div>
      <div class="flex flex-col-reverse justify-between gap-x-16 gap-y-8 rounded-2xl bg-orange-500 p-8 sm:flex-row-reverse sm:items-end lg:w-full lg:max-w-sm lg:flex-auto lg:flex-col lg:items-start lg:gap-y-44">
        <p class="flex-none text-3xl font-bold tracking-tight text-white">5M sats</p>
        <div class="sm:w-80 sm:shrink lg:w-auto lg:flex-none">
          <p class="text-lg font-semibold tracking-tight text-white">of Satoshis in Prizes</p>
          <p class="mt-2 text-base/7 text-gray-50">With a grand total of 5M sats to take home, you'll want to execute your best privacy ideas</p>
        </div>
      </div>
      <div class="flex flex-col-reverse justify-between gap-x-16 gap-y-8 rounded-2xl bg-gray-200 p-8 sm:w-11/12 sm:max-w-xl sm:flex-row-reverse sm:items-end lg:w-full lg:max-w-none lg:flex-auto lg:flex-col lg:items-start lg:gap-y-28">
        <p class="flex-none text-3xl font-bold tracking-tight text-gray-900">21,020,103</p>
        <div class="sm:w-80 sm:shrink lg:w-auto lg:flex-none">
          <p class="text-lg font-semibold tracking-tight text-gray-900">Lines of Code to Write</p>
          <p class="mt-2 text-base/7 text-gray-600">Builders build at bitcoin++. Come show us what you can do in 6 hours. Vibe coding strongly encouraged.</p>
        </div>
      </div>
    </div>
  </div>
</div>
<div class="mx-auto max-w-7xl sm:px-6 sm:pt-24 lg:px-8">
    <div class="relative isolate overflow-hidden bg-orange-500 px-6 py-24 text-center shadow-2xl sm:rounded-3xl sm:px-16 bg-[url(/static/img/berlin/bnw.png)] bg-center">
      <h2 class="text-balance text-4xl font-semibold tracking-tight text-white sm:text-5xl">Compete. Present. Win.</h2>
      <p class="mx-auto mt-6 max-w-xl text-pretty text-lg/8 text-gray-50">Find more details about our judges, prize categories, and winning criteria on Devpost</p>
      <div class="mt-10 flex items-center justify-center gap-x-6">
        <a href="https://lightning.devpost.com/?preview_token=LOmLADd9ksRg3gj%2B33V4qQFnQj62aUILDG9dDm8FaLs%3D" target="_blank" 
	class="rounded-md bg-white px-3.5 py-2.5 text-sm font-semibold shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 berlin25">Find out more on Devpost</a>
      </div>
      <svg viewBox="0 0 1024 1024" class="absolute left-1/2 top-1/2 -z-10 size-[64rem] -translate-x-1/2 [mask-image:radial-gradient(closest-side,white,transparent)]" aria-hidden="true">
        <circle cx="512" cy="512" r="512" fill="#fff" fill-opacity="0.7" />
        <defs>
          <radialGradient id="827591b1-ce8c-4110-b064-7cb85a0b1217">
            <stop stop-color="#7775D6" />
            <stop offset="1" stop-color="#E935C1" />
          </radialGradient>
        </defs>
      </svg>
    </div>
  </div>
</section>
<section id="speakers">
<div class="bg-white py-32">
  <div class="mx-auto max-w-7xl px-6 text-center lg:px-8">
    <div class="mx-auto max-w-2xl">
      <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Who's Coming</h2>
      <p class="mt-4 text-lg leading-8 text-gray-600"><span class="font-bitcoin">bitcoin++</span>'s third ever Berlin conference has an all-star lineup of lightning and payment experts.</p>
    </div>
    <ul role="list" class="mx-auto mt-20 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 sm:grid-cols-2 lg:mx-0 lg:max-w-none lg:grid-cols-3">
      {{ range .EventSpeakers }}
        {{ block "speaker" . }} {{ end }}
      {{ end }}
    </ul>
  </div>
</div>
</section>
{{ if .Conf.HasAgenda }}
<section id="agenda">
  <div class="bg-white py-32">
    <div class="mx-auto max-w-7xl px-6 text-center lg:px-8">
      <div class="mx-auto max-w-2xl">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Conference Agenda</h2>
      </div>
      {{ if .Conf.HasEnded }}
        {{ template "agenda_past" . }}
      {{ else }}
        {{ template "agenda_active" . }}
      {{ end }}
    </div>
  </div>
</section>
{{ end }}
{{ if not .Conf.HasEnded }}
<section id="tickets">
  <div class="mx-auto max-w-7xl px-6 text-center lg:px-8">
    <div class="mx-auto max-w-2xl">
      <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">Get Your All Conference Pass</h2>
      {{ if .Tix }}
        {{ if eq .Tix.USD .MaxTix.USD }}
           <!-- max ticket reached -->
           {{ if lt .TixLeft 40 }}
              <p class="mt-6 text-xl leading-8 text-gray-600">Only <span class="text-zinc-900 font-bold">{{ .TixLeft }}</span> tickets are left!</p>
           {{ end }}
        {{ else }}
          <p class="mt-6 text-xl leading-8 text-gray-600">Ticket prices go up on <span class="text-buenos">{{ .Tix.Expires.DateDesc }}</span>
          {{ if lt .TixLeft 40 }}
          or after 
            <span class="text-zinc-900 font-bold">{{ .TixLeft }}</span> more tickets are sold!</p>
          {{ else }}
            </p>
          {{ end }}
        {{ end }}
      {{ else }}
      <p class="mt-6 text-lg leading-8 text-gray-600">This event is sold out! 🙈</p>
      {{ end }}
    </div>
  </div>
  {{ if .Tix }}
  <div class="relative isolate bg-white pb-24 px-6 sm:pb-32 lg:px-16">
    <div class="absolute inset-x-0 -top-3 -z-10 transform-gpu overflow-hidden px-36 blur-3xl" aria-hidden="true">
      <svg class="mx-auto w-[72.1875rem]" viewBox="0 0 1155 678">
        <path fill="url(#083c110e-60c8-42bb-a9db-29bba74cc569)" fill-opacity=".3" d="M317.219 518.975L203.852 678 0 438.341l317.219 80.634 204.172-286.402c1.307 132.337 45.083 346.658 209.733 145.248C936.936 126.058 882.053-94.234 1031.02 41.331c119.18 108.451 130.68 295.337 121.53 375.223L855 299l21.173 362.054-558.954-142.079z" />
        <defs>
          <linearGradient id="083c110e-60c8-42bb-a9db-29bba74cc569" x1="1155.49" x2="-78.208" y1=".177" y2="474.645" gradientUnits="userSpaceOnUse">
            <stop stop-color="#9089FC" />
            <stop offset="1" stop-color="#FF80B5" />
          </linearGradient>
        </defs>
      </svg>
    </div>
    <div class="mx-auto max-w-4xl lg:max-w-7xl">
    <div class="isolate mx-auto mt-16 grid max-w-md grid-cols-1 gap-y-8 sm:mt-20 lg:mx-0 lg:max-w-none lg:grid-cols-2">
    <div class="flex flex-col justify-between rounded-3xl bg-white p-8 ring-1 ring-gray-200 xl:p-10 lg:z-10 lg:rounded-b-none">
      <div>
        <h3 id="tier-bitcoin" class="text-base font-semibold leading-7 text-bitcoin">Pay with Bitcoin</h3>
        <p class="mt-4 flex items-baseline gap-x-2">
          {{ if ne .MaxTix.BTC .Tix.BTC }}
          <span class="line-through text-3xl font-bold tracking-tight text-gray-300">{{ .Tix.Symbol }}{{ .MaxTix.BTC }} {{ .Tix.Currency }}</span>
          {{ end }}
          <span class="text-3xl font-bold tracking-tight text-orange">{{ .Tix.Symbol }}{{ .Tix.BTC }} {{ .Tix.Currency }}</span>
          <span class="text-base text-gray-500">/ticket</span>
        </p>
        <p class="mt-6 text-base leading-7 text-gray-600">Spend bitcoin, save money.</p>
        <ul role="list" class="mt-8 space-y-3 text-sm leading-6 text-gray-600 sm:mt-10">
          <li class="flex gap-x-3">
            <svg class="h-6 w-5 flex-none berlin25-color" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
            </svg>
            All conference pass
          </li>
          <li class="flex gap-x-3">
            <svg class="h-6 w-5 flex-none berlin25-color" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
            </svg>
            Unlimited access to workshops
          </li>
