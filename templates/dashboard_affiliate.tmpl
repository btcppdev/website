<!DOCTYPE html>
<html>
<head>
  <title>{{ if .IsEdit }}Edit{{ else }}Create{{ end }} affiliate code · bitcoin++</title>
  {{ block "header" . }} {{ end }}
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>&#127991;</text></svg>">
</head>
<body class="btcpp-admin-page bg-gray-50">
  {{ block "mainnav" . }} {{ end }}
  <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8 py-12">
    <a href="/dashboard" class="text-xs text-gray-500 hover:text-gray-700">&larr; Back to dashboard</a>
    <h1 class="mt-1 text-xl font-bold text-gray-900">
      {{ if .IsEdit }}Edit your affiliate code{{ else }}Create an affiliate code{{ end }}
    </h1>
    <p class="mt-1 text-sm text-gray-500">
      {{ if .IsEdit }}
      Pick a new name or change your slider. The 20% reference cap is fixed — whatever you don't give the buyer, you keep.
      {{ else }}
      Pick a unique code name + a buyer-discount %. Out of a fixed 20% ceiling, whatever you don't give the buyer is yours per ticket sold via this code.
      {{ end }}
    </p>

    {{ if .FormError }}
    <div class="mt-6 rounded-md bg-red-50 border border-red-200 px-4 py-3">
      <p class="text-sm text-red-800">{{ .FormError }}</p>
    </div>
    {{ end }}

    <form method="POST" action="{{ if .IsEdit }}/dashboard/affiliate/edit{{ else }}/dashboard/affiliate/new{{ end }}"
          class="mt-6 bg-white shadow rounded-lg p-6 space-y-6">

      <div>
        <label for="CodeName" class="block text-sm font-semibold text-gray-900">Code name</label>
        <p class="mt-1 text-xs text-gray-500">Letters and numbers only. Uppercased automatically. Must be unique.</p>
        <input type="text" id="CodeName" name="CodeName" required
               value="{{ .Form.CodeName }}"
               placeholder="MYNAME20"
               maxlength="32"
               style="text-transform: uppercase"
               class="mt-2 block w-full rounded-md bg-white px-3 py-2 text-sm font-mono text-gray-900 outline outline-1 outline-gray-300 focus:outline-2 focus:outline-bitcoin">
      </div>

      <div>
        <label class="block text-sm font-semibold text-gray-900">Buyer discount</label>
        <p class="mt-1 text-xs text-gray-500">Slide right to give the buyer a bigger break (and earn less per sale yourself). 0% means the code is silent — no buyer-facing discount but you still earn the full 20%.</p>
        <div class="mt-3 grid grid-cols-5 gap-2">
          {{ range .BuyerPctOpts }}
          <label class="cursor-pointer">
            <input type="radio" name="BuyerPct" value="{{ . }}"
                   {{ if eq $.Form.BuyerPct . }}checked{{ end }}
                   class="peer sr-only" onchange="updatePctPreview()">
            <span class="block rounded-md border border-gray-300 bg-white py-3 text-center text-sm font-semibold text-gray-700 peer-checked:bg-green-100 peer-checked:text-green-800 peer-checked:border-green-600 peer-checked:ring-2 peer-checked:ring-green-600">
              {{ . }}%
            </span>
          </label>
          {{ end }}
        </div>
        <p id="PctPreview" class="mt-3 text-xs text-gray-600"></p>
        <div class="mt-3 grid grid-cols-2 gap-2 rounded-md bg-gray-50 px-3 py-2 text-xs">
          <div>
            <div class="text-gray-500 uppercase tracking-wider">Buyer pays</div>
            <div id="ExampleBuyerPays" class="mt-0.5 text-sm font-semibold text-gray-900"></div>
          </div>
          <div>
            <div class="text-gray-500 uppercase tracking-wider">You earn</div>
            <div id="ExampleYouEarn" class="mt-0.5 text-sm font-semibold text-green-700"></div>
          </div>
          <div class="col-span-2 text-[11px] text-gray-400">
            On a $100 ticket.
          </div>
        </div>
      </div>

      <div class="rounded-md bg-gray-50 px-3 py-2 text-xs text-gray-600">
        Works at any active bitcoin++ event{{ if .ConfNames }} (currently {{ range $idx, $tag := .ConfNames }}{{ if $idx }}, {{ end }}<span class="font-mono">{{ $tag }}</span>{{ end }}){{ end }}.
      </div>

      <div class="flex items-center justify-end gap-3 pt-2">
        <a href="/dashboard" class="text-sm text-gray-600 hover:text-gray-800">Cancel</a>
        <button type="submit"
                class="inline-flex items-center rounded-md bg-green-600 px-4 py-2 text-sm font-semibold text-white hover:bg-green-700">
          {{ if .IsEdit }}Save changes{{ else }}Create code{{ end }}
        </button>
      </div>
    </form>
  </div>

  <script>
    function updatePctPreview() {
      const el = document.querySelector('input[name="BuyerPct"]:checked');
      if (!el) return;
      const buyer = parseInt(el.value, 10);
      const aff   = 20 - buyer;
      const out   = document.getElementById('PctPreview');
      if (buyer === 0) {
        out.textContent = 'Silent code — buyer sees no discount, you earn ' + aff + '% per ticket.';
      } else {
        out.textContent = 'Buyer saves ' + buyer + '% per ticket. You earn ' + aff + '% per ticket.';
      }
      // $100-ticket worked example so the percentage abstractly
      // turns into a number the user can sanity-check against.
      // The 20% slider stop pays the affiliate nothing — replace
      // the $0.00 with $BRAGGING.RIGHTS so the cell still feels
      // like a win.
      const buyerPays = 100 - buyer;
      const youEarn   = aff;
      document.getElementById('ExampleBuyerPays').textContent = '$' + buyerPays.toFixed(2);
      document.getElementById('ExampleYouEarn').textContent   = youEarn === 0 ? '$BRAGGING.RIGHTS' : '$' + youEarn.toFixed(2);
    }
    document.addEventListener('DOMContentLoaded', updatePctPreview);
  </script>
  {{ block "footer" . }} {{ end }}
</body>
</html>
