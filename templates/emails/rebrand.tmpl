<!doctype html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,300;1,400;1,600&family=IBM+Plex+Mono:wght@400;500;600;700&family=Source+Serif+4:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet">
  <style type="text/css">{{ .Styles }}</style>
</head>
<body>
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" class="btcpp-shell">
    <tr>
      <td align="center" style="padding:24px 12px;">
        <table role="presentation" width="640" cellpadding="0" cellspacing="0" class="btcpp-inner">
          {{ if .Config.Ticker }}
          <tr>
            <td style="background:#1C1C1E;color:#FFFFFF;padding:10px 20px;font-family:'IBM Plex Mono',ui-monospace,Menlo,Consolas,monospace;font-size:11px;letter-spacing:1.5px;white-space:nowrap;overflow:hidden;">
              <span style="color:#F57247;margin-right:16px;">&#9654; LIVE</span>
              {{ range $i, $item := .Config.Ticker }}{{ if $i }}<span style="color:#6B655C;margin:0 12px;">&bull;</span>{{ end }}<span>{{ $item }}</span>{{ end }}
            </td>
          </tr>
          {{ end }}
          <tr>
            <td class="btcpp-row" style="padding:22px 32px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td style="vertical-align:bottom;">
                    <div style="font-size:28px;font-weight:700;letter-spacing:-1px;font-family:'IBM Plex Mono',ui-monospace,Menlo,Consolas,monospace;line-height:1;">
                      bitcoin<span style="color:#F57247;">++</span>
                    </div>
                    <div style="font-family:Georgia,'Times New Roman',serif;font-style:italic;font-size:14px;color:#6B655C;margin-top:4px;">
                      a dispatch from the frontier
                    </div>
                  </td>
                  <td style="vertical-align:bottom;text-align:right;font-family:'IBM Plex Mono',ui-monospace,Menlo,Consolas,monospace;font-size:11px;letter-spacing:1.2px;color:#6B655C;">
                    <div>ISSUE {{ .Config.Issue }}</div>
                    <div>{{ .Config.Date }}</div>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          {{ if .Config.Hero }}
          <tr>
            <td style="padding:0;border-bottom:1px solid #1C1C1E;">
              <img src="{{ .Config.Hero }}" width="640" height="270" style="width:100%;max-width:640px;height:270px;max-height:270px;object-fit:cover;display:block;" alt="">
            </td>
          </tr>
          {{ end }}
          <tr>
            <td class="btcpp-row btcpp-content">
              {{ .Content }}
            </td>
          </tr>
          <tr>
            <td style="padding:28px 32px;border-top:1px solid #1C1C1E;">
              <div style="font-family:'IBM Plex Mono',ui-monospace,Menlo,Consolas,monospace;font-size:11px;letter-spacing:1px;color:#6B655C;">
                bitcoin<span style="color:#F57247;">++</span> / protocol dispatches, conference notes, and builder signals
              </div>
            </td>
          </tr>
          {{ if .Unsubscribe }}
          <tr>
            <td style="padding:16px 32px;border-top:1px solid #1C1C1E;font-family:'IBM Plex Sans',-apple-system,BlinkMacSystemFont,'Helvetica Neue',Arial,sans-serif;font-size:13px;color:#6B655C;">
              <a style="color:#1C1C1E;text-underline-offset:4px;text-decoration-line:underline;font-weight:400;" href="{{ .URI }}/newsletter/unsubscribe/{{ .Unsubscribe }}">Unsubscribe</a> from this newsletter
            </td>
          </tr>
          {{ end }}
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
