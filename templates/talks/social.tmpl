<!DOCTYPE html>
<html>
  <head>
    <title>social posts @ bitcoin++</title>
    {{ block "header" . }} {{ end }}
    {{ template "admin_favicon" .Conf }}
  </head>
  <body class="btcpp-admin-page">
    {{ block "mainnav" . }} {{ end }}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-5xl">
            <a href="/{{ .Conf.Tag }}/admin" class="text-xs text-gray-500 hover:text-gray-700">&larr; {{ .Conf.Desc }} dashboard</a>
            <section id="topline" class="mt-2 mb-6">
                <div class="overflow-hidden sm:rounded-lg bg-white shadow">
                    <div class="px-4 py-5 sm:p-6">
                        <h1 class="text-xl font-bold text-gray-900">Social Media Posts</h1>
                        <p class="text-sm text-gray-500">{{ .Conf.Desc }} - {{ .Conf.DateDesc }}</p>
                        <p class="mt-1 text-xs text-gray-400">Posts to: X, Instagram, LinkedIn</p>
                    </div>
                </div>
            </section>

            {{ if .FlashMessage }}
            <section class="mb-6">
                <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg">
                    {{ .FlashMessage }}
                </div>
            </section>
            {{ end }}

            {{ if not .BufferOK }}
            <section class="mb-6">
                <div class="bg-yellow-100 border border-yellow-400 text-yellow-700 px-4 py-3 rounded-lg">
                    Buffer API key not configured. Set the BUFFER_KEY environment variable.
                </div>
            </section>
            {{ else }}

            <form method="POST" action="/{{ .Conf.Tag }}/admin/social/post">

            <!-- Speakers Section -->
            <section id="speakers" class="mb-6">
                <div class="bg-white shadow rounded-lg overflow-hidden">
                    <div class="px-6 py-4 bg-gray-50 border-b border-gray-200 flex items-center justify-between">
                        <h2 class="text-lg font-semibold text-gray-900">Speakers</h2>
                        {{ if .SpeakerRows }}
                        <label class="flex items-center gap-2 text-sm text-gray-600">
                            <input type="checkbox" onclick="toggleAll(this, 'speaker_')" class="rounded border-gray-300">
                            Select All
                        </label>
                        {{ end }}
                    </div>
                    {{ if .SpeakerRows }}
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-10"></th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Image</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Post Text</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            {{ range .SpeakerRows }}
                            <tr class="hover:bg-gray-50">
                                <td class="px-6 py-4 align-top">
                                    <input type="checkbox" name="speaker_{{ .ID }}" value="1" class="rounded border-gray-300">
                                    <input type="hidden" name="talkid_speaker{{ .ID }}" value="{{ .TalkID }}" class="rounded border-gray-300">
                                    <input type="hidden" name="speakerphoto_speaker_{{ .ID }}" value="{{ .SpeakerPhotoURL }}">
                                    <input type="hidden" name="photo_speaker_{{ .ID }}" value="{{ .PhotoURL }}">
                                    <input type="hidden" name="instaphoto_speaker_{{ .ID }}" value="{{ .InstaPhotoURL }}">
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-900 align-top">
                                    {{ .Name }}
                                    {{ if .TwitterHandle }}<div class="text-xs text-gray-400">@{{ .TwitterHandle }}</div>{{ end }}
                                </td>
                                <td class="px-6 py-4 align-top">
                                    <img src="{{ .PhotoURL | safeURL }}" loading="lazy" class="w-32 rounded border border-gray-200" alt="{{ .Name }}">
                                </td>
                                <td class="px-6 py-4">
                                    <textarea name="text_speaker_{{ .ID }}" rows="5" class="w-full rounded border border-gray-300 px-3 py-2 text-sm font-mono">{{ .PostText }}</textarea>
                                </td>
                            </tr>
                            {{ end }}
                        </tbody>
                    </table>
                    <div class="px-6 py-3 bg-gray-50 text-sm text-gray-500">
                        {{ len .SpeakerRows }} speakers
                    </div>
                    {{ else }}
                    <div class="px-6 py-4 text-sm text-gray-500 text-center">No speakers found.</div>
                    {{ end }}
                </div>
            </section>

            <!-- Talks Section -->
            <section id="talks" class="mb-6">
                <div class="bg-white shadow rounded-lg overflow-hidden">
                    <div class="px-6 py-4 bg-gray-50 border-b border-gray-200 flex items-center justify-between">
                        <h2 class="text-lg font-semibold text-gray-900">Talks</h2>
                        {{ if .TalkRows }}
                        <label class="flex items-center gap-2 text-sm text-gray-600">
                            <input type="checkbox" onclick="toggleAll(this, 'talk_')" class="rounded border-gray-300">
                            Select All
                        </label>
                        {{ end }}
                    </div>
                    {{ if .TalkRows }}
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-10"></th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Talk</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Image</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Post Text</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            {{ range .TalkRows }}
                            <tr class="hover:bg-gray-50">
                                <td class="px-6 py-4 align-top">
                                    <input type="checkbox" name="talk_{{ .ID }}" value="1" class="rounded border-gray-300">
                                    <input type="hidden" name="photo_talk_{{ .ID }}" value="{{ .PhotoURL }}">
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-900 align-top">
                                    {{ .Name }}
                                    <div class="text-xs text-gray-400">{{ .SpeakerNames }}</div>
                                </td>
                                <td class="px-6 py-4 align-top">
                                    <picture>
                                        {{ if avifSibling .PhotoURL }}<source srcset="{{ avifSibling .PhotoURL | safeURL }}" type="image/avif">{{ end }}
                                        <img src="{{ .PhotoURL | safeURL }}" loading="lazy" class="w-32 rounded border border-gray-200" alt="{{ .Name }}">
                                    </picture>
                                </td>
                                <td class="px-6 py-4">
                                    <textarea name="text_talk_{{ .ID }}" rows="5" class="w-full rounded border border-gray-300 px-3 py-2 text-sm font-mono">{{ .PostText }}</textarea>
                                </td>
                            </tr>
                            {{ end }}
                        </tbody>
                    </table>
                    <div class="px-6 py-3 bg-gray-50 text-sm text-gray-500">
                        {{ len .TalkRows }} talks
                    </div>
                    {{ else }}
                    <div class="px-6 py-4 text-sm text-gray-500 text-center">No talks found.</div>
                    {{ end }}
                </div>
            </section>

            <!-- Sponsors Section -->
            <section id="sponsors" class="mb-6">
                <div class="bg-white shadow rounded-lg overflow-hidden">
                    <div class="px-6 py-4 bg-gray-50 border-b border-gray-200 flex items-center justify-between">
                        <h2 class="text-lg font-semibold text-gray-900">Sponsors</h2>
                        {{ if .SponsorRows }}
                        <label class="flex items-center gap-2 text-sm text-gray-600">
                            <input type="checkbox" onclick="toggleAll(this, 'sponsor_')" class="rounded border-gray-300">
                            Select All
                        </label>
                        {{ end }}
                    </div>
                    {{ if .SponsorRows }}
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-10"></th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Sponsor</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Logo</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Post Text</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            {{ range .SponsorRows }}
                            <tr class="hover:bg-gray-50">
                                <td class="px-6 py-4 align-top">
                                    <input type="checkbox" name="sponsor_{{ .Ref }}" value="1" class="rounded border-gray-300">
                                    <input type="hidden" name="card_sponsor_{{ .Ref }}" value="{{ .CardURL }}">
                                    <input type="hidden" name="level_sponsor_{{ .Ref }}" value="{{ .Level }}">
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-900 align-top">
                                    {{ .OrgName }}
                                    {{ if .Twitter }}<div class="text-xs text-gray-400">@{{ .Twitter }}</div>{{ end }}
                                    <div class="text-xs text-gray-400">{{ .Level }}</div>
                                </td>
                                <td class="px-6 py-4 align-top">
                                    {{ if .CardURL }}<img src="{{ .CardURL | safeURL }}" loading="lazy" class="w-32 rounded border border-gray-200" alt="{{ .OrgName }}">{{ end }}
                                </td>
                                <td class="px-6 py-4">
                                    <textarea name="text_sponsor_{{ .Ref }}" rows="5" class="w-full rounded border border-gray-300 px-3 py-2 text-sm font-mono">{{ .PostText }}</textarea>
                                </td>
                            </tr>
                            {{ end }}
                        </tbody>
                    </table>
                    <div class="px-6 py-3 bg-gray-50 text-sm text-gray-500">
                        {{ len .SponsorRows }} sponsors
                    </div>
                    {{ else }}
                    <div class="px-6 py-4 text-sm text-gray-500 text-center">No sponsors found for this event.</div>
                    {{ end }}

                    {{ if .SponsorBatchText }}
                    <div class="px-6 py-4 border-t border-gray-200">
                        <label class="block text-sm font-medium text-gray-700 mb-2">Instagram Batch Post Text (all checked sponsors as carousel)</label>
                        <textarea name="text_sponsor_batch" rows="5" class="w-full rounded border border-gray-300 px-3 py-2 text-sm font-mono">{{ .SponsorBatchText }}</textarea>
                    </div>
                    {{ end }}
                </div>
            </section>

            <section class="mb-6">
                <button type="submit" class="w-full px-4 py-3 text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" onclick="return confirm('Queue selected posts to Buffer?')">
                    Queue Selected Posts to Buffer
                </button>
            </section>

            </form>
            {{ end }}
        </div>
    </div>
    <script>
    function toggleAll(source, prefix) {
        var checkboxes = document.querySelectorAll('input[type="checkbox"][name^="' + prefix + '"]');
        checkboxes.forEach(function(cb) { cb.checked = source.checked; });
    }
    </script>
  </body>
</html>
