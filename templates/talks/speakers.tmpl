<!DOCTYPE html>
<html>
  <head>
    <title>speaker admin @ bitcoin++</title>
    {{ block "header" . }} {{ end }}
    {{ template "admin_favicon" .Conf }}
  </head>
  <body>
    {{ block "mainnav" . }} {{ end }}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-5xl">
            <a href="/{{ .Conf.Tag }}/admin" class="text-xs text-gray-500 hover:text-gray-700">&larr; {{ .Conf.Desc }} dashboard</a>
            <section id="topline" class="mt-2 mb-6">
                <div class="overflow-hidden sm:rounded-lg bg-white shadow">
                    <div class="px-4 py-5 sm:p-6">
                        <h1 class="text-xl font-bold text-gray-900">Speaker Admin</h1>
                        <p class="text-sm text-gray-500">{{ .Conf.Desc }} - {{ .Conf.DateDesc }}</p>
                    </div>
                </div>
            </section>

            {{ if .FlashMessage }}
            <section class="mb-6">
                <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg">
                    {{ .FlashMessage }}
                </div>
            </section>
            {{ end }}

            <section id="controls" class="mb-6">
                <div class="bg-white shadow rounded-lg px-4 py-4 sm:px-6">
                    <div class="flex items-center gap-2">
                        {{ if .Rows }}
                        <button type="button" onclick="downloadCSV()" class="px-3 py-1.5 text-sm rounded-md text-white bg-green-600 hover:bg-green-700">Download CSV</button>
                        {{ if .IsConfAdmin }}
                        <a href="#compose" class="px-3 py-1.5 text-sm rounded-md text-white bg-indigo-600 hover:bg-indigo-700">Email Selected</a>
                        {{ end }}
                        {{ end }}
                        {{ if .IsConfAdmin }}
                        <form method="POST" action="/{{ .Conf.Tag }}/admin/speakers/sendcal">
                            <button type="submit" class="px-3 py-1.5 text-sm rounded-md text-white bg-orange-600 hover:bg-orange-700" onclick="return confirm('Send calendar invites to all speakers for {{ .Conf.Desc }}?')">Send Speaker Calendar Invites</button>
                        </form>
                        {{ end }}
                    </div>
                </div>
            </section>

            {{ if .Rows }}
            {{ if .IsConfAdmin }}<form id="speaker-email-form" method="POST" action="/{{ .Conf.Tag }}/admin/speakers/email">{{ end }}

            <div class="mb-3 flex items-center gap-2 flex-wrap">
                {{ if .IsConfAdmin }}
                <label class="inline-flex items-center gap-1 text-xs text-gray-600">
                    <input type="checkbox" onclick="toggleAllSpeakers(this)" class="rounded border-gray-300">
                    Select all
                </label>
                {{ end }}
                <span class="text-xs text-gray-400">{{ len .Rows }} speakers</span>
                <span class="text-xs text-gray-400" id="speaker-filter-count" data-total="{{ len .Rows }}"></span>
            </div>

            {{/*
              Client-side filter bar — same pattern as the applicants
              page. Each card carries data-{search, only-soft, has-talks}
              attributes; the JS at the bottom hides cards whose attrs
              don't match.
            */}}
            <div class="mb-3 flex flex-wrap items-center gap-2 rounded-md bg-gray-50 border border-gray-200 px-3 py-2">
                <input type="search" id="speaker-filter-q" placeholder="Search name, email, org, hometown…"
                       class="flex-1 min-w-[14rem] rounded border border-gray-300 px-2 py-1 text-xs focus:outline-2 focus:outline-bitcoin" />
                <label class="inline-flex items-center gap-1 text-xs text-gray-700">
                    <input type="checkbox" id="speaker-filter-hidesoft" class="rounded border-gray-300">
                    Hide invited/waitlisted-only
                </label>
                <button type="button" id="speaker-filter-clear"
                        class="rounded border border-gray-300 bg-white px-2 py-1 text-xs text-gray-700 hover:bg-gray-100">
                    Clear
                </button>
            </div>

            <section id="speakers-table" class="mb-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
                {{ range .Rows }}
                <article class="speaker-card bg-white shadow rounded-lg p-4 flex flex-col gap-2"
                         data-speaker-name="{{ .Name }}"
                         data-speaker-email="{{ .Email }}"
                         data-only-soft="{{ if .OnlySoftStatuses }}1{{ else }}0{{ end }}"
                         data-search="{{ .Name }} {{ .Email }} {{ .Company }} {{ .ComingFrom }}">
                    <div class="flex items-start gap-2">
                        {{ if $.IsConfAdmin }}
                        <input type="checkbox" name="speaker_refs" value="{{ .ID }}"
                               class="speaker-checkbox mt-1 rounded border-gray-300 shrink-0">
                        {{ end }}
                        <img src="{{ if .Photo }}{{ speakerPhoto .Photo }}{{ else }}/static/img/speaker-placeholder.png{{ end }}"
                             alt="{{ .Name }}"
                             class="size-10 rounded-full object-cover bg-gray-100 shrink-0" />
                        <div class="min-w-0 flex-1">
                            <h2 class="text-sm font-semibold text-gray-900 leading-snug break-words">{{ .Name }}</h2>
                            {{ if .Email }}
                            <p class="text-xs text-gray-600 font-mono break-all">{{ .Email }}</p>
                            {{ end }}
                            {{ if .Signal }}
                            <p class="text-[11px] text-gray-500">Signal: <span class="font-mono">{{ .Signal }}</span></p>
                            {{ end }}
                        </div>
                    </div>

                    <dl class="text-xs text-gray-600 grid grid-cols-[auto_1fr] gap-x-2 gap-y-0.5">
                        {{ if .ComingFrom }}
                        <dt class="font-medium text-gray-500">From:</dt>
                        <dd class="break-words">{{ .ComingFrom }}</dd>
                        {{ end }}
                        {{ if .Company }}
                        <dt class="font-medium text-gray-500">Org:</dt>
                        <dd class="flex items-center gap-1 break-words">
                            {{ if .OrgLogo }}
                            <img src="/static/img/sponsors/{{ .OrgLogo }}" alt="" class="size-4 rounded bg-gray-50 object-contain shrink-0" />
                            {{ end }}
                            <span>{{ .Company }}</span>
                        </dd>
                        {{ end }}
                    </dl>

                    {{ if .Talks }}
                    <div class="flex flex-wrap items-center gap-1">
                        {{ range .Talks }}
                        <a href="/{{ $.Conf.Tag }}/admin/proposal/{{ .ProposalID }}/edit"
                           class="inline-flex items-center gap-1 rounded-full bg-indigo-50 border border-indigo-200 px-2 py-0.5 text-[11px] text-indigo-900 hover:bg-indigo-100"
                           title="{{ .Title }} · {{ .Status }}">
                            <span class="truncate max-w-[10rem]">{{ .Title }}</span>
                            {{ if .Status }}
                            <span class="text-[9px] uppercase tracking-wide text-indigo-500">{{ .Status }}</span>
                            {{ end }}
                        </a>
                        {{ end }}
                    </div>
                    {{ else }}
                    <p class="text-[11px] italic text-amber-700">No talks attached</p>
                    {{ end }}

                    <div class="mt-1 flex items-center gap-3 text-[11px]">
                        <a href="/{{ $.Conf.Tag }}/admin/speakers/{{ .ID }}/edit"
                           class="text-indigo-600 hover:text-indigo-700">
                            Speaker &rarr;
                        </a>
                        {{ if .SpeakerConfID }}
                        <a href="/{{ $.Conf.Tag }}/admin/speakerconfs/{{ .SpeakerConfID }}/edit"
                           class="text-indigo-600 hover:text-indigo-700">
                            SpeakerConf &rarr;
                        </a>
                        {{ end }}
                    </div>
                </article>
                {{ end }}
            </section>

            {{ if .IsConfAdmin }}
            {{ template "email_compose" .EmailCompose }}
            </form>
            {{ end }}
            {{ else }}
            <section class="mb-6">
                <div class="bg-white shadow rounded-lg px-4 py-5 sm:p-6 text-center text-gray-500">
                    No speakers found for this event.
                </div>
            </section>
            {{ end }}
        </div>
    </div>
    {{ if .Rows }}
    <script>
    function downloadCSV() {
        var cards = document.querySelectorAll('.speaker-card');
        var csv = 'Name,Email\n';
        cards.forEach(function(card) {
            // data-speaker-* attrs are on each card so the CSV
            // doesn't have to peer into the markup of the row.
            var name = '"' + (card.dataset.speakerName || '').replace(/"/g, '""') + '"';
            var email = '"' + (card.dataset.speakerEmail || '').replace(/"/g, '""') + '"';
            csv += name + ',' + email + '\n';
        });
        var blob = new Blob([csv], {type: 'text/csv'});
        var a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = '{{ .Conf.Tag }}_speakers.csv';
        a.click();
    }
    function toggleAllSpeakers(source) {
        var checkboxes = document.querySelectorAll('.speaker-checkbox');
        checkboxes.forEach(function(cb) { cb.checked = source.checked; });
    }

    // Card filter: substring search + hide-only-soft toggle.
    // Hides cards whose data-* attrs don't match; counter shows
    // "M of N shown" when any filter is active.
    (function () {
      var q        = document.getElementById('speaker-filter-q');
      var hideSoft = document.getElementById('speaker-filter-hidesoft');
      var clear    = document.getElementById('speaker-filter-clear');
      var counter  = document.getElementById('speaker-filter-count');
      if (!q || !hideSoft) return;
      var cards = Array.prototype.slice.call(document.querySelectorAll('.speaker-card'));
      var total = cards.length;

      function apply() {
        var needle = (q.value || '').trim().toLowerCase();
        var hs     = hideSoft.checked;
        var shown = 0;
        for (var i = 0; i < cards.length; i++) {
          var c = cards[i];
          var matchQ  = !needle || (c.dataset.search || '').toLowerCase().indexOf(needle) !== -1;
          var matchHS = !hs || c.dataset.onlySoft !== '1';
          var visible = matchQ && matchHS;
          c.style.display = visible ? '' : 'none';
          if (visible) shown++;
        }
        if (counter) {
          counter.textContent = shown === total ? '' : '· ' + shown + ' of ' + total + ' shown';
        }
      }

      q.addEventListener('input', apply);
      hideSoft.addEventListener('change', apply);
      if (clear) {
        clear.addEventListener('click', function () {
          q.value = '';
          hideSoft.checked = false;
          apply();
          q.focus();
        });
      }
      apply();
    })();
    </script>
    {{ end }}
  </body>
</html>
