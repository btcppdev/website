<!DOCTYPE html>
<html>
  <head>
    <title>speaker gifts @ bitcoin++</title>
    {{ block "header" . }} {{ end }}
    {{ template "admin_favicon" .Conf }}
  </head>
  <body class="btcpp-admin-page">
    {{ block "mainnav" . }} {{ end }}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-5xl">
            <div class="mb-4">
                <a href="/{{ .Conf.Tag }}/admin" class="text-xs text-gray-500 hover:text-gray-700">&larr; {{ .Conf.Desc }} dashboard</a>
            </div>

            <section id="topline" class="mb-6">
                <div class="overflow-hidden sm:rounded-lg bg-white shadow">
                    <div class="px-4 py-5 sm:p-6">
                        <h1 class="text-xl font-bold text-gray-900">Speaker Gifts List</h1>
                        <p class="text-sm text-gray-500">{{ .Conf.Desc }} - {{ .Conf.DateDesc }}</p>
                    </div>
                </div>
            </section>

            <section id="controls" class="mb-6">
                <div class="bg-white shadow rounded-lg px-4 py-4 sm:px-6">
                    <form method="GET" action="/{{ .Conf.Tag }}/admin/gifts" class="flex items-end gap-4 flex-wrap">
                        <div>
                            <label for="filepath" class="block text-sm font-medium text-gray-700 mb-1">File Path Prefix</label>
                            <input type="text" name="filepath" id="filepath" value="{{ .FilePath }}" placeholder="/path/to/clipart/" class="rounded border border-gray-300 px-3 py-1.5 text-sm w-64">
                        </div>
                        <div class="flex items-center gap-2">
                            <button type="submit" class="px-3 py-1.5 text-sm rounded-md text-white bg-indigo-600 hover:bg-indigo-700">Apply</button>
                            {{ if .Rows }}
                            <button type="button" onclick="downloadCSV()" class="px-3 py-1.5 text-sm rounded-md text-white bg-green-600 hover:bg-green-700">Download CSV</button>
                            <a href="/{{ .Conf.Tag }}/admin/gifts/clipart.zip" class="px-3 py-1.5 text-sm rounded-md text-white bg-blue-600 hover:bg-blue-700">Download clipart</a>
                            {{ end }}
                        </div>
                    </form>
                </div>
            </section>

            {{ if .Rows }}
            <section id="talks-table" class="mb-6">
                <div class="bg-white shadow rounded-lg overflow-hidden">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Clipart</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Speaker</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            {{ range .Rows }}
                            <tr class="hover:bg-gray-50">
                                <td class="px-6 py-4 text-sm text-gray-900">{{ if $.FilePath }}{{ $.FilePath }}{{ end }}{{ .Clipart }}</td>
                                <td class="px-6 py-4 text-sm text-gray-900">{{ .SpeakerName }}</td>
                            </tr>
                            {{ end }}
                        </tbody>
                    </table>
                    <div class="px-6 py-3 bg-gray-50 text-sm text-gray-500">
                        {{ len .Rows }} speakers
                    </div>
                </div>
            </section>
            {{ else }}
            <section class="mb-6">
                <div class="bg-white shadow rounded-lg px-4 py-5 sm:p-6 text-center text-gray-500">
                    No talks found for this event.
                </div>
            </section>
            {{ end }}
        </div>
    </div>
    {{ if .Rows }}
    <script>
    function downloadCSV() {
        var rows = document.querySelectorAll('#talks-table tbody tr');
        var csv = '@Photo,Name\n';
        rows.forEach(function(row) {
            var cells = row.querySelectorAll('td');
            var photo = '"' + cells[0].textContent.trim().replace(/"/g, '""') + '"';
            var name = '"' + cells[1].textContent.trim().replace(/"/g, '""') + '"';
            csv += photo + ',' + name + '\n';
        });
        var blob = new Blob([csv], {type: 'text/csv'});
        var a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = '{{ .Conf.Tag }}_canvases.csv';
        a.click();
    }
    </script>
    {{ end }}
  </body>
</html>
