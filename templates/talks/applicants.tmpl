<!DOCTYPE html>
<html>
  <head>
    <title>talk proposals @ bitcoin++</title>
    {{ block "header" . }} {{ end }}
    {{ template "admin_favicon" .Conf }}
  </head>
  <body class="bg-gray-50">
    {{ block "mainnav" . }} {{ end }}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
        <a href="/{{ .Conf.Tag }}/admin" class="text-xs text-gray-500 hover:text-gray-700">&larr; {{ .Conf.Desc }} dashboard</a>
        <section id="topline" class="mt-2 mb-6">
            <div class="overflow-hidden sm:rounded-lg bg-white shadow">
                <div class="px-4 py-5 sm:p-6 flex items-center justify-between gap-4 flex-wrap">
                    <div>
                        <h1 class="text-xl font-bold text-gray-900">Talk Proposals</h1>
                        <p class="text-sm text-gray-500">{{ .Conf.Desc }} · {{ .Conf.DateDesc }}</p>
                    </div>
                    <div class="flex items-center gap-2 shrink-0 flex-wrap">
                        <a href="/{{ .Conf.Tag }}/admin/invite-speaker"
                           class="inline-flex items-center rounded-md bg-green-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-green-700">
                            Invite a speaker
                        </a>
                        <form method="POST" action="/{{ .Conf.Tag }}/admin/applicants/sendcal-all">
                            <button type="submit"
                                    onclick="return confirm('Send cal invites to every scheduled proposal whose data is unchanged since the last send? Proposals with pending updates (orange button) are skipped — review those individually.');"
                                    class="inline-flex items-center rounded-md bg-blue-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-blue-700">
                                📅 Send all cal invites
                            </button>
                        </form>
                        <form method="POST" action="/{{ .Conf.Tag }}/admin/applicants/resend-tickets">
                            <button type="submit"
                                    onclick="return confirm('Issue speaker tickets for every Accepted proposal whose speakers don\'t already have a ticket for this conf?');"
                                    class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-indigo-700">
                                Resend tickets
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </section>

        {{ if .FlashMessage }}
        <section class="mb-6">
            <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg">
                {{ .FlashMessage }}
            </div>
        </section>
        {{ end }}

        {{ if .Rows }}
        <form method="POST" action="/{{ .Conf.Tag }}/admin/applicants/email">
            <div class="mb-3 flex items-center gap-2 flex-wrap">
                <label class="inline-flex items-center gap-1 text-xs text-gray-600">
                    <input type="checkbox" id="select-all" onclick="toggleAll(this)" class="rounded border-gray-300">
                    Select all
                </label>
                <span class="text-xs text-gray-400">{{ len .Rows }} proposals</span>
                <span class="text-xs text-gray-400" id="filter-count" data-total="{{ len .Rows }}"></span>
            </div>

            {{/*
              Client-side filter bar — keeps the page render server-
              side cheap (one big slice; the dashboard is bounded by
              the conf's proposal count). data-status / data-placed /
              data-search attributes on each card drive the JS at the
              bottom of the template; no XHR / server round-trip per
              keystroke.
            */}}
            <div class="mb-3 flex flex-wrap items-center gap-2 rounded-md bg-gray-50 border border-gray-200 px-3 py-2">
                <input type="search" id="filter-q" placeholder="Search title or speaker…"
                       class="flex-1 min-w-[12rem] rounded border border-gray-300 px-2 py-1 text-xs focus:outline-2 focus:outline-bitcoin" />
                <select id="filter-status" class="rounded border border-gray-300 px-2 py-1 text-xs">
                    <option value="">All statuses</option>
                    <option value="">─────────</option>
                    <option value="Applied">Applied</option>
                    <option value="InReview">In review</option>
                    <option value="Waitlisted">Waitlisted</option>
                    <option value="Invited">Invited</option>
                    <option value="Accepted">Accepted</option>
                    <option value="Scheduled">Scheduled</option>
                    <option value="TheyDecline">TheyDecline</option>
                    <option value="WeDecline">WeDecline</option>
                    <option value="Rejected">Rejected</option>
                </select>
                <select id="filter-placed" class="rounded border border-gray-300 px-2 py-1 text-xs">
                    <option value="">Any placement</option>
                    <option value="1">Has scheduled time</option>
                    <option value="0">No scheduled time</option>
                </select>
                <select id="filter-talktype" class="rounded border border-gray-300 px-2 py-1 text-xs">
                    <option value="">Any type</option>
                    <option value="talk">talk</option>
                    <option value="workshop">workshop</option>
                    <option value="panel">panel</option>
                    <option value="keynote">keynote</option>
                    <option value="hackathon">hackathon</option>
                </select>
                <button type="button" id="filter-clear"
                        class="rounded border border-gray-300 bg-white px-2 py-1 text-xs text-gray-700 hover:bg-gray-100">
                    Clear
                </button>
            </div>

            <section id="proposals-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
                {{ range .Rows }}
                {{ $row := . }}
                {{ $invite := inviteLink .Proposal }}
                {{ $terminal := or (eq .Proposal.Status "Accepted") (eq .Proposal.Status "Scheduled") (eq .Proposal.Status "TheyDecline") (eq .Proposal.Status "WeDecline") (eq .Proposal.Status "Rejected") }}
                <article class="proposal-card shadow rounded-lg p-4 flex flex-col gap-2 {{ if eq .CalState "stale" }}bg-amber-50 ring-1 ring-amber-300{{ else }}bg-white{{ end }}"
                         data-status="{{ .Proposal.Status }}"
                         data-placed="{{ if .StartLabel }}1{{ else }}0{{ end }}"
                         data-talktype="{{ .Proposal.TalkType }}"
                         data-search="{{ .Proposal.Title }}{{ range .Speakers }} {{ .Name }} {{ .Email }}{{ end }}">
                    <div class="flex items-start gap-2">
                        <input type="checkbox" name="proposal_refs" value="{{ .Proposal.ID }}"
                               class="app-checkbox mt-1 rounded border-gray-300 shrink-0">
                        {{ if .TalkCardURL }}
                        <a href="{{ .TalkCardURL }}" target="_blank" rel="noopener noreferrer" class="shrink-0">
                            <img src="{{ .TalkCardURL }}" alt="" loading="lazy"
                                 class="h-16 w-16 rounded-md object-cover bg-gray-100 ring-1 ring-gray-200" />
                        </a>
                        {{ end }}
                        <div class="min-w-0 flex-1">
                            <h2 class="text-sm font-semibold text-gray-900 leading-snug break-words">{{ .Proposal.Title }}</h2>
                            {{ if .Speakers }}
                            <div class="mt-1 flex flex-wrap items-center gap-1">
                                {{ range .Speakers }}
                                <span class="inline-flex items-center gap-1 rounded-full bg-gray-50 border border-gray-200 pl-0.5 pr-2 py-0.5 text-[11px] text-gray-700"
                                      title="{{ .Name }}{{ if .Email }} — {{ .Email }}{{ end }}{{ if .Company }} ({{ .Company }}){{ end }}">
                                    <img src="{{ if .Photo }}{{ speakerPhoto .Photo }}{{ else }}/static/img/speaker-placeholder.png{{ end }}"
                                         alt=""
                                         class="size-4 rounded-full object-cover bg-gray-100 shrink-0" />
                                    <span class="truncate max-w-[8rem]">{{ .Name }}</span>
                                </span>
                                {{ end }}
                                <span class="text-[10px] text-gray-400 ml-1">{{ len .Speakers }} speaker{{ if ne (len .Speakers) 1 }}s{{ end }}</span>
                            </div>
                            {{ else }}
                            <p class="mt-1 text-[11px] italic text-amber-700">No speakers attached</p>
                            {{ end }}
                            <p class="mt-1 text-xs">
                                <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 font-medium text-gray-700">{{ .Proposal.Status }}</span>
                            </p>
                        </div>
                    </div>

                    <dl class="text-xs text-gray-600 grid grid-cols-[auto_1fr] gap-x-2 gap-y-0.5">
                        {{ if .StartLabel }}
                        <dt class="font-medium text-gray-500">When:</dt>
                        <dd class="break-words">{{ .StartLabel }}{{ if .EndLabel }} – {{ .EndLabel }}{{ end }}</dd>
                        {{ else }}
                        <dt class="font-medium text-gray-500">When:</dt>
                        <dd class="text-gray-400 italic">not scheduled</dd>
                        {{ end }}

                        {{ if .VenueLabel }}
                        <dt class="font-medium text-gray-500">Where:</dt>
                        <dd class="break-words">{{ .VenueLabel }}</dd>
                        {{ end }}

                        <dt class="font-medium text-gray-500">Duration:</dt>
                        <dd>
                            {{ if .DurationActualMin }}{{ .DurationActualMin }}m scheduled{{ else }}—{{ end }}
                            {{ if .DurationDesiredMin }}<span class="text-gray-400">· {{ .DurationDesiredMin }}m desired</span>{{ end }}
                        </dd>
                    </dl>

                    <div class="flex items-center gap-2 flex-wrap pt-1">
                        <a href="/{{ $.Conf.Tag }}/admin/proposal/{{ .Proposal.ID }}/edit?return=%2F{{ $.Conf.Tag }}%2Fadmin%2Fapplicants"
                           class="inline-flex items-center rounded-md border border-gray-300 bg-white px-2.5 py-1 text-xs font-semibold text-gray-700 hover:bg-gray-50">
                            Edit
                        </a>
                        {{ if .TalkCardURL }}
                        <button type="submit"
                            formaction="/{{ $.Conf.Tag }}/admin/applicants/{{ .Proposal.ID }}/refresh-card"
                            formmethod="POST"
                            class="inline-flex items-center rounded-md bg-purple-600 px-2.5 py-1 text-xs font-semibold text-white hover:bg-purple-700">
                            Refresh card
                        </button>
                        {{ end }}
                        {{/* Cal-invite button: only renders when the proposal has a ConfTalk with a scheduled end. */}}
                        {{ if .CalState }}
                        <button type="submit"
                            formaction="/{{ $.Conf.Tag }}/admin/proposals/{{ .Proposal.ID }}/sendcal"
                            formmethod="POST"
                            class="inline-flex items-center rounded-md px-2.5 py-1 text-xs font-semibold text-white {{ if eq .CalState "none" }}bg-blue-600 hover:bg-blue-700{{ else if eq .CalState "stale" }}bg-orange-600 hover:bg-orange-700{{ else }}bg-gray-500 hover:bg-gray-600{{ end }}">
                            {{ if eq .CalState "none" }}📅 Send cal invite
                            {{ else if eq .CalState "stale" }}📅 Update cal invite
                            {{ else }}📅 Resend cal invite{{ end }}
                        </button>
                        {{ end }}

                        {{/* Per-proposal status actions. Pull from the existing applicants surface so the proposals page stays a one-stop admin view. */}}
                        {{ if $invite }}
                        <button type="button"
                                data-invite-url="{{ $invite }}"
                                class="copy-invite-btn inline-flex items-center rounded-md bg-indigo-600 px-2.5 py-1 text-xs font-semibold text-white hover:bg-indigo-700">
                            Copy invite
                        </button>
                        {{ end }}

                        {{ if not $terminal }}
                            {{ if ne .Proposal.Status "Invited" }}
                            <button type="submit"
                                formaction="/{{ $.Conf.Tag }}/admin/review/{{ .Proposal.ID }}/invite?return=%2F{{ $.Conf.Tag }}%2Fadmin%2Fapplicants"
                                formmethod="POST"
                                class="inline-flex items-center rounded-md bg-green-600 px-2.5 py-1 text-xs font-semibold text-white hover:bg-green-700">
                                Invite
                            </button>
                            {{ end }}
                            {{ if and (ne .Proposal.Status "Waitlisted") (ne .Proposal.Status "Invited") }}
                            <button type="submit"
                                formaction="/{{ $.Conf.Tag }}/admin/review/{{ .Proposal.ID }}/waitlist?return=%2F{{ $.Conf.Tag }}%2Fadmin%2Fapplicants"
                                formmethod="POST"
                                class="inline-flex items-center rounded-md bg-yellow-500 px-2.5 py-1 text-xs font-semibold text-white hover:bg-yellow-600">
                                Waitlist
                            </button>
                            {{ end }}
                            <button type="submit"
                                formaction="/{{ $.Conf.Tag }}/admin/review/{{ .Proposal.ID }}/decline?return=%2F{{ $.Conf.Tag }}%2Fadmin%2Fapplicants"
                                formmethod="POST"
                                class="inline-flex items-center rounded-md bg-gray-600 px-2.5 py-1 text-xs font-semibold text-white hover:bg-gray-700">
                                Decline
                            </button>
                            <button type="submit"
                                formaction="/{{ $.Conf.Tag }}/admin/review/{{ .Proposal.ID }}/confirm?return=%2F{{ $.Conf.Tag }}%2Fadmin%2Fapplicants"
                                formmethod="POST"
                                class="text-xs text-gray-500 hover:text-gray-800 underline bg-transparent border-0 p-0">
                                Mark Confirmed
                            </button>
                        {{ end }}

                        {{ if or (eq .Proposal.Status "Accepted") (eq .Proposal.Status "Scheduled") }}
                        <button type="submit"
                            formaction="/{{ $.Conf.Tag }}/admin/applicants/{{ .Proposal.ID }}/cancel"
                            formmethod="POST"
                            onclick="return confirm('Cancel this talk? Status will be set to TheyDecline. This is for the case where the speaker pulls out after confirming.');"
                            class="inline-flex items-center rounded-md bg-red-600 px-2.5 py-1 text-xs font-semibold text-white hover:bg-red-700">
                            Cancel
                        </button>
                        {{ end }}
                    </div>
                </article>
                {{ end }}
            </section>

            {{ template "email_compose" .EmailCompose }}
        </form>
        {{ else }}
        <section class="mb-6">
            <div class="bg-white shadow rounded-lg px-4 py-5 sm:p-6 text-center text-gray-500">
                No proposals found for this event.
            </div>
        </section>
        {{ end }}
    </div>
    <script>
    function toggleAll(source) {
        var checkboxes = document.querySelectorAll('.app-checkbox');
        checkboxes.forEach(function(cb) { cb.checked = source.checked; });
    }
    // Per-card Copy invite buttons. data-invite-url carries the
    // speaker's pre-built magic link so we don't string-build at
    // click time; server-rendered to keep the template in charge
    // of URL shape.
    (function () {
      document.querySelectorAll('.copy-invite-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var url = btn.dataset.inviteUrl;
          if (!url) return;
          var original = btn.textContent;
          navigator.clipboard.writeText(url).then(function () {
            btn.textContent = 'Copied!';
            btn.classList.add('bg-green-600');
            btn.classList.remove('bg-indigo-600', 'hover:bg-indigo-700');
            setTimeout(function () {
              btn.textContent = original;
              btn.classList.remove('bg-green-600');
              btn.classList.add('bg-indigo-600', 'hover:bg-indigo-700');
            }, 1500);
          }).catch(function () {
            btn.textContent = 'Copy failed';
            setTimeout(function () { btn.textContent = original; }, 1500);
          });
        });
      });
    })();

    // Proposal-card filter bar — hide cards whose
    // data-{status,placed,search} don't match the three inputs.
    // Pure DOM filter: no XHR, no server reload; cheap for the
    // applicants page's bounded proposal count.
    (function () {
      var q        = document.getElementById('filter-q');
      var status   = document.getElementById('filter-status');
      var placed   = document.getElementById('filter-placed');
      var talktype = document.getElementById('filter-talktype');
      var clear    = document.getElementById('filter-clear');
      var counter  = document.getElementById('filter-count');
      if (!q || !status || !placed) return;
      var cards = Array.prototype.slice.call(
        document.querySelectorAll('.proposal-card')
      );
      var total = cards.length;

      function apply() {
        var needle = (q.value || '').trim().toLowerCase();
        var st     = status.value;
        var pl     = placed.value;
        var tt     = talktype ? talktype.value : '';
        var shown = 0;
        for (var i = 0; i < cards.length; i++) {
          var c = cards[i];
          var matchSt = !st || c.dataset.status === st;
          var matchPl = !pl || c.dataset.placed === pl;
          var matchTT = !tt || c.dataset.talktype === tt;
          var matchQ  = !needle || (c.dataset.search || '').toLowerCase().indexOf(needle) !== -1;
          var visible = matchSt && matchPl && matchTT && matchQ;
          c.style.display = visible ? '' : 'none';
          if (visible) shown++;
        }
        if (counter) {
          counter.textContent = shown === total
            ? ''
            : '· ' + shown + ' of ' + total + ' shown';
        }
      }

      q.addEventListener('input', apply);
      status.addEventListener('change', apply);
      placed.addEventListener('change', apply);
      if (talktype) talktype.addEventListener('change', apply);
      if (clear) {
        clear.addEventListener('click', function () {
          q.value = '';
          status.value = '';
          placed.value = '';
          if (talktype) talktype.value = '';
          apply();
          q.focus();
        });
      }
      apply();
    })();
    </script>
  </body>
</html>
