<!doctype html>
<html lang="en">
<head>
  <title>{{ .Competition.Title }} - bitcoin++ hackathon</title>
  {{ block "header" . }} {{ end }}
</head>
<body class="hack-redesign">
  {{ block "mainnav" . }} {{ end }}
  <main class="hack-shell">
    <div class="hack-ticker" aria-label="Hackathon highlights">
      <span class="hack-ticker__live">▶ Live</span>
      <span>{{ .Competition.Title }}</span>
      <span>•</span>
      <span>{{ .CompetitionStatusLabel }}</span>
      <span>•</span>
      <span>{{ with .Competition.MaxTeamSize }}Up to {{ . }} builders per team{{ else }}Unlimited team size{{ end }}</span>
      {{ if .ConferenceLabel }}<span>•</span><span>{{ .ConferenceLabel }}</span>{{ end }}
    </div>

    <header class="hack-header">
      <div>
        <a href="/" class="hack-brand">bitcoin<span>++</span></a>
        <div class="hack-header__meta">[ {{ if .ConferenceLabel }}{{ .ConferenceLabel }} · {{ end }}Hackathon ]</div>
      </div>
      <nav class="hack-header__nav" aria-label="Hackathon links">
        <a href="#overview">overview/</a>
        <a href="#projects">projects/</a>
        {{ if or .Competition.PublicTablesEnabled .CanAdminEdit }}<a href="#tables">tables/</a>{{ end }}
        <a href="{{ .ScheduleURL }}">schedule/</a>
        {{ if .ConferenceURL }}<a href="{{ .ConferenceURL }}">← conf</a>{{ end }}
      </nav>
    </header>

    <section class="hack-hero">
      <img src="/static/img/rebrand/hero-hackathon.png" alt="">
      <div class="hack-hero__content">
        <div class="hack-hero__top">
          <div>The hackathon</div>
          <div>{{ if .ConferenceLabel }}{{ .ConferenceLabel }}{{ else }}bitcoin++{{ end }}</div>
        </div>
        <div>
          <div class="hack-hero__label"><strong>Hack</strong> Build · Ship · Demo</div>
          <h1>{{ .Competition.Title }}</h1>
          <div class="hack-hero__deck">
            {{ if .Competition.Description }}
            {{ .Competition.Description }}
            {{ else }}
            Build something real alongside the conference, submit your project, and put it in front of judges and the bitcoin++ community.
            {{ end }}
          </div>
          <div class="hack-actions">
            {{ if .CanCreate }}
            <a href="{{ .ProjectNewURL }}" class="hack-button hack-button--accent">Create project →</a>
            {{ else if not .Viewer }}
            <a href="{{ .LoginURL }}" class="hack-button hack-button--accent">Sign in →</a>
            {{ end }}
            <a href="#projects" class="hack-button hack-button--light">View projects →</a>
            <a href="{{ .ScheduleURL }}" class="hack-button hack-button--light">View schedule →</a>
            {{ if .CanJudge }}<a href="{{ .JudgingURL }}" class="hack-button hack-button--light">Judging →</a>{{ end }}
            {{ if .CanAdminEdit }}<a href="{{ .AdminEditURL }}" class="hack-button hack-button--light">Edit hackathon →</a>{{ end }}
          </div>
        </div>
      </div>
    </section>

    {{ if .FlashMessage }}
    <div class="mx-6 mt-6 border border-green-700 bg-green-50 px-4 py-3 text-sm text-green-900">{{ .FlashMessage }}</div>
    {{ end }}
    {{ if .FlashError }}
    <div class="mx-6 mt-6 border border-red-700 bg-red-50 px-4 py-3 text-sm text-red-900">{{ .FlashError }}</div>
    {{ end }}

    <section class="hack-section" id="overview">
      <div class="hack-stat-grid">
        <div class="hack-stat">
          <div class="hack-stat__value">{{ .CompetitionStatusLabel }}</div>
          <div class="hack-stat__label">Status</div>
        </div>
        <div class="hack-stat">
          <div class="hack-stat__value">{{ with .Competition.MaxTeamSize }}{{ . }}{{ else }}∞{{ end }}</div>
          <div class="hack-stat__label">{{ with .Competition.MaxTeamSize }}Max builders per team{{ else }}Team size{{ end }}</div>
        </div>
        <div class="hack-stat">
          <div class="hack-stat__value">{{ len .Projects }}</div>
          <div class="hack-stat__label">Visible projects</div>
        </div>
        <div class="hack-stat">
          <div class="hack-stat__value">{{ len .Awards }}</div>
          <div class="hack-stat__label">Awards</div>
        </div>
      </div>

      <div class="hack-section__head">
        <div>
          <div class="hack-label">§01 · Overview</div>
          <h2>Build in <span class="hack-serif">public.</span></h2>
        </div>
        <div class="hack-section__deck">
          Projects stay private until organizers open the public gallery. Judges and admins can review submissions while the event is running.
        </div>
      </div>

      <div class="hack-overview-grid">
        <div class="hack-copy">
          <div class="hack-copy__body">
            {{ if .Competition.Description }}
            {{ .RichText .Competition.Description }}
            {{ else }}
            Details are still being finalized.
            {{ end }}
          </div>
        </div>
        <dl class="hack-side">
          <div class="hack-side-row">
            <dt>Conference</dt>
            <dd>
              {{ if .ConferenceLabel }}
              {{ if .ConferenceURL }}<a href="{{ .ConferenceURL }}">{{ .ConferenceLabel }}</a>{{ else }}{{ .ConferenceLabel }}{{ end }}
              {{ else }}
              TBA
              {{ end }}
            </dd>
          </div>
          <div class="hack-side-row">
            <dt>{{ if and .NextMilestoneLabel (not .NextMilestoneIsScheduleLink) }}{{ .NextMilestoneLabel }}{{ else }}Timeline{{ end }}</dt>
            <dd>
              {{ if .NextMilestoneValue }}
              {{ with .NextMilestoneTime }}
              <time class="hackathon-detail-time" datetime="{{ .Format "2006-01-02T15:04:05Z07:00" }}">{{ $.NextMilestoneValue }}</time>
              {{ else }}
              {{ $.NextMilestoneValue }}
              {{ end }}
              {{ else }}
              TBA
              {{ end }}
            </dd>
            <a href="{{ .ScheduleURL }}">View schedule →</a>
          </div>
          <div class="hack-side-row">
            <dt>Team size</dt>
            <dd>{{ with .Competition.MaxTeamSize }}Up to {{ . }}{{ else }}Unlimited{{ end }}</dd>
          </div>
        </dl>
      </div>
    </section>

    <nav class="hack-tabs" aria-label="Hackathon sections">
      <button type="button" data-hackathon-tab="projects" class="hack-tab" aria-selected="true">Projects · {{ len .Projects }}</button>
      {{ if .Awards }}<button type="button" data-hackathon-tab="awards" class="hack-tab" aria-selected="false">Winners · {{ len .Awards }}</button>{{ end }}
      {{ if or .Competition.PublicTablesEnabled .CanAdminEdit }}<button type="button" data-hackathon-tab="tables" class="hack-tab" aria-selected="false">Tables</button>{{ end }}
    </nav>

    <section data-hackathon-tab-panel="projects" class="hack-panel" id="projects">
      <div class="hack-section__head">
        <div>
          <div class="hack-label">§02 · Projects</div>
          <h2>What got <span class="hack-serif">built.</span></h2>
        </div>
        <div class="hack-section__deck">Every visible project from this hackathon, sorted by the current platform rules.</div>
      </div>
      {{ if .Projects }}
      <div class="hack-card-grid">
        {{ range $index, $project := .Projects }}
        {{ $winningAwards := $.ProjectWinningAwards $project }}
        <article id="project-{{ $project.ID }}" class="hack-card">
          <div class="hack-card__media" data-initials="++">
            {{ if $winningAwards }}<span class="hack-badge" style="position:absolute;top:12px;left:12px;z-index:1;">★ Winner</span>{{ end }}
          </div>
          <div class="hack-card__body">
            <div class="hack-card__top">
              <h3>{{ $project.Title }}</h3>
              <div class="hack-card__number">{{ $.ProjectNumberLabel $project }}</div>
            </div>
            {{ if $project.ShortDescription }}<div class="hack-card__desc">{{ $project.ShortDescription }}</div>{{ end }}
            {{ if $winningAwards }}
            <div class="hack-tags">
              {{ range $winningAwards }}<span class="hack-badge">{{ .Title }}</span>{{ end }}
            </div>
            {{ else if $.ProjectIsFinalist $project }}
            <div class="hack-tags"><span class="hack-badge">Finalist</span></div>
            {{ end }}
            {{ if $project.Description }}
            <div class="hack-copy__body" style="font-size:14px;line-height:1.55;">{{ $.RichText $project.Description }}</div>
            {{ end }}
            {{ if $project.Tags }}
            <div class="hack-tags">
              {{ range $project.Tags }}<span class="hack-tag">{{ . }}</span>{{ end }}
            </div>
            {{ end }}
            <div class="hack-card__links">
              {{ if $project.GitHubURL }}<a href="{{ $project.GitHubURL }}">GitHub</a>{{ end }}
              {{ if $project.DemoURL }}<a href="{{ $project.DemoURL }}">Demo</a>{{ end }}
              {{ if $project.VideoURL }}<a href="{{ $project.VideoURL }}">Video</a>{{ end }}
              {{ if $project.SlidesURL }}<a href="{{ $project.SlidesURL }}">Slides</a>{{ end }}
              {{ if $project.DocsURL }}<a href="{{ $project.DocsURL }}">Docs</a>{{ end }}
              {{ if $.CanManageProject $project.ID }}<a href="{{ $.ProjectURL $project }}">Manage</a>{{ end }}
            </div>
          </div>
        </article>
        {{ end }}
      </div>
      {{ else }}
      <div class="hack-empty">
        <p>No visible projects yet.</p>
        {{ if .CanCreate }}<a href="{{ .ProjectNewURL }}" class="hack-button hack-button--accent">Create project →</a>{{ end }}
      </div>
      {{ end }}
    </section>

    {{ if .Awards }}
    <section data-hackathon-tab-panel="awards" class="hack-panel hidden hack-awards" id="awards">
      <div class="hack-section__head">
        <div>
          <div class="hack-label">§03 · Winners</div>
          <h2>Prize <span class="hack-serif">record.</span></h2>
        </div>
        <div class="hack-section__deck">Ranked awards, bounties, and assigned winning projects.</div>
      </div>
      <div class="hack-card-grid">
        {{ range .Awards }}
        <article class="hack-card hack-award-card">
          <div class="hack-card__body">
            <div class="hack-label">★ Award</div>
            <h3>{{ .Title }}</h3>
            {{ if .Description }}<div class="hack-card__desc">{{ $.RichText .Description }}</div>{{ end }}
            {{ $awardees := $.Awardees . }}
            {{ if $awardees }}
            <div class="hack-tags">
              {{ range $awardees }}<a href="#project-{{ .ProjectID }}" class="hack-badge">{{ .ProjectTitle }}</a>{{ end }}
            </div>
            {{ end }}
            {{ $prizes := $.AwardPrizes . }}
            {{ if $prizes }}
            <div class="hack-card__links">
              {{ range $prizes }}
              <span>{{ .Title }}{{ if .ValueText }} · {{ .ValueText }}{{ end }}</span>
              {{ end }}
            </div>
            {{ end }}
          </div>
        </article>
        {{ end }}
      </div>
    </section>
    {{ end }}

    {{ if or .Competition.PublicTablesEnabled .CanAdminEdit }}
    <section data-hackathon-tab-panel="tables" class="hack-panel hidden" id="tables">
      <div class="hack-section__head">
        <div>
          <div class="hack-label">§04 · Tables</div>
          <h2>Find the <span class="hack-serif">projects.</span></h2>
        </div>
        <div class="hack-section__deck">Public project table assignments for demos and expo-style review.</div>
      </div>
      {{ if .Projects }}
      <div class="hack-table-wrap">
        <table class="hack-table">
          <thead>
            <tr>
              <th scope="col">Table</th>
              <th scope="col">Project</th>
            </tr>
          </thead>
          <tbody>
            {{ range .Projects }}
            <tr>
              <td>{{ $.ProjectNumberLabel . }}</td>
              <td><a href="#project-{{ .ID }}">{{ .Title }}</a></td>
            </tr>
            {{ end }}
          </tbody>
        </table>
      </div>
      {{ else }}
      <div class="hack-empty"><p>No visible projects yet.</p></div>
      {{ end }}
    </section>
    {{ end }}
  </main>
  <script>
    (function () {
      const tabs = Array.prototype.slice.call(document.querySelectorAll('[data-hackathon-tab]'));
      const panels = Array.prototype.slice.call(document.querySelectorAll('[data-hackathon-tab-panel]'));
      if (tabs.length === 0 || panels.length === 0) return;

      function setTab(name) {
        const exists = tabs.some(tab => tab.dataset.hackathonTab === name);
        if (!exists) name = 'projects';
        for (const tab of tabs) {
          const active = tab.dataset.hackathonTab === name;
          tab.setAttribute('aria-selected', active ? 'true' : 'false');
        }
        for (const panel of panels) {
          panel.classList.toggle('hidden', panel.dataset.hackathonTabPanel !== name);
        }
      }

      function tabFromHash() {
        if (window.location.hash === '#awards') return 'awards';
        if (window.location.hash === '#tables') return 'tables';
        if (window.location.hash.indexOf('#project-') === 0) return 'projects';
        return 'projects';
      }

      for (const tab of tabs) {
        tab.addEventListener('click', function () {
          const name = tab.dataset.hackathonTab;
          setTab(name);
          history.replaceState(null, '', '#' + name);
        });
      }

      function showHashTarget() {
        setTab(tabFromHash());
        if (window.location.hash.indexOf('#project-') !== 0) return;
        const target = document.getElementById(window.location.hash.slice(1));
        if (target) window.setTimeout(() => target.scrollIntoView({ block: 'start' }), 0);
      }

      window.addEventListener('hashchange', showHashTarget);
      showHashTarget();
    })();

    (function () {
      const times = Array.prototype.slice.call(document.querySelectorAll('.hackathon-detail-time'));
      if (times.length === 0) return;
      const localTZ = Intl.DateTimeFormat().resolvedOptions().timeZone || 'UTC';
      for (const el of times) {
        const value = el.getAttribute('datetime');
        if (!value) continue;
        const date = new Date(value);
        el.textContent = new Intl.DateTimeFormat(undefined, {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
          hour: 'numeric',
          minute: '2-digit',
          timeZone: localTZ,
          timeZoneName: 'short'
        }).format(date);
      }
    })();
  </script>
  {{ block "footer" . }} {{ end }}
</body>
</html>
