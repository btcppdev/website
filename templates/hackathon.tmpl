<!doctype html>
<html lang="en">
<head>
  <title>{{ .Competition.Title }} - bitcoin++ hackathon</title>
  {{ template "hackathon_header" . }}
</head>
<body class="hack-redesign">
  {{ $galleryProjects := .GalleryProjects }}
  {{ $myProjects := .MyProjects }}
  {{ $showProjectGallery := .ProjectGalleryOpen }}
  {{ template "generic_conf_ticker" (dict "Conf" .Conf "Label" "Hackathon live" "Count" (len $galleryProjects)) }}
  {{ template "generic_conf_nav" .Conf }}
  <main class="hack-shell">
    <section class="hack-hero">
      <img src="{{ .CompetitionImagePNG .Competition }}" alt="">
      <div class="hack-hero__content">
        <div class="hack-hero__top">
          <div>The hackathon</div>
          <div>{{ if .ConferenceLabel }}{{ .ConferenceLabel }}{{ else }}bitcoin++{{ end }}</div>
        </div>
        <div>
          <div class="hack-hero__label"><strong>Hack</strong> Build · Ship · Demo</div>
          <h1>{{ .Competition.Title }}</h1>
          <div class="hack-hero__deck">
            {{ if .Competition.Description }}
            {{ hackathonDescription .Competition.Description .Competition.DescriptionFormat }}
            {{ else }}
            Build something real alongside the conference, submit your project, and put it in front of judges and the bitcoin++ community.
            {{ end }}
          </div>
          <div class="hack-actions">
            {{ template "hackathon_primary_action" . }}
            {{ if $showProjectGallery }}
            <a href="#projects" class="hack-button hack-button--light">View project gallery →</a>
            {{ end }}
            <a href="{{ .ScheduleURL }}" class="hack-button hack-button--light">View schedule →</a>
            {{ if .CanJudge }}<a href="{{ .JudgingURL }}" class="hack-button hack-button--light">Judging →</a>{{ end }}
            {{ if .CanAdminEdit }}<a href="{{ .AdminEditURL }}" class="hack-button hack-button--light">Edit hackathon →</a>{{ end }}
          </div>
        </div>
      </div>
    </section>

    {{ if .FlashMessage }}
    <div class="mx-6 mt-6 border border-green-700 bg-green-50 px-4 py-3 text-sm text-green-900">{{ .FlashMessage }}</div>
    {{ end }}
    {{ if .FlashError }}
    <div class="mx-6 mt-6 border border-red-700 bg-red-50 px-4 py-3 text-sm text-red-900">{{ .FlashError }}</div>
    {{ end }}
    <nav class="hack-tabs" aria-label="Hackathon sections">
      <button type="button" data-hackathon-tab="overview" class="hack-tab" aria-selected="true">Overview</button>
      {{ if .Viewer }}<button type="button" data-hackathon-tab="my-projects" class="hack-tab" aria-selected="false">My projects · {{ len $myProjects }}</button>{{ end }}
      {{ if $showProjectGallery }}
      <button type="button" data-hackathon-tab="projects" class="hack-tab" aria-selected="false">Project gallery · {{ len $galleryProjects }}</button>
      {{ end }}
      {{ if .Awards }}<button type="button" data-hackathon-tab="awards" class="hack-tab" aria-selected="false">Awards · {{ len .Awards }}</button>{{ end }}
      {{ if or .Competition.PublicTablesEnabled .CanAdminEdit }}<button type="button" data-hackathon-tab="tables" class="hack-tab" aria-selected="false">Tables</button>{{ end }}
    </nav>

    <section data-hackathon-tab-panel="overview" class="hack-panel" id="overview">
      <div class="hack-stat-grid">
        <div class="hack-stat">
          <div class="hack-stat__value">{{ .PrizePoolValue }}</div>
          <div class="hack-stat__label">Prize Pool (satoshis)</div>
        </div>
        <div class="hack-stat">
          <div class="hack-stat__value">{{ with .Competition.MaxTeamSize }}{{ . }}{{ else }}∞{{ end }}</div>
          <div class="hack-stat__label">{{ with .Competition.MaxTeamSize }}Max builders per team{{ else }}Team size{{ end }}</div>
        </div>
        <div class="hack-stat">
          <div class="hack-stat__value">{{ len $galleryProjects }}</div>
          <div class="hack-stat__label">Visible projects</div>
        </div>
        <div class="hack-stat">
          <div class="hack-stat__value">{{ len .Awards }}</div>
          <div class="hack-stat__label">Awards</div>
        </div>
      </div>

      {{ $hackathonEdition := .HackathonEditionName }}
      {{ $hackathonEditionTitle := .HackathonEditionTitle }}
      {{ $hackathonLocation := .HackathonLocation }}
      <section class="hack-welcome" aria-label="Hackathon welcome">
        <div class="hack-label">§ Welcome</div>
        <h2>Welcome to the Bitcoin++ {{ $hackathonEditionTitle }} Edition Hackathon!</h2>
        <div class="hack-welcome__body">
          <p>This is the hackathon site for the bitcoin++ {{ $hackathonEdition }} edition hackathon in {{ $hackathonLocation }}.</p>
          <p>The main hackathon competition will be open ended (overall 1st, 2nd, 3rd). Anything involving bitcoin is fair game. Bonus points for {{ $hackathonEdition }} related projects.</p>
          <p>There are optional challenges that hackers may create projects around. Submitting for a challenge is optional, and ALL projects will be considered for the main competition.</p>
        </div>
      </section>

      {{ if .HackathonPlaceRows }}
      <section class="hack-prizes" aria-label="Ranked prizes">
        <div class="hack-section__head hack-prizes__head">
          <div>
            <div class="hack-label">§ Prizes</div>
            <h2>Prize <span class="hack-serif">pool.</span></h2>
          </div>
          <div class="hack-section__deck">Ranked rewards for the top projects. Challenges can stack on top.</div>
        </div>
        <div class="hack-prize-grid">
          {{ range .HackathonPlaceRows }}
          <a href="{{ if .ProjectID }}#project-{{ .ProjectID }}{{ else }}#awards{{ end }}" class="hack-prize-card{{ if .GrandPrize }} hack-prize-card--grand{{ end }}">
            <div class="hack-prize-card__top">
              <div class="hack-prize-card__place">★ {{ .PlaceName }} place{{ if .GrandPrize }} · grand prize{{ end }}</div>
              {{ if .SponsorLogoURL }}<span class="hack-prize-card__sponsor-logo"><img src="{{ .SponsorLogoURL }}" alt="{{ .SponsorLogoAlt }}"></span>{{ end }}
            </div>
            <div>
              <div class="hack-prize-card__amount">{{ if .Amount }}{{ .Amount }}{{ else }}TBA{{ end }}</div>
              <div class="hack-prize-card__title">
                <span>{{ .ProjectTitle }}</span>
                {{ range .ExtraPrizeNames }}<span class="hack-prize-card__extra">+ {{ . }}</span>{{ end }}
              </div>
              {{ if and .Detail (ne .Detail .Amount) }}<div class="hack-prize-card__desc">{{ .Detail }}</div>{{ end }}
            </div>
          </a>
          {{ end }}
        </div>
      </section>
      {{ end }}

      {{ $additionalAwards := .AdditionalOverviewAwards }}
      {{ if $additionalAwards }}
      <section class="hack-bounties" aria-label="Additional awards">
        <div class="hack-bounties__bar">+ Additional awards</div>
        <div class="hack-bounty-grid">
          {{ range $additionalAwards }}
          {{ $award := . }}
          <article class="hack-bounty-card">
            {{ if $.AwardHasSponsor . }}{{ with $.AwardLogoURL . }}<div class="hack-sponsored-award-logo"><img src="{{ . }}" alt="{{ $.AwardLogoAlt $award }}"></div>{{ end }}{{ end }}
            <div class="hack-bounty-card__top">
              <div class="hack-bounty-card__sponsor">
                {{ if $.AwardHasSponsor . }}
                {{ if $.AwardSponsorURL . }}
                <a href="{{ $.AwardSponsorURL . }}" target="_blank" rel="noreferrer">[ {{ $.AwardSponsorLabel . }} ]</a>
                {{ else }}
                <span>[ {{ $.AwardSponsorLabel . }} ]</span>
                {{ end }}
              {{ else }}
              <span>[ {{ $.AwardDisplayLabel . }} ]</span>
              {{ end }}
            </div>
          </div>
            <h3>{{ .Title }}</h3>
            {{ if .Description }}<div class="hack-bounty-card__desc">{{ hackathonDescription .Description "markdown" }}</div>{{ end }}
            {{ $prizes := $.AwardPrizes . }}
            {{ if $prizes }}
            <div class="hack-bounty-card__prize-label">Prizes</div>
            <div class="hack-bounty-card__prizes">
              {{ range $prizes }}
              <div class="hack-bounty-card__prize">
                <div class="hack-bounty-card__prize-head">
                  <span>{{ .Title }}</span>
                  <strong>{{ $.PrizeValueLabel . }}</strong>
                </div>
                {{ if .Description }}<div class="hack-bounty-card__prize-desc">{{ hackathonDescription .Description "markdown" }}</div>{{ end }}
              </div>
              {{ end }}
            </div>
            {{ end }}
          </article>
          {{ end }}
        </div>
      </section>
      {{ end }}

      {{ $challengeAwards := .ChallengeAwards }}
      {{ if $challengeAwards }}
      <section class="hack-bounties" aria-label="Challenge awards">
        <div class="hack-bounties__bar">+ Challenges · stackable</div>
        <div class="hack-bounty-grid">
          {{ range $challengeAwards }}
          {{ $award := . }}
          <article class="hack-bounty-card">
            {{ if $.AwardHasSponsor . }}{{ with $.AwardLogoURL . }}<div class="hack-sponsored-award-logo"><img src="{{ . }}" alt="{{ $.AwardLogoAlt $award }}"></div>{{ end }}{{ end }}
            <div class="hack-bounty-card__top">
              <div class="hack-bounty-card__sponsor">
                {{ if $.AwardHasSponsor . }}
                {{ if $.AwardSponsorURL . }}
                <a href="{{ $.AwardSponsorURL . }}" target="_blank" rel="noreferrer">[ {{ $.AwardSponsorLabel . }} ]</a>
                {{ else }}
                <span>[ {{ $.AwardSponsorLabel . }} ]</span>
                {{ end }}
              {{ else }}
              <span>[ Challenge ]</span>
              {{ end }}
            </div>
          </div>
            <h3>{{ .Title }}</h3>
            {{ if .Description }}<div class="hack-bounty-card__desc">{{ hackathonDescription .Description "markdown" }}</div>{{ end }}
            {{ $prizes := $.AwardPrizes . }}
            {{ if $prizes }}
            <div class="hack-bounty-card__prize-label">Prizes</div>
            <div class="hack-bounty-card__prizes">
              {{ range $prizes }}
              <div class="hack-bounty-card__prize">
                <div class="hack-bounty-card__prize-head">
                  <span>{{ .Title }}</span>
                  <strong>{{ $.PrizeValueLabel . }}</strong>
                </div>
                {{ if .Description }}<div class="hack-bounty-card__prize-desc">{{ hackathonDescription .Description "markdown" }}</div>{{ end }}
              </div>
              {{ end }}
            </div>
            {{ end }}
          </article>
          {{ end }}
        </div>
      </section>
      {{ end }}

      <section class="hack-judges" aria-label="Hackathon judges">
        <div class="hack-section__head hack-judges__head">
          <div>
            <div class="hack-label">§ The judges</div>
            <h2>{{ if .Judges }}{{ len .Judges }} {{ if eq (len .Judges) 1 }}judge{{ else }}judges{{ end }}.{{ else }}Judges <span class="hack-serif">soon.</span>{{ end }}</h2>
          </div>
          <div class="hack-section__deck">Scoring is handled by the assigned hackathon judges and coordinators.</div>
        </div>
        {{ if .Judges }}
        <div class="hack-judge-grid">
          {{ range $index, $judge := .Judges }}
          {{ $profileURL := $.JudgeProfileURL $judge }}
          {{ if $profileURL }}<a href="{{ $profileURL }}" class="hack-judge-card hack-judge-card--linked" aria-label="View {{ if $judge.Name }}{{ $judge.Name }}{{ else }}this judge{{ end }}’s profile">{{ else }}<article class="hack-judge-card">{{ end }}
            <div class="hack-judge-card__portrait">
              <img src="{{ speakerPhoto $judge.Photo }}" alt="{{ $judge.Name }}">
            </div>
            <div class="hack-judge-card__body">
              <div class="hack-label">{{ $.JudgeNumber $index }}</div>
              <h3>{{ if $judge.Name }}{{ $judge.Name }}{{ else }}Hackathon judge{{ end }}</h3>
              <div class="hack-judge-card__role">{{ $.PublicJudgeRoleLabel $judge }}</div>
            </div>
          {{ if $profileURL }}</a>{{ else }}</article>{{ end }}
          {{ end }}
        </div>
        {{ else }}
        <div class="hack-empty hack-empty--inline">
          <p>Judges have not been announced yet.</p>
        </div>
        {{ end }}
      </section>

      <div class="hack-section__head">
        <div>
          <div class="hack-label">§ Overview</div>
          <h2>Build in <span class="hack-serif">public.</span></h2>
        </div>
        <div class="hack-section__deck">
          Projects stay private until organizers open the public gallery. Judges and admins can review submissions while the event is running.
          <div class="hack-section__cta">{{ template "hackathon_primary_action" . }}</div>
        </div>
      </div>

      <div class="hack-overview-grid">
        <div class="hack-copy">
          <div class="hack-copy__body">
            {{ if .Competition.Description }}
            {{ hackathonDescription .Competition.Description .Competition.DescriptionFormat }}
            {{ else }}
            Details are still being finalized.
            {{ end }}
          </div>
        </div>
        <dl class="hack-side">
          <div class="hack-side-row">
            <dt>Conference</dt>
            <dd>
              {{ if .ConferenceLabel }}
              {{ if .ConferenceURL }}<a href="{{ .ConferenceURL }}">{{ .ConferenceLabel }}</a>{{ else }}{{ .ConferenceLabel }}{{ end }}
              {{ else }}
              TBA
              {{ end }}
            </dd>
          </div>
          <div class="hack-side-row">
            <dt>{{ if and .NextMilestoneLabel (not .NextMilestoneIsScheduleLink) }}{{ .NextMilestoneLabel }}{{ else }}Timeline{{ end }}</dt>
            <dd>
              {{ if .NextMilestoneValue }}
              {{ with .NextMilestoneTime }}
              <time datetime="{{ .Format "2006-01-02T15:04:05Z07:00" }}">{{ $.NextMilestoneValue }}</time>
              {{ else }}
              {{ $.NextMilestoneValue }}
              {{ end }}
              {{ else }}
              TBA
              {{ end }}
            </dd>
            <a href="{{ .ScheduleURL }}">View schedule →</a>
          </div>
          <div class="hack-side-row">
            <dt>Team size</dt>
            <dd>{{ with .Competition.MaxTeamSize }}Up to {{ . }}{{ else }}Unlimited{{ end }}</dd>
          </div>
        </dl>
      </div>

      {{ $featuredProjects := .FeaturedProjects }}
      {{ if $featuredProjects }}
      <section class="hack-featured-projects" aria-label="Featured hackathon projects">
        <div class="hack-section__head">
          <div>
            <div class="hack-label">§ Featured builds</div>
            <h2>Built in <span class="hack-serif">public.</span></h2>
          </div>
          <div class="hack-section__deck">Winning and featured projects from this hackathon. <a href="#projects">Explore the full gallery →</a></div>
        </div>
        <div class="hack-card-grid">
          {{ range $project := $featuredProjects }}
          {{ template "hackathon_project_card" (dict "Page" $ "Project" $project "ShowManage" false "Compact" true "Featured" true) }}
          {{ end }}
        </div>
      </section>
      {{ end }}

      {{ if .CanCreate }}
      <section id="submit" class="hack-submit">
        <div class="hack-submit__copy">
          <div class="hack-label">§ Submit</div>
          <h2>Enter your <span class="hack-serif">evidence.</span></h2>
          <p>Start a project page for your build, add links for judges, and keep updating it until submissions close.</p>
          <div class="hack-submit__rules">
            <span>✶ Working project links</span>
            <span>✶ Team members from profiles</span>
            <span>✶ Demo, repo, video, slides, or docs</span>
            <span>✶ Visible to judges before the public gallery opens</span>
          </div>
        </div>
        <form method="POST" action="{{ .ProjectCreateURL }}" class="hack-submit__panel">
          <label class="hack-submit__field hack-submit__field--wide">
            <span>Project name *</span>
            <input name="Title" type="text" required placeholder="Your project name">
          </label>
          <label class="hack-submit__field hack-submit__field--wide">
            <span>One-line pitch *</span>
            <input name="ShortDescription" type="text" required maxlength="280" placeholder="What it does in one sentence">
          </label>
          <label class="hack-submit__field">
            <span>GitHub URL</span>
            <input name="GitHubURL" type="url" placeholder="https://github.com/...">
          </label>
          <label class="hack-submit__field">
            <span>Demo URL</span>
            <input name="DemoURL" type="url" placeholder="https://...">
          </label>
          <label class="hack-submit__field hack-submit__field--wide">
            <span>What you built *</span>
            <textarea name="Description" rows="6" required placeholder="Describe the problem, the build, and what works."></textarea>
          </label>
          <button type="submit" class="hack-submit__button">Create project →</button>
        </form>
      </section>
      {{ end }}
    </section>

    {{ if $showProjectGallery }}
    <section data-hackathon-tab-panel="projects" class="hack-panel hidden" id="projects">
      <div class="hack-section__head">
        <div>
          <div class="hack-label">§ Project gallery</div>
          <h2>What got <span class="hack-serif">built.</span></h2>
        </div>
        <div class="hack-section__deck">
          Every visible project from this hackathon, sorted by the current platform rules.
          <div class="hack-section__cta">{{ template "hackathon_primary_action" . }}</div>
        </div>
      </div>
      {{ if $galleryProjects }}
      <div class="hack-card-grid">
        {{ range $project := $galleryProjects }}
        {{ template "hackathon_project_card" (dict "Page" $ "Project" $project "ShowManage" false) }}
        {{ end }}
      </div>
      {{ else }}
      <div class="hack-empty">
        <p>No visible projects yet.</p>
      </div>
      {{ end }}
    </section>
    {{ end }}

    {{ if .Viewer }}
    <section data-hackathon-tab-panel="my-projects" class="hack-panel hidden" id="my-projects">
      <div class="hack-section__head">
        <div>
          <div class="hack-label">§ My projects</div>
          <h2>Your hackathon <span class="hack-serif">builds.</span></h2>
        </div>
        <div class="hack-section__deck">
          Projects where you are listed as a team member. Manage the page, links, teammates, and award opt-ins from here.
          <div class="hack-section__cta">{{ template "hackathon_primary_action" . }}</div>
        </div>
      </div>
      {{ if $myProjects }}
      <div class="hack-card-grid">
        {{ range $project := $myProjects }}
        {{ template "hackathon_project_card" (dict "Page" $ "Project" $project "ShowManage" true) }}
        {{ end }}
      </div>
      {{ else }}
      <div class="hack-empty">
        <p>You are not on any projects for this hackathon yet.</p>
      </div>
      {{ end }}
    </section>
    {{ end }}

    {{ if .Awards }}
    <section data-hackathon-tab-panel="awards" class="hack-panel hidden hack-awards" id="awards">
      <div class="hack-section__head">
        <div>
          <div class="hack-label">§ Awards</div>
          <h2>Prize <span class="hack-serif">pool.</span></h2>
        </div>
        <div class="hack-section__deck">
          Normal awards, challenges, and assigned winning projects when winners have been selected.
          <div class="hack-section__cta">{{ template "hackathon_primary_action" . }}</div>
        </div>
      </div>
      <div class="hack-card-grid">
        {{ range .Awards }}
        {{ $award := . }}
        <article class="hack-card hack-award-card">
          <div class="hack-card__body">
            {{ if $.AwardHasSponsor . }}{{ with $.AwardLogoURL . }}<div class="hack-sponsored-award-logo"><img src="{{ . }}" alt="{{ $.AwardLogoAlt $award }}"></div>{{ end }}{{ end }}
            <div class="hack-award-card__top">
              <div class="hack-award-card__label">
                <span>{{ if $.AwardIsChallenge . }}[ {{ $.AwardDisplayLabel . }} ]{{ else }}★ {{ $.AwardDisplayLabel . }}{{ end }}</span>
              </div>
          </div>
            <h3>{{ .Title }}</h3>
            {{ if $.AwardHasSponsor . }}
            <div class="hack-tags">
              {{ if $.AwardSponsorURL . }}<a href="{{ $.AwardSponsorURL . }}" target="_blank" rel="noreferrer" class="hack-tag">{{ $.AwardSponsorLabel . }}</a>{{ else }}<span class="hack-tag">{{ $.AwardSponsorLabel . }}</span>{{ end }}
            </div>
            {{ end }}
            {{ if .Description }}<div class="hack-card__desc">{{ hackathonDescription .Description "markdown" }}</div>{{ end }}
            {{ $awardees := $.Awardees . }}
            {{ if $awardees }}
            <div class="hack-tags" aria-label="Award winners">
              {{ range $awardees }}
              <a href="#project-{{ .ProjectID }}" class="hack-badge">★ Winner: {{ .ProjectTitle }}</a>
              {{ if $.CanAdminEdit }}
              <form method="POST" action="{{ $.AdminEditURL }}/awards/remove" style="display:inline;">
                <input type="hidden" name="AwardID" value="{{ .AwardID }}">
                <input type="hidden" name="ProjectID" value="{{ .ProjectID }}">
                <input type="hidden" name="Source" value="public">
                <button type="submit" class="hack-badge" style="border:0;cursor:pointer;">Remove</button>
              </form>
              {{ end }}
              {{ end }}
            </div>
            {{ end }}
            {{ $prizes := $.AwardPrizes . }}
            {{ if $prizes }}
            <div class="hack-award-card__prize-label">Prizes</div>
            <div class="hack-card__links hack-award-card__prizes">
              {{ range $prizes }}
              <div class="hack-award-card__prize">
                <span>{{ .Title }}{{ if .ValueText }} · {{ $.PrizeValueLabel . }}{{ end }}</span>
                {{ if .Description }}<div class="hack-award-card__prize-desc">{{ hackathonDescription .Description "markdown" }}</div>{{ end }}
              </div>
              {{ end }}
            </div>
            {{ end }}
          </div>
        </article>
        {{ end }}
      </div>
    </section>
    {{ end }}

    {{ if or .Competition.PublicTablesEnabled .CanAdminEdit }}
    <section data-hackathon-tab-panel="tables" class="hack-panel hidden" id="tables">
      <div class="hack-section__head">
        <div>
          <div class="hack-label">§ Tables</div>
          <h2>Find the <span class="hack-serif">projects.</span></h2>
        </div>
        <div class="hack-section__deck">
          Public project table assignments for demos and expo-style review.
          <div class="hack-section__cta">{{ template "hackathon_primary_action" . }}</div>
        </div>
      </div>
      {{ if .Projects }}
      <div class="hack-table-wrap">
        <table class="hack-table">
          <thead>
            <tr>
              <th scope="col">Table</th>
              <th scope="col">Project</th>
            </tr>
          </thead>
          <tbody>
            {{ range .Projects }}
            <tr>
              <td>{{ $.ProjectNumberLabel . }}</td>
              <td><a href="#project-{{ .ID }}">{{ .Title }}</a></td>
            </tr>
            {{ end }}
          </tbody>
        </table>
      </div>
      {{ else }}
      <div class="hack-empty"><p>No visible projects yet.</p></div>
      {{ end }}
    </section>
    {{ end }}
  </main>
  <script>
    (function () {
      const tabs = Array.prototype.slice.call(document.querySelectorAll('[data-hackathon-tab]'));
      const panels = Array.prototype.slice.call(document.querySelectorAll('[data-hackathon-tab-panel]'));
      if (tabs.length === 0 || panels.length === 0) return;

      function setTab(name) {
        const exists = tabs.some(tab => tab.dataset.hackathonTab === name);
        if (!exists) name = 'overview';
        for (const tab of tabs) {
          const active = tab.dataset.hackathonTab === name;
          tab.setAttribute('aria-selected', active ? 'true' : 'false');
        }
        for (const panel of panels) {
          panel.classList.toggle('hidden', panel.dataset.hackathonTabPanel !== name);
        }
      }

      function tabFromHash() {
        if (window.location.hash === '#overview') return 'overview';
        if (window.location.hash === '#awards') return 'awards';
        if (window.location.hash === '#tables') return 'tables';
        if (window.location.hash === '#my-projects') return 'my-projects';
        if (window.location.hash === '#projects') return 'projects';
        if (window.location.hash.indexOf('#project-') === 0) {
          const target = document.getElementById(window.location.hash.slice(1));
          const panel = target && target.closest('[data-hackathon-tab-panel]');
          if (panel && panel.dataset.hackathonTabPanel) return panel.dataset.hackathonTabPanel;
          return 'projects';
        }
        return 'overview';
      }

      for (const tab of tabs) {
        tab.addEventListener('click', function () {
          const name = tab.dataset.hackathonTab;
          setTab(name);
          history.replaceState(null, '', '#' + name);
        });
      }

      function showHashTarget() {
        setTab(tabFromHash());
        if (window.location.hash.indexOf('#project-') !== 0) return;
        const target = document.getElementById(window.location.hash.slice(1));
        if (!target) return;
        window.requestAnimationFrame(function () {
          window.requestAnimationFrame(function () {
            target.scrollIntoView({ block: 'start' });
          });
        });
      }

      window.addEventListener('hashchange', showHashTarget);
      showHashTarget();

      document.querySelectorAll('[data-project-card-url]').forEach((card) => {
        function openCard(event) {
          if (event.target.closest('a, button, input, select, textarea')) return;
          window.location.href = card.dataset.projectCardUrl;
        }
        card.addEventListener('click', openCard);
        card.addEventListener('keydown', function (event) {
          if (event.key !== 'Enter' && event.key !== ' ') return;
          event.preventDefault();
          openCard(event);
        });
      });
    })();

  </script>
  {{ template "generic_conf_footer" . }}
</body>
</html>

{{ define "hackathon_primary_action" }}
{{ $action := .PrimaryProjectAction }}
{{ if or $action.Disabled (not $action.URL) }}
<span class="hack-button hack-button--accent hack-button--disabled" aria-disabled="true">{{ $action.Label }}</span>
{{ else }}
<a href="{{ $action.URL }}" class="hack-button hack-button--accent">{{ $action.Label }}</a>
{{ end }}
{{ end }}

{{ define "hackathon_project_card" }}
{{ $page := .Page }}
{{ $project := .Project }}
{{ $winningAwards := $page.ProjectWinningAwards $project }}
<article id="{{ if .Featured }}featured-{{ else }}project-{{ end }}{{ $project.ID }}" class="hack-card hack-card--project{{ if not .ShowManage }} hack-card--clickable{{ end }}" {{ if not .ShowManage }}data-project-card-url="{{ $page.ProjectURL $project }}" tabindex="0" role="link"{{ end }}>
  <div class="hack-card__media" data-initials="++" {{ if $project.ImageURL }}data-has-image="true"{{ end }}>
    {{ if $project.ImageURL }}<img src="{{ $project.ImageURL }}" alt="" loading="lazy">{{ end }}
    {{ if $winningAwards }}
    <div class="hack-card__award-badges">
      {{ range $winningAwards }}<span class="hack-badge">★ {{ $page.AwardWinnerBadgeLabel . }}</span>{{ end }}
    </div>
    {{ end }}
  </div>
  <div class="hack-card__body">
    <div class="hack-card__top">
      <h3>{{ $project.Title }}</h3>
      <div class="hack-card__number">{{ $page.ProjectNumberLabel $project }}</div>
    </div>
    {{ if $page.CanAdminEdit }}
    <div class="hack-tags">
      <span class="hack-badge">Admin: {{ $page.ProjectStatusLabel $project.Status }}</span>
    </div>
    {{ end }}
    {{ if $project.ShortDescription }}<div class="hack-card__desc">{{ $project.ShortDescription }}</div>{{ end }}
    {{ if $project.Tags }}
    <div class="hack-tags">
      {{ range $project.Tags }}<span class="hack-tag">{{ . }}</span>{{ end }}
    </div>
    {{ end }}
    {{ $members := $page.ProjectMembers $project }}
    {{ if $members }}
    <div class="hack-card__team" aria-label="Project team">
      {{ range $members }}
      <span class="hack-card__member" title="{{ .Name }}">
        {{ if .Photo }}<img src="{{ speakerPhoto .Photo }}" alt="{{ .Name }}" loading="lazy">{{ else }}<span aria-hidden="true">+</span>{{ end }}
      </span>
      {{ end }}
    </div>
    {{ end }}
    <div class="hack-card__links">
      {{ if .ShowManage }}<a href="{{ $page.ProjectEditURL $project }}">Manage</a>{{ end }}
      {{ if $project.GitHubURL }}<a href="{{ $project.GitHubURL }}">GitHub</a>{{ end }}
      {{ if $project.DemoURL }}<a href="{{ $project.DemoURL }}">Demo</a>{{ end }}
      {{ if $project.VideoURL }}<a href="{{ $project.VideoURL }}">Video</a>{{ end }}
      {{ if $project.SlidesURL }}<a href="{{ $project.SlidesURL }}">Slides</a>{{ end }}
      {{ if $project.DocsURL }}<a href="{{ $project.DocsURL }}">Docs</a>{{ end }}
      {{ if .ShowManage }}<a href="{{ $page.ProjectURL $project }}" class="hack-card__link--push">View</a>{{ end }}
    </div>
  </div>
</article>
{{ end }}
