<!DOCTYPE html>
<html>
  <head>
    <title>sponsors @ bitcoin++</title>
    {{ block "header" . }} {{ end }}
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>&#127970;</text></svg>">
  </head>
  <body>
    {{ block "mainnav" . }} {{ end }}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-5xl">
            <a href="/{{ .Conf.Tag }}/admin" class="text-xs text-gray-500 hover:text-gray-700">&larr; {{ .Conf.Desc }} dashboard</a>
            <section id="topline" class="mt-2 mb-6">
                <div class="overflow-hidden sm:rounded-lg bg-white shadow">
                    <div class="px-4 py-5 sm:p-6">
                        <h1 class="text-xl font-bold text-gray-900">Sponsors</h1>
                        <p class="text-sm text-gray-500">{{ .Conf.Desc }} - {{ .Conf.DateDesc }}</p>
                    </div>
                </div>
            </section>

            {{ if .FlashMessage }}
            <section class="mb-6">
                <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg">
                    {{ .FlashMessage }}
                </div>
            </section>
            {{ end }}

            <!-- Add Sponsorship -->
            <section class="mb-6">
                <div class="bg-white shadow rounded-lg px-6 py-4">
                    <div class="flex items-center justify-between mb-3">
                        <h2 class="text-sm font-semibold text-gray-900">Add Sponsorship</h2>
                        <a href="/admin/orgs/new?return=%2F{{ .Conf.Tag }}%2Fadmin%2Fsponsors"
                           class="text-xs font-semibold text-indigo-700 hover:text-indigo-900">+ Add new org</a>
                    </div>
                    <form method="POST" action="/{{ .Conf.Tag }}/admin/sponsors/new" class="flex items-end gap-4">
                        <div class="flex-1">
                            <label for="OrgRef" class="block text-xs font-medium text-gray-700 mb-1">Organization</label>
                            <select name="OrgRef" id="OrgRef" required
                                class="w-full rounded-md border border-gray-300 px-3 py-1.5 text-sm">
                                <option value="">-- select --</option>
                                {{ range .Orgs }}
                                <option value="{{ .Ref }}">{{ .Name }}</option>
                                {{ end }}
                            </select>
                        </div>
                        <div>
                            <label for="Level" class="block text-xs font-medium text-gray-700 mb-1">Level</label>
                            <select name="Level" id="Level" required
                                class="rounded-md border border-gray-300 px-3 py-1.5 text-sm">
                                <option value="">-- select --</option>
                                <option value="Headline">Headline</option>
                                <option value="Title">Title</option>
                                <option value="Diamond">Diamond</option>
                                <option value="Workshop">Workshop</option>
                                <option value="Hackathon">Hackathon</option>
                                <option value="Gold">Gold</option>
                                <option value="Silver">Silver</option>
                                <option value="Bronze">Bronze</option>
                                <option value="Networking">Networking</option>
                                <option value="Media">Media</option>
                                <option value="Community">Community</option>
                            </select>
                        </div>
                        <div>
                            <button type="submit" class="px-3 py-1.5 text-sm rounded-md text-white bg-indigo-600 hover:bg-indigo-700">Add</button>
                        </div>
                    </form>
                </div>
            </section>

            <!-- Sponsorships Table -->
            {{ if .Sponsorships }}
            <section class="mb-6">
                <div class="bg-white shadow rounded-lg overflow-hidden">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Organization</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Level</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Payment</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Vendor</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Notes</th>
                                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            {{ range .Sponsorships }}
                            <tr class="hover:bg-gray-50">
                                <td class="px-6 py-4 text-sm">
                                    {{ if .Org }}
                                    <a href="/admin/orgs/{{ .Org.Ref }}" class="text-indigo-600 hover:text-indigo-900 font-medium">{{ .Org.Name }}</a>
                                    {{ else }}
                                    <span class="text-gray-400">Unknown</span>
                                    {{ end }}
                                </td>
                                <td class="px-6 py-4 text-sm">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                                        {{ if eq .Level "Headline" }}bg-purple-100 text-purple-800
                                        {{ else if eq .Level "Title" }}bg-purple-100 text-purple-800
                                        {{ else if eq .Level "Diamond" }}bg-blue-100 text-blue-800
                                        {{ else if eq .Level "Gold" }}bg-yellow-100 text-yellow-800
                                        {{ else if eq .Level "Silver" }}bg-gray-100 text-gray-800
                                        {{ else if eq .Level "Bronze" }}bg-orange-100 text-orange-800
                                        {{ else }}bg-green-100 text-green-800{{ end }}">
                                        {{ .Level }}
                                    </span>
                                    {{ if .Label }}<div class="mt-1 text-xs text-gray-500">{{ .Label }}</div>{{ end }}
                                </td>
                                <td class="px-6 py-4 text-sm">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                                        {{ if eq .Status "Paid" }}bg-green-100 text-green-800
                                        {{ else if eq .Status "Committed" }}bg-blue-100 text-blue-800
                                        {{ else if eq .Status "InvoiceSent" }}bg-yellow-100 text-yellow-800
                                        {{ else if eq .Status "InProgress" }}bg-indigo-100 text-indigo-800
                                        {{ else }}bg-red-100 text-red-800{{ end }}">
                                        {{ .Status }}
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-500">
                                    {{ if .IsVendor }}Yes{{ end }}
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-500">
                                    {{ if .Notes }}{{ .Notes }}{{ else }}&mdash;{{ end }}
                                </td>
                                <td class="px-6 py-4 text-right text-sm">
                                    <button type="button" data-edit-target="sponsorship-{{ .Ref }}-edit"
                                        class="sponsorship-edit-trigger rounded-md bg-white px-3 py-1.5 text-xs font-semibold text-gray-700 ring-1 ring-inset ring-gray-300 hover:bg-gray-50">Edit</button>
                                    <form method="POST" action="/{{ $.Conf.Tag }}/admin/sponsors/{{ .Ref }}/delete" class="ml-2 inline-block"
                                        onsubmit="return confirm('Remove this sponsorship?')">
                                        <button type="submit" class="rounded-md border border-red-300 bg-white px-3 py-1.5 text-xs font-semibold text-red-700 hover:bg-red-50">Remove</button>
                                    </form>
                                </td>
                            </tr>
                            <tr id="sponsorship-{{ .Ref }}-edit" class="hidden bg-gray-50">
                                <td colspan="6" class="px-6 py-4">
                                    <form method="POST" action="/{{ $.Conf.Tag }}/admin/sponsors/{{ .Ref }}" class="grid grid-cols-1 gap-4 md:grid-cols-6">
                                        <div class="md:col-span-2">
                                            <label class="block text-xs font-medium text-gray-700 mb-1">Organization</label>
                                            <select name="OrgRef" required class="w-full rounded-md border border-gray-300 px-3 py-1.5 text-sm">
                                                <option value="">-- select --</option>
                                                {{ $spOrg := .Org }}
                                                {{ range $.Orgs }}
                                                <option value="{{ .Ref }}" {{ if and $spOrg (eq .Ref $spOrg.Ref) }}selected{{ end }}>{{ .Name }}</option>
                                                {{ end }}
                                            </select>
                                        </div>
                                        <div>
                                            <label class="block text-xs font-medium text-gray-700 mb-1">Level</label>
                                            <select name="Level" required class="w-full rounded-md border border-gray-300 px-3 py-1.5 text-sm">
                                                <option value="Headline" {{ if eq .Level "Headline" }}selected{{ end }}>Headline</option>
                                                <option value="Title" {{ if eq .Level "Title" }}selected{{ end }}>Title</option>
                                                <option value="Diamond" {{ if eq .Level "Diamond" }}selected{{ end }}>Diamond</option>
                                                <option value="Workshop" {{ if eq .Level "Workshop" }}selected{{ end }}>Workshop</option>
                                                <option value="Hackathon" {{ if eq .Level "Hackathon" }}selected{{ end }}>Hackathon</option>
                                                <option value="Gold" {{ if eq .Level "Gold" }}selected{{ end }}>Gold</option>
                                                <option value="Silver" {{ if eq .Level "Silver" }}selected{{ end }}>Silver</option>
                                                <option value="Bronze" {{ if eq .Level "Bronze" }}selected{{ end }}>Bronze</option>
                                                <option value="Networking" {{ if eq .Level "Networking" }}selected{{ end }}>Networking</option>
                                                <option value="Media" {{ if eq .Level "Media" }}selected{{ end }}>Media</option>
                                                <option value="Community" {{ if eq .Level "Community" }}selected{{ end }}>Community</option>
                                            </select>
                                        </div>
                                        <div>
                                            <label class="block text-xs font-medium text-gray-700 mb-1">Status</label>
                                            <select name="Status" class="w-full rounded-md border border-gray-300 px-3 py-1.5 text-sm">
                                                <option value="Pending" {{ if eq .Status "Pending" }}selected{{ end }}>Pending</option>
                                                <option value="InProgress" {{ if eq .Status "InProgress" }}selected{{ end }}>InProgress</option>
                                                <option value="InvoiceSent" {{ if eq .Status "InvoiceSent" }}selected{{ end }}>InvoiceSent</option>
                                                <option value="Committed" {{ if eq .Status "Committed" }}selected{{ end }}>Committed</option>
                                                <option value="Paid" {{ if eq .Status "Paid" }}selected{{ end }}>Paid</option>
                                                <option value="Declined" {{ if eq .Status "Declined" }}selected{{ end }}>Declined</option>
                                            </select>
                                        </div>
                                        <div>
                                            <label class="block text-xs font-medium text-gray-700 mb-1">Vendor</label>
                                            <label class="inline-flex h-[34px] items-center gap-2 text-sm text-gray-700">
                                                <input type="checkbox" name="IsVendor" class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" {{ if .IsVendor }}checked{{ end }}>
                                                Yes
                                            </label>
                                        </div>
                                        <div class="md:col-span-3">
                                            <label class="block text-xs font-medium text-gray-700 mb-1">Label</label>
                                            <input type="text" name="Label" value="{{ .Label }}" class="w-full rounded-md border border-gray-300 px-3 py-1.5 text-sm" placeholder="Optional section label">
                                        </div>
                                        <div class="md:col-span-3">
                                            <label class="block text-xs font-medium text-gray-700 mb-1">Notes</label>
                                            <input type="text" name="Notes" value="{{ .Notes }}" class="w-full rounded-md border border-gray-300 px-3 py-1.5 text-sm" placeholder="Internal notes">
                                        </div>
                                        <div class="flex items-center gap-3 md:col-span-6">
                                            <button type="submit" class="rounded-md bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-indigo-700">Save changes</button>
                                            <button type="button" data-edit-target="sponsorship-{{ .Ref }}-edit"
                                                class="sponsorship-edit-trigger text-xs font-medium text-gray-600 hover:text-gray-900">Cancel</button>
                                        </div>
                                    </form>
                                </td>
                            </tr>
                            {{ end }}
                        </tbody>
                    </table>
                    <div class="px-6 py-3 bg-gray-50 text-sm text-gray-500">
                        {{ len .Sponsorships }} sponsorships
                    </div>
                </div>
            </section>
            {{ else }}
            <section class="mb-6">
                <div class="bg-white shadow rounded-lg px-4 py-5 sm:p-6 text-center text-gray-500">
                    No sponsorships for this event yet.
                </div>
            </section>
            {{ end }}
        </div>
    </div>
    <script>
      (function () {
        document.querySelectorAll('.sponsorship-edit-trigger').forEach(function (btn) {
          btn.addEventListener('click', function () {
            const row = document.getElementById(btn.dataset.editTarget);
            if (row) row.classList.toggle('hidden');
          });
        });
      })();
    </script>
  </body>
</html>
