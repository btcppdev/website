<!DOCTYPE html>
<html>
  <head>
    <title>{{ if .IsNew }}new org{{ else }}{{ .Org.Name }}{{ end }} @ bitcoin++</title>
    {{ block "header" . }} {{ end }}
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>&#127970;</text></svg>">
  </head>
  <body class="btcpp-admin-page">
    {{ block "mainnav" . }} {{ end }}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-2xl">
            <section id="topline" class="mb-6">
                <div class="overflow-hidden sm:rounded-lg bg-white shadow">
                    <div class="px-4 py-5 sm:p-6 flex items-center justify-between">
                        <div>
                            <h1 class="text-xl font-bold text-gray-900">{{ if .IsNew }}New Org{{ else }}{{ .Org.Name }}{{ end }}</h1>
                            <a href="/admin/orgs" class="text-sm text-indigo-600 hover:text-indigo-900">&larr; Companies</a>
                        </div>
                    </div>
                </div>
            </section>

            {{ if .FlashMessage }}
            <section class="mb-6">
                <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg">
                    {{ .FlashMessage }}
                </div>
            </section>
            {{ end }}

            <section class="mb-6">
                <div class="bg-white shadow rounded-lg px-6 py-6">
                    <form method="POST" action="{{ if .IsNew }}/admin/orgs/new{{ else }}/admin/orgs/{{ .Org.Ref }}{{ end }}">
                        <div class="grid grid-cols-1 gap-y-4">
                            <div>
                                <label for="Name" class="block text-sm font-medium text-gray-700">Org Name *</label>
                                <input type="text" name="Name" id="Name" value="{{ .Org.Name }}" required
                                    class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm">
                            </div>
                            <div>
                                <label for="Tagline" class="block text-sm font-medium text-gray-700">Tagline</label>
                                <input type="text" name="Tagline" id="Tagline" value="{{ .Org.Tagline }}"
                                    class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm">
                            </div>
                            <div>
                                <label for="Email" class="block text-sm font-medium text-gray-700">Email</label>
                                <input type="email" name="Email" id="Email" value="{{ .Org.Email }}"
                                    class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm">
                            </div>

                            <hr class="my-2">

                            <div>
                                <label for="Website" class="block text-sm font-medium text-gray-700">Website</label>
                                <input type="url" name="Website" id="Website" value="{{ .Org.Website }}" placeholder="https://"
                                    class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm">
                            </div>
                            <div>
                                <label for="Twitter" class="block text-sm font-medium text-gray-700">X / Twitter</label>
                                <input type="text" name="Twitter" id="Twitter" value="{{ .Org.Twitter.Handle }}" placeholder="btcplusplus"
                                    class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm">
                            </div>
                            <div>
                                <label for="Nostr" class="block text-sm font-medium text-gray-700">Nostr npub</label>
                                <input type="text" name="Nostr" id="Nostr" value="{{ .Org.Nostr }}" placeholder="npub1..."
                                    class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm">
                            </div>
                            <div>
                                <label for="Matrix" class="block text-sm font-medium text-gray-700">Matrix</label>
                                <input type="text" name="Matrix" id="Matrix" value="{{ .Org.Matrix }}" placeholder="@org:matrix.org"
                                    class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm">
                            </div>
                            <div>
                                <label for="LinkedIn" class="block text-sm font-medium text-gray-700">LinkedIn</label>
                                <input type="url" name="LinkedIn" id="LinkedIn" value="{{ .Org.LinkedIn }}" placeholder="https://linkedin.com/org/..."
                                    class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm">
                            </div>
                            <div>
                                <label for="Instagram" class="block text-sm font-medium text-gray-700">Instagram</label>
                                <input type="url" name="Instagram" id="Instagram" value="{{ .Org.Instagram }}" placeholder="https://instagram.com/..."
                                    class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm">
                            </div>
                            <div>
                                <label for="Youtube" class="block text-sm font-medium text-gray-700">YouTube</label>
                                <input type="url" name="Youtube" id="Youtube" value="{{ .Org.Youtube }}" placeholder="https://youtube.com/..."
                                    class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm">
                            </div>
                            <div>
                                <label for="Github" class="block text-sm font-medium text-gray-700">GitHub</label>
                                <input type="url" name="Github" id="Github" value="{{ .Org.Github }}" placeholder="https://github.com/..."
                                    class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm">
                            </div>

                            <hr class="my-2">

                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div>
                                    <span class="block text-sm font-medium text-gray-700">Logo Light</span>
                                    <p class="text-xs text-gray-500">Displayed on light backgrounds.</p>
                                    <input id="LogoLight" name="LogoLight" type="hidden" value="{{ .Org.LogoLight }}">
                                    <div class="mt-2 flex items-center gap-3">
                                        <button type="button" data-target="LogoLight" {{ if not .SpacesReady }}disabled{{ end }}
                                            class="logo-upload-trigger inline-flex items-center rounded-md border border-gray-300 bg-white px-3 py-1.5 text-xs font-semibold text-gray-700 hover:bg-gray-50 disabled:cursor-not-allowed disabled:opacity-50">
                                            Upload a file
                                        </button>
                                        <span class="inline-flex h-14 min-w-24 items-center justify-center rounded border border-gray-200 bg-white px-3 py-2">
                                            <img id="LogoLight-preview" {{ if .Org.LogoLight }}src="{{ .Org.LogoLight }}"{{ end }} alt="" class="{{ if not .Org.LogoLight }}hidden {{ end }}max-h-10 w-auto max-w-[160px] object-contain">
                                        </span>
                                        <button type="button" data-target="LogoLight"
                                            class="logo-clear-trigger {{ if not .Org.LogoLight }}hidden {{ end }}text-xs font-medium text-red-600 hover:text-red-700">
                                            Remove
                                        </button>
                                    </div>
                                    <p id="LogoLight-status" class="mt-1 text-xs text-gray-500">{{ if .Org.LogoLight }}Uploaded logo selected.{{ else if .SpacesReady }}No file selected.{{ else }}Spaces is not configured, so uploads are disabled.{{ end }}</p>
                                </div>
                                <div>
                                    <span class="block text-sm font-medium text-gray-700">Logo Dark</span>
                                    <p class="text-xs text-gray-500">Displayed on dark backgrounds.</p>
                                    <input id="LogoDark" name="LogoDark" type="hidden" value="{{ .Org.LogoDark }}">
                                    <div class="mt-2 flex items-center gap-3">
                                        <button type="button" data-target="LogoDark" {{ if not .SpacesReady }}disabled{{ end }}
                                            class="logo-upload-trigger inline-flex items-center rounded-md border border-gray-300 bg-white px-3 py-1.5 text-xs font-semibold text-gray-700 hover:bg-gray-50 disabled:cursor-not-allowed disabled:opacity-50">
                                            Upload a file
                                        </button>
                                        <span class="inline-flex h-14 min-w-24 items-center justify-center rounded border border-gray-800 bg-gray-950 px-3 py-2">
                                            <img id="LogoDark-preview" {{ if .Org.LogoDark }}src="{{ .Org.LogoDark }}"{{ end }} alt="" class="{{ if not .Org.LogoDark }}hidden {{ end }}max-h-10 w-auto max-w-[160px] object-contain">
                                        </span>
                                        <button type="button" data-target="LogoDark"
                                            class="logo-clear-trigger {{ if not .Org.LogoDark }}hidden {{ end }}text-xs font-medium text-red-600 hover:text-red-700">
                                            Remove
                                        </button>
                                    </div>
                                    <p id="LogoDark-status" class="mt-1 text-xs text-gray-500">{{ if .Org.LogoDark }}Uploaded logo selected.{{ else if .SpacesReady }}No file selected.{{ else }}Spaces is not configured, so uploads are disabled.{{ end }}</p>
                                </div>
                            </div>
                            <input type="file" id="LogoFilePicker" accept="image/*" class="hidden">
                            <div class="flex items-center gap-2">
                                <input type="checkbox" name="Hiring" id="Hiring" {{ if .Org.Hiring }}checked{{ end }}
                                    class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                                <label for="Hiring" class="text-sm font-medium text-gray-700">Hiring</label>
                            </div>

                            <hr class="my-2">

                            <div>
                                <label for="Notes" class="block text-sm font-medium text-gray-700">Notes</label>
                                <textarea name="Notes" id="Notes" rows="3"
                                    class="mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 text-sm">{{ .Org.Notes }}</textarea>
                            </div>

                            <div class="mt-4">
                                <button type="submit"
                                    class="w-full px-4 py-2 text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700">
                                    {{ if .IsNew }}Create Org{{ else }}Save Changes{{ end }}
                                </button>
                            </div>
                        </div>
                    </form>
                    <script>
                      (function () {
                        const picker = document.getElementById('LogoFilePicker');
                        if (!picker) return;
                        let activeTarget = null;

                        document.querySelectorAll('.logo-upload-trigger').forEach(function (btn) {
                          btn.addEventListener('click', function () {
                            if (btn.disabled) return;
                            activeTarget = btn.dataset.target;
                            picker.value = '';
                            picker.click();
                          });
                        });

                        picker.addEventListener('change', function () {
                          if (!activeTarget || !picker.files || picker.files.length === 0) return;
                          const file = picker.files[0];
                          const targetID = activeTarget;
                          const status = document.getElementById(targetID + '-status');
                          const input = document.getElementById(targetID);
                          const preview = document.getElementById(targetID + '-preview');
                          const clear = document.querySelector('.logo-clear-trigger[data-target="' + targetID + '"]');
                          status.textContent = 'Uploading ' + file.name + '...';
                          status.className = 'mt-1 text-xs text-gray-700';

                          const fd = new FormData();
                          fd.append('file', file);
                          fetch('/admin/orgs/upload-logo', { method: 'POST', body: fd, credentials: 'same-origin' })
                            .then(function (r) {
                              if (!r.ok) return r.text().then(function (t) { throw new Error(t || ('HTTP ' + r.status)); });
                              return r.json();
                            })
                            .then(function (data) {
                              input.value = data.url;
                              preview.src = data.url;
                              preview.classList.remove('hidden');
                              if (clear) clear.classList.remove('hidden');
                              status.textContent = file.name + ' uploaded. Save changes to keep it.';
                              status.className = 'mt-1 text-xs text-green-700';
                            })
                            .catch(function (err) {
                              status.textContent = 'Upload failed: ' + (err.message || err);
                              status.className = 'mt-1 text-xs text-red-700';
                            })
                            .finally(function () {
                              if (activeTarget === targetID) activeTarget = null;
                            });
                        });

                        document.querySelectorAll('.logo-clear-trigger').forEach(function (btn) {
                          btn.addEventListener('click', function () {
                            const targetID = btn.dataset.target;
                            const status = document.getElementById(targetID + '-status');
                            const input = document.getElementById(targetID);
                            const preview = document.getElementById(targetID + '-preview');
                            input.value = '';
                            preview.removeAttribute('src');
                            preview.classList.add('hidden');
                            btn.classList.add('hidden');
                            status.textContent = 'Logo removed. Save changes to clear it.';
                            status.className = 'mt-1 text-xs text-gray-500';
                          });
                        });
                      })();
                    </script>
                </div>
            </section>
        </div>
    </div>
  </body>
</html>
