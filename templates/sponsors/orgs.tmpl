<!DOCTYPE html>
<html>
  <head>
    <title>orgs @ bitcoin++</title>
    {{ block "header" . }} {{ end }}
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>&#127970;</text></svg>">
  </head>
  <body class="btcpp-admin-page">
    {{ block "mainnav" . }} {{ end }}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-5xl">
            <section id="topline" class="mb-6">
                <div class="overflow-hidden sm:rounded-lg bg-white shadow">
                    <div class="px-4 py-5 sm:p-6 flex items-center justify-between">
                        <h1 class="text-xl font-bold text-gray-900">Organizations</h1>
                        <a href="/admin/orgs/new" class="px-3 py-1.5 text-sm rounded-md text-white bg-indigo-600 hover:bg-indigo-700">Add Org</a>
                    </div>
                </div>
            </section>

            {{ if .FlashMessage }}
            <section class="mb-6">
                <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg">
                    {{ .FlashMessage }}
                </div>
            </section>
            {{ end }}

            {{ if .Orgs }}
            <section class="mb-6">
                <div class="bg-white shadow rounded-lg overflow-hidden">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Organization</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Website</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            {{ range .Orgs }}
                            <tr class="hover:bg-gray-50">
                                <td class="px-6 py-4 text-sm">
                                    <a href="/admin/orgs/{{ .Ref }}" class="text-indigo-600 hover:text-indigo-900 font-medium">{{ .Name }}</a>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-500">
                                    {{ if .Email }}<a href="mailto:{{ .Email }}" class="text-indigo-600 hover:text-indigo-900">{{ .Email }}</a>{{ else }}<span class="text-gray-400">—</span>{{ end }}
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-500">{{ if .Website }}<a href="{{ .Website }}" class="text-indigo-600 hover:text-indigo-900">{{ .Website }}</a>{{ else }}<span class="text-gray-400">—</span>{{ end }}</td>
                            </tr>
                            {{ end }}
                        </tbody>
                    </table>
                    <div class="px-6 py-3 bg-gray-50 text-sm text-gray-500">
                        {{ len .Orgs }} organizations
                    </div>
                </div>
            </section>
            {{ else }}
            <section class="mb-6">
                <div class="bg-white shadow rounded-lg px-4 py-5 sm:p-6 text-center text-gray-500">
                    No organizations yet. <a href="/admin/orgs/new" class="text-indigo-600 hover:text-indigo-900">Add one</a>.
                </div>
            </section>
            {{ end }}
        </div>
    </div>
  </body>
</html>
