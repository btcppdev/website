<!DOCTYPE html>
<html>
<head>
  <title>New org · bitcoin++</title>
  {{ block "header" . }} {{ end }}
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>&#127970;</text></svg>">
</head>
<body class="bg-gray-50">
  {{ block "mainnav" . }} {{ end }}
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-12">
    {{ if .ReturnTo }}
    <a href="{{ .ReturnTo }}" class="text-sm text-gray-500 hover:text-gray-700">&larr; Back</a>
    {{ else }}
    <a href="/admin/orgs" class="text-sm text-gray-500 hover:text-gray-700">&larr; All orgs</a>
    {{ end }}

    <h1 class="mt-4 text-2xl font-bold text-gray-900">Add a new org</h1>
    <p class="mt-1 text-sm text-gray-600">Creates an org profile for sponsorship contacts, speaker affiliations, or anything you'd reference by company.</p>

    {{ if .FlashMessage }}
    <div class="mt-6 rounded-md bg-green-50 border border-green-200 px-4 py-3">
      <p class="text-sm text-green-800">{{ .FlashMessage }}</p>
    </div>
    {{ end }}

    <form method="POST" action="/admin/orgs/new" class="mt-8 bg-white shadow rounded-lg p-6 space-y-5">
      <input type="hidden" name="return" value="{{ .ReturnTo }}" />

      <div>
        <label for="Name" class="block text-sm/6 font-semibold text-gray-900">Name <span class="text-red-600">*</span></label>
        <input id="Name" name="Name" type="text" required
               autocomplete="organization" autocorrect="off" spellcheck="false"
               class="mt-2 block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin"
               placeholder="Acme Bitcoin Inc." />
      </div>

      <div>
        <label for="Tagline" class="block text-sm/6 font-semibold text-gray-900">Tagline</label>
        <input id="Tagline" name="Tagline" type="text"
               autocomplete="off" spellcheck="false"
               class="mt-2 block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin"
               placeholder="Sound money for sound minds" />
      </div>

      <div>
        <label for="Website" class="block text-sm/6 font-semibold text-gray-900">Website</label>
        <input id="Website" name="Website" type="url"
               autocomplete="url" autocorrect="off" autocapitalize="off" spellcheck="false"
               class="mt-2 block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin"
               placeholder="https://example.com" />
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label for="Twitter" class="block text-sm/6 font-semibold text-gray-900">X / Twitter</label>
          <input id="Twitter" name="Twitter" type="text"
                 autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"
                 class="mt-2 block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin"
                 placeholder="@btcplusplus" />
        </div>
        <div>
          <label for="Nostr" class="block text-sm/6 font-semibold text-gray-900">Nostr npub</label>
          <input id="Nostr" name="Nostr" type="text"
                 autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"
                 class="mt-2 block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin"
                 placeholder="npub1…" />
        </div>
        <div>
          <label for="Github" class="block text-sm/6 font-semibold text-gray-900">Github</label>
          <input id="Github" name="Github" type="url"
                 autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"
                 class="mt-2 block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin"
                 placeholder="https://github.com/…" />
        </div>
        <div>
          <label for="LinkedIn" class="block text-sm/6 font-semibold text-gray-900">LinkedIn</label>
          <input id="LinkedIn" name="LinkedIn" type="url"
                 autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"
                 class="mt-2 block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin"
                 placeholder="https://linkedin.com/company/…" />
        </div>
        <div>
          <label for="Instagram" class="block text-sm/6 font-semibold text-gray-900">Instagram</label>
          <input id="Instagram" name="Instagram" type="url"
                 autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"
                 class="mt-2 block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin"
                 placeholder="https://instagram.com/…" />
        </div>
        <div>
          <label for="Youtube" class="block text-sm/6 font-semibold text-gray-900">YouTube</label>
          <input id="Youtube" name="Youtube" type="url"
                 autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false"
                 class="mt-2 block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin"
                 placeholder="https://youtube.com/@…" />
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <span class="block text-sm/6 font-semibold text-gray-900">Logo (light bg)</span>
          <p class="text-xs text-gray-500">For light backgrounds.</p>
          <input id="LogoLight" name="LogoLight" type="hidden" value="">
          <div class="mt-2 flex items-center gap-3">
            <button type="button" data-target="LogoLight"
                    class="logo-upload-trigger inline-flex items-center rounded-md border border-gray-300 bg-white px-3 py-1.5 text-xs font-semibold text-gray-700 hover:bg-gray-50">
              Upload a file
            </button>
            <img id="LogoLight-preview" alt="" class="hidden h-10 w-auto max-w-[160px] rounded border border-gray-200 bg-white object-contain">
            <button type="button" data-target="LogoLight"
                    class="logo-clear-trigger hidden text-xs font-medium text-red-600 hover:text-red-700">
              Remove
            </button>
          </div>
          <p id="LogoLight-status" class="mt-1 text-xs text-gray-500">No file selected.</p>
        </div>
        <div>
          <span class="block text-sm/6 font-semibold text-gray-900">Logo (dark bg)</span>
          <p class="text-xs text-gray-500">For dark backgrounds.</p>
          <input id="LogoDark" name="LogoDark" type="hidden" value="">
          <div class="mt-2 flex items-center gap-3">
            <button type="button" data-target="LogoDark"
                    class="logo-upload-trigger inline-flex items-center rounded-md border border-gray-300 bg-white px-3 py-1.5 text-xs font-semibold text-gray-700 hover:bg-gray-50">
              Upload a file
            </button>
            <img id="LogoDark-preview" alt="" class="hidden h-10 w-auto max-w-[160px] rounded border border-gray-200 bg-gray-900 object-contain">
            <button type="button" data-target="LogoDark"
                    class="logo-clear-trigger hidden text-xs font-medium text-red-600 hover:text-red-700">
              Remove
            </button>
          </div>
          <p id="LogoDark-status" class="mt-1 text-xs text-gray-500">No file selected.</p>
        </div>
      </div>

      <input type="file" id="LogoFilePicker" accept="image/*" class="hidden">
      <script>
        // "Upload a file" button → hidden file picker → POST to
        // /admin/orgs/upload-logo → store the returned Spaces URL
        // on a hidden input the form submits, plus show a preview
        // thumbnail so the admin sees what they picked. The full
        // URL never appears on the form — the admin doesn't need
        // to think about Spaces at all.
        (function () {
          const picker = document.getElementById('LogoFilePicker');
          let activeTarget = null;
          document.querySelectorAll('.logo-upload-trigger').forEach(function (btn) {
            btn.addEventListener('click', function () {
              activeTarget = btn.dataset.target;
              picker.value = '';
              picker.click();
            });
          });
          picker.addEventListener('change', function () {
            if (!activeTarget || !picker.files || picker.files.length === 0) return;
            const file = picker.files[0];
            const targetID = activeTarget;
            const status  = document.getElementById(targetID + '-status');
            const input   = document.getElementById(targetID);
            const preview = document.getElementById(targetID + '-preview');
            const clear   = document.querySelector('.logo-clear-trigger[data-target="' + targetID + '"]');
            status.textContent = 'Uploading ' + file.name + '…';
            status.className = 'mt-1 text-xs text-gray-700';
            const fd = new FormData();
            fd.append('file', file);
            fetch('/admin/orgs/upload-logo', { method: 'POST', body: fd, credentials: 'same-origin' })
              .then(function (r) {
                if (!r.ok) return r.text().then(function (t) { throw new Error(t || ('HTTP ' + r.status)); });
                return r.json();
              })
              .then(function (data) {
                input.value = data.url;
                preview.src = data.url;
                preview.classList.remove('hidden');
                if (clear) clear.classList.remove('hidden');
                status.textContent = file.name + ' — uploaded.';
                status.className = 'mt-1 text-xs text-green-700';
              })
              .catch(function (err) {
                status.textContent = 'Upload failed: ' + (err.message || err);
                status.className = 'mt-1 text-xs text-red-700';
              })
              .finally(function () {
                if (activeTarget === targetID) activeTarget = null;
              });
          });

          // Remove: clears the hidden URL input + hides the preview
          // and the Remove button itself, so the form submits with
          // an empty Logo* and the admin sees the upload UI reset.
          // The file already in Spaces is left untouched (cheap to
          // keep; content-hashed key means a re-upload of the same
          // bytes would land on the same key anyway).
          document.querySelectorAll('.logo-clear-trigger').forEach(function (btn) {
            btn.addEventListener('click', function () {
              const targetID = btn.dataset.target;
              const status  = document.getElementById(targetID + '-status');
              const input   = document.getElementById(targetID);
              const preview = document.getElementById(targetID + '-preview');
              input.value = '';
              preview.removeAttribute('src');
              preview.classList.add('hidden');
              btn.classList.add('hidden');
              status.textContent = 'No file selected.';
              status.className = 'mt-1 text-xs text-gray-500';
            });
          });
        })();
      </script>

      <div class="flex items-center gap-3">
        <input id="Hiring" name="Hiring" type="checkbox" class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500" />
        <label for="Hiring" class="text-sm/6 font-medium text-gray-900">Hiring</label>
      </div>

      <div>
        <label for="Notes" class="block text-sm/6 font-semibold text-gray-900">Notes</label>
        <textarea id="Notes" name="Notes" rows="3"
                  class="mt-2 block w-full rounded-md bg-white px-3.5 py-2 text-base text-gray-900 outline outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-bitcoin"
                  placeholder="Internal notes for the team."></textarea>
      </div>

      <div class="flex items-center gap-3 pt-2">
        <button type="submit" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700">
          Create org
        </button>
        {{ if .ReturnTo }}
        <a href="{{ .ReturnTo }}" class="text-sm text-gray-500 hover:text-gray-700">Cancel</a>
        {{ else }}
        <a href="/admin/orgs" class="text-sm text-gray-500 hover:text-gray-700">Cancel</a>
        {{ end }}
      </div>
    </form>
  </div>
  {{ block "footer" . }} {{ end }}
</body>
</html>
