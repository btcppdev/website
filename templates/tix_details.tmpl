<div id="discount_result" name="hidden_stuffs" class="checkout-summary"
  data-ticket-btc-price-cents="{{ mul (int .DiscountPrice) 100 }}"
  data-ticket-card-price-cents="{{ mul (int .CardPrice) 100 }}">
  <div class="checkout-summary__lines">
    <div>
      <span>{{ if .SponsorCheckout }}Sponsor a builder{{ else }}{{ .Tix.Tier }}{{ end }} · <span data-ticket-count-label data-ticket-noun="{{ if .SponsorCheckout }}pass{{ else }}ticket{{ end }}">{{ .Count }} {{ if .SponsorCheckout }}pass{{ else }}ticket{{ end }}{{ if ne .Count 1 }}s{{ end }}</span></span>
      <strong>{{ .Tix.Symbol }}{{ .TixPrice }}{{ .Tix.PostSymbol }} ea</strong>
    </div>
    {{ if ne .TixPrice .DiscountPrice }}
    <div class="is-discount">
      <span>{{ .Discount }} applied</span>
      <strong>-{{ .Tix.Symbol }}{{ usub .TixPrice .DiscountPrice }}{{ .Tix.PostSymbol }}</strong>
    </div>
    {{ end }}
    <div class="is-total" data-selected-payment-price
      data-bitcoin-price="{{ .Tix.Symbol }}{{ .DiscountPrice }}{{ .Tix.PostSymbol }} ea"
      data-card-price="{{ .Tix.Symbol }}{{ .CardPrice }}{{ .Tix.PostSymbol }} ea">
      <span data-payment-price-label>{{ if eq .PaymentMethod "card" }}Card{{ else }}Bitcoin{{ end }} price</span>
      <strong data-payment-price-amount>{{ if eq .PaymentMethod "card" }}{{ .Tix.Symbol }}{{ .CardPrice }}{{ .Tix.PostSymbol }}{{ else }}{{ .Tix.Symbol }}{{ .DiscountPrice }}{{ .Tix.PostSymbol }}{{ end }} ea</strong>
    </div>
  </div>

  {{ if .Err }}
    {{ if .Discount }}
  <div class="checkout-summary__error">{{ .Err }}</div>
    {{ end }}
  {{ end }}

  <input type="hidden" name="Tix" value="{{ .Tix }}" required>
  <input type="hidden" name="HMAC" value="{{ .HMAC }}" required>
  <input type="hidden" name="TixPrice" value="{{ .TixPrice }}" required>
  <input type="hidden" name="DiscountPrice" value="{{ .DiscountPrice }}" required>
  <input type="hidden" name="DiscountRef" value="{{ .DiscountRef }}" required>
  <input type="hidden" name="AffiliateCode" value="{{ .AffiliateCode }}">
</div>
