        <strong><a href="/dashboard/orders/{{ .PublicID }}?hr={{ $.HMAC }}&em={{ $.Email }}">{{ .PublicID }}</a></strong>
        <span>{{ .CreatedAt.Format "Jan 2, 2006" }} · {{ .Status }} · {{ .CheckoutKind }}</span>
      </div>
      <div class="dashboard-purchase-row__side">
