        <a href="/dashboard/orders/{{ .PublicID }}/receipt?hr={{ $.HMAC }}&em={{ $.Email }}">receipt</a>
      </div>
    </article>
    {{ end }}
  </div>
</section>
{{ end }}

{{/* ---- Past conferences ---- */}}
{{ if .PastBlocks }}
<section id="past" class="dashboard-past-ledger">
  <div class="dashboard-past-ledger__head">
    <div class="dashboard-kicker">§ Past conferences · {{ len .PastBlocks }}</div>
    {{ if .ArchiveOwnerPath }}<a href="{{ .ArchiveOwnerPath }}">show all {{ len .PastBlocks }} &rarr;</a>{{ end }}
  </div>
  <div class="dashboard-past-ledger__rows">
      {{ range $i, $eb := .PastBlocks }}
      {{ if lt $i 5 }}
      {{ $conf := .Conf }}
      <article class="dashboard-past-row">
        <div class="dashboard-past-row__emoji">{{ $conf.EmojiOrDefault }}</div>
        <div class="dashboard-past-row__main">
          <strong>{{ $conf.Desc }}</strong>
          <span>{{ $conf.DateDesc }} · {{ $conf.Location }}</span>
        </div>
        <div class="dashboard-past-row__roles">
          {{ if $eb.SpeakerConf }}<span>speaker</span>{{ end }}
          {{ if $eb.VolApp }}<span>volunteer</span>{{ end }}
          {{ if $eb.Tickets }}<span>{{ len $eb.Tickets }} ticket{{ if gt (len $eb.Tickets) 1 }}s{{ end }}</span>{{ end }}
          {{ if $eb.IsHackathonJudge }}<span>{{ $eb.HackathonJudgeLabel }}</span>{{ end }}
          {{ if $eb.IsHackathonCoordinator }}<a href="/{{ $conf.Tag }}/admin/hackathon" class="dashboard-past-row__admin">hackathon admin</a>{{ end }}
          {{ if $eb.AdminRole }}
          <a href="{{ if eq $eb.AdminRole "admin" }}/{{ $conf.Tag }}/admin{{ else }}/{{ $conf.Tag }}/volcoord{{ end }}"
             class="dashboard-past-row__admin">
            {{ if eq $eb.AdminRole "admin" }}admin{{ else }}vol coord{{ end }}
          </a>
          {{ end }}
        </div>
      </article>
      {{ end }}
      {{ end }}
  </div>
</section>
{{ end }}

{{ if .IsGlobalAdmin }}
<section id="global-admin-tools">
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="px-4 py-5 sm:p-6">
      <div class="flex items-center justify-between gap-4">
        <div>
          <h3 class="text-sm font-semibold text-gray-900">Global admin tools</h3>
          <p class="mt-1 text-xs text-gray-500">Manage site-wide newsletter templates and admin-only infrastructure.</p>
        </div>
        <span class="inline-flex items-center rounded-full bg-amber-100 text-amber-800 px-2 py-0.5 text-xs font-medium">global-admin</span>
      </div>
      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        <a href="/admin" class="block rounded-md border border-gray-200 px-4 py-3 hover:border-indigo-300 hover:bg-indigo-50">
          <div class="text-sm font-medium text-gray-900">Global admin dashboard</div>
          <div class="mt-1 text-xs text-gray-500">Manage templated newsletters, organizations, and global permissions.</div>
        </a>
      </div>
    </div>
  </div>
</section>
{{ end }}

{{ if or .HasUpcomingTalk .HasUpcomingVol }}
<section id="contact" class="dashboard-help-block">
  <div>
    <div class="dashboard-kicker">§ Need help?</div>
    <p>We read every message. Reach the right crew:</p>
  </div>
  <div class="dashboard-help-block__links">
    {{ if .HasUpcomingTalk }}<a class="is-accent" href="mailto:speak@btcpp.dev">speak@btcpp.dev</a>{{ end }}
    {{ if .HasUpcomingVol }}<a href="mailto:volunteer@btcpp.dev">volunteer@btcpp.dev</a>{{ end }}
  </div>
</section>
{{ end }}

    </div>
  </div>
  {{ block "footer" . }} {{ end }}
  {{ if .AffiliateCode }}
  <script>
    // Per-event-card "Copy link" buttons: click → copy the
    // affiliate share URL to the clipboard + briefly flash the
    // button to acknowledge. Each button carries its conf-scoped
    // share URL on data-share-url so we don't string-build at
    // click time.
    (function () {
      document.querySelectorAll('.affiliate-share-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          const url = btn.dataset.shareUrl;
          if (!url) return;
          const original = btn.textContent;
          navigator.clipboard.writeText(url).then(function () {
            btn.textContent = 'Copied!';
            btn.classList.add('bg-green-600');
            btn.classList.remove('bg-indigo-600', 'hover:bg-indigo-700');
            setTimeout(function () {
              btn.textContent = original;
              btn.classList.remove('bg-green-600');
              btn.classList.add('bg-indigo-600', 'hover:bg-indigo-700');
            }, 1500);
          }).catch(function () {
            btn.textContent = 'Copy failed';
            setTimeout(function () { btn.textContent = original; }, 1500);
          });
        });
      });
    })();
  </script>
  {{ end }}
</body>
</html>
