<!DOCTYPE html>
<html>
<head>
  <title>your bitcoin++ dashboard</title>
  {{ block "header" . }} {{ end }}
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>&#10024;</text></svg>">
</head>
<body class="btcpp-dashboard-page">
  {{ block "mainnav" . }} {{ end }}
  <div class="dashboard-shell">
    <div class="dashboard-main">

      {{ if .FlashMessage }}
      <div class="dashboard-flash is-success">
        <p>{{ .FlashMessage }}</p>
      </div>
      {{ end }}
      {{ if .FlashError }}
      <div class="dashboard-flash is-error">
        <p>{{ .FlashError }}</p>
      </div>
      {{ end }}

      <section id="topline" class="dashboard-topline">
        <div class="dashboard-topline__profile">
          <div class="dashboard-avatar">
            {{ if .Photo }}
            <img src="{{ speakerPhoto .Photo }}" alt="{{ .Name }}" />
            {{ else }}
            <span>{{ printf "%.1s" .Name }}</span>
            {{ end }}
          </div>
          <div class="dashboard-identity">
            <div class="dashboard-kicker">Welcome back</div>
            <h1>{{ .Name }}</h1>
            <div class="dashboard-meta">
              {{ if .Speaker }}
              {{ if .Speaker.Email }}<a href="mailto:{{ .Speaker.Email }}">{{ .Speaker.Email }}</a>{{ end }}
              {{ if .Speaker.Twitter.Handle }}<a href="https://x.com/{{ .Speaker.Twitter.Handle }}" target="_blank" rel="noopener noreferrer">@{{ .Speaker.Twitter.Handle }}</a>{{ end }}
              {{ end }}
              {{ if and .Hometown (ne .Hometown "unknown") }}<span>{{ .Hometown }}</span>{{ end }}
            </div>
          </div>
          <div class="dashboard-topline__actions">
            <a href="/dashboard/speaker?hr={{ .HMAC }}&em={{ .Email }}">{{ if .Speaker }}Edit profile{{ else }}Create profile{{ end }}</a>
            {{ if and .Speaker .HasPublicProfile }}
            <a href="{{ speakerPublicPath .Speaker }}">View profile</a>
            {{ end }}
            <form method="POST" action="/logout"><button type="submit">Sign out</button></form>
          </div>
        </div>
        <div class="dashboard-stat-grid dashboard-stat-grid--ledger" aria-label="Dashboard stats">
          <div class="dashboard-stat-group">
            <div class="dashboard-stat-group__legend">Speaking</div>
            <div class="dashboard-stat-group__cells">
              <div class="dashboard-stat"><span>Talks submitted</span><strong>{{ .Stats.TalksApplied }}</strong></div>
              <div class="dashboard-stat is-accent"><span>Talks accepted</span><strong>{{ .Stats.TalksAccepted }}</strong></div>
            </div>
          </div>
          <div class="dashboard-stat-group">
            <div class="dashboard-stat-group__legend">Volunteering</div>
            <div class="dashboard-stat-group__cells">
              <div class="dashboard-stat"><span>Conferences volunteered</span><strong>{{ .Stats.ShiftsApplied }}</strong></div>
              <div class="dashboard-stat"><span>Upcoming shifts</span><strong>{{ .Stats.ShiftsBooked }}</strong></div>
            </div>
          </div>
        </div>
      </section>

{{/* ---- Affiliate ---- */}}
{{ if .HasAnyTicket }}
<section id="affiliate" class="dashboard-affiliate dashboard-affiliate-cta">
  <a class="dashboard-affiliate-cta__link" href="/dashboard/affiliate" aria-label="Open affiliate program">
    <div class="dashboard-affiliate__copy">
      <div class="dashboard-kicker">§ Affiliate</div>
      <div class="dashboard-affiliate__title">
        {{ if .AffiliateCode }}
        <h2>Bring your crew. Get paid in sats.</h2>
        <code>{{ .AffiliateCode.CodeName }}</code>
        <span>buyer saves {{ .AffiliateCode.Amount }}% · you keep {{ usub 20 .AffiliateCode.Amount }}%</span>
        {{ else }}
        <h2>Create an affiliate code.</h2>
        <span>Choose how the 20% pool splits between you and your friends.</span>
        {{ end }}
      </div>
      <p>{{ if .AffiliateCode }}Track sales, copy your referral link, and adjust future buyer discounts from your affiliate page.{{ else }}Affiliate codes are available to ticket holders and work across active bitcoin++ editions.{{ end }}</p>
    </div>
    <div class="dashboard-affiliate-cta__side">
      {{ if .AffiliateStats }}
      <div class="dashboard-affiliate-cta__mini">
        <strong>{{ .AffiliateStats.TicketsSold }}</strong>
        <span>tickets sold</span>
      </div>
      <div class="dashboard-affiliate-cta__mini">
        <strong>{{ sats .AffiliateStats.EarnedSats }}</strong>
        <span>sats earned</span>
      </div>
      {{ end }}
      <span class="dashboard-affiliate-cta__button">{{ if .AffiliateCode }}Open affiliate dashboard{{ else }}Create affiliate code{{ end }} →</span>
    </div>
  </a>
</section>
{{ end }}

{{ if .TicketEntitlements }}
<section id="hackathon-ticket-awards" class="dashboard-affiliate dashboard-affiliate-cta{{ if eq .UnclaimedTicketEntitlements 0 }} dashboard-affiliate-cta--complete{{ end }}">
  <a class="dashboard-affiliate-cta__link" href="/dashboard/tickets" aria-label="Open hackathon ticket awards">
    <div class="dashboard-affiliate__copy">
      <div class="dashboard-kicker">§ Hackathon ticket awards</div>
      {{ if gt .UnclaimedTicketEntitlements 0 }}
      <div class="dashboard-affiliate__title"><h2>You have {{ .UnclaimedTicketEntitlements }} ticket reward{{ if ne .UnclaimedTicketEntitlements 1 }}s{{ end }} ready to claim.</h2></div>
      <p>Choose a future bitcoin++ event and claim each person-bound ticket from your ticket awards page.</p>
      {{ else }}
      <div class="dashboard-affiliate__title"><h2>Your ticket {{ if eq (len .TicketEntitlements) 1 }}reward has{{ else }}rewards have{{ end }} been claimed.</h2></div>
      <p>View the event {{ if eq (len .TicketEntitlements) 1 }}ticket{{ else }}tickets{{ end }} issued from your hackathon awards.</p>
      {{ end }}
    </div>
    <div class="dashboard-affiliate-cta__side"><span class="dashboard-affiliate-cta__button">{{ if gt .UnclaimedTicketEntitlements 0 }}View and claim tickets{{ else }}View claimed tickets{{ end }} →</span></div>
  </a>
</section>
{{ end }}

{{/*
  Per-event blocks: one section per conf the user has any relationship
  with (speaker, volunteer, ticket-holder). All applicable subsections
  render inside the block — talks, vol shift status, tickets, plus
  CTAs to buy more / apply / propose another.
*/}}
{{ if .ActiveBlocks }}
<section id="events" class="dashboard-ledger-list">
  <div class="dashboard-section-label">§ Your editions · {{ len .ActiveBlocks }}</div>
  {{ range .ActiveBlocks }}
  {{ $eb := . }}
  {{ $conf := .Conf }}
  <article class="dashboard-ledger-card">
    {{/* Hero band — uses the conf's leading image with a gradient
         scrim so the title text stays legible on any photo. Anchor
         takes the user to the public conf page. */}}
    <div class="dashboard-ledger-card__hero-wrap">
      <a href="/{{ $conf.Tag }}" class="dashboard-ledger-card__hero">
        <picture>
          <source srcset="/static/img/{{ $conf.Tag }}/leading.avif" type="image/avif" />
          <img src="/static/img/{{ $conf.Tag }}/leading.png" alt="{{ $conf.Desc }}" />
        </picture>
        <div class="dashboard-ledger-card__scrim"></div>
        <div class="dashboard-ledger-card__hero-copy">
          <div class="dashboard-ledger-card__meta">{{ $conf.DateDesc }} · {{ $conf.Location }}</div>
          <h2><span>{{ $conf.EmojiOrDefault }}</span>{{ $conf.Desc }}</h2>
        </div>
      </a>
      {{ if $eb.SatelliteEvents }}
      <a href="#satellites-{{ $conf.Tag }}"
         class="dashboard-ledger-card__pill is-left">
        Satellite events ({{ len $eb.SatelliteEvents }})
      </a>
      {{ end }}
      <div class="dashboard-ledger-card__tools">
        <div class="dashboard-ledger-countdown">{{ template "conf_countdown" $conf }}</div>
      {{ if $eb.AdminRole }}
      <a href="{{ if eq $eb.AdminRole "admin" }}/{{ $conf.Tag }}/admin{{ else }}/{{ $conf.Tag }}/volcoord{{ end }}"
         class="dashboard-ledger-card__pill is-accent">
        {{ if eq $eb.AdminRole "admin" }}Admin{{ else }}Vol coord{{ end }}
      </a>
      {{ end }}
      </div>
    </div>

    {{ if or $eb.SpeakerConf $eb.VolApp $eb.Tickets $eb.SatelliteEvents $eb.CanBuy $eb.IsHackathonJudge $eb.IsHackathonCoordinator $.AffiliateCode $conf.TalksOpen $conf.VolunteerOpen }}
    {{ if $eb.Tickets }}
    <div class="dashboard-ticket-block">
      <div class="dashboard-ticket-list">
        {{ range $eb.Tickets }}
        <div class="dashboard-ticket-row">
          <div class="dashboard-ticket-block__qr">
            {{ if .QRCodeURI }}
            <img class="dashboard-ticket-row__qr" src="{{ .QRCodeURI | safeURL }}" width="104" height="104" alt="Ticket QR code for {{ .RefID }}">
            {{ else }}
            <span>QR</span>
            {{ end }}
          </div>
          <div class="dashboard-ticket-block__body">
            <div class="dashboard-kicker">§ Your ticket · check-in ready</div>
            <div class="dashboard-ticket-row__summary">
              <strong>{{ if .Type }}{{ .Type }}{{ else }}Ticket{{ end }}</strong>
            </div>
            <span>ID {{ .RefID }}{{ if $.Email }} · {{ $.Email }}{{ end }}</span>
            <div class="dashboard-ticket-row__actions">
              <a href="/ticket/{{ .RefID }}/pdf?type={{ .Type }}&conf={{ .ConfRef }}">Download ticket ↓</a>
            </div>
          </div>
        </div>
        {{ end }}
      </div>
    </div>
    {{ else if $eb.CanBuy }}
    <div class="dashboard-ticket-block is-needed">
      <div>
        <div class="dashboard-kicker">§ Ticket</div>
        <strong>You don't have a ticket yet</strong>
        <span>{{ $conf.DateDesc }} · {{ $conf.Location }}</span>
      </div>
      <a href="/{{ $conf.Tag }}#tickets">Buy ticket &rarr;</a>
    </div>
    {{ end }}
    <div class="dashboard-ledger-card__body">
      <div class="dashboard-actions dashboard-ledger-actions">
        <div class="dashboard-actions__head">
          <div>
            <h3>Available actions</h3>
            <p>What you can do for this edition from your dashboard.</p>
          </div>
          <div class="dashboard-status-row">
            {{ if $eb.Tickets }}<span>{{ len $eb.Tickets }} ticket{{ if gt (len $eb.Tickets) 1 }}s{{ end }}</span>{{ end }}
            {{ if $eb.SpeakerConf }}<span>{{ len $eb.SpeakerConf.Proposals }} talk{{ if ne (len $eb.SpeakerConf.Proposals) 1 }}s{{ end }}</span>{{ end }}
            {{ if $eb.VolApp }}<span>volunteer: {{ $eb.VolApp.Status }}</span>{{ end }}
            {{ if $eb.IsHackathonJudge }}<span>{{ $eb.HackathonJudgeLabel }}</span>{{ end }}
            {{ if $eb.IsHackathonCoordinator }}<span>Hackathon coordinator</span>{{ end }}
          </div>
        </div>
        <div class="dashboard-action-grid">
          {{ if $.AffiliateCode }}
          <button type="button"
                  data-share-url="{{ $.BaseURI }}/{{ $conf.Tag }}?code={{ $.AffiliateCode.CodeName }}"
                  class="dashboard-action affiliate-share-btn">
            <span class="dashboard-action__label">Share affiliate link</span>
            <span class="dashboard-action__hint">Code {{ $.AffiliateCode.CodeName }}</span>
          </button>
          {{ else if $.HasAnyTicket }}
          <a href="/dashboard/affiliate" class="dashboard-action">
            <span class="dashboard-action__label">Create affiliate code</span>
            <span class="dashboard-action__hint">Share discounts and earn on ticket sales</span>
          </a>
          {{ end }}

          {{ if $eb.CanBuy }}
          <a href="/{{ $conf.Tag }}#tickets" class="dashboard-action">
            <span class="dashboard-action__label">{{ if $eb.Tickets }}Buy another ticket{{ else }}Buy a ticket{{ end }}</span>
            <span class="dashboard-action__hint">{{ $conf.DateDesc }}</span>
          </a>
          {{ end }}

          {{ if $eb.IsHackathonJudge }}
          <a href="/{{ $conf.Tag }}/hackathon/judging" class="dashboard-action">
            <span class="dashboard-action__label">Score hackathon projects</span>
            <span class="dashboard-action__hint">You're assigned to judge this event · Open your scoring ballot</span>
          </a>
          {{ end }}

          {{ if $eb.IsHackathonCoordinator }}
          <a href="/{{ $conf.Tag }}/admin/hackathon" class="dashboard-action">
            <span class="dashboard-action__label">Admin hackathon</span>
            <span class="dashboard-action__hint">Manage projects, judging, awards, and the public hackathon page</span>
          </a>
          {{ end }}

          {{ if $eb.SpeakerConf }}
          <a href="#talks-{{ $conf.Tag }}" class="dashboard-action">
            <span class="dashboard-action__label">Manage talks</span>
            <span class="dashboard-action__hint">{{ len $eb.SpeakerConf.Proposals }} Active</span>
          </a>
          {{ else if $conf.TalksOpen }}
          <a href="/talk/{{ $conf.Tag }}?hr={{ $.HMAC }}&em={{ $.Email }}" class="dashboard-action">
            <span class="dashboard-action__label">Apply to speak</span>
            <span class="dashboard-action__hint">Submit a talk, workshop, or panel</span>
          </a>
          {{ end }}

          {{ if $eb.VolApp }}
          {{ if or (eq $eb.VolApp.Status "PendingShifts") (eq $eb.VolApp.Status "Scheduled") }}
          <a href="/vols/shift/{{ $conf.Tag }}?hr={{ $.HMAC }}&em={{ $.Email }}" class="dashboard-action">
            <span class="dashboard-action__label">Manage volunteer schedule</span>
            <span class="dashboard-action__hint">Select, view, or edit your shifts</span>
          </a>
          {{ else }}
          <a href="#volunteer-{{ $conf.Tag }}" class="dashboard-action">
            <span class="dashboard-action__label">View volunteer application</span>
            <span class="dashboard-action__hint">{{ $eb.VolApp.Status }}</span>
          </a>
          {{ end }}
          {{ else if $conf.VolunteerOpen }}
          <a href="/volunteer/{{ $conf.Tag }}?hr={{ $.HMAC }}&em={{ $.Email }}" class="dashboard-action">
            <span class="dashboard-action__label">Apply to volunteer</span>
            <span class="dashboard-action__hint">Help run the event</span>
          </a>
          {{ end }}
        </div>
      </div>

      {{ if and $eb.SpeakerConf $conf.CanInvite }}
      <div class="flex justify-end mt-4 mb-2">
        <a href="/dashboard/{{ $conf.Tag }}/edit?hr={{ $.HMAC }}&em={{ $.Email }}"
           class="text-xs font-medium text-gray-600 hover:text-gray-900">
          Edit speaker info &rarr;
        </a>
      </div>
      {{ end }}

      {{/* ---- Talks ---- */}}
      {{ if $eb.SpeakerConf }}
      <div id="talks-{{ $conf.Tag }}" class="dashboard-ledger-section dashboard-talks-ledger">
        <div class="dashboard-ledger-section__head">
          <h3>§ Talks · {{ len $eb.SpeakerConf.Proposals }}</h3>
          {{ if $conf.TalksOpen }}
          <a class="dashboard-ledger-inline-action" href="/talk/{{ $conf.Tag }}?hr={{ $.HMAC }}&em={{ $.Email }}">+ propose another</a>
          {{ end }}
        </div>
        <div class="dashboard-talks-ledger__rows">
          {{ range $eb.SpeakerConf.Proposals }}
          <article class="dashboard-talk-row">
            {{ if and .ConfTalk .ConfTalk.Clipart }}
            <div class="shrink-0">
              <picture>
                <source srcset="{{ talkClipart .ConfTalk.ClipartAvif }}" type="image/avif" />
                <img src="{{ talkClipart .ConfTalk.Clipart }}" alt=""
                     class="size-16 rounded-md object-cover bg-gray-100 ring-1 ring-gray-200" />
              </picture>
            </div>
            {{ end }}

            <div class="min-w-0 flex-1 flex flex-col">
              <div class="flex items-start justify-between gap-2">
                <div class="min-w-0">
                  <p class="text-sm font-semibold text-gray-900 truncate">{{ .Title }}</p>
                  <p class="mt-0.5 text-xs text-gray-500">
                    {{ if .TalkType }}{{ .TalkType }}{{ end }}
                    {{ if .DesiredDuration }} &middot; {{ .DesiredDuration }} min{{ end }}
                  </p>
                </div>
                <div class="flex flex-col items-end gap-2 shrink-0">
                  <div class="flex items-center gap-2">
                    {{ if and .Recording .Recording.YTLink }}
                    <a href="{{ .Recording.YTLink }}" target="_blank" rel="noopener noreferrer"
                       title="Watch recording"
                       class="dashboard-recording-link">
                      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                    </a>
                    {{ end }}
                    {{ if eq .Status "Applied" }}
                    <span class="dashboard-status-chip is-applied">Applied</span>
                    {{ else if eq .Status "InReview" }}
                    <span class="dashboard-status-chip is-review">In review</span>
                    {{ else if eq .Status "Waitlisted" }}
                    <span class="dashboard-status-chip is-waitlisted">Waitlisted</span>
                    {{ else if eq .Status "Invited" }}
                    <span class="dashboard-status-chip is-invited">Invited</span>
                    {{ else if eq .Status "Accepted" }}
                    <span class="dashboard-status-chip is-accepted">Accepted</span>
                    {{ else if eq .Status "TheyDecline" }}
                    <span class="dashboard-status-chip is-muted">Declined</span>
                    {{ else if or (eq .Status "WeDecline") (eq .Status "Rejected") }}
                    <span class="dashboard-status-chip is-muted">Not selected</span>
                    {{ else }}
                    <span class="dashboard-status-chip">{{ .Status }}</span>
                    {{ end }}
                  </div>
                  {{ if not (or (eq .Status "Accepted") (eq .Status "TheyDecline") (eq .Status "WeDecline") (eq .Status "Rejected")) }}
                  <form method="POST" action="/dashboard/talks/{{ .ID }}/withdraw?hr={{ $.HMAC }}&em={{ $.Email }}" class="inline">
                    <button type="submit"
                            class="dashboard-inline-action is-danger"
                            onclick="return confirm('Withdraw this talk? {{ if eq .TalkType "panel" }}You''ll be removed from the panel; the talk continues with the other speakers.{{ else }}This will withdraw the whole talk.{{ end }}');">
                      Withdraw Proposal
                    </button>
                  </form>
                  {{ end }}
                </div>
              </div>

              {{ if .Speakers }}
              {{ $proposal := . }}
              {{ $canEditSpeakers := and (and $conf $conf.CanInvite) (not (or (eq .Status "TheyDecline") (eq .Status "WeDecline") (eq .Status "Rejected"))) }}
              {{ $multi := gt (len .Speakers) 1 }}
              <div class="mt-2 flex flex-wrap items-center gap-1.5">
                {{ range .Speakers }}
                {{ if .Speaker }}
                <span class="dashboard-speaker-chip">
                  <img src="{{ if .Speaker.Photo }}{{ speakerPhoto .Speaker.Photo }}{{ else }}/static/img/speaker-placeholder.png{{ end }}"
                       alt="{{ .Speaker.Name }}"
                       class="dashboard-speaker-chip__avatar" />
                  <span>{{ .Speaker.Name }}</span>
                  {{ if and $canEditSpeakers (and $multi (ne .ID $eb.SpeakerConf.ID)) }}
                  <form method="POST" action="/dashboard/talks/{{ $proposal.ID }}/speakers/{{ .ID }}/remove?hr={{ $.HMAC }}&em={{ $.Email }}" class="inline-flex">
                    <button type="submit"
                            title="Remove {{ .Speaker.Name }} from this talk"
                            onclick="return confirm('Remove {{ .Speaker.Name }} from this talk?');"
                            class="dashboard-speaker-chip__remove">
                      &times;
                    </button>
                  </form>
                  {{ end }}
                </span>
                {{ end }}
                {{ end }}
              </div>
              {{ end }}

              <div class="mt-2 flex flex-wrap items-center gap-3">
                {{ if or (eq .Status "TheyDecline") (eq .Status "WeDecline") (eq .Status "Rejected") }}
                <a href="/dashboard/talks/{{ .ID }}/details?hr={{ $.HMAC }}&em={{ $.Email }}"
                   class="inline-flex items-center text-xs font-medium text-gray-600 hover:text-gray-900">
                  Talk details &rarr;
                </a>
                {{ else }}
                <a href="/dashboard/talks/{{ .ID }}/edit?hr={{ $.HMAC }}&em={{ $.Email }}"
                   class="inline-flex items-center text-xs font-medium text-gray-600 hover:text-gray-900">
                  Edit talk &rarr;
                </a>
                {{ end }}
                {{/* Scheduled-status talks already had a cal invite
                     emailed (Accepted → Scheduled flip on the
                     proposals admin). Surface a backup "Add to
                     calendar" download so speakers who missed or
                     dismissed the invite email can pull a fresh
                     copy from the dashboard. AnchorOrID falls back
                     to the raw page ID when no clipart is set yet,
                     so the link works the moment a talk goes
                     Scheduled — admins don't need to upload art
                     first. */}}
                {{ if and (eq .Status "Scheduled") .ConfTalk }}
                {{ template "cal_picker" (dict
                  "Title"       .Title
                  "StartISO"    (rfc3339 .ConfTalk.Sched.Start)
                  "EndISO"      (rfc3339 .ConfTalk.Sched.End)
                  "Description" .Description
                  "Location"    (or (mapVenue .ConfTalk.Venue) $conf.Venue)
                  "ICSURL"      (printf "/%s/talk/%s/calendar.ics" $conf.Tag .ConfTalk.AnchorOrID)
                ) }}
                {{ end }}
                {{ if and (and $conf $conf.CanInvite) (not (or (eq .Status "TheyDecline") (eq .Status "WeDecline") (eq .Status "Rejected"))) }}
                <a href="/dashboard/invite/{{ .ID }}?hr={{ $.HMAC }}&em={{ $.Email }}"
                   class="inline-flex items-center text-xs font-medium text-indigo-600 hover:text-indigo-700">
                  Invite a co-speaker &rarr;
                </a>
                {{ end }}
                {{ if eq .Status "Invited" }}
                <form method="POST" action="/dashboard/talks/{{ .ID }}/accept?hr={{ $.HMAC }}&em={{ $.Email }}" class="inline">
                  <button type="submit"
                          class="dashboard-inline-action is-primary"
                          onclick="return confirm('Accept this invitation? Your talk will be added to the program and you''ll be on the public agenda.');">
                    Accept invitation
                  </button>
                </form>
                <form method="POST" action="/dashboard/talks/{{ .ID }}/decline?hr={{ $.HMAC }}&em={{ $.Email }}" class="inline">
                  <button type="submit"
                          class="dashboard-inline-action"
                          onclick="return confirm('Decline this invitation? Your talk will not be added to the program and your co-speakers (if any) will be notified.');">
                    Decline invite
                  </button>
                </form>
                {{ end }}
              </div>

              {{ if .ConfTalk }}
              <form class="dashboard-talk-resources" method="POST" enctype="multipart/form-data" action="/dashboard/talks/{{ .ID }}/resources?hr={{ $.HMAC }}&em={{ $.Email }}">
                <div class="dashboard-talk-resources__head">
                  <span>Talk resources</span>
                  <small>Add public links for the agenda and speaker archive.</small>
                </div>
                <label>
                  <span>GitHub repo</span>
                  <input type="url" name="GithubRepoURL" value="{{ .ConfTalk.GithubRepoURL }}" placeholder="https://github.com/org/repo">
                </label>
                <label>
                  <span>Slides link</span>
                  {{ if .ConfTalk.SlidesURL }}
                  <a href="{{ .ConfTalk.SlidesURL | safeURL }}" target="_blank" rel="noopener noreferrer">View current slides</a>
                  {{ else }}
                  <input type="url" name="SlidesURL" value="{{ .ConfTalk.SlidesURL }}" placeholder="https://example.com/slides.pdf">
                  {{ end }}
                </label>
                {{ if .ConfTalk.SlidesURL }}
                <label class="dashboard-talk-resources__remove">
                  <span>Remove slides</span>
                  <input type="checkbox" name="RemoveSlides" value="1">
                </label>
                {{ else }}
                <label>
                  <span>Upload slides</span>
                  <input type="file" name="SlidesFile" accept=".pdf,.ppt,.pptx,.key,.odp">
                </label>
                {{ end }}
                <div class="dashboard-talk-resources__actions">
                  {{ if .ConfTalk.GithubRepoURL }}<a href="{{ .ConfTalk.GithubRepoURL | safeURL }}" target="_blank" rel="noopener noreferrer">View repo</a>{{ end }}
                  <button type="submit" class="dashboard-inline-action is-primary">Save resources</button>
                </div>
              </form>
              {{ end }}
            </div>
          </article>
          {{ end }}
        </div>
      </div>
      {{ else if $conf.TalksOpen }}
      <div id="talks-{{ $conf.Tag }}" class="dashboard-ledger-section">
        <a href="/talk/{{ $conf.Tag }}?hr={{ $.HMAC }}&em={{ $.Email }}"
           class="inline-flex items-center text-sm font-medium text-indigo-600 hover:text-indigo-700">
          + Propose a talk for {{ $conf.Desc }}
        </a>
      </div>
      {{ end }}

      {{ if $eb.SatelliteEvents }}
      <div id="satellites-{{ $conf.Tag }}" class="dashboard-ledger-section dashboard-satellite-ledger">
        <h3>§ Satellite events</h3>
        <ul class="space-y-2">
          {{ range $eb.SatelliteEvents }}
          <li class="flex items-center justify-between gap-3 rounded-md bg-gray-50/50 border border-gray-100 px-3 py-2">
            <div class="min-w-0">
              <p class="text-sm font-medium text-gray-900 truncate">{{ .Title }}</p>
              <div class="mt-1 flex flex-wrap items-center gap-2">
                {{ if eq .Status "published" }}
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">published</span>
                {{ else if eq .Status "submitted" }}
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">submitted</span>
                {{ else }}
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">draft</span>
                {{ end }}
                {{ $satTime := satelliteTimeLabel . $conf }}{{ if $satTime }}<span class="text-xs text-gray-500">{{ $satTime }}</span>{{ end }}
              </div>
            </div>
            <a href="/dashboard/satellites/{{ .ID }}/edit?hr={{ $.HMAC }}&em={{ $.Email }}"
               class="shrink-0 inline-flex items-center px-3 py-1.5 rounded-md text-xs font-semibold text-indigo-700 bg-indigo-50 hover:bg-indigo-100">
              Edit
            </a>
          </li>
          {{ end }}
        </ul>
      </div>
      {{ end }}

      {{/* ---- Volunteer ---- */}}
      {{ if $eb.VolApp }}
      {{ $vol := $eb.VolApp }}
      <div id="volunteer-{{ $conf.Tag }}" class="dashboard-ledger-section dashboard-volunteer-ledger">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-500">Volunteer</h3>
          {{ if eq $vol.Status "Waitlist" }}
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">Waitlist</span>
          {{ else if eq $vol.Status "Accepted" }}
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Accepted</span>
          {{ else if eq $vol.Status "PendingShifts" }}
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">Select shifts</span>
          {{ else if eq $vol.Status "Scheduled" }}
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Scheduled</span>
          {{ else if eq $vol.Status "Declined" }}
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">Declined</span>
          {{ else }}
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">{{ $vol.Status }}</span>
          {{ end }}
        </div>

        {{ if and (eq $vol.Status "Scheduled") $eb.VolInfo }}
        {{ $vinfo := $eb.VolInfo }}
        <div class="rounded-lg bg-indigo-50 border border-indigo-200 px-4 py-4 mb-3">
          <div class="flex items-start justify-between">
            <div>
              <h4 class="text-sm font-semibold text-indigo-900">Volunteer Orientation</h4>
              {{ if $vinfo.OrientTimes }}
              <p class="mt-1 text-sm text-indigo-800">{{ $vinfo.OrientTimes.FmtRange }}</p>
              {{ else }}
              <p class="mt-1 text-sm text-indigo-700">Time TBD - check back soon!</p>
              {{ end }}
              {{ if $vinfo.Notes }}
              <p class="mt-1 text-xs text-indigo-700">{{ $vinfo.Notes }}</p>
              {{ end }}
            </div>
            {{ if $vinfo.OrientLink }}
            <a href="{{ $vinfo.OrientLink }}" target="_blank" rel="noopener noreferrer"
               class="ml-4 shrink-0 inline-flex items-center px-3 py-2 border border-transparent text-xs font-medium rounded-md shadow-sm text-white bg-green-600 hover:bg-green-700">
              Join Orientation
            </a>
            {{ end }}
          </div>
        </div>
        {{ end }}

        {{ if and $vol.WorkShifts (ne $vol.Status "Declined") }}
        <div class="overflow-hidden rounded-lg border border-gray-200 mb-3">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Day</th>
                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Time</th>
                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Shift</th>
                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><span class="sr-only">Calendar</span></th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              {{ range $vol.WorkShifts }}
              <tr>
                <td class="px-4 py-2 whitespace-nowrap text-sm text-gray-900">{{ .DayOfDesc }}</td>
                <td class="px-4 py-2 whitespace-nowrap text-sm text-gray-500">{{ .TimeDesc }}</td>
                <td class="px-4 py-2 text-sm text-gray-900">
                  {{ .Name }}
                  {{ if .Type }}
                  <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600">{{ .Type.Title }}</span>
                  {{ end }}
                </td>
                <td class="px-4 py-2 whitespace-nowrap text-right">
                  {{ if and .ShiftTime .ShiftTime.End (isFuture .ShiftTime.Start) }}
                  {{ template "cal_picker" (dict
                    "Title"       (printf "vol shift @ btc++: %s" .Name)
                    "StartISO"    (rfc3339 .ShiftTime.Start)
                    "EndISO"      (rfc3339 .ShiftTime.End)
                    "Description" .TypeLongDesc
                    "Location"    $conf.Venue
                    "ICSURL"      (printf "/dashboard/vol/%s/calendar.ics?hr=%s&em=%s" .Ref $.HMAC $.Email)
                    "Compact"     true
                  ) }}
                  {{ end }}
                </td>
              </tr>
              {{ end }}
            </tbody>
          </table>
        </div>
        {{ end }}

        <div class="dashboard-volunteer-actions">
          {{ if eq $vol.Status "PendingShifts" }}
          <a href="/vols/shift/{{ $conf.Tag }}?hr={{ $.HMAC }}&em={{ $.Email }}"
             class="dashboard-volunteer-button is-primary">Select your shifts</a>
          {{ else if eq $vol.Status "Scheduled" }}
          <a href="/vols/shift/{{ $conf.Tag }}?hr={{ $.HMAC }}&em={{ $.Email }}"
             class="dashboard-volunteer-button is-secondary">View/edit shifts</a>
          <a href="/ticket/{{ $vol.TicketRef }}/pdf?type=volunteer&conf={{ $conf.Ref }}"
             class="dashboard-volunteer-button is-secondary">Download volunteer ticket</a>
          {{ if $vol.WorkShifts }}
          <form method="POST" action="/dashboard/vol/{{ $conf.Tag }}/shifts/resend-invites?hr={{ $.HMAC }}&em={{ $.Email }}" class="inline">
            <button type="submit"
                    class="dashboard-volunteer-button is-secondary"
                    onclick="return confirm('Re-send the calendar invite emails for all your shifts at {{ $conf.Desc }}?');">
              Resend calendar invites
            </button>
          </form>
          {{ end }}
          {{ else if eq $vol.Status "Applied" }}
          <p class="text-sm text-gray-600">Your application has been received! Shift selection will open soon.</p>
          {{ else if eq $vol.Status "Waitlist" }}
          <p class="text-sm text-gray-600">We're currently out of available shifts. We'll email you if a spot opens up.</p>
          {{ else if eq $vol.Status "Declined" }}
          <p class="text-sm text-gray-600">You've let us know you can't attend. Thanks for letting us know!</p>
          {{ else }}
          <a href="/vols/shift/{{ $conf.Tag }}?hr={{ $.HMAC }}&em={{ $.Email }}"
             class="dashboard-volunteer-button is-primary">Sign up for shifts</a>
          {{ end }}

          {{ if ne $vol.Status "Declined" }}
          <form method="POST" action="/vols/shift/{{ $conf.Tag }}/decline?hr={{ $.HMAC }}&em={{ $.Email }}" class="inline">
            <button type="submit"
                    class="dashboard-volunteer-button is-danger"
                    onclick="return confirm('Let us know you can no longer attend? This will release any shifts you signed up for.')">Can't attend</button>
          </form>
          {{ end }}
        </div>
        {{ if and (eq $vol.Status "Scheduled") $conf.WithinTwoWeeks }}
        <p class="mt-2 text-xs text-gray-500">You're scheduled and we're within two weeks of the conference. If you can no longer attend, please reach out: <a href="mailto:volunteer@btcpp.dev" class="text-indigo-600 hover:text-indigo-500">volunteer@btcpp.dev</a>.</p>
        {{ end }}
      </div>
      {{ end }}

      {{/* ---- Volunteer signup CTA: shown when the user has no
           VolApp for this conf yet and the conf is still upcoming.
           Pre-fills Name / Phone / Email / Signal / Twitter / Nostr
           from the user's Speakers row via the hr+em query params
           the dashboard already mints for other magic-link CTAs.
      */}}
      {{ if and (not $eb.VolApp) $conf.VolunteerOpen }}
      <div id="volunteer-{{ $conf.Tag }}" class="dashboard-ledger-section dashboard-volunteer-ledger">
        <div class="dashboard-volunteer-open">
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-500">Volunteer</h3>
            <p>Shifts are open for this edition.</p>
          </div>
          <a href="/volunteer/{{ $conf.Tag }}?hr={{ $.HMAC }}&em={{ $.Email }}"
             class="dashboard-volunteer-button is-primary">
            Sign up for shifts
          </a>
        </div>
      </div>
      {{ end }}

    </div>
    {{ end }}
  </article>
  {{ end }}
</section>
{{ end }}

{{/* ---- Empty state ---- */}}
{{ if and (not .ActiveBlocks) (not .DiscoverConfs) }}
<section id="empty">
  <div class="dashboard-empty-card">
    <div class="dashboard-empty-card__body">
      <h3 class="text-base font-semibold text-gray-900">Nothing here yet</h3>
      <p class="mt-2 text-sm text-gray-600">We don't have any talk applications, volunteer signups, or tickets for this email. Want to get involved?</p>
      <div class="mt-4 flex justify-center gap-3 flex-wrap">
        <a href="/" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700">Pick a conf</a>
      </div>
    </div>
  </div>
</section>
{{ end }}

{{/* ---- Discover: per-event cards with hero image + 3 CTAs ----
     Same visual shape as the speaker EventBlocks above, just for
     confs the user has no existing relationship with. */}}
{{ if .DiscoverConfs }}
<section id="discover" class="dashboard-ledger-list">
  <h2 class="dashboard-section-label">§ Other upcoming events</h2>
  {{ range .DiscoverConfs }}
  {{ $conf := . }}
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <a href="/{{ $conf.Tag }}" class="block relative h-36 sm:h-40 group bg-gray-200">
      <picture>
        <source srcset="/static/img/{{ $conf.Tag }}/leading.avif" type="image/avif" />
        <img src="/static/img/{{ $conf.Tag }}/leading.png" alt="{{ $conf.Desc }}"
             class="absolute inset-0 w-full h-full object-cover" />
      </picture>
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 px-4 sm:px-6 pb-4 text-white">
        <div class="flex items-center gap-2">
          <span class="text-xl">{{ $conf.EmojiOrDefault }}</span>
          <h3 class="text-lg sm:text-xl font-bold">{{ $conf.Desc }}</h3>
        </div>
        <p class="text-xs sm:text-sm text-white/80">{{ $conf.DateDesc }}{{ if $conf.Location }} &middot; {{ $conf.Location }}{{ end }}</p>
      </div>
    </a>

    <div class="px-4 py-4 sm:px-6">
      <div class="dashboard-actions">
        <div class="dashboard-actions__head">
          <div>
            <h3>Available actions</h3>
            <p>Start here if you want to attend, speak, volunteer, or share this edition.</p>
          </div>
        </div>
        <div class="dashboard-action-grid">
          {{ if $.AffiliateCode }}
          <button type="button"
                  data-share-url="{{ $.BaseURI }}/{{ $conf.Tag }}?code={{ $.AffiliateCode.CodeName }}"
                  class="dashboard-action affiliate-share-btn">
            <span class="dashboard-action__label">Share affiliate link</span>
            <span class="dashboard-action__hint">Code {{ $.AffiliateCode.CodeName }}</span>
          </button>
          {{ else if $.HasAnyTicket }}
          <a href="/dashboard/affiliate" class="dashboard-action">
            <span class="dashboard-action__label">Create affiliate code</span>
            <span class="dashboard-action__hint">Share discounts and earn on ticket sales</span>
          </a>
          {{ end }}

          <a href="/{{ $conf.Tag }}#tickets" class="dashboard-action">
            <span class="dashboard-action__label">Buy a ticket</span>
            <span class="dashboard-action__hint">{{ $conf.DateDesc }}</span>
          </a>

          {{ if $conf.TalksOpen }}
          <a href="/talk/{{ $conf.Tag }}?hr={{ $.HMAC }}&em={{ $.Email }}" class="dashboard-action">
            <span class="dashboard-action__label">Apply to speak</span>
            <span class="dashboard-action__hint">Submit a talk, workshop, or panel</span>
          </a>
          {{ end }}

          {{ if $conf.VolunteerOpen }}
          <a href="/volunteer/{{ $conf.Tag }}?hr={{ $.HMAC }}&em={{ $.Email }}" class="dashboard-action">
            <span class="dashboard-action__label">Apply to volunteer</span>
            <span class="dashboard-action__hint">Help run the event</span>
          </a>
          {{ end }}
        </div>
      </div>
    </div>
  </div>
  {{ end }}
</section>
{{ end }}

{{ if .RecentShopOrders }}
<section id="purchases" class="dashboard-purchase-ledger">
  <div class="dashboard-purchase-ledger__head">
    <div class="dashboard-kicker">§ Purchases · {{ len .RecentShopOrders }}</div>
    <a href="/dashboard/orders?hr={{ .HMAC }}&em={{ .Email }}">view order history &rarr;</a>
  </div>
  <div class="dashboard-purchase-ledger__rows">
    {{ range .RecentShopOrders }}
