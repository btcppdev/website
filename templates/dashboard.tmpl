<!DOCTYPE html>
<html>
<head>
  <title>your bitcoin++ dashboard</title>
  {{ block "header" . }} {{ end }}
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>&#10024;</text></svg>">
</head>
<body>
  {{ block "mainnav" . }} {{ end }}
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">

      {{ if .FlashMessage }}
      <div class="mb-4 rounded-md bg-green-50 border border-green-200 px-4 py-3">
        <p class="text-sm text-green-800">{{ .FlashMessage }}</p>
      </div>
      {{ end }}
      {{ if .FlashError }}
      <div class="mb-4 rounded-md bg-red-50 border border-red-200 px-4 py-3">
        <p class="text-sm text-red-800">{{ .FlashError }}</p>
      </div>
      {{ end }}

      <section id="topline">
        <div class="overflow-hidden sm:rounded-lg bg-white shadow">
          <div class="px-4 py-5 sm:p-6">
            <h2 class="sr-only">Dashboard</h2>
            <div class="bg-white p-6">
              <div class="sm:flex sm:items-center sm:justify-between sm:gap-4">
                <div class="sm:flex sm:space-x-5 min-w-0">
                  <div class="shrink-0">
                    {{ if .Photo }}
                    <img src="{{ speakerPhoto .Photo }}" alt="{{ .Name }}"
                         class="mx-auto size-20 rounded-full object-cover bg-gray-50 ring-2 ring-white shadow" />
                    {{ else }}
                    <div class="mx-auto size-20 rounded-full bg-indigo-100 flex items-center justify-center">
                      <span class="text-3xl">&#128075;</span>
                    </div>
                    {{ end }}
                  </div>
                  <div class="mt-4 text-center sm:mt-0 sm:pt-1 sm:text-left min-w-0">
                    <p class="text-sm font-medium text-gray-600">Welcome back,</p>
                    <p class="text-xl font-bold text-gray-900 sm:text-2xl truncate">{{ .Name }}</p>
                    {{ if and .Hometown (ne .Hometown "unknown") }}
                    <p class="text-sm font-medium text-gray-600">From {{ .Hometown }}</p>
                    {{ end }}
                    {{ if .Speaker }}
                    <div class="mt-1 flex flex-wrap justify-center sm:justify-start items-center gap-x-3 gap-y-1 text-xs text-gray-600">
                      {{ if .Speaker.Email }}
                      <a href="mailto:{{ .Speaker.Email }}" class="hover:text-gray-900 truncate">{{ .Speaker.Email }}</a>
                      {{ end }}
                      {{ if .Speaker.Twitter.Handle }}
                      <a href="https://x.com/{{ .Speaker.Twitter.Handle }}" target="_blank" rel="noopener noreferrer" class="hover:text-gray-900">@{{ .Speaker.Twitter.Handle }}</a>
                      {{ end }}
                    </div>
                    {{ end }}
                  </div>
                </div>
                <div class="mt-4 sm:mt-0 flex justify-center sm:justify-end shrink-0 gap-2">
                  {{ if .Speaker }}
                  <a href="/dashboard/speaker?hr={{ .HMAC }}&em={{ .Email }}"
                     class="inline-flex items-center px-3 py-1.5 text-xs font-semibold rounded-md border border-gray-200 text-gray-700 hover:bg-gray-50">
                    Edit profile
                  </a>
                  {{ else }}
                  <a href="/dashboard/speaker?hr={{ .HMAC }}&em={{ .Email }}"
                     class="inline-flex items-center px-3 py-1.5 text-xs font-semibold rounded-md text-white bg-indigo-600 hover:bg-indigo-700">
                    + Create profile
                  </a>
                  {{ end }}
                  <form method="POST" action="/logout" class="inline">
                    <button type="submit"
                            class="inline-flex items-center px-3 py-1.5 text-xs font-semibold rounded-md border border-gray-200 text-gray-500 hover:bg-gray-50 hover:text-gray-700">
                      Sign out
                    </button>
                  </form>
                </div>
              </div>
            </div>
            <div class="grid grid-cols-2 divide-y divide-gray-200 border-t border-gray-200 bg-gray-50 sm:grid-cols-4 sm:divide-x sm:divide-y-0">
              <div class="px-6 py-5 text-center text-sm font-medium">
                <span class="text-gray-900">{{ .Stats.TalksApplied }}</span>
                <span class="text-gray-600">Talks submitted</span>
              </div>
              <div class="px-6 py-5 text-center text-sm font-medium">
                <span class="text-gray-900">{{ .Stats.TalksAccepted }}</span>
                <span class="text-gray-600">Talks accepted</span>
              </div>
              <div class="px-6 py-5 text-center text-sm font-medium">
                <span class="text-gray-900">{{ .Stats.ShiftsApplied }}</span>
                <span class="text-gray-600">Vol. confs</span>
              </div>
              <div class="px-6 py-5 text-center text-sm font-medium">
                <span class="text-gray-900">{{ .Stats.ShiftsBooked }}</span>
                <span class="text-gray-600">Shifts booked</span>
              </div>
            </div>
          </div>
        </div>
      </section>

{{/* ---- Affiliate ---- */}}
{{ if .HasAnyTicket }}
<section id="affiliate" class="mt-8">
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="px-4 py-5 sm:p-6">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h3 class="text-base font-semibold text-gray-900">Affiliate</h3>
          <p class="mt-1 text-sm text-gray-500">Mint your own discount code. Share it; bitcoin++ pays you a cut for every ticket sold via your link.</p>
        </div>
        {{ if .AffiliateCode }}
        <div class="flex items-center gap-2 shrink-0">
          <a href="/dashboard/affiliate/edit"
             class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-indigo-700">Update code</a>
          <form method="POST" action="/dashboard/affiliate/disable" class="inline">
            <button type="submit"
                    onclick="return confirm('Disable {{ .AffiliateCode.CodeName }}? Past redemption stats stay; the code stops working immediately.');"
                    class="inline-flex items-center rounded-md border border-gray-300 bg-white px-3 py-1.5 text-xs font-semibold text-gray-700 hover:bg-gray-50">Disable</button>
          </form>
        </div>
        {{ else }}
        <a href="/dashboard/affiliate/new"
           class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-indigo-700 shrink-0">Create code</a>
        {{ end }}
      </div>

      {{ if .AffiliateCode }}
      <div class="mt-4 flex flex-wrap items-baseline gap-2">
        <span class="text-xs text-gray-500">Your code:</span>
        <code class="inline-flex items-center rounded bg-gray-100 px-2 py-0.5 font-mono text-sm font-semibold text-gray-900">{{ .AffiliateCode.CodeName }}</code>
        <span class="text-xs text-gray-500">— buyer saves {{ .AffiliateCode.Amount }}% off</span>
      </div>
      {{ end }}

      {{ if .AffiliateStats }}
      <div class="mt-5 grid grid-cols-1 sm:grid-cols-3 gap-3">
        <div class="rounded-md border border-gray-200 px-4 py-3">
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Tickets sold</p>
          <p class="mt-1 text-2xl font-semibold text-gray-900">{{ .AffiliateStats.TicketsSold }}</p>
        </div>
        <div class="rounded-md border border-gray-200 px-4 py-3">
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Buyers saved</p>
          <p class="mt-1 text-2xl font-semibold text-green-700 font-mono">{{ satsBitcoin .AffiliateStats.SavedSats }} <span class="text-sm font-normal text-gray-500 font-sans">BTC</span></p>
        </div>
        <div class="rounded-md border border-gray-200 px-4 py-3">
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">You earned</p>
          <p class="mt-1 text-2xl font-semibold text-indigo-700 font-mono">{{ satsBitcoin .AffiliateStats.EarnedSats }} <span class="text-sm font-normal text-gray-500 font-sans">BTC</span></p>
        </div>
      </div>
      {{ end }}
    </div>
  </div>
</section>
{{ end }}

{{/*
  Per-event blocks: one section per conf the user has any relationship
  with (speaker, volunteer, ticket-holder). All applicable subsections
  render inside the block — talks, vol shift status, tickets, plus
  CTAs to buy more / apply / propose another.
*/}}
{{ if .ActiveBlocks }}
<section id="events" class="mt-8 space-y-6">
  {{ range .ActiveBlocks }}
  {{ $eb := . }}
  {{ $conf := .Conf }}
  <div class="bg-white shadow rounded-lg overflow-hidden">
    {{/* Hero band — uses the conf's leading image with a gradient
         scrim so the title text stays legible on any photo. Anchor
         takes the user to the public conf page. */}}
    <div class="relative">
      <a href="/{{ $conf.Tag }}" class="block relative h-36 sm:h-40 group bg-gray-200">
        <picture>
          <source srcset="/static/img/{{ $conf.Tag }}/leading.avif" type="image/avif" />
          <img src="/static/img/{{ $conf.Tag }}/leading.png" alt="{{ $conf.Desc }}"
               class="absolute inset-0 w-full h-full object-cover" />
        </picture>
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent"></div>
        <div class="absolute bottom-0 left-0 right-0 px-4 sm:px-6 pb-4 flex items-end justify-between gap-3 text-white">
          <div class="min-w-0">
            <div class="flex items-center gap-2">
              <span class="text-xl">{{ $conf.EmojiOrDefault }}</span>
              <h2 class="text-lg sm:text-xl font-bold truncate">{{ $conf.Desc }}</h2>
            </div>
            <p class="mt-0.5 text-xs sm:text-sm opacity-90">{{ $conf.DateDesc }} · {{ $conf.Location }}</p>
            <div class="conf-countdown-on-dark">{{ template "conf_countdown" $conf }}</div>
          </div>
          <span class="shrink-0 text-xs opacity-80 group-hover:opacity-100 hidden sm:inline">View conf &rarr;</span>
        </div>
      </a>
      {{ if $eb.AdminRole }}
      <a href="{{ if eq $eb.AdminRole "admin" }}/{{ $conf.Tag }}/admin{{ else }}/{{ $conf.Tag }}/volcoord{{ end }}"
         class="absolute top-2 right-2 inline-flex items-center gap-1 rounded-md bg-white/90 backdrop-blur px-2.5 py-1 text-xs font-semibold text-gray-900 shadow hover:bg-white">
        <span aria-hidden="true">🧜‍♂️</span>
        {{ if eq $eb.AdminRole "admin" }}Admin{{ else }}Vol coord{{ end }}
      </a>
      {{ end }}
    </div>

    {{ if or $eb.SpeakerConf $eb.VolApp $eb.Tickets $eb.CanBuy $.AffiliateCode }}
    <div class="px-4 py-5 sm:p-6">
      {{ if $.AffiliateCode }}
      <div class="flex items-center justify-between gap-2 mb-3 rounded-md bg-indigo-50 border border-indigo-200 px-3 py-2 text-xs">
        <span class="text-indigo-900 truncate">
          Share your <code class="font-mono font-semibold">{{ $.AffiliateCode.CodeName }}</code> link for {{ $conf.Desc }}
        </span>
        <button type="button"
                data-share-url="{{ $.BaseURI }}/{{ $conf.Tag }}?code={{ $.AffiliateCode.CodeName }}"
                class="affiliate-share-btn shrink-0 inline-flex items-center rounded-md bg-indigo-600 px-2.5 py-1 font-semibold text-white hover:bg-indigo-700">
          Copy link
        </button>
      </div>
      {{ end }}
      {{ if and $eb.SpeakerConf $conf.CanInvite }}
      <div class="flex justify-end -mt-2 mb-2">
        <a href="/dashboard/{{ $conf.Tag }}/edit?hr={{ $.HMAC }}&em={{ $.Email }}"
           class="text-xs font-medium text-gray-600 hover:text-gray-900">
          Edit speaker info &rarr;
        </a>
      </div>
      {{ end }}

      {{/* ---- Talks ---- */}}
      {{ if $eb.SpeakerConf }}
      <div class="mt-5">
        <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-3">Talks</h3>
        <div class="space-y-3">
          {{ range $eb.SpeakerConf.Proposals }}
          <article class="flex items-stretch gap-3 rounded-md border border-gray-100 bg-gray-50/50 p-3">
            {{ if and .ConfTalk .ConfTalk.Clipart }}
            <div class="shrink-0">
              <picture>
                <source srcset="{{ talkClipart .ConfTalk.ClipartAvif }}" type="image/avif" />
                <img src="{{ talkClipart .ConfTalk.Clipart }}" alt=""
                     class="size-16 rounded-md object-cover bg-gray-100 ring-1 ring-gray-200" />
              </picture>
            </div>
            {{ end }}

            <div class="min-w-0 flex-1 flex flex-col">
              <div class="flex items-start justify-between gap-2">
                <div class="min-w-0">
                  <p class="text-sm font-semibold text-gray-900 truncate">{{ .Title }}</p>
                  <p class="mt-0.5 text-xs text-gray-500">
                    {{ if .TalkType }}{{ .TalkType }}{{ end }}
                    {{ if .DesiredDuration }} &middot; {{ .DesiredDuration }} min{{ end }}
                  </p>
                </div>
                <div class="flex flex-col items-end gap-2 shrink-0">
                  <div class="flex items-center gap-2">
                    {{ if and .Recording .Recording.YTLink }}
                    <a href="{{ .Recording.YTLink }}" target="_blank" rel="noopener noreferrer"
                       title="Watch recording"
                       class="inline-flex items-center justify-center size-7 rounded-full bg-red-600 text-white hover:bg-red-700">
                      <svg viewBox="0 0 24 24" fill="currentColor" class="size-4"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                    </a>
                    {{ end }}
                    {{ if eq .Status "Applied" }}
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">Applied</span>
                    {{ else if eq .Status "InReview" }}
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">In review</span>
                    {{ else if eq .Status "Waitlisted" }}
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">Waitlisted</span>
                    {{ else if eq .Status "Invited" }}
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">Invited</span>
                    {{ else if eq .Status "Accepted" }}
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Accepted</span>
                    {{ else if eq .Status "TheyDecline" }}
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">Declined</span>
                    {{ else if or (eq .Status "WeDecline") (eq .Status "Rejected") }}
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">Not selected</span>
                    {{ else }}
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">{{ .Status }}</span>
                    {{ end }}
                  </div>
                  {{ if not (or (eq .Status "Accepted") (eq .Status "TheyDecline") (eq .Status "WeDecline") (eq .Status "Rejected")) }}
                  <form method="POST" action="/dashboard/talks/{{ .ID }}/withdraw?hr={{ $.HMAC }}&em={{ $.Email }}" class="inline">
                    <button type="submit"
                            class="inline-flex items-center px-2.5 py-1 border border-transparent text-xs font-medium rounded text-red-700 bg-red-100 hover:bg-red-200"
                            onclick="return confirm('Withdraw this talk? {{ if eq .TalkType "panel" }}You''ll be removed from the panel; the talk continues with the other speakers.{{ else }}This will withdraw the whole talk.{{ end }}');">
                      Withdraw Proposal
                    </button>
                  </form>
                  {{ end }}
                </div>
              </div>

              {{ if .Speakers }}
              {{ $proposal := . }}
              {{ $canEditSpeakers := and (and $conf $conf.CanInvite) (not (or (eq .Status "TheyDecline") (eq .Status "WeDecline") (eq .Status "Rejected"))) }}
              {{ $multi := gt (len .Speakers) 1 }}
              <div class="mt-2 flex flex-wrap items-center gap-1.5">
                {{ range .Speakers }}
                {{ if .Speaker }}
                <span class="inline-flex items-center gap-1.5 rounded-full bg-white border border-gray-200 pl-1 pr-2 py-0.5 text-xs text-gray-700">
                  <img src="{{ if .Speaker.Photo }}{{ speakerPhoto .Speaker.Photo }}{{ else }}/static/img/speaker-placeholder.png{{ end }}"
                       alt="{{ .Speaker.Name }}"
                       class="size-5 rounded-full object-cover bg-gray-100" />
                  <span class="truncate max-w-[10rem]">{{ .Speaker.Name }}</span>
                  {{ if and $canEditSpeakers (and $multi (ne .ID $eb.SpeakerConf.ID)) }}
                  <form method="POST" action="/dashboard/talks/{{ $proposal.ID }}/speakers/{{ .ID }}/remove?hr={{ $.HMAC }}&em={{ $.Email }}" class="inline-flex">
                    <button type="submit"
                            title="Remove {{ .Speaker.Name }} from this talk"
                            onclick="return confirm('Remove {{ .Speaker.Name }} from this talk?');"
                            class="ml-0.5 inline-flex items-center justify-center size-4 rounded-full text-gray-400 hover:text-red-700 hover:bg-red-100 leading-none">
                      &times;
                    </button>
                  </form>
                  {{ end }}
                </span>
                {{ end }}
                {{ end }}
              </div>
              {{ end }}

              <div class="mt-2 flex flex-wrap items-center gap-3">
                {{ if or (eq .Status "TheyDecline") (eq .Status "WeDecline") (eq .Status "Rejected") }}
                <a href="/dashboard/talks/{{ .ID }}/details?hr={{ $.HMAC }}&em={{ $.Email }}"
                   class="inline-flex items-center text-xs font-medium text-gray-600 hover:text-gray-900">
                  Talk details &rarr;
                </a>
                {{ else }}
                <a href="/dashboard/talks/{{ .ID }}/edit?hr={{ $.HMAC }}&em={{ $.Email }}"
                   class="inline-flex items-center text-xs font-medium text-gray-600 hover:text-gray-900">
                  Edit talk &rarr;
                </a>
                {{ end }}
                {{/* Scheduled-status talks already had a cal invite
                     emailed (Accepted → Scheduled flip on the
                     proposals admin). Surface a backup "Add to
                     calendar" download so speakers who missed or
                     dismissed the invite email can pull a fresh
                     copy from the dashboard. AnchorOrID falls back
                     to the raw page ID when no clipart is set yet,
                     so the link works the moment a talk goes
                     Scheduled — admins don't need to upload art
                     first. */}}
                {{ if and (eq .Status "Scheduled") .ConfTalk }}
                {{ template "cal_picker" (dict
                  "Title"       .Title
                  "StartISO"    (rfc3339 .ConfTalk.Sched.Start)
                  "EndISO"      (rfc3339 .ConfTalk.Sched.End)
                  "Description" .Description
                  "Location"    (or (mapVenue .ConfTalk.Venue) $conf.Venue)
                  "ICSURL"      (printf "/%s/talk/%s/calendar.ics" $conf.Tag .ConfTalk.AnchorOrID)
                ) }}
                {{ end }}
                {{ if and (and $conf $conf.CanInvite) (not (or (eq .Status "TheyDecline") (eq .Status "WeDecline") (eq .Status "Rejected"))) }}
                <a href="/dashboard/invite/{{ .ID }}?hr={{ $.HMAC }}&em={{ $.Email }}"
                   class="inline-flex items-center text-xs font-medium text-indigo-600 hover:text-indigo-700">
                  Invite a co-speaker &rarr;
                </a>
                {{ end }}
                {{ if eq .Status "Invited" }}
                <form method="POST" action="/dashboard/talks/{{ .ID }}/accept?hr={{ $.HMAC }}&em={{ $.Email }}" class="inline">
                  <button type="submit"
                          class="inline-flex items-center px-2.5 py-1 border border-transparent text-xs font-medium rounded text-white bg-green-600 hover:bg-green-700"
                          onclick="return confirm('Accept this invitation? Your talk will be added to the program and you''ll be on the public agenda.');">
                    Accept invitation
                  </button>
                </form>
                <form method="POST" action="/dashboard/talks/{{ .ID }}/decline?hr={{ $.HMAC }}&em={{ $.Email }}" class="inline">
                  <button type="submit"
                          class="inline-flex items-center px-2.5 py-1 border border-gray-300 text-xs font-medium rounded text-gray-700 bg-white hover:bg-gray-50"
                          onclick="return confirm('Decline this invitation? Your talk will not be added to the program and your co-speakers (if any) will be notified.');">
                    Decline invite
                  </button>
                </form>
                {{ end }}
              </div>
            </div>
          </article>
          {{ end }}
        </div>
        {{ if $conf.TalksOpen }}
        <div class="mt-3 text-right">
          <a href="/talk/{{ $conf.Tag }}?hr={{ $.HMAC }}&em={{ $.Email }}"
             class="inline-flex items-center text-xs font-medium text-indigo-600 hover:text-indigo-700">
            + Propose another talk
          </a>
        </div>
        {{ end }}
      </div>
      {{ else if $conf.TalksOpen }}
      <div class="mt-5">
        <a href="/talk/{{ $conf.Tag }}?hr={{ $.HMAC }}&em={{ $.Email }}"
           class="inline-flex items-center text-sm font-medium text-indigo-600 hover:text-indigo-700">
          + Propose a talk for {{ $conf.Desc }}
        </a>
      </div>
      {{ end }}

      {{/* ---- Volunteer ---- */}}
      {{ if $eb.VolApp }}
      {{ $vol := $eb.VolApp }}
      <div class="mt-5">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-500">Volunteer</h3>
          {{ if eq $vol.Status "Waitlist" }}
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">Waitlist</span>
          {{ else if eq $vol.Status "Accepted" }}
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Accepted</span>
          {{ else if eq $vol.Status "PendingShifts" }}
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">Select shifts</span>
          {{ else if eq $vol.Status "Scheduled" }}
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Scheduled</span>
          {{ else if eq $vol.Status "Declined" }}
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">Declined</span>
          {{ else }}
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">{{ $vol.Status }}</span>
          {{ end }}
        </div>

        {{ if and (eq $vol.Status "Scheduled") $eb.VolInfo }}
        {{ $vinfo := $eb.VolInfo }}
        <div class="rounded-lg bg-indigo-50 border border-indigo-200 px-4 py-4 mb-3">
          <div class="flex items-start justify-between">
            <div>
              <h4 class="text-sm font-semibold text-indigo-900">Volunteer Orientation</h4>
              {{ if $vinfo.OrientTimes }}
              <p class="mt-1 text-sm text-indigo-800">{{ $vinfo.OrientTimes.FmtRange }}</p>
              {{ else }}
              <p class="mt-1 text-sm text-indigo-700">Time TBD - check back soon!</p>
              {{ end }}
              {{ if $vinfo.Notes }}
              <p class="mt-1 text-xs text-indigo-700">{{ $vinfo.Notes }}</p>
              {{ end }}
            </div>
            {{ if $vinfo.OrientLink }}
            <a href="{{ $vinfo.OrientLink }}" target="_blank" rel="noopener noreferrer"
               class="ml-4 shrink-0 inline-flex items-center px-3 py-2 border border-transparent text-xs font-medium rounded-md shadow-sm text-white bg-green-600 hover:bg-green-700">
              Join Orientation
            </a>
            {{ end }}
          </div>
        </div>
        {{ end }}

        {{ if and $vol.WorkShifts (ne $vol.Status "Declined") }}
        <div class="overflow-hidden rounded-lg border border-gray-200 mb-3">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Day</th>
                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Time</th>
                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Shift</th>
                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider"><span class="sr-only">Calendar</span></th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              {{ range $vol.WorkShifts }}
              <tr>
                <td class="px-4 py-2 whitespace-nowrap text-sm text-gray-900">{{ .DayOfDesc }}</td>
                <td class="px-4 py-2 whitespace-nowrap text-sm text-gray-500">{{ .TimeDesc }}</td>
                <td class="px-4 py-2 text-sm text-gray-900">
                  {{ .Name }}
                  {{ if .Type }}
                  <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600">{{ .Type.Title }}</span>
                  {{ end }}
                </td>
                <td class="px-4 py-2 whitespace-nowrap text-right">
                  {{ if and .ShiftTime .ShiftTime.End (isFuture .ShiftTime.Start) }}
                  {{ template "cal_picker" (dict
                    "Title"       (printf "vol shift @ btc++: %s" .Name)
                    "StartISO"    (rfc3339 .ShiftTime.Start)
                    "EndISO"      (rfc3339 .ShiftTime.End)
                    "Description" .TypeLongDesc
                    "Location"    $conf.Venue
                    "ICSURL"      (printf "/dashboard/vol/%s/calendar.ics?hr=%s&em=%s" .Ref $.HMAC $.Email)
                    "Compact"     true
                  ) }}
                  {{ end }}
                </td>
              </tr>
              {{ end }}
            </tbody>
          </table>
        </div>
        {{ end }}

        <div class="flex flex-wrap items-center gap-3">
          {{ if eq $vol.Status "PendingShifts" }}
          <a href="/vols/shift/{{ $conf.Tag }}?hr={{ $.HMAC }}&em={{ $.Email }}"
             class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700">Select your shifts</a>
          {{ else if eq $vol.Status "Scheduled" }}
          <a href="/vols/shift/{{ $conf.Tag }}?hr={{ $.HMAC }}&em={{ $.Email }}"
             class="inline-flex items-center px-3 py-1.5 border border-gray-300 text-xs font-medium rounded text-gray-700 bg-white hover:bg-gray-50">View/edit shifts</a>
          <a href="/ticket/{{ $vol.TicketRef }}/pdf?type=volunteer&conf={{ $conf.Ref }}"
             class="inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded text-orange-700 bg-orange-100 hover:bg-orange-200">Download volunteer ticket</a>
          {{ if $vol.WorkShifts }}
          <form method="POST" action="/dashboard/vol/{{ $conf.Tag }}/shifts/resend-invites?hr={{ $.HMAC }}&em={{ $.Email }}" class="inline">
            <button type="submit"
                    class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium rounded text-white bg-teal-600 hover:bg-teal-700"
                    onclick="return confirm('Re-send the calendar invite emails for all your shifts at {{ $conf.Desc }}?');">
              📅 Resend Cal Invites for Shifts
            </button>
          </form>
          {{ end }}
          {{ else if eq $vol.Status "Applied" }}
          <p class="text-sm text-gray-600">Your application has been received! Shift selection will open soon.</p>
          {{ else if eq $vol.Status "Waitlist" }}
          <p class="text-sm text-gray-600">We're currently out of available shifts. We'll email you if a spot opens up.</p>
          {{ else if eq $vol.Status "Declined" }}
          <p class="text-sm text-gray-600">You've let us know you can't attend. Thanks for letting us know!</p>
          {{ else }}
          <a href="/vols/shift/{{ $conf.Tag }}?hr={{ $.HMAC }}&em={{ $.Email }}"
             class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md shadow-sm text-gray-700 bg-white hover:bg-gray-50">Sign up for shifts</a>
          {{ end }}

          {{ if ne $vol.Status "Declined" }}
          <form method="POST" action="/vols/shift/{{ $conf.Tag }}/decline?hr={{ $.HMAC }}&em={{ $.Email }}" class="inline">
            <button type="submit"
                    class="inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded text-red-700 bg-red-100 hover:bg-red-200"
                    onclick="return confirm('Let us know you can no longer attend? This will release any shifts you signed up for.')">Can't attend</button>
          </form>
          {{ end }}
        </div>
        {{ if and (eq $vol.Status "Scheduled") $conf.WithinTwoWeeks }}
        <p class="mt-2 text-xs text-gray-500">You're scheduled and we're within two weeks of the conference. If you can no longer attend, please reach out: <a href="mailto:volunteer@btcpp.dev" class="text-indigo-600 hover:text-indigo-500">volunteer@btcpp.dev</a>.</p>
        {{ end }}
      </div>
      {{ end }}

      {{/* ---- Volunteer signup CTA: shown when the user has no
           VolApp for this conf yet and the conf is still upcoming.
           Pre-fills Name / Phone / Email / Signal / Twitter / Nostr
           from the user's Speakers row via the hr+em query params
           the dashboard already mints for other magic-link CTAs.
      */}}
      {{ if and (not $eb.VolApp) $conf.VolunteerOpen }}
      <div class="mt-5">
        <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-3">Volunteer</h3>
        <a href="/volunteer/{{ $conf.Tag }}?hr={{ $.HMAC }}&em={{ $.Email }}"
           class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-purple-600 hover:bg-purple-700">
          Sign up for volunteer shifts
        </a>
      </div>
      {{ end }}

      {{/* ---- Tickets ---- */}}
      {{ if $eb.Tickets }}
      <div class="mt-5">
        <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-500 mb-3">Tickets</h3>
        <ul class="space-y-2">
          {{ range $eb.Tickets }}
          <li class="flex items-center justify-between gap-3 rounded-md bg-gray-50/50 border border-gray-100 px-3 py-2">
            <div class="min-w-0">
              <p class="text-sm font-medium text-gray-900 truncate">{{ if .Type }}{{ .Type }} ticket{{ else }}Ticket{{ end }}</p>
            </div>
            <a href="/ticket/{{ .RefID }}/pdf?type={{ .Type }}&conf={{ .ConfRef }}"
               class="shrink-0 inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded-md text-orange-700 bg-orange-100 hover:bg-orange-200">
              Download
            </a>
          </li>
          {{ end }}
        </ul>
      </div>
      {{ end }}

      {{/* ---- Buy more / get a ticket CTA ---- */}}
      {{ if $eb.CanBuy }}
      <div class="mt-5">
        <a href="/{{ $conf.Tag }}#tickets"
           class="inline-flex items-center text-sm font-medium text-orange-600 hover:text-orange-700">
          {{ if $eb.Tickets }}+ Buy another ticket{{ else }}+ Get a ticket{{ end }} for {{ $conf.Desc }} &rarr;
        </a>
      </div>
      {{ end }}

    </div>
    {{ end }}
  </div>
  {{ end }}
</section>
{{ end }}

{{/* ---- Empty state ---- */}}
{{ if and (not .ActiveBlocks) (not .DiscoverConfs) }}
<section id="empty" class="mt-8">
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="px-4 py-5 sm:p-6 text-center">
      <h3 class="text-base font-semibold text-gray-900">Nothing here yet</h3>
      <p class="mt-2 text-sm text-gray-600">We don't have any talk applications, volunteer signups, or tickets for this email. Want to get involved?</p>
      <div class="mt-4 flex justify-center gap-3 flex-wrap">
        <a href="/" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700">Pick a conf</a>
      </div>
    </div>
  </div>
</section>
{{ end }}

{{/* ---- Discover: per-event cards with hero image + 3 CTAs ----
     Same visual shape as the speaker EventBlocks above, just for
     confs the user has no existing relationship with. */}}
{{ if .DiscoverConfs }}
<section id="discover" class="mt-8 space-y-6">
  <h2 class="text-lg font-semibold text-gray-900">Other upcoming events</h2>
  {{ range .DiscoverConfs }}
  {{ $conf := . }}
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <a href="/{{ $conf.Tag }}" class="block relative h-36 sm:h-40 group bg-gray-200">
      <picture>
        <source srcset="/static/img/{{ $conf.Tag }}/leading.avif" type="image/avif" />
        <img src="/static/img/{{ $conf.Tag }}/leading.png" alt="{{ $conf.Desc }}"
             class="absolute inset-0 w-full h-full object-cover" />
      </picture>
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent"></div>
      <div class="absolute bottom-0 left-0 right-0 px-4 sm:px-6 pb-4 text-white">
        <div class="flex items-center gap-2">
          <span class="text-xl">{{ $conf.EmojiOrDefault }}</span>
          <h3 class="text-lg sm:text-xl font-bold">{{ $conf.Desc }}</h3>
        </div>
        <p class="text-xs sm:text-sm text-white/80">{{ $conf.DateDesc }}{{ if $conf.Location }} &middot; {{ $conf.Location }}{{ end }}</p>
      </div>
    </a>

    {{ if $.AffiliateCode }}
    <div class="px-4 pt-4 sm:px-6">
      <div class="flex items-center justify-between gap-2 rounded-md bg-indigo-50 border border-indigo-200 px-3 py-2 text-xs">
        <span class="text-indigo-900 truncate">
          Share your <code class="font-mono font-semibold">{{ $.AffiliateCode.CodeName }}</code> link for {{ $conf.Desc }}
        </span>
        <button type="button"
                data-share-url="{{ $.BaseURI }}/{{ $conf.Tag }}?code={{ $.AffiliateCode.CodeName }}"
                class="affiliate-share-btn shrink-0 inline-flex items-center rounded-md bg-indigo-600 px-2.5 py-1 font-semibold text-white hover:bg-indigo-700">
          Copy link
        </button>
      </div>
    </div>
    {{ end }}

    <div class="px-4 py-4 sm:px-6 flex flex-wrap gap-2">
      <a href="/{{ $conf.Tag }}#tickets"
         class="inline-flex items-center px-3 py-1.5 rounded-md text-xs font-semibold text-white bg-orange-600 hover:bg-orange-700">
        Get a ticket
      </a>
      {{ if $conf.TalksOpen }}
      <a href="/talk/{{ $conf.Tag }}?hr={{ $.HMAC }}&em={{ $.Email }}"
         class="inline-flex items-center px-3 py-1.5 rounded-md text-xs font-semibold text-white bg-indigo-600 hover:bg-indigo-700">
        Apply to speak
      </a>
      {{ else }}
      <span title="Talk applications have closed for this event"
            class="inline-flex items-center px-3 py-1.5 rounded-md text-xs font-semibold text-gray-400 bg-gray-100 cursor-not-allowed">
        Apply to speak
      </span>
      {{ end }}
      {{ if $conf.VolunteerOpen }}
        <a href="/volunteer/{{ $conf.Tag }}?hr={{ $.HMAC }}&em={{ $.Email }}"
           class="inline-flex items-center px-3 py-1.5 rounded-md text-xs font-semibold text-gray-700 bg-gray-100 hover:bg-gray-200">
          Apply to volunteer
        </a>
      {{ end }}
    </div>
  </div>
  {{ end }}
</section>
{{ end }}

{{/* ---- Past conferences ---- */}}
{{ if .PastBlocks }}
<section id="past" class="mt-8">
  <details class="bg-white shadow rounded-lg overflow-hidden">
    <summary class="cursor-pointer px-4 py-3 sm:px-6 text-sm font-semibold text-gray-700 hover:bg-gray-50 flex items-center justify-between">
      <span>Past conferences ({{ len .PastBlocks }})</span>
      <span class="text-xs text-gray-400">click to expand</span>
    </summary>
    <div class="border-t border-gray-200 divide-y divide-gray-100">
      {{ range .PastBlocks }}
      {{ $eb := . }}
      {{ $conf := .Conf }}
      <div class="px-4 py-4 sm:px-6">
        <div class="flex items-start justify-between gap-4">
          <div class="flex items-start space-x-3 min-w-0">
            <div class="text-2xl">{{ $conf.EmojiOrDefault }}</div>
            <div class="min-w-0">
              <p class="text-sm font-medium text-gray-900">{{ $conf.Desc }}</p>
              <p class="text-xs text-gray-500">{{ $conf.DateDesc }} - {{ $conf.Location }}</p>
              {{ if $eb.SpeakerConf }}
              <ul class="mt-2 space-y-1">
                {{ range $eb.SpeakerConf.Proposals }}
                <li class="text-xs text-gray-600">
                  <span class="font-medium text-gray-800">{{ .Title }}</span>
                  {{ if eq .Status "Accepted" }}
                  <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Accepted</span>
                  {{ else if eq .Status "TheyDecline" }}
                  <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">Declined</span>
                  {{ else if or (eq .Status "WeDecline") (eq .Status "Rejected") }}
                  <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">Not selected</span>
                  {{ else }}
                  <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">{{ .Status }}</span>
                  {{ end }}
                  {{ if and .Recording .Recording.YTLink }}
                  <a href="{{ .Recording.YTLink }}" target="_blank" rel="noopener noreferrer"
                     title="Watch recording"
                     class="ml-2 inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-medium bg-red-600 text-white hover:bg-red-700">
                    <svg viewBox="0 0 24 24" fill="currentColor" class="size-3.5"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                    <span class="hidden sm:inline">Watch</span>
                  </a>
                  {{ end }}
                </li>
                {{ end }}
              </ul>
              {{ end }}
            </div>
          </div>
          <div class="shrink-0 flex flex-col items-end gap-1 text-xs text-gray-400">
            {{ if $eb.SpeakerConf }}<span>speaker</span>{{ end }}
            {{ if $eb.VolApp }}<span>volunteer</span>{{ end }}
            {{ if $eb.Tickets }}<span>{{ len $eb.Tickets }} ticket{{ if gt (len $eb.Tickets) 1 }}s{{ end }}</span>{{ end }}
          </div>
        </div>
      </div>
      {{ end }}
    </div>
  </details>
</section>
{{ end }}

{{ if .IsGlobalAdmin }}
<section id="global-admin-tools" class="mt-8">
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="px-4 py-5 sm:p-6">
      <div class="flex items-center justify-between gap-4">
        <div>
          <h3 class="text-sm font-semibold text-gray-900">Global admin tools</h3>
          <p class="mt-1 text-xs text-gray-500">Manage site-wide newsletter templates and admin-only infrastructure.</p>
        </div>
        <span class="inline-flex items-center rounded-full bg-amber-100 text-amber-800 px-2 py-0.5 text-xs font-medium">global-admin</span>
      </div>
      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        <a href="/admin" class="block rounded-md border border-gray-200 px-4 py-3 hover:border-indigo-300 hover:bg-indigo-50">
          <div class="text-sm font-medium text-gray-900">Global admin dashboard</div>
          <div class="mt-1 text-xs text-gray-500">Manage templated newsletters, organizations, and global permissions.</div>
        </a>
      </div>
    </div>
  </div>
</section>
{{ end }}

{{ if or .HasUpcomingTalk .HasUpcomingVol }}
<section id="contact" class="mt-8 mb-12">
  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="px-4 py-5 sm:p-6">
      <h3 class="text-sm font-medium text-gray-900">Need help?</h3>
      <p class="mt-1 text-sm text-gray-600">
        {{ if .HasUpcomingTalk }}
        Talk-related questions: <a href="mailto:speak@btcpp.dev" class="text-indigo-600 hover:text-indigo-500">speak@btcpp.dev</a><br>
        {{ end }}
        {{ if .HasUpcomingVol }}
        Volunteer questions: <a href="mailto:volunteer@btcpp.dev" class="text-indigo-600 hover:text-indigo-500">volunteer@btcpp.dev</a>
        {{ end }}
      </p>
    </div>
  </div>
</section>
{{ end }}

    </div>
  </div>
  {{ if .AffiliateCode }}
  <script>
    // Per-event-card "Copy link" buttons: click → copy the
    // affiliate share URL to the clipboard + briefly flash the
    // button to acknowledge. Each button carries its conf-scoped
    // share URL on data-share-url so we don't string-build at
    // click time.
    (function () {
      document.querySelectorAll('.affiliate-share-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          const url = btn.dataset.shareUrl;
          if (!url) return;
          const original = btn.textContent;
          navigator.clipboard.writeText(url).then(function () {
            btn.textContent = 'Copied!';
            btn.classList.add('bg-green-600');
            btn.classList.remove('bg-indigo-600', 'hover:bg-indigo-700');
            setTimeout(function () {
              btn.textContent = original;
              btn.classList.remove('bg-green-600');
              btn.classList.add('bg-indigo-600', 'hover:bg-indigo-700');
            }, 1500);
          }).catch(function () {
            btn.textContent = 'Copy failed';
            setTimeout(function () { btn.textContent = original; }, 1500);
          });
        });
      });
    })();
  </script>
  {{ end }}
</body>
</html>
