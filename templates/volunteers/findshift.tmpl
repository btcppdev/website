<!DOCTYPE html>
<html>
<head>
  <title>bitcoin++</title>
  {{ block "header" . }} {{ end }}
  <!-- FIXME: Show emoji that maps to the conf you're checking in for? -->
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>✨</text></svg>">
</head>
<body class="btcpp-admin-page h-full">
    {{ block "mainnav" . }} {{ end }}
    <!-- can i get tailwind to pick up these colors? -->
    <section id="check-in">
        <div class="flex flex-col" >
            <div class="pt-20 pb-20 sm:pt-20 grow-0">
                <div class="mx-auto max-w-7xl px-6 lg:px-8">
                    <div class="max-w-2xl text-start">
                        <form method="POST">
                            <input id="Email" 
                                type="email" 
                                name="Email" 
                                autocomplete="email"
                                placeholder="hello@example.com" 
                                required class="py-3 px-4 border-gray border-2 rounded-sm" />
                            <button class="mt-4 bg-black text-white hover:text-white-400 px-4 py-2 rounded-md" type="submit" >Enter</button>
                        </form> 
                    </div>
                </div>
            </div>
        </div>
    </section>
    {{ block "footer" . }} {{ end }}
</body>
</html>
