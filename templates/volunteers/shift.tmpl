<!DOCTYPE html>
<html>
  <head>
    <title>volunteer @ bitcoin++</title>
    {{ block "header" . }} {{ end }}
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>&#10024;</text></svg>">
  </head>
  <body class="btcpp-admin-page">
    {{ block "mainnav" . }} {{ end }}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-3xl">
            <section id="topline">
                <div class="overflow-hidden sm:rounded-lg bg-white shadow">
                    <div class="px-4 py-5 sm:p-6">
                        <h2 id="profile-overview-title" class="sr-only">Volunteer Dashboard</h2>
                        <div class="bg-white p-6">
                            <div class="sm:flex sm:items-center sm:justify-between">
                                <div class="sm:flex sm:space-x-5">
                                    <div class="shrink-0">
                                        <div class="mx-auto size-20 rounded-full bg-indigo-100 flex items-center justify-center">
                                            <span class="text-3xl">&#128075;</span>
                                        </div>
                                    </div>
                                    <div class="mt-4 text-center sm:mt-0 sm:pt-1 sm:text-left">
                                        <p class="text-sm font-medium text-gray-600">Welcome back,</p>
                                        <p class="text-xl font-bold text-gray-900 sm:text-2xl">{{ .Name }}</p>
                                        <p class="text-sm font-medium text-gray-600">Traveling from {{ .Hometown }}</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="grid grid-cols-1 divide-y divide-gray-200 border-t border-gray-200 bg-gray-50 sm:grid-cols-4 sm:divide-x sm:divide-y-0">
                            <div class="px-6 py-5 text-center text-sm font-medium">
                                <span class="text-gray-900">{{ .Stats.Applied }}</span>
                                <span class="text-gray-600">Confs Applied</span>
                            </div>
                            <div class="px-6 py-5 text-center text-sm font-medium">
                                <span class="text-gray-900">{{ .Stats.Pending }}</span>
                                <span class="text-gray-600">Pending</span>
                            </div>
                            <div class="px-6 py-5 text-center text-sm font-medium">
                                <span class="text-gray-900">{{ .Stats.Accepted }}</span>
                                <span class="text-gray-600">Accepted</span>
                            </div>
                            <div class="px-6 py-5 text-center text-sm font-medium">
                                <span class="text-gray-900">{{ .Stats.TotalShifts }}</span>
                                <span class="text-gray-600">Total Shifts</span>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section id="applications" class="mt-8">
                <h2 class="text-lg font-semibold text-gray-900 mb-4">Your Volunteer Applications</h2>
                <div class="space-y-4">
                    {{ range .VolApps }}
                    {{ $conf := index .ScheduleFor 0 }}
                    <div class="bg-white shadow rounded-lg overflow-hidden">
                        <div class="px-4 py-5 sm:p-6">
                            <div class="flex items-center justify-between">
                                <div class="flex items-center space-x-4">
                                    <div class="text-3xl">{{ $conf.Emoji }}</div>
                                    <div>
                                        <h3 class="text-sm font-medium text-gray-900">{{ $conf.Desc }}</h3>
                                        <p class="text-sm text-gray-500">{{ $conf.DateDesc }} - {{ $conf.Location }}</p>
                                    </div>
                                </div>
                                <div class="flex items-center space-x-4">
                                    <!-- Status Badge -->
                                    {{ if eq .Status "Waitlist" }}
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                                        Waitlist
                                    </span>
                                    {{ else if eq .Status "Accepted" }}
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                        Accepted
                                    </span>
                                    {{ else if eq .Status "PendingShifts" }}
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                        Select Shifts
                                    </span>
                                    {{ else if eq .Status "Scheduled" }}
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                        Scheduled
                                    </span>
                                    {{ else if eq .Status "Declined" }}
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                        Declined
                                    </span>
                                    {{ else }}
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                                        {{ .Status }}
                                    </span>
                                    {{ end }}
                                </div>
                            </div>

                            <!-- Orientation Info (Scheduled only) -->
                            {{ if eq .Status "Scheduled" }}
                            {{ $vinfo := index $.VolInfos $conf.Tag }}
                            {{ if $vinfo }}
                            <div class="mt-4 border-t border-gray-200 pt-4">
                                <div class="rounded-lg bg-indigo-50 border border-indigo-200 px-4 py-4">
                                    <div class="flex items-start justify-between">
                                        <div>
                                            <h4 class="text-sm font-semibold text-indigo-900">Volunteer Orientation</h4>
                                            {{ if $vinfo.OrientTimes }}
                                            <p class="mt-1 text-sm text-indigo-800">{{ $vinfo.OrientTimes.FmtRange }}</p>
                                            {{ else }}
                                            <p class="mt-1 text-sm text-indigo-700">Time TBD - check back soon!</p>
                                            {{ end }}
                                            {{ if $vinfo.Notes }}
                                            <p class="mt-1 text-xs text-indigo-700">{{ $vinfo.Notes }}</p>
                                            {{ end }}
                                        </div>
                                        {{ if $vinfo.OrientLink }}
                                        <a href="{{ $vinfo.OrientLink }}" target="_blank" rel="noopener noreferrer"
                                           class="ml-4 shrink-0 inline-flex items-center px-3 py-2 border border-transparent text-xs font-medium rounded-md shadow-sm text-white bg-green-600 hover:bg-green-700">
                                            Join Orientation
                                        </a>
                                        {{ end }}
                                    </div>
                                </div>
                            </div>
                            {{ end }}
                            {{ end }}

                            <!-- Shifts Table -->
                            {{ if and .WorkShifts (ne .Status "Declined") }}
                            <div class="mt-4 border-t border-gray-200 pt-4">
                                <h4 class="text-sm font-medium text-gray-900 mb-3">Your Scheduled Shifts</h4>
                                <div class="overflow-hidden rounded-lg border border-gray-200">
                                    <table class="min-w-full divide-y divide-gray-200">
                                        <thead class="bg-gray-50">
                                            <tr>
                                                <th scope="col" class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Day</th>
                                                <th scope="col" class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Time</th>
                                                <th scope="col" class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Shift</th>
                                            </tr>
                                        </thead>
                                        <tbody class="bg-white divide-y divide-gray-200">
                                            {{ range .WorkShifts }}
                                            <tr>
                                                <td class="px-4 py-2 whitespace-nowrap text-sm text-gray-900">{{ .DayOfDesc }}</td>
                                                <td class="px-4 py-2 whitespace-nowrap text-sm text-gray-500">{{ .TimeDesc }}</td>
                                                <td class="px-4 py-2 text-sm text-gray-900">
                                                    {{ .Name }}
                                                    {{ if .Type }}
                                                    <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600">
                                                        {{ .Type.Title }}
                                                    </span>
                                                    {{ end }}
                                                </td>
                                            </tr>
                                            {{ end }}
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            {{ end }}

                            <!-- Action buttons based on status -->
                            <div class="mt-4">
                                <div class="flex flex-wrap items-center gap-3">
                                    {{ if eq .Status "PendingShifts" }}
                                    <a href="/vols/shift/{{ $conf.Tag }}?hr={{ $.HMAC }}&em={{ $.Email }}"
                                       class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700">
                                        Select Your Shifts
                                    </a>
                                    {{ else if eq .Status "Scheduled" }}
                                    <a href="/vols/shift/{{ $conf.Tag }}?hr={{ $.HMAC }}&em={{ $.Email }}"
                                       class="inline-flex items-center px-3 py-1.5 border border-gray-300 text-xs font-medium rounded text-gray-700 bg-white hover:bg-gray-50">
                                        View/Edit Shifts
                                    </a>
                                    <a href="/ticket/{{ .TicketRef }}?type=volunteer&conf={{ $conf.Ref }}"
                                       class="inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded text-orange-700 bg-orange-100 hover:bg-orange-200">
                                        Download Ticket
                                    </a>
                                    {{ else if eq .Status "Applied" }}
                                    <p class="text-sm text-gray-600">Your application has been accepted! Shift selection will open soon.</p>
                                    {{ else if eq .Status "Waitlist" }}
                                    <p class="text-sm text-gray-600">We're currently out of available shifts. We'll notify you by email if a spot opens up.</p>
                                    {{ else if eq .Status "Declined" }}
                                    <p class="text-sm text-gray-600">You've let us know you can't attend. Thanks for letting us know!</p>
                                    {{ else }}
                                    <a href="/vols/shift/{{ $conf.Tag }}?hr={{ $.HMAC }}&em={{ $.Email }}"
                                       class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md shadow-sm text-gray-700 bg-white hover:bg-gray-50">
                                        Sign Up for Shifts
                                    </a>
                                    {{ end }}

                                    {{ if ne .Status "Declined" }}
                                    {{ if and (eq .Status "Scheduled") $conf.WithinTwoWeeks }}
                                    <p class="text-sm text-gray-600">You're scheduled for shifts and we're within two weeks of the conference. If you can no longer attend, please reach out to the Volunteer coordinator or send us an email at 
                            <a href="mailto:volunteer@btcpp.dev" class="text-indigo-600 hover:text-indigo-500">volunteer@btcpp.dev</a>.
                                    {{ end }}
                                    <form method="POST" action="/vols/shift/{{ $conf.Tag }}/decline?hr={{ $.HMAC }}&em={{ $.Email }}" class="inline">
                                        <button type="submit"
                                                class="inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded text-red-700 bg-red-100 hover:bg-red-200"
                                                onclick="return confirm('Let us know you can no longer attend? This will release any shifts you signed up for.')">
                                            Can't Attend
                                        </button>
                                    </form>
                                    {{ end }}
                                </div>
                            </div>
                        </div>
                    </div>
                    {{ end }}
                </div>
            </section>

            <!-- Contact Info -->
            <section id="contact" class="mt-8 mb-12">
                <div class="bg-white shadow rounded-lg overflow-hidden">
                    <div class="px-4 py-5 sm:p-6">
                        <h3 class="text-sm font-medium text-gray-900">Need Help?</h3>
                        <p class="mt-1 text-sm text-gray-600">
                            If you have questions about your volunteer application or shifts, contact us at
                            <a href="mailto:volunteer@btcpp.dev" class="text-indigo-600 hover:text-indigo-500">volunteer@btcpp.dev</a>
                        </p>
                    </div>
                </div>
            </section>

            <!-- FAQs -->
            <section id="faq" class="mt-8 mb-12">
                <div class="bg-white shadow rounded-lg overflow-hidden">
                    <div class="px-4 py-5 sm:p-6">
                        <h2 class="text-lg font-semibold text-gray-900 mb-6">Volunteer FAQs</h2>
                        <dl class="divide-y divide-gray-200">
                            <details class="py-4 group">
                                <summary class="flex w-full items-center justify-between cursor-pointer list-none">
                                    <dt class="text-base font-medium text-gray-900">How many shifts do I need to work?</dt>
                                    <span class="ml-4 shrink-0 text-gray-400 group-open:rotate-180 transition-transform duration-200">
                                        <svg class="size-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" /></svg>
                                    </span>
                                </summary>
                                <dd class="mt-2 text-sm text-gray-600">Every volunteer that signs up for at least 3 four-hour shifts is eligible for a free pass to the event.</dd>
                            </details>
                            <details class="py-4 group">
                                <summary class="flex w-full items-center justify-between cursor-pointer list-none">
                                    <dt class="text-base font-medium text-gray-900">Do I need a ticket to bitcoin++ to volunteer?</dt>
                                    <span class="ml-4 shrink-0 text-gray-400 group-open:rotate-180 transition-transform duration-200">
                                        <svg class="size-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" /></svg>
                                    </span>
                                </summary>
                                <dd class="mt-2 text-sm text-gray-600">No, if you're scheduled to work at least 3 shifts, you'll receive a ticket for the event.</dd>
                            </details>
                            <details class="py-4 group">
                                <summary class="flex w-full items-center justify-between cursor-pointer list-none">
                                    <dt class="text-base font-medium text-gray-900">When should I arrive for my shift?</dt>
                                    <span class="ml-4 shrink-0 text-gray-400 group-open:rotate-180 transition-transform duration-200">
                                        <svg class="size-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" /></svg>
                                    </span>
                                </summary>
                                <dd class="mt-2 text-sm text-gray-600">We ask that you arrive about 10-15m before your shift starts so that you have time to find the place and do check-in as required. Each shift will have a coordinator that's responsible for making sure you've arrived and are at your post when your shift starts. Please make sure you check-in with them when you arrive.</dd>
                            </details>
                            <details class="py-4 group">
                                <summary class="flex w-full items-center justify-between cursor-pointer list-none">
                                    <dt class="text-base font-medium text-gray-900">I can no longer attend/cover my volunteer shift. What should I do?</dt>
                                    <span class="ml-4 shrink-0 text-gray-400 group-open:rotate-180 transition-transform duration-200">
                                        <svg class="size-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" /></svg>
                                    </span>
                                </summary>
                                <dd class="mt-2 text-sm text-gray-600">Please send us a note via DMs or email <a href="mailto:volunteer@btcpp.dev" class="text-indigo-600 hover:text-indigo-500">volunteer@btcpp.dev</a> to let us know you can no longer make it!</dd>
                            </details>
                        </dl>
                    </div>
                </div>
            </section>
        </div>
    </div>
    {{ block "footer" . }} {{ end }}
  </body>
</html>
