<!DOCTYPE html>
<html>
  <head>
    <title>volcoord @ bitcoin++</title>
    {{ block "header" . }} {{ end }}
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>&#10024;</text></svg>">
  </head>
  <body class="btcpp-admin-page">
    {{ block "mainnav" . }} {{ end }}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-5xl">
            <a href="/{{ .Conf.Tag }}/admin" class="text-xs text-gray-500 hover:text-gray-700">&larr; {{ .Conf.Desc }} dashboard</a>
            <section id="topline" class="mt-2 mb-6">
                <div class="overflow-hidden sm:rounded-lg bg-white shadow">
                    <div class="px-4 py-5 sm:p-6">
                        <div class="flex items-center justify-between">
                            <div>
                                <h1 class="text-xl font-bold text-gray-900">Volunteer Coordinator Dashboard</h1>
                                <p class="text-sm text-gray-500">{{ .Conf.Desc }} - {{ .Conf.DateDesc }}</p>
                            </div>
                            <div class="flex items-center gap-3">
                                <a href="/{{ .Conf.Tag }}/volcoord/shifts" class="inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-md text-indigo-700 bg-indigo-100 hover:bg-indigo-200">Manage Shifts</a>
                                <form method="POST" action="/{{ .Conf.Tag }}/volcoord/sendcal">
                                    <button type="submit" class="inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-md text-white bg-orange-600 hover:bg-orange-700" onclick="return confirm('Send calendar invites for all volunteer shifts at {{ .Conf.Desc }}?')">Send Shift Calendar Invites</button>
                                </form>
                                <div class="text-3xl">{{ .Conf.Emoji }}</div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Orientation Info -->
            {{ if .VolInfo }}
            <section id="orientation" class="mb-6">
                <div class="rounded-lg bg-indigo-50 border border-indigo-200 shadow px-4 py-4">
                    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                        <div class="min-w-0">
                            <h4 class="text-sm font-semibold text-indigo-900">Volunteer Orientation</h4>
                            {{ if .VolInfo.OrientTimes }}
                            <p class="mt-1 text-sm text-indigo-800">{{ .VolInfo.OrientTimes.FmtRange }}</p>
                            {{ else }}
                            <p class="mt-1 text-sm text-indigo-700">Time TBD - check back soon!</p>
                            {{ end }}
                            {{ if .VolInfo.Notes }}
                            <p class="mt-1 text-xs text-indigo-700">{{ .VolInfo.Notes }}</p>
                            {{ end }}
                            {{ if .VolInfo.OrientLink }}
                            <p class="mt-1 text-xs text-indigo-700 break-all">Location: <a href="{{ .VolInfo.OrientLink }}" target="_blank" rel="noopener noreferrer" class="underline">{{ .VolInfo.OrientLink }}</a></p>
                            {{ end }}
                            <p class="mt-2 text-xs text-indigo-700">Invites go to Scheduled volunteers plus event staff, admins, and volunteer coordinators. Current recipient count: {{ .OrientationRecipientCt }}.</p>
                        </div>
                        <div class="shrink-0 flex flex-col items-start lg:items-end gap-2">
                          {{ if .VolInfo.OrientLink }}
                          <a href="{{ .VolInfo.OrientLink }}" target="_blank" rel="noopener noreferrer"
                             class="inline-flex items-center px-3 py-2 border border-transparent text-xs font-medium rounded-md shadow-sm text-white bg-green-600 hover:bg-green-700">
                              Join Orientation
                          </a>
                          {{ end }}
                        </div>
                    </div>
                    <form method="POST" action="/{{ .Conf.Tag }}/volcoord/orientation" class="mt-4 grid grid-cols-1 gap-3 md:grid-cols-2 lg:grid-cols-4">
                        <label class="block text-xs font-medium text-indigo-900">
                            Starts
                            <input type="datetime-local" name="start" required value="{{ .OrientationStartInput }}"
                                   class="mt-1 block w-full rounded-md border-indigo-200 text-sm text-gray-900 shadow-sm focus:border-indigo-500 focus:ring-indigo-500">
                        </label>
                        <label class="block text-xs font-medium text-indigo-900">
                            Ends
                            <input type="datetime-local" name="end" required value="{{ .OrientationEndInput }}"
                                   class="mt-1 block w-full rounded-md border-indigo-200 text-sm text-gray-900 shadow-sm focus:border-indigo-500 focus:ring-indigo-500">
                        </label>
                        <label class="block text-xs font-medium text-indigo-900 md:col-span-2">
                            Online link
                            <input type="url" name="orient_link" required value="{{ .VolInfo.OrientLink }}"
                                   class="mt-1 block w-full rounded-md border-indigo-200 text-sm text-gray-900 shadow-sm focus:border-indigo-500 focus:ring-indigo-500">
                        </label>
                        <div class="md:col-span-2 lg:col-span-4 flex flex-wrap items-center gap-2">
                            <button type="submit"
                                    class="inline-flex items-center px-3 py-2 text-sm font-medium rounded-md text-white bg-indigo-700 hover:bg-indigo-800"
                                    onclick="return confirm('Save the volunteer orientation and send calendar invites to Scheduled volunteers plus staff/admin/volcoord recipients?');">
                                {{ if .VolInfo.OrientTimes }}Reschedule orientation{{ else }}Schedule orientation{{ end }}
                            </button>
                            {{ if and .VolInfo.OrientTimes .VolInfo.OrientTimes.End }}
                            <button type="submit" formaction="/{{ .Conf.Tag }}/volcoord/send-orientation"
                                    class="inline-flex items-center px-3 py-2 text-sm font-medium rounded-md text-amber-900 bg-amber-100 hover:bg-amber-200 border border-amber-300"
                                    onclick="return confirm('Re-send the current orientation calendar invite to Scheduled volunteers plus staff/admin/volcoord recipients?');">
                                Resend current invite
                            </button>
                            {{ end }}
                        </div>
                    </form>
                </div>
            </section>
            {{ end }}

            <!-- Dashboard: shift coverage at a glance -->
            {{ with .Stats }}
            <section id="dashboard" class="mb-6">
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                    <div class="bg-white shadow rounded-lg px-4 py-3">
                        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Shifts filled</p>
                        <p class="mt-1 text-2xl font-semibold text-gray-900">{{ .ShiftsFilled }}<span class="text-sm font-normal text-gray-500"> / {{ .ShiftsTotal }}</span></p>
                    </div>
                    <div class="bg-white shadow rounded-lg px-4 py-3">
                        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Shifts left</p>
                        <p class="mt-1 text-2xl font-semibold {{ if gt .ShiftsLeft 0 }}text-amber-600{{ else }}text-green-600{{ end }}">{{ .ShiftsLeft }}</p>
                    </div>
                    <div class="bg-white shadow rounded-lg px-4 py-3">
                        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Unscheduled vols</p>
                        <p class="mt-1 text-2xl font-semibold text-gray-900">{{ .UnscheduledVols }}</p>
                        <p class="text-xs text-gray-500">Applied + Pending Shifts</p>
                    </div>
                    <div class="bg-white shadow rounded-lg px-4 py-3">
                        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Vols still needed</p>
                        <p class="mt-1 text-2xl font-semibold {{ if gt .VolsNeeded .UnscheduledVols }}text-red-600{{ else if gt .VolsNeeded 0 }}text-amber-600{{ else }}text-green-600{{ end }}">{{ .VolsNeeded }}</p>
                        <p class="text-xs text-gray-500">@ 3 shifts each</p>
                    </div>
                </div>
            </section>
            {{ end }}

            <!-- Status Filter -->
            <section id="filters" class="mb-6">
                <div class="bg-white shadow rounded-lg px-4 py-4 sm:px-6">
                    <div class="flex items-center space-x-3 flex-wrap">
                        <span class="text-sm font-medium text-gray-700">Filter by status:</span>
                        <a href="/{{ .Conf.Tag }}/volcoord"
                           class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium {{ if eq .StatusFilter "" }}bg-gray-800 text-white{{ else }}bg-gray-100 text-gray-800 hover:bg-gray-200{{ end }}">
                            All
                        </a>
                        <a href="/{{ .Conf.Tag }}/volcoord?status=Applied"
                           class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium {{ if eq .StatusFilter "Applied" }}bg-gray-800 text-white{{ else }}bg-gray-100 text-gray-800 hover:bg-gray-200{{ end }}">
                            Applied
                        </a>
                        <a href="/{{ .Conf.Tag }}/volcoord?status=PendingShifts"
                           class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium {{ if eq .StatusFilter "PendingShifts" }}bg-blue-800 text-white{{ else }}bg-blue-100 text-blue-800 hover:bg-blue-200{{ end }}">
                            Pending Shifts
                        </a>
                        <a href="/{{ .Conf.Tag }}/volcoord?status=Waitlist"
                           class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium {{ if eq .StatusFilter "Waitlist" }}bg-yellow-800 text-white{{ else }}bg-yellow-100 text-yellow-800 hover:bg-yellow-200{{ end }}">
                            Waitlist
                        </a>
                        <a href="/{{ .Conf.Tag }}/volcoord?status=Scheduled"
                           class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium {{ if eq .StatusFilter "Scheduled" }}bg-green-800 text-white{{ else }}bg-green-100 text-green-800 hover:bg-green-200{{ end }}">
                            Scheduled
                        </a>
                        <a href="/{{ .Conf.Tag }}/volcoord?status=Declined"
                           class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium {{ if eq .StatusFilter "Declined" }}bg-red-800 text-white{{ else }}bg-red-100 text-red-800 hover:bg-red-200{{ end }}">
                            Declined
                        </a>
                    </div>
                </div>
            </section>

            <!-- Promote Actions -->
            <section id="actions" class="mb-6">
                <div class="bg-white shadow rounded-lg px-4 py-4 sm:px-6">
                    <h3 class="text-sm font-medium text-gray-900 mb-3">Bulk Actions</h3>
                    <div class="flex flex-wrap items-center gap-3">
                        <form method="POST" action="/{{ .Conf.Tag }}/volcoord/promote" class="inline">
                            <input type="hidden" name="from_status" value="Applied">
                            <input type="hidden" name="target_status" value="PendingShifts">
                            <button type="submit" class="inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700"
                                    onclick="return confirm('Promote all Applied volunteers to PendingShifts and send shift signup emails?')">
                                Applied &rarr; Pending Shifts
                            </button>
                        </form>
                        <form method="POST" action="/{{ .Conf.Tag }}/volcoord/auto-assign" class="inline">
                            <button type="submit" class="inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700"
                                    onclick="return confirm('Auto-assign PendingShifts volunteers to open shifts? Each volunteer will be filled up to 3 shifts based on availability and preferences.')">
                                Auto-Assign Shifts
                            </button>
                        </form>
                    </div>
                </div>
            </section>

            {{ if .FlashMessage }}
            <div class="mb-4 rounded-md bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-800">
                {{ .FlashMessage }}
            </div>
            {{ end }}

            <!-- Volunteers Table + Bulk Email Form -->
            <form id="bulk-email-form" method="POST" action="/{{ .Conf.Tag }}/volcoord/email">
            <section id="volunteers" class="mb-8">
                <div class="bg-white shadow rounded-lg overflow-hidden">
                    <div class="px-4 py-4 sm:px-6 flex flex-wrap items-center justify-between gap-3">
                        <h3 class="text-sm font-medium text-gray-900">
                            Volunteers ({{ len .Volunteers }})
                            {{ if .StatusFilter }} - {{ .StatusFilter }}{{ end }}
                        </h3>
                        <div class="flex flex-wrap items-center gap-2 text-xs">
                            <span class="text-gray-500">Quick select:</span>
                            <button type="button" onclick="bulkSelect('all')" class="px-2 py-1 rounded bg-gray-100 hover:bg-gray-200 text-gray-800">All visible</button>
                            <button type="button" onclick="bulkSelect('unscheduled')" class="px-2 py-1 rounded bg-purple-100 hover:bg-purple-200 text-purple-800">Unscheduled only</button>
                            <button type="button" onclick="bulkSelect('Applied')" class="px-2 py-1 rounded bg-gray-100 hover:bg-gray-200 text-gray-800">Applied</button>
                            <button type="button" onclick="bulkSelect('PendingShifts')" class="px-2 py-1 rounded bg-blue-100 hover:bg-blue-200 text-blue-800">Pending Shifts</button>
                            <button type="button" onclick="bulkSelect('Waitlist')" class="px-2 py-1 rounded bg-yellow-100 hover:bg-yellow-200 text-yellow-800">Waitlist</button>
                            <button type="button" onclick="bulkSelect('Scheduled')" class="px-2 py-1 rounded bg-green-100 hover:bg-green-200 text-green-800">Scheduled</button>
                            <button type="button" onclick="bulkSelect('Declined')" class="px-2 py-1 rounded bg-red-100 hover:bg-red-200 text-red-800">Declined</button>
                            <button type="button" onclick="bulkSelect('none')" class="px-2 py-1 rounded bg-gray-100 hover:bg-gray-200 text-gray-800">Clear</button>
                            <a href="#compose" class="px-2 py-1 rounded bg-indigo-600 text-white hover:bg-indigo-700">Email selected &darr;</a>
                        </div>
                    </div>
                    {{ if .Volunteers }}
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-gray-200">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th scope="col" class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                        <input type="checkbox" id="select-all-toggle" onclick="toggleSelectAll(this)">
                                    </th>
                                    <th scope="col" class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
                                    <th scope="col" class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                                    <th scope="col" class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                                    <th scope="col" class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
                                    <th scope="col" class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Signal</th>
                                    <th scope="col" class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Phone</th>
                                    <th scope="col" class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">From</th>
                                    <th scope="col" class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Shifts</th>
                                    <th scope="col" class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Notes</th>
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-gray-200">
                                {{ range .Volunteers }}
                                <tr>
                                    <td class="px-4 py-2">
                                        <input type="checkbox" name="vol_refs" value="{{ .Ref }}" data-status="{{ .Status }}" data-shifts="{{ len .WorkShifts }}" class="vol-checkbox">
                                    </td>
                                    <td class="px-4 py-2 text-sm font-medium text-gray-900">
                                        <a href="/{{ $.Conf.Tag }}/volcoord/vol/{{ .Ref }}" class="text-indigo-600 hover:text-indigo-500">{{ .Name }}</a>
                                    </td>
                                    <td class="px-4 py-2 whitespace-nowrap text-sm">
                                        {{ if eq .Status "Applied" }}
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">Applied</span>
                                        {{ else if eq .Status "Waitlist" }}
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">Waitlist</span>
                                        {{ else if eq .Status "PendingShifts" }}
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">Pending Shifts</span>
                                        {{ else if eq .Status "Scheduled" }}
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Scheduled</span>
                                        {{ else if eq .Status "Declined" }}
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">Declined</span>
                                        {{ else }}
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">{{ .Status }}</span>
                                        {{ end }}
                                    </td>
                                    <td class="px-4 py-2 whitespace-nowrap">
                                        {{ $returnURL := printf "/%s/volcoord" $.Conf.Tag }}
                                        {{ if $.StatusFilter }}{{ $returnURL = printf "%s?status=%s" $returnURL $.StatusFilter }}{{ end }}
                                        {{ $statusURL := printf "/%s/volcoord/vol/%s/status?return=%s" $.Conf.Tag .Ref (urlquery $returnURL) }}
                                        {{ $schedURL := printf "/%s/volcoord/vol/%s/scheduled?return=%s" $.Conf.Tag .Ref (urlquery $returnURL) }}
                                        <span class="inline-flex items-center gap-1">
                                            {{ if eq .Status "Applied" }}
                                            <button type="submit" name="status" value="PendingShifts"
                                                formaction="{{ $statusURL }}" formmethod="POST" formnovalidate
                                                title="Promote to Pending Shifts"
                                                class="inline-flex items-center rounded bg-blue-600 px-2 py-1 text-xs font-semibold text-white hover:bg-blue-700">→ Pending</button>
                                            <button type="submit" name="status" value="Waitlist"
                                                formaction="{{ $statusURL }}" formmethod="POST" formnovalidate
                                                class="inline-flex items-center rounded bg-yellow-500 px-2 py-1 text-xs font-semibold text-white hover:bg-yellow-600">Waitlist</button>
                                            {{ else if eq .Status "Waitlist" }}
                                            <button type="submit" name="status" value="PendingShifts"
                                                formaction="{{ $statusURL }}" formmethod="POST" formnovalidate
                                                title="Promote to Pending Shifts"
                                                class="inline-flex items-center rounded bg-blue-600 px-2 py-1 text-xs font-semibold text-white hover:bg-blue-700">→ Pending</button>
                                            {{ else if eq .Status "PendingShifts" }}
                                            {{ if gt (len .WorkShifts) 0 }}
                                            <button type="submit"
                                                formaction="{{ $schedURL }}" formmethod="POST" formnovalidate
                                                onclick="return confirm('Mark {{ .Name }} as Scheduled? Sends onboarding email, issues a ticket, and sends calendar invites.')"
                                                class="inline-flex items-center rounded bg-green-600 px-2 py-1 text-xs font-semibold text-white hover:bg-green-700">Schedule</button>
                                            {{ else }}
                                            <span class="text-xs text-gray-400" title="Assign shifts before scheduling">no shifts</span>
                                            {{ end }}
                                            {{ end }}
                                            {{ if ne .Status "Declined" }}
                                            <button type="submit" name="status" value="Declined"
                                                formaction="{{ $statusURL }}" formmethod="POST" formnovalidate
                                                onclick="return confirm('Decline {{ .Name }}?')"
                                                class="inline-flex items-center rounded bg-gray-600 px-2 py-1 text-xs font-semibold text-white hover:bg-gray-700">Decline</button>
                                            {{ else }}
                                            <button type="submit" name="status" value="Applied"
                                                formaction="{{ $statusURL }}" formmethod="POST" formnovalidate
                                                title="Reset to Applied"
                                                class="inline-flex items-center rounded bg-gray-200 px-2 py-1 text-xs font-semibold text-gray-700 hover:bg-gray-300">Reopen</button>
                                            {{ end }}
                                        </span>
                                    </td>
                                    <td class="px-4 py-2 text-sm text-gray-500">{{ .Email }}</td>
                                    <td class="px-4 py-2 text-sm text-gray-500">{{ .Signal }}</td>
                                    <td class="px-4 py-2 text-sm text-gray-500">{{ .Phone }}</td>
                                    <td class="px-4 py-2 text-sm text-gray-500">{{ .Hometown }}</td>
                                    <td class="px-4 py-2 text-sm text-gray-500">{{ len .WorkShifts }}</td>
                                    <td class="px-4 py-2 text-sm text-gray-500 max-w-xs truncate" title="{{ .Comments }}">{{ .Comments }}</td>
                                </tr>
                                {{ end }}
                            </tbody>
                        </table>
                    </div>
                    {{ else }}
                    <div class="px-4 py-8 text-center text-sm text-gray-500">
                        No volunteers found{{ if .StatusFilter }} with status "{{ .StatusFilter }}"{{ end }}.
                    </div>
                    {{ end }}
                </div>
            </section>

            <section id="decline-compose" class="mb-6">
                <div class="bg-white shadow rounded-lg px-4 py-4 sm:px-6 border border-red-100">
                    <h3 class="text-sm font-semibold text-gray-900 mb-3">Decline Selected Volunteers</h3>
                    <p class="text-xs text-gray-500 mb-3">Sends this note with a discount code, releases any selected shifts, then moves successful recipients to Declined. Only Applied and Pending Shifts volunteers are eligible.</p>
                    <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
                        <label class="block text-xs font-medium text-gray-700 sm:col-span-2">
                            Title
                            <input type="text" name="decline_title" value="{{ .DeclineTitle }}" class="mt-1 w-full rounded border border-gray-300 px-3 py-1.5 text-sm">
                        </label>
                        <label class="block text-xs font-medium text-gray-700">
                            Discount code
                            <input type="text" name="decline_discount_code" placeholder="VOLTHANKS" class="mt-1 w-full rounded border border-gray-300 px-3 py-1.5 text-sm uppercase">
                        </label>
                    </div>
                    <label class="mt-3 block text-xs font-medium text-gray-700">
                        Body (Markdown)
                        <textarea name="decline_body" rows="9" class="mt-1 w-full rounded border border-gray-300 px-3 py-1.5 text-sm font-mono">{{ .DeclineBody }}</textarea>
                    </label>
                    <p class="mt-2 text-xs text-gray-500">Available fields include <code>{{`{{ .Volunteer.Name }}`}}</code>, <code>{{`{{ .Conf.Desc }}`}}</code>, and <code>{{`{{ .DiscountCode.CodeName }}`}}</code>.</p>
                    <div class="mt-3 flex flex-wrap items-center gap-3">
                        <button type="submit"
                                formaction="/{{ .Conf.Tag }}/volcoord/decline-selected"
                                formmethod="POST"
                                class="inline-flex items-center px-4 py-2 text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700"
                                onclick="return confirmDeclineSelected();">
                            Send and Decline
                        </button>
                        <span class="text-xs text-gray-400">or</span>
                        <input type="email" name="decline_test_email" placeholder="test@example.com" class="rounded border border-gray-300 px-3 py-1.5 text-sm w-48">
                        <button type="submit"
                                name="decline_send_test"
                                value="1"
                                formaction="/{{ .Conf.Tag }}/volcoord/decline-selected"
                                formmethod="POST"
                                class="inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-md text-gray-700 bg-gray-100 hover:bg-gray-200 border border-gray-300">
                            Send Test
                        </button>
                    </div>
                </div>
            </section>

            {{ template "email_compose" .EmailCompose }}
            </form>

            <script>
            function bulkSelect(status) {
                const checkboxes = document.querySelectorAll('.vol-checkbox');
                checkboxes.forEach(cb => {
                    if (status === 'none') {
                        cb.checked = false;
                    } else if (status === 'all') {
                        cb.checked = true;
                    } else if (status === 'unscheduled') {
                        cb.checked = ((cb.dataset.status === 'Applied' || cb.dataset.status === 'PendingShifts') && cb.dataset.shifts === '0');
                    } else {
                        cb.checked = (cb.dataset.status === status);
                    }
                });
            }
            function toggleSelectAll(toggle) {
                document.querySelectorAll('.vol-checkbox').forEach(cb => cb.checked = toggle.checked);
            }
            function toggleComposeMode() {
                const isCustom = document.getElementById('mode-custom').checked;
                document.getElementById('custom-fields').classList.toggle('hidden', !isCustom);
                document.getElementById('missive-picker').classList.toggle('hidden', isCustom);
            }
            function confirmSend() {
                const checked = document.querySelectorAll('.vol-checkbox:checked').length;
                if (checked === 0) {
                    alert('No volunteers selected.');
                    return false;
                }
                return confirm('Send email to ' + checked + ' volunteer(s)?');
            }
            function confirmDeclineSelected() {
                const checked = Array.from(document.querySelectorAll('.vol-checkbox:checked'));
                const eligible = checked.filter(cb => cb.dataset.status === 'Applied' || cb.dataset.status === 'PendingShifts');
                if (eligible.length === 0) {
                    alert('No Applied or Pending Shifts volunteers selected.');
                    return false;
                }
                return confirm('Send decline email and move ' + eligible.length + ' selected volunteer(s) to Declined?');
            }
            </script>

            <!-- Shift Capacity Overview -->
            {{ if .Shifts }}
            <section id="shifts" class="mb-6">
                <div class="bg-white shadow rounded-lg overflow-hidden">
                    <div class="px-4 py-4 sm:px-6">
                        <h3 class="text-sm font-medium text-gray-900 mb-3">Shift Capacity</h3>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-gray-200">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th scope="col" class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Shift</th>
                                    <th scope="col" class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Day</th>
                                    <th scope="col" class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Time</th>
                                    <th scope="col" class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
                                    <th scope="col" class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Filled</th>
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-gray-200">
                                {{ range .Shifts }}
                                <tr>
                                    <td class="px-4 py-2 text-sm text-gray-900">{{ .Name }}</td>
                                    <td class="px-4 py-2 whitespace-nowrap text-sm text-gray-500">{{ .DayOfDesc }}</td>
                                    <td class="px-4 py-2 whitespace-nowrap text-sm text-gray-500">{{ .TimeDesc }}</td>
                                    <td class="px-4 py-2 text-sm text-gray-500">{{ if .Type }}{{ .Type.Title }}{{ end }}</td>
                                    <td class="px-4 py-2 whitespace-nowrap text-sm">
                                        {{ if .IsFull }}
                                        <span class="text-green-600 font-medium">{{ len .AssigneesRef }}/{{ .MaxVols }} Full</span>
                                        {{ else }}
                                        <span class="text-red-600">{{ len .AssigneesRef }}/{{ .MaxVols }}</span>
                                        {{ end }}
                                    </td>
                                </tr>
                                {{ end }}
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
            {{ end }}

        </div>
    </div>
  </body>
</html>
