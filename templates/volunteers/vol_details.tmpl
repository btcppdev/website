<!DOCTYPE html>
<html>
  <head>
    <title>volcoord: {{ .Vol.Name }} @ bitcoin++</title>
    {{ block "header" . }} {{ end }}
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>&#10024;</text></svg>">
  </head>
  <body class="btcpp-admin-page">
    {{ block "mainnav" . }} {{ end }}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mx-auto max-w-4xl">
            <!-- Back link -->
            <div class="mb-4 mt-4">
                <a href="/{{ .Conf.Tag }}/volcoord" class="text-sm text-indigo-600 hover:text-indigo-500">&larr; Dashboard</a>
            </div>

            <!-- Profile Header -->
            <section class="mb-6">
                <div class="bg-white shadow rounded-lg overflow-hidden">
                    <div class="px-4 py-5 sm:p-6">
                        <div class="flex items-start justify-between">
                            <div>
                                <h1 class="text-2xl font-bold text-gray-900">{{ .Vol.Name }}</h1>
                                <p class="text-sm text-gray-500">{{ .Conf.Desc }} - {{ .Conf.DateDesc }}</p>
                                <div class="mt-3">
                                    {{ if eq .Vol.Status "Applied" }}
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">Applied</span>
                                    {{ else if eq .Vol.Status "Waitlist" }}
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">Waitlist</span>
                                    {{ else if eq .Vol.Status "PendingShifts" }}
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">Pending Shifts</span>
                                    {{ else if eq .Vol.Status "Scheduled" }}
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Scheduled</span>
                                    {{ else if eq .Vol.Status "Declined" }}
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">Declined</span>
                                    {{ else }}
                                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">{{ .Vol.Status }}</span>
                                    {{ end }}
                                </div>
                            </div>
                        </div>

                        <dl class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
                            <div>
                                <dt class="text-xs font-medium text-gray-500 uppercase">Email</dt>
                                <dd class="text-gray-900">{{ .Vol.Email }}</dd>
                            </div>
                            <div>
                                <dt class="text-xs font-medium text-gray-500 uppercase">Phone</dt>
                                <dd class="text-gray-900">{{ .Vol.Phone }}</dd>
                            </div>
                            <div>
                                <dt class="text-xs font-medium text-gray-500 uppercase">Signal</dt>
                                <dd class="text-gray-900">{{ .Vol.Signal }}</dd>
                            </div>
                            <div>
                                <dt class="text-xs font-medium text-gray-500 uppercase">Contact preferred</dt>
                                <dd class="text-gray-900">{{ .Vol.ContactAt }}</dd>
                            </div>
                            <div>
                                <dt class="text-xs font-medium text-gray-500 uppercase">Hometown</dt>
                                <dd class="text-gray-900">{{ .Vol.Hometown }}</dd>
                            </div>
                            <div>
                                <dt class="text-xs font-medium text-gray-500 uppercase">Discovered via</dt>
                                <dd class="text-gray-900">{{ .Vol.DiscoveredVia }}</dd>
                            </div>
                            <div>
                                <dt class="text-xs font-medium text-gray-500 uppercase">First event?</dt>
                                <dd class="text-gray-900">{{ if .Vol.FirstEvent }}Yes{{ else }}No{{ end }}</dd>
                            </div>
                            <div>
                                <dt class="text-xs font-medium text-gray-500 uppercase">Twitter</dt>
                                <dd class="text-gray-900">{{ .Vol.Twitter.Handle }}</dd>
                            </div>
                            <div>
                                <dt class="text-xs font-medium text-gray-500 uppercase">Nostr</dt>
                                <dd class="text-gray-900">{{ .Vol.Nostr }}</dd>
                            </div>
                        </dl>

                        {{ if .Vol.Comments }}
                        <div class="mt-6 border-t border-gray-200 pt-4">
                            <dt class="text-xs font-medium text-gray-500 uppercase">Comments / Notes</dt>
                            <dd class="mt-1 text-sm text-gray-900 whitespace-pre-wrap">{{ .Vol.Comments }}</dd>
                        </div>
                        {{ end }}
                    </div>
                </div>
            </section>

            <!-- Status editor -->
            <section class="mb-6">
                <div class="bg-white shadow rounded-lg px-4 py-4 sm:px-6">
                    <h3 class="text-sm font-semibold text-gray-900 mb-3">Status</h3>
                    <form method="POST" action="/{{ .Conf.Tag }}/volcoord/vol/{{ .Vol.Ref }}/status" class="flex items-center gap-3">
                        <select name="status" class="rounded border border-gray-300 px-3 py-1.5 text-sm">
                            {{ range $.Statuses }}
                            <option value="{{ . }}" {{ if eq . $.Vol.Status }}selected{{ end }}>{{ . }}</option>
                            {{ end }}
                        </select>
                        <button type="submit" class="inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700">Update Status</button>
                    </form>

                    {{ if eq .Vol.Status "PendingShifts" }}
                    <div class="mt-4 pt-4 border-t border-gray-200">
                        <p class="text-xs text-gray-500 mb-2">Run the full scheduled flow: send onboarding email, issue ticket, send calendar invites.</p>
                        <form method="POST" action="/{{ .Conf.Tag }}/volcoord/vol/{{ .Vol.Ref }}/scheduled" class="inline">
                            <button type="submit"
                                    class="inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700"
                                    onclick="return confirm('Mark as Scheduled? This will send the onboarding email, issue a ticket, and send calendar invites.')">
                                Mark as Scheduled
                            </button>
                        </form>
                    </div>
                    {{ end }}
                </div>
            </section>

            <!-- Shifts: selection + assignment editor -->
            <section class="mb-6">
                <div class="bg-white shadow rounded-lg px-4 py-4 sm:px-6">
                    <h3 class="text-sm font-semibold text-gray-900 mb-3">Shifts ({{ len .SelectedShifts }} assigned)</h3>

                    <!-- Selected Shifts Summary (mirrors volunteer's signup page) -->
                    {{ if .SelectedShifts }}
                    <div class="bg-indigo-50 border border-indigo-200 rounded-lg p-4 mb-4">
                        <h4 class="text-sm font-semibold text-indigo-900 mb-3">Assigned Shifts</h4>
                        <ul class="space-y-2">
                            {{ range .SelectedShifts }}
                            <li class="flex items-center justify-between text-sm">
                                <span class="text-indigo-800">
                                    <span class="font-medium">{{ .Name }}</span>
                                    <span class="text-indigo-600"> - {{ .DayOfDesc }} {{ .TimeDesc }}</span>
                                    {{ if .Type }}
                                    <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-white text-indigo-700">{{ .Type.Title }}</span>
                                    {{ end }}
                                </span>
                                <form method="POST" action="/{{ $.Conf.Tag }}/volcoord/vol/{{ $.Vol.Ref }}/remove-shift" class="inline">
                                    <input type="hidden" name="shiftRef" value="{{ .Ref }}">
                                    <button type="submit" class="text-indigo-600 hover:text-indigo-800 text-xs underline">Remove</button>
                                </form>
                            </li>
                            {{ end }}
                        </ul>
                    </div>
                    {{ end }}

                    <!-- Filters -->
                    <div class="mb-4 flex flex-wrap items-center gap-3 text-xs">
                        <span class="text-gray-500 font-medium">Filter:</span>
                        <label class="inline-flex items-center gap-1">
                            <span>Day</span>
                            <select id="shift-filter-day" onchange="filterShifts()" class="rounded border border-gray-300 px-2 py-1 text-xs">
                                <option value="">All days</option>
                                {{ range .DayKeys }}
                                <option value="{{ . }}">{{ (index (index $.ShiftDisplays .) 0).Shift.DayOfDesc }}</option>
                                {{ end }}
                            </select>
                        </label>
                        <label class="inline-flex items-center gap-1">
                            <span>Job type</span>
                            <select id="shift-filter-type" onchange="filterShifts()" class="rounded border border-gray-300 px-2 py-1 text-xs">
                                <option value="">All types</option>
                                {{ range .JobTypes }}
                                <option value="{{ .Tag }}">{{ .Title }}</option>
                                {{ end }}
                            </select>
                        </label>
                        <button type="button" onclick="document.getElementById('shift-filter-day').value=''; document.getElementById('shift-filter-type').value=''; filterShifts();" class="px-2 py-1 rounded bg-gray-100 hover:bg-gray-200 text-gray-700">Clear</button>
                    </div>

                    <!-- All Shifts grouped by day -->
                    <div class="space-y-4">
                        {{ range $day := .DayKeys }}
                        {{ $shifts := index $.ShiftDisplays $day }}
                        <div class="shift-day-group" data-day="{{ $day }}">
                            <div class="bg-gray-50 px-3 py-2 border border-gray-200 rounded-t">
                                <h4 class="text-xs font-semibold text-gray-900">{{ (index $shifts 0).Shift.DayOfDesc }}</h4>
                            </div>
                            <ul class="divide-y divide-gray-200 border border-t-0 border-gray-200 rounded-b">
                                {{ range $shifts }}
                                <li class="shift-row px-3 py-2 {{ if .IsSelected }}bg-indigo-50{{ else if not .CanSelect }}bg-gray-50{{ end }}"
                                    data-day="{{ $day }}"
                                    data-type="{{ if .Shift.Type }}{{ .Shift.Type.Tag }}{{ end }}">
                                    <div class="flex items-center justify-between gap-3">
                                        <div class="flex-1 min-w-0">
                                            <div class="flex items-center gap-2">
                                                <p class="text-sm font-medium text-gray-900 truncate">{{ .Shift.Name }}</p>
                                                {{ if .Shift.Type }}
                                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-700">{{ .Shift.Type.Title }}</span>
                                                {{ end }}
                                            </div>
                                            <div class="mt-0.5 flex items-center gap-3 text-xs text-gray-500">
                                                <span>{{ .Shift.TimeDesc }}</span>
                                                <span>{{ .Shift.SpotsAvailable }} spots left</span>
                                            </div>
                                            {{ if and (not .CanSelect) (not .IsSelected) }}
                                            <p class="mt-0.5 text-xs text-red-600">{{ .Reason }}</p>
                                            {{ end }}
                                        </div>
                                        <div class="ml-2 shrink-0">
                                            {{ if .IsSelected }}
                                            <form method="POST" action="/{{ $.Conf.Tag }}/volcoord/vol/{{ $.Vol.Ref }}/remove-shift" class="inline">
                                                <input type="hidden" name="shiftRef" value="{{ .Shift.Ref }}">
                                                <button type="submit" class="inline-flex items-center px-3 py-1.5 border border-indigo-300 text-xs font-medium rounded text-indigo-700 bg-indigo-100 hover:bg-indigo-200">
                                                    Selected
                                                </button>
                                            </form>
                                            {{ else }}
                                            <form method="POST" action="/{{ $.Conf.Tag }}/volcoord/vol/{{ $.Vol.Ref }}/add-shift" class="inline">
                                                <input type="hidden" name="shiftRef" value="{{ .Shift.Ref }}">
                                                <button type="submit" class="inline-flex items-center px-3 py-1.5 border border-gray-300 text-xs font-medium rounded text-gray-700 bg-white hover:bg-gray-50">
                                                    Add
                                                </button>
                                            </form>
                                            {{ end }}
                                        </div>
                                    </div>
                                </li>
                                {{ end }}
                            </ul>
                        </div>
                        {{ end }}
                    </div>
                </div>
            </section>

            <script>
            function filterShifts() {
                const day = document.getElementById('shift-filter-day').value;
                const type = document.getElementById('shift-filter-type').value;
                document.querySelectorAll('.shift-row').forEach(row => {
                    const dayMatch = !day || row.dataset.day === day;
                    const typeMatch = !type || row.dataset.type === type;
                    row.style.display = (dayMatch && typeMatch) ? '' : 'none';
                });
                // Hide day-group headers that have no visible rows
                document.querySelectorAll('.shift-day-group').forEach(group => {
                    const visible = Array.from(group.querySelectorAll('.shift-row')).some(r => r.style.display !== 'none');
                    group.style.display = visible ? '' : 'none';
                });
            }
            </script>

            <!-- Availability editor -->
            <section class="mb-6">
                <div class="bg-white shadow rounded-lg px-4 py-4 sm:px-6">
                    <h3 class="text-sm font-semibold text-gray-900 mb-3">Availability</h3>
                    <form method="POST" action="/{{ .Conf.Tag }}/volcoord/vol/{{ .Vol.Ref }}/availability">
                        {{ range .DaysList }}
                            {{ block "form_list" . }} {{ end }}
                        {{ end }}
                        <div class="mt-4">
                            <button type="submit" class="inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700">Save Availability</button>
                        </div>
                    </form>
                </div>
            </section>

            <!-- Work Preferences editor -->
            <section class="mb-6">
                <div class="bg-white shadow rounded-lg px-4 py-4 sm:px-6">
                    <h3 class="text-sm font-semibold text-gray-900 mb-3">Work Preferences</h3>
                    <form method="POST" action="/{{ .Conf.Tag }}/volcoord/vol/{{ .Vol.Ref }}/work-prefs">
                        <fieldset class="mb-4">
                            <legend class="text-sm font-medium text-gray-700 mb-2">Will work</legend>
                            {{ range .YesJobs }}
                                {{ block "form_list" . }} {{ end }}
                            {{ end }}
                        </fieldset>
                        <fieldset class="mb-4">
                            <legend class="text-sm font-medium text-gray-700 mb-2">Won't work</legend>
                            {{ range .NoJobs }}
                                {{ block "form_list" . }} {{ end }}
                            {{ end }}
                        </fieldset>
                        <button type="submit" class="inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700">Save Preferences</button>
                    </form>
                </div>
            </section>

        </div>
    </div>
  </body>
</html>
