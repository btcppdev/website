<!DOCTYPE html>
<html>
  <head>
    <title>bitcoin++ | You're going</title>
    {{ block "checkout_header" . }}{{ end }}
  </head>
  <body class="btcpp-checkout-page">
    <main class="checkout-shell checkout-shell--success">
      <aside class="checkout-hero">
        <picture>
          <source srcset="/static/img/{{ .Conf.Tag }}/leading.avif" type="image/avif">
          <img src="/static/img/{{ .Conf.Tag }}/leading.png" alt="">
        </picture>
        <div class="checkout-hero__shade"></div>
        <div class="checkout-hero__content">
          <a href="/{{ .Conf.Tag }}" class="checkout-brand"><img src="/static/img/logo_blk.svg" alt="bitcoin++"></a>
          <div>
            <p class="checkout-kicker">Payment received</p>
            <h1>{{ .Conf.Desc }}</h1>
            <p>{{ .Conf.DateDesc }} · {{ .Conf.Location }}</p>
          </div>
        </div>
      </aside>

      <section class="checkout-panel">
        <nav class="checkout-steps" aria-label="Checkout steps" data-step="03/03" data-current="confirmed">
          <span class="is-complete"><b>01</b> register</span>
          <span class="is-complete"><b>02</b> pay</span>
          <span class="is-active"><b>03</b> confirmed</span>
        </nav>

        <div class="checkout-form checkout-confirmation">
          <div class="checkout-copy">
            {{ if .Sponsored }}
            <p class="checkout-confirmation__status">✓ Sponsorship received</p>
            <h2>Builder pass funded.</h2>
            <p>Thanks for helping another builder attend <span class="font-bitcoin">bitcoin++</span>. The team will distribute sponsored passes before the event and follow up if we need anything else.</p>
            {{ else }}
            <p class="checkout-confirmation__status">✓ Ticket received</p>
            <h2>You're in.</h2>
            <p>Your ticket for the upcoming <span class="font-bitcoin">bitcoin++</span> conference is on its way to your email. Keep an eye on spam if it does not arrive within a few minutes.</p>
            {{ end }}
          </div>

          <div class="checkout-ticket-stub">
            <div>
              {{ if .Sponsored }}
              <span>Sponsored builder pass · bitcoin++</span>
              <strong>{{ .Conf.Desc }}</strong>
              <small>{{ .Conf.DateDesc }} · {{ .Conf.Location }}</small>
              {{ else }}
              <span>Admit one · bitcoin++</span>
              <strong>{{ .Conf.Desc }}</strong>
              <small>{{ .Conf.DateDesc }} · {{ .Conf.Location }}</small>
              {{ end }}
            </div>
            <div class="checkout-ticket-stub__mark">
              {{ if and .Ticket .Ticket.QRCodeURI }}
              <img class="checkout-ticket-stub__qr" src="{{ .Ticket.QRCodeURI | safeURL }}" width="120" height="120" alt="Ticket QR code for {{ .Ticket.RefID }}">
              {{ else if .Sponsored }}
              funded
              {{ else }}
              ++
              {{ end }}
            </div>
          </div>

          <div class="checkout-actions">
            <a href="/{{ .Conf.Tag }}" class="checkout-actions__primary">Back to conference</a>
            <a href="/dashboard">Go to dashboard</a>
            <a href="/{{ .Conf.Tag }}#tickets">Buy another</a>
          </div>
        </div>

        <footer class="checkout-footer">
          <span>Ticket delivered by email</span>
          <a href="mailto:hello@btcpp.dev">Questions? hello@btcpp.dev</a>
        </footer>
      </section>
    </main>
  </body>
</html>
